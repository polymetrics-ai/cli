FROM node:24.13.1-bookworm-slim

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        ca-certificates \
        git \
    && rm -rf /var/lib/apt/lists/*

RUN npm install --global --omit=dev --no-audit --no-fund @opengsd/gsd-pi@1.11.0 \
    && groupmod --new-name shepherd node \
    && usermod --login shepherd --home /home/shepherd --move-home node \
    && mkdir -p /home/shepherd/.pi/agent /workspace \
    && chown -R shepherd:shepherd /home/shepherd /workspace

USER shepherd
WORKDIR /workspace
ENV HOME=/home/shepherd
ENV GSD_HOME=/home/shepherd/.pi

ENTRYPOINT ["gsd"]
