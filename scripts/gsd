#!/usr/bin/env node
"use strict";

const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const { spawnSync } = require("node:child_process");

function repoRoot() {
  const result = spawnSync("git", ["rev-parse", "--show-toplevel"], { encoding: "utf8" });
  if (result.status !== 0) return process.cwd();
  return result.stdout.trim();
}

const root = repoRoot();
const home = os.homedir();
const gsdHome = process.env.GSD_HOME || path.join(home, ".claude", "get-shit-done");
const claudeGSDCommands = process.env.GSD_COMMANDS_HOME || path.join(home, ".claude", "commands", "gsd");
const gsdTools = path.join(gsdHome, "bin", "gsd-tools.cjs");

const upstreamSources = {
  "map-codebase": [
    path.join(claudeGSDCommands, "map-codebase.md"),
    path.join(gsdHome, "workflows", "map-codebase.md"),
  ],
  "new-project": [
    path.join(claudeGSDCommands, "new-project.md"),
    path.join(gsdHome, "workflows", "new-project.md"),
  ],
  "plan-phase": [
    path.join(claudeGSDCommands, "plan-phase.md"),
    path.join(gsdHome, "workflows", "plan-phase.md"),
  ],
  "programming-loop": [
    path.join(claudeGSDCommands, "programming-loop.md"),
    path.join(home, ".claude", "skills", "gsd-programming-loop", "SKILL.md"),
    path.join(home, ".claude", "skills", "gsd-programming-loop", "references", "workflows", "programming-loop.md"),
  ],
};

const promptSources = {
  "issue-122-rebootstrap": {
    file: path.join(root, ".gsd", "prompts", "issue-122-rebootstrap.md"),
    workflows: ["map-codebase", "new-project", "plan-phase", "programming-loop"],
  },
};

function usage() {
  console.log(`repo-local GSD command\n\nUsage:\n  scripts/gsd help\n  scripts/gsd doctor\n  scripts/gsd workflows\n  scripts/gsd sources <workflow|prompt>\n  scripts/gsd prompt <prompt-name> [args...]\n  scripts/gsd init <gsd-tools-init-command> [args...]\n\nExamples:\n  scripts/gsd doctor\n  scripts/gsd sources issue-122-rebootstrap\n  scripts/gsd prompt issue-122-rebootstrap > .planning/traces/issue-122-gsd-onboarding-prompt.md\n  scripts/gsd init map-codebase\n\nEnvironment:\n  GSD_HOME          Override upstream GSD Core home (default: ~/.claude/get-shit-done)\n  GSD_COMMANDS_HOME Override upstream GSD command docs (default: ~/.claude/commands/gsd)\n`);
}

function exists(file) {
  try { fs.accessSync(file, fs.constants.R_OK); return true; } catch { return false; }
}

function requireFile(file) {
  if (!exists(file)) {
    throw new Error(`missing required GSD source: ${file}`);
  }
}

function workflowsFor(name) {
  if (upstreamSources[name]) return [name];
  if (promptSources[name]) return promptSources[name].workflows;
  throw new Error(`unknown workflow or prompt: ${name}`);
}

function sourceList(name) {
  const workflows = workflowsFor(name);
  const files = [];
  for (const workflow of workflows) {
    for (const file of upstreamSources[workflow] || []) files.push(file);
  }
  if (promptSources[name]) files.push(promptSources[name].file);
  return [...new Set(files)];
}

function doctor() {
  const checks = [
    ["repo root", root],
    ["GSD_HOME", gsdHome],
    ["gsd-tools", gsdTools],
    ["GSD commands", claudeGSDCommands],
  ];
  let ok = true;
  for (const [label, file] of checks) {
    const good = exists(file);
    ok = ok && good;
    console.log(`${good ? "ok" : "missing"}\t${label}\t${file}`);
  }
  for (const name of Object.keys(upstreamSources)) {
    for (const file of upstreamSources[name]) {
      const good = exists(file);
      ok = ok && good;
      console.log(`${good ? "ok" : "missing"}\tsource:${name}\t${file}`);
    }
  }
  for (const [name, meta] of Object.entries(promptSources)) {
    const good = exists(meta.file);
    ok = ok && good;
    console.log(`${good ? "ok" : "missing"}\tprompt:${name}\t${meta.file}`);
  }
  if (!ok) process.exit(1);
}

function printSources(name) {
  for (const file of sourceList(name)) {
    requireFile(file);
    console.log(file);
  }
}

function printPrompt(name, args) {
  const meta = promptSources[name];
  if (!meta) throw new Error(`unknown prompt: ${name}`);
  for (const file of sourceList(name)) requireFile(file);
  const prompt = fs.readFileSync(meta.file, "utf8");
  console.log(`# Generated by scripts/gsd prompt ${name}${args.length ? ` ${args.join(" ")}` : ""}`);
  console.log(`# Repo: ${root}`);
  console.log(`# Upstream GSD home: ${gsdHome}`);
  console.log("");
  console.log(prompt.trimEnd());
  console.log("");
  console.log("## Upstream source files resolved by scripts/gsd");
  console.log("");
  for (const file of sourceList(name)) console.log(`- \`${file}\``);
}

function runInit(args) {
  requireFile(gsdTools);
  const child = spawnSync("node", [gsdTools, "init", ...args], {
    cwd: root,
    stdio: "inherit",
  });
  process.exit(child.status ?? 1);
}

function main() {
  const [cmd, ...args] = process.argv.slice(2);
  try {
    switch (cmd || "help") {
      case "help":
      case "--help":
      case "-h":
        usage();
        break;
      case "doctor":
        doctor();
        break;
      case "workflows":
        console.log("# workflows");
        Object.keys(upstreamSources).sort().forEach((name) => console.log(name));
        console.log("# prompts");
        Object.keys(promptSources).sort().forEach((name) => console.log(name));
        break;
      case "sources":
        if (!args[0]) throw new Error("sources requires <workflow|prompt>");
        printSources(args[0]);
        break;
      case "prompt":
        if (!args[0]) throw new Error("prompt requires <prompt-name>");
        printPrompt(args[0], args.slice(1));
        break;
      case "init":
        if (!args[0]) throw new Error("init requires a gsd-tools init command, e.g. map-codebase");
        runInit(args);
        break;
      default:
        throw new Error(`unknown command: ${cmd}`);
    }
  } catch (error) {
    console.error(`scripts/gsd: ${error.message}`);
    process.exit(1);
  }
}

main();
