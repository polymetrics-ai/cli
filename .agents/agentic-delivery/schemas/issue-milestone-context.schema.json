{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Issue to GSD milestone context",
  "type": "object",
  "additionalProperties": false,
  "required": ["issue", "parent_issue", "objective", "scope", "non_goals", "acceptance_criteria", "dependencies", "write_scope", "required_reading", "required_skills", "tdd", "verification", "safety", "human_gates", "branch", "pr_base", "review_route", "sources"],
  "properties": {
    "issue": {"type": "integer", "minimum": 1},
    "parent_issue": {"type": "integer", "minimum": 1},
    "objective": {"type": "string", "minLength": 1, "maxLength": 4000},
    "scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "non_goals": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "integer", "minimum": 1}},
    "write_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "not": {"pattern": "(^/|\\.\\.)"}}},
    "required_reading": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "required_skills": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "tdd": {"type": "object", "required": ["red", "green", "refactor"], "properties": {"red": {"type": "string"}, "green": {"type": "string"}, "refactor": {"type": "string"}}},
    "verification": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "safety": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "human_gates": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "branch": {"type": "string", "minLength": 1},
    "pr_base": {"type": "string", "minLength": 1},
    "review_route": {"type": "string", "minLength": 1},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
