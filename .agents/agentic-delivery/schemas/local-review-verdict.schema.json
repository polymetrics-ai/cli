{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local exact-head review verdict",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidate_head_sha", "base_sha", "policy_bundle_hash", "validator_model_observed", "thinking_observed", "independent_checks", "findings", "dispositions", "verdict", "created_at"],
  "properties": {
    "candidate_head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "policy_bundle_hash": {"type": "string", "minLength": 1},
    "validator_model_observed": {"const": "openai-codex/gpt-5.6-sol"},
    "thinking_observed": {"const": "high"},
    "independent_checks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "findings": {"type": "array", "items": {"type": "object"}},
    "dispositions": {"type": "array", "items": {"type": "object"}},
    "verdict": {"enum": ["PROCEED", "RETRY", "REVERT", "HALT"]},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
