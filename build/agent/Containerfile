# Containerfile — polymetrics RLM agent (PI mono + Python ML).
#
# Multi-stage, glibc base (node:22-slim, NOT alpine: musl makes DuckDB/polars
# fall back to slow/source builds). Pin every base/dep by digest/version before
# publishing (HUMAN GATE 2). Build with: pm agent image build  (or podman build).
#
# Runtime contract (see build/agent/README.md):
#   IN : /work/in/input.ndjson (warehouse-enveloped) + /work/in/request.json
#   OUT: /work/out/output.ndjson (+ manifest.json), written atomically on success
#   ENV: PM_LLM_PROVIDER, PM_LLM_MODEL, and provider creds (PM_LLM_*/OPENROUTER_API_KEY
#        or a mounted ~/.pi/agent/auth.json for subscription OAuth); PM_RLM_MAXITER
#   EXIT: 0 ok · 3 reflection-exhausted · 4 LLM unreachable

# ---- Stage 1: build the PI mono TS agent -----------------------------------
FROM node:22-slim AS agent-build
WORKDIR /agent
COPY package.json package-lock.json* ./
RUN --mount=type=cache,target=/root/.npm npm install --no-audit --no-fund
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

# ---- Stage 2: DuckDB CLI (pinned, checksum-verified before publish) --------
FROM debian:bookworm-slim AS duckdb-cli
ARG DUCKDB_VERSION=1.1.3
# TARGETARCH is injected by the builder (amd64/arm64). DuckDB names the arm asset
# "aarch64", so map Docker's arch name to DuckDB's.
ARG TARGETARCH
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates unzip \
 && case "${TARGETARCH:-amd64}" in \
      amd64) DUCKARCH=amd64 ;; \
      arm64) DUCKARCH=aarch64 ;; \
      *) DUCKARCH="${TARGETARCH}" ;; \
    esac \
 && curl -fsSL "https://github.com/duckdb/duckdb/releases/download/v${DUCKDB_VERSION}/duckdb_cli-linux-${DUCKARCH}.zip" -o /tmp/duckdb.zip \
 && unzip /tmp/duckdb.zip -d /usr/local/bin \
 && chmod +x /usr/local/bin/duckdb

# ---- Stage 3: runtime ------------------------------------------------------
FROM node:22-slim AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends python3 python3-venv ca-certificates \
 && rm -rf /var/lib/apt/lists/*
ENV VENV=/opt/venv
RUN python3 -m venv $VENV
ENV PATH="$VENV/bin:$PATH"
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY --from=duckdb-cli /usr/local/bin/duckdb /usr/local/bin/duckdb
WORKDIR /agent
COPY --from=agent-build /agent/dist ./dist
COPY --from=agent-build /agent/node_modules ./node_modules
COPY validate.py ./validate.py
# Non-root; the container is the trust boundary.
USER node
ENTRYPOINT ["node", "dist/agent.mjs"]
