{
  "name": "polymetrics-rlm-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PI mono RLM agent: classify -> generate Python/SQL -> execute -> validate (query-validates-query) -> reflect. Runs inside the polymetrics RLM container.",
  "scripts": {
    "build": "esbuild src/agent.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist/agent.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.10",
    "@earendil-works/pi-ai": "0.80.10",
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
