{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["base_url"],
  "properties": {
    "base_url": { "type": "string", "default": "https://api.example.com" },
    "max_pages": { "type": "integer", "default": "not-a-number" },
    "token": { "type": "string", "x-secret": true }
  }
}
