# Local development env for blog comments/bookmarks + sign-in.
# Copy to .env.local and fill in. All values are optional for building
# and browsing the site; they gate the annotation features only.

# Postgres (e.g. `podman run -d -p 5432:5432 -e POSTGRES_PASSWORD=dev -e POSTGRES_USER=website -e POSTGRES_DB=website postgres:17-alpine`)
DATABASE_URL=postgres://website:dev@localhost:5432/website

# openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3100

# GitHub OAuth app callback: http://localhost:3100/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated emails allowed to delete any comment.
ADMIN_EMAILS=
