{
  "name": "cli-polymetrics-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack",
    "gen:bundles": "node scripts/gen-connector-bundles.mjs",
    "gen:connectors": "node scripts/gen-connectors.mjs",
    "gen:penrose": "node scripts/gen-penrose.mjs",
    "gen:patterns": "node scripts/gen-patterns.mjs",
    "gen:catalog": "node scripts/gen-connector-bundles.mjs && node scripts/gen-connector-catalog.mjs",
    "gen:docs": "node scripts/gen-docs-data.mjs",
    "gen:website-data": "node scripts/gen-docs-data.mjs && node scripts/gen-connector-bundles.mjs && node scripts/gen-connector-catalog.mjs && node scripts/gen-connectors.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "start": "next start",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fumadocs-core": "^16.10.7",
    "fumadocs-mdx": "^15.0.13",
    "fumadocs-ui": "^16.10.7",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  }
}
