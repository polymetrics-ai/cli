{
  "mode": "yolo",
  "granularity": "coarse",
  "runtime": "pi",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true,
    "use_worktrees": false,
    "tdd_mode": true,
    "universal_programming_loop": true
  },
  "planning": {
    "commit_docs": true,
    "search_gitignored": false
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": false,
    "max_concurrent_agents": 4,
    "min_plans_for_parallel": 2
  },
  "gates": {
    "confirm_project": false,
    "confirm_phases": false,
    "confirm_roadmap": false,
    "confirm_breakdown": true,
    "confirm_plan": true,
    "execute_next_plan": false,
    "issues_review": true,
    "confirm_transition": true
  },
  "safety": {
    "always_confirm_destructive": true,
    "always_confirm_external_services": true,
    "human_gates": [
      "new_dependencies",
      "auth_scope_changes",
      "destructive_admin_actions",
      "production_deploys",
      "credentialed_connector_checks",
      "reverse_etl_execution",
      "quality_gate_reductions",
      "main_branch_merge"
    ]
  },
  "model_profile": "inherit",
  "model_overrides": {
    "gsd-loop-coordinator": "openai-codex/gpt-5.6-sol",
    "gsd-loop-planner": "openai-codex/gpt-5.6-sol",
    "gsd-loop-reviewer": "openai-codex/gpt-5.6-sol",
    "gsd-loop-backend": "openai-codex/gpt-5.6-sol",
    "gsd-loop-tester": "openai-codex/gpt-5.6-sol",
    "gsd-loop-security": "openai-codex/gpt-5.6-sol",
    "gsd-loop-reliability-observability": "openai-codex/gpt-5.6-sol",
    "gsd-planner": "openai-codex/gpt-5.6-sol",
    "gsd-plan-checker": "openai-codex/gpt-5.6-sol",
    "gsd-verifier": "openai-codex/gpt-5.6-sol",
    "gsd-executor": "openai-codex/gpt-5.6-sol",
    "gsd-code-fixer": "openai-codex/gpt-5.6-sol",
    "gsd-doc-writer": "openai-codex/gpt-5.6-sol"
  },
  "effort": {
    "default": "xhigh",
    "routing_tier_defaults": {
      "light": "xhigh",
      "standard": "xhigh",
      "heavy": "xhigh"
    },
    "agent_overrides": {
      "gsd-loop-backend": "high",
      "gsd-executor": "high",
      "gsd-code-fixer": "high",
      "gsd-doc-writer": "high"
    }
  }
}
