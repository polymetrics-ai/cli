{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "datasets",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "date_created",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "href": { "type": ["string", "null"] },
    "date_created": { "type": ["string", "null"] },
    "total_size": { "type": ["integer", "null"] },
    "dataset_type": { "type": ["object", "null"] },
    "project": { "type": ["object", "null"] }
  }
}
