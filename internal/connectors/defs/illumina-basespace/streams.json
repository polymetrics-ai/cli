{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_header",
        "header": "x-access-token",
        "value": "{{ secrets.access_token }}"
      }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "Limit",
      "offset_param": "Offset",
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/v1pre3/users/{{ config.user }}"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "illumina-basespace access_token is missing or invalid; re-run pm credentials add illumina-basespace"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "illumina-basespace rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/v1pre3/users/{{ config.user }}/projects",
      "records": {
        "path": "Response.Items"
      },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "name": "{{ record.Name }}",
        "href": "{{ record.Href }}",
        "date_created": "{{ record.DateCreated }}",
        "date_modified": "{{ record.DateModified }}",
        "total_size": "{{ record.TotalSize }}",
        "user_owned_by": "{{ record.UserOwnedBy }}"
      },
      "schema": "schemas/projects.json"
    },
    {
      "name": "runs",
      "path": "/v1pre3/users/{{ config.user }}/runs",
      "records": {
        "path": "Response.Items"
      },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "name": "{{ record.Name }}",
        "href": "{{ record.Href }}",
        "experiment_name": "{{ record.ExperimentName }}",
        "status": "{{ record.Status }}",
        "date_created": "{{ record.DateCreated }}",
        "date_modified": "{{ record.DateModified }}",
        "total_size": "{{ record.TotalSize }}",
        "instrument_name": "{{ record.InstrumentName }}"
      },
      "schema": "schemas/runs.json"
    },
    {
      "name": "samples",
      "path": "/v1pre3/users/{{ config.user }}/samples",
      "records": {
        "path": "Response.Items"
      },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "name": "{{ record.Name }}",
        "href": "{{ record.Href }}",
        "sample_id": "{{ record.SampleId }}",
        "status": "{{ record.Status }}",
        "date_created": "{{ record.DateCreated }}",
        "num_reads_raw": "{{ record.NumReadsRaw }}",
        "num_reads_pf": "{{ record.NumReadsPF }}",
        "total_size": "{{ record.TotalSize }}"
      },
      "schema": "schemas/samples.json"
    },
    {
      "name": "appsessions",
      "path": "/v1pre3/users/{{ config.user }}/appsessions",
      "records": {
        "path": "Response.Items"
      },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "name": "{{ record.Name }}",
        "href": "{{ record.Href }}",
        "status": "{{ record.Status }}",
        "status_summary": "{{ record.StatusSummary }}",
        "date_created": "{{ record.DateCreated }}",
        "date_completed": "{{ record.DateCompleted }}",
        "total_size": "{{ record.TotalSize }}",
        "application": "{{ record.Application }}"
      },
      "schema": "schemas/appsessions.json"
    },
    {
      "name": "datasets",
      "path": "/v1pre3/users/{{ config.user }}/datasets",
      "records": {
        "path": "Response.Items"
      },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "name": "{{ record.Name }}",
        "href": "{{ record.Href }}",
        "date_created": "{{ record.DateCreated }}",
        "total_size": "{{ record.TotalSize }}",
        "dataset_type": "{{ record.DatasetType }}",
        "project": "{{ record.Project }}"
      },
      "schema": "schemas/datasets.json"
    },
    {
      "name": "applications",
      "path": "/v1pre3/applications",
      "records": {
        "path": "Response.Items"
      },
      "projection": "passthrough",
      "schema": "schemas/applications.json"
    },
    {
      "name": "application",
      "path": "/v1pre3/applications/{{ config.application_id }}",
      "records": {
        "path": "Response"
      },
      "projection": "passthrough",
      "schema": "schemas/application.json",
      "pagination": {
        "type": "none"
      }
    },
    {
      "name": "application_qcthresholds",
