{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "uploads",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "file_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "height": {
      "type": [
        "integer",
        "null"
      ]
    },
    "width": {
      "type": [
        "integer",
        "null"
      ]
    },
    "size": {
      "type": [
        "integer",
        "null"
      ]
    },
    "mime_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "preview_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "upload_time": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-cursor-field": "upload_time"
}
