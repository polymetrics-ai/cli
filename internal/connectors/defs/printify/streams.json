{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_token }}" }
    ],
    "check": { "method": "GET", "path": "/shops.json" },
    "error_map": [
      { "status": 401, "hint": "printify api_token is missing or invalid; re-run pm credentials add printify" },
      { "status": 403, "hint": "printify account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "printify rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "shops",
      "path": "/shops.json",
      "records": { "path": "." },
      "schema": "schemas/shops.json"
    },
    {
      "name": "products",
      "path": "/shops/{{ config.shop_id }}/products.json",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "next_page_url"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "orders",
      "path": "/shops/{{ config.shop_id }}/orders.json",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "next_page_url"
      },
      "schema": "schemas/orders.json"
    },
    {
      "name": "blueprints",
      "path": "/catalog/blueprints.json",
      "records": { "path": "." },
      "schema": "schemas/blueprints.json"
    },
    {
      "name": "print_providers",
      "path": "/catalog/print_providers.json",
      "records": { "path": "." },
      "schema": "schemas/print_providers.json"
    }
  ]
}
