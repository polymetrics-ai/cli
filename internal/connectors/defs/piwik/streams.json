{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "token_auth", "value": "{{ secrets.token_auth }}" }
    ],
    "check": {
      "method": "GET",
      "path": "/index.php",
      "query": { "module": "API", "format": "JSON", "method": "SitesManager.getAllSites" }
    },
    "error_map": [
      { "status": 401, "hint": "piwik token_auth is missing or invalid; re-run pm credentials add piwik" },
      { "status": 403, "hint": "piwik token_auth lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "piwik rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "sites",
      "path": "/index.php",
      "query": {
        "module": "API",
        "format": "JSON",
        "method": "SitesManager.getAllSites",
        "filter_limit": "100",
        "filter_offset": "0"
      },
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "site_id": "{{ record.idsite }}",
        "main_url": "{{ record.main_url }}"
      },
      "schema": "schemas/sites.json"
    },
    {
      "name": "visits",
      "path": "/index.php",
      "query": {
        "module": "API",
        "format": "JSON",
        "method": "Live.getLastVisitsDetails",
        "idSite": "{{ config.site_id }}",
        "period": "{{ config.period }}",
        "date": "{{ config.date }}"
      },
      "records": { "path": "" },
      "pagination": {
        "type": "offset_limit",
        "limit_param": "filter_limit",
        "offset_param": "filter_offset",
        "page_size": 100
      },
      "computed_fields": {
        "visit_id": "{{ record.idVisit }}",
        "visitor_id": "{{ record.visitorId }}",
        "last_action_at": "{{ record.lastActionDateTime }}"
      },
      "schema": "schemas/visits.json"
    },
    {
      "name": "actions",
      "path": "/index.php",
      "query": {
        "module": "API",
        "format": "JSON",
        "method": "Actions.getPageUrls",
        "idSite": "{{ config.site_id }}",
        "period": "{{ config.period }}",
        "date": "{{ config.date }}"
      },
      "records": { "path": "" },
      "pagination": {
        "type": "offset_limit",
        "limit_param": "filter_limit",
        "offset_param": "filter_offset",
        "page_size": 100
      },
      "computed_fields": {
        "hits": "{{ record.nb_hits }}",
        "visits": "{{ record.nb_visits }}"
      },
      "schema": "schemas/actions.json"
    },
    {
      "name": "goals",
      "path": "/index.php",
      "query": {
        "module": "API",
        "format": "JSON",
        "method": "Goals.getGoals",
        "idSite": "{{ config.site_id }}",
        "period": "{{ config.period }}",
        "date": "{{ config.date }}",
        "filter_limit": "100",
        "filter_offset": "0"
      },
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "goal_id": "{{ record.idgoal }}"
      },
      "schema": "schemas/goals.json"
    }
  ]
}
