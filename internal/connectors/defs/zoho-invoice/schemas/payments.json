  "title": "payments",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "payment_id": { "type": "string" },
    "payment_number": { "type": ["string", "null"] },
    "reference_number": { "type": ["string", "null"] },
    "customer_id": { "type": ["string", "null"] },
