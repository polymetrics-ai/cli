{
  "api": "Split Admin API (https://api.split.io)",
  "docs": "https://docs.split.io/reference/api-overview",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only, matching internal/connectors/split-io's exact endpoint set; the full Split Admin API (change requests, attributes, API keys, restrictions, etc.) is out of scope until Pass B",
