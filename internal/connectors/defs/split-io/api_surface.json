    { "method": "GET", "path": "/internal/api/v2/segments/ws/{workspace_id}", "covered_by": { "stream": "segments" } },
    { "method": "GET", "path": "/internal/api/v2/segments/ws/{workspace_id}/{segment_name}/keys", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/internal/api/v2/splits/ws/{workspace_id}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/internal/api/v2/apiKeys", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
