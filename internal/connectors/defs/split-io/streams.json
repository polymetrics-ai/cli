{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/internal/api/v2/workspaces", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "split-io API key is missing or invalid; re-run pm credentials add split-io" },
      { "status": 403, "hint": "split-io account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "split-io rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "workspaces",
      "path": "/internal/api/v2/workspaces",
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 100
      },
      "records": { "path": "objects" },
      "schema": "schemas/workspaces.json"
    },
    {
      "name": "environments",
      "path": "/internal/api/v2/environments/ws/{{ config.workspace_id }}",
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 100
      },
      "records": { "path": "objects" },
      "schema": "schemas/environments.json"
    },
    {
      "name": "splits",
      "path": "/internal/api/v2/splits/ws/{{ config.workspace_id }}",
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 100
      },
      "records": { "path": "objects" },
      "schema": "schemas/splits.json"
    },
    {
      "name": "segments",
      "path": "/internal/api/v2/segments/ws/{{ config.workspace_id }}",
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 100
      },
      "records": { "path": "objects" },
      "schema": "schemas/segments.json"
    },
    {
      "name": "groups",
      "path": "/internal/api/v2/groups",
      "pagination": { "type": "none" },
      "records": { "path": "objects" },
      "schema": "schemas/groups.json"
    },
    {
      "name": "traffic_types",
      "path": "/internal/api/v2/trafficTypes/ws/{{ config.workspace_id }}",
      "pagination": { "type": "none" },
      "records": { "path": "" },
      "schema": "schemas/traffic_types.json"
    },
    {
      "name": "users",
      "path": "/internal/api/v2/users",
      "pagination": {
        "type": "cursor",
        "cursor_param": "after",
        "token_path": "nextMarker"
      },
      "records": { "path": "data" },
      "schema": "schemas/users.json"
    }
  ]
}
