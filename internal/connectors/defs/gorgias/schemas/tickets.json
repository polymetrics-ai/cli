{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tickets",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_datetime",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "subject": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "channel": { "type": ["string", "null"] },
    "via": { "type": ["string", "null"] },
    "priority": { "type": ["string", "null"] },
    "language": { "type": ["string", "null"] },
    "is_unread": { "type": ["boolean", "null"] },
    "spam": { "type": ["boolean", "null"] },
    "trashed_datetime": { "type": ["string", "null"] },
    "created_datetime": { "type": ["string", "null"] },
    "updated_datetime": { "type": ["string", "null"] },
    "opened_datetime": { "type": ["string", "null"] },
    "closed_datetime": { "type": ["string", "null"] }
  }
}
