{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "messages",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "created_datetime",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "ticket_id": { "type": ["integer", "null"] },
    "channel": { "type": ["string", "null"] },
    "via": { "type": ["string", "null"] },
    "from_agent": { "type": ["boolean", "null"] },
    "subject": { "type": ["string", "null"] },
    "body_text": { "type": ["string", "null"] },
    "stripped_text": { "type": ["string", "null"] },
    "public": { "type": ["boolean", "null"] },
    "created_datetime": { "type": ["string", "null"] },
    "sent_datetime": { "type": ["string", "null"] }
  }
}
