  "global_flags": [
    {
      "name": "json",
      "type": "boolean",
      "summary": "Write machine-readable JSON output."
    },
    {
      "name": "connection",
      "type": "string",
      "summary": "Use a saved Gorgias connector credential and account API root.",
      "maps_to": "connection"
    }
  ],
  "commands": [
    {
      "path": "ticket list",
      "summary": "List tickets",
      "intent": "etl",
      "availability": "implemented",
      "stream": "tickets",
      "source_url": "https://developers.gorgias.com/reference/list-tickets.md",
      "flags": [
        {
          "name": "limit",
          "type": "integer",
          "summary": "Records per page, bounded by the connector page_size configuration.",
          "maps_to": "query.limit"
        }
      ],
      "examples": [
        "pm gorgias ticket list --json"
      ],
      "api_surface": [
        {
          "method": "GET",
          "path": "/tickets"
        }
      ]
    },
    {
      "path": "ticket view",
      "summary": "View a ticket by ID",
      "intent": "direct_read",
      "availability": "planned",
      "source_url": "https://developers.gorgias.com/reference/get-ticket.md",
      "notes": "Planned for the direct-read lane; no raw HTTP passthrough is exposed."
    },
    {
      "path": "ticket create",
      "summary": "Create a ticket",
      "intent": "reverse_etl",
      "availability": "planned",
      "source_url": "https://developers.gorgias.com/reference/create-ticket.md",
      "risk": "Creates a helpdesk ticket in the configured Gorgias account.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute."
    },
    {
      "path": "ticket update",
      "summary": "Update a ticket",
