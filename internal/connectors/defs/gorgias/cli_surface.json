    {
      "id": "helpdesk",
      "title": "Helpdesk Records",
      "commands": [
        "ticket",
        "message",
        "customer",
        "satisfaction-survey"
      ]
    },
    {
      "id": "configuration",
      "title": "Configuration And Administration",
      "commands": [
        "account",
        "setting",
