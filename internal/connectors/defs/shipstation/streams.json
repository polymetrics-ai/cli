{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "{{ secrets.api_secret }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/orders", "query": { "page": "1", "pageSize": "1" } },
    "error_map": [
      { "status": 401, "hint": "shipstation api_key/api_secret are missing or invalid; re-run pm credentials add shipstation" },
      { "status": 403, "hint": "shipstation account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "shipstation rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "orders",
      "path": "/orders",
      "records": { "path": "orders" },
      "computed_fields": {
        "id": "{{ record.orderId }}",
        "order_number": "{{ record.orderNumber }}",
        "status": "{{ record.orderStatus }}",
        "modified_at": "{{ record.modifyDate }}"
      },
      "schema": "schemas/orders.json"
    },
    {
      "name": "shipments",
      "path": "/shipments",
      "records": { "path": "shipments" },
      "computed_fields": {
        "id": "{{ record.shipmentId }}",
        "order_number": "{{ record.orderNumber }}",
        "status": "{{ record.shipmentStatus }}",
        "modified_at": "{{ record.modifyDate }}"
      },
      "schema": "schemas/shipments.json"
    },
    {
      "name": "products",
      "path": "/products",
      "records": { "path": "products" },
      "computed_fields": {
        "id": "{{ record.productId }}",
        "name": "{{ record.name }}",
        "modified_at": "{{ record.modifyDate }}"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "records": { "path": "customers" },
      "computed_fields": {
        "id": "{{ record.customerId }}",
        "name": "{{ record.name }}",
        "modified_at": "{{ record.modifyDate }}"
      },
      "schema": "schemas/customers.json"
    }
  ]
}
