{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/account/{{ config.account }}/users" },
    "error_map": [
      { "status": 401, "hint": "klaus-api api_key is missing or invalid; re-run pm credentials add klaus-api" },
      { "status": 429, "class": "rate_limited", "hint": "klaus-api rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/account/{{ config.account }}/users",
      "records": { "path": "users" },
      "schema": "schemas/users.json"
    },
    {
      "name": "categories",
      "path": "/account/{{ config.account }}/workspace/{{ config.workspace }}/categories",
      "records": { "path": "categories" },
      "schema": "schemas/categories.json"
    }
  ]
}
