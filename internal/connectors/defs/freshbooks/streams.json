{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Api-Version": "alpha"
    },
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.oauth_access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/accounting/account/{{ config.account_id }}/users/clients",
      "query": { "per_page": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "freshbooks oauth_access_token is missing or invalid; re-run pm credentials add freshbooks" },
      { "status": 403, "hint": "freshbooks account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "freshbooks rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "clients",
      "path": "/accounting/account/{{ config.account_id }}/users/clients",
      "records": { "path": "response.result.clients" },
      "schema": "schemas/clients.json"
    },
    {
      "name": "invoices",
      "path": "/accounting/account/{{ config.account_id }}/invoices/invoices",
      "records": { "path": "response.result.invoices" },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "expenses",
      "path": "/accounting/account/{{ config.account_id }}/expenses/expenses",
      "records": { "path": "response.result.expenses" },
      "schema": "schemas/expenses.json"
    },
    {
      "name": "payments",
      "path": "/accounting/account/{{ config.account_id }}/payments/payments",
      "records": { "path": "response.result.payments" },
      "schema": "schemas/payments.json"
    },
    {
      "name": "items",
      "path": "/accounting/account/{{ config.account_id }}/items/items",
      "records": { "path": "response.result.items" },
      "schema": "schemas/items.json"
    }
  ]
}
