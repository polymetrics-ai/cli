{
  "actions": [
    {
      "name": "create_asset",
      "kind": "create",
      "method": "POST",
      "path": "/assets.api",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["fixed_asset[name]", "fixed_asset[group_id]", "fixed_asset[location_id]"],
        "properties": {
          "fixed_asset[name]": { "type": "string" },
          "fixed_asset[group_id]": { "type": "integer" },
          "fixed_asset[location_id]": { "type": "integer" },
          "fixed_asset[sub_group_id]": { "type": "integer" },
          "fixed_asset[purchased_on]": { "type": "string" },
          "fixed_asset[identifier]": { "type": "string" },
          "fixed_asset[manufacturer]": { "type": "string" },
          "fixed_asset[image_url]": { "type": "string" }
        }
      },
      "risk": "external mutation; creates a new asset record; approval required"
    },
    {
      "name": "update_asset",
      "kind": "update",
      "method": "PUT",
      "path": "/assets/{{ record.id }}.api",
      "path_fields": ["id"],
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer" },
          "fixed_asset[name]": { "type": "string" },
          "fixed_asset[group_id]": { "type": "integer" },
          "fixed_asset[location_id]": { "type": "integer" },
          "fixed_asset[identifier]": { "type": "string" },
          "fixed_asset[description]": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
