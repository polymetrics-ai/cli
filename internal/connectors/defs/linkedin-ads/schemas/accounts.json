{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accounts",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "last_modified",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "currency": { "type": ["string", "null"] },
    "reference": { "type": ["string", "null"] },
    "test": { "type": ["boolean", "null"] },
    "version": { "type": ["object", "null"] },
    "created_at": { "type": ["integer", "null"], "description": "changeAuditStamps.created.time, epoch millis." },
    "last_modified": { "type": ["integer", "null"], "description": "changeAuditStamps.lastModified.time, epoch millis." }
  }
}
