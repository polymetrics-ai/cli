{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "campaigns",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "last_modified",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "account": { "type": ["string", "null"] },
    "campaign_group": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "cost_type": { "type": ["string", "null"] },
    "objective_type": { "type": ["string", "null"] },
    "format": { "type": ["string", "null"] },
    "daily_budget": { "type": ["object", "null"] },
    "unit_cost": { "type": ["object", "null"] },
    "run_schedule": { "type": ["object", "null"] },
    "created_at": { "type": ["integer", "null"], "description": "changeAuditStamps.created.time, epoch millis." },
    "last_modified": { "type": ["integer", "null"], "description": "changeAuditStamps.lastModified.time, epoch millis." }
  }
}
