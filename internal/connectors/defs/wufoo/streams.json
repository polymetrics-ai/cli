{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "pass" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/forms.json" },
    "error_map": [
      { "status": 401, "hint": "wufoo api_key is missing or invalid; re-run pm credentials add wufoo" },
      { "status": 403, "hint": "wufoo account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "wufoo rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "forms",
      "path": "/forms.json",
      "records": { "path": "Forms" },
      "schema": "schemas/forms.json",
      "projection": "passthrough"
    },
    {
      "name": "form_fields",
      "path": "/forms/{{ config.form_hash }}/fields.json",
      "records": { "path": "Fields" },
      "schema": "schemas/form_fields.json",
      "projection": "passthrough",
      "pagination": { "type": "none" }
    },
    {
      "name": "entries",
      "path": "/forms/{{ config.form_hash }}/entries.json",
      "records": { "path": "Entries" },
      "schema": "schemas/entries.json",
      "projection": "passthrough",
      "pagination": {
        "type": "offset_limit",
        "offset_param": "pageStart",
        "limit_param": "pageSize",
        "page_size": 100
      }
    },
    {
      "name": "form_comments",
      "path": "/forms/{{ config.form_hash }}/comments.json",
      "records": { "path": "Comments" },
      "schema": "schemas/form_comments.json",
      "projection": "passthrough",
      "pagination": {
        "type": "offset_limit",
        "offset_param": "pageStart",
        "limit_param": "pageSize",
        "page_size": 25
      }
    },
    {
      "name": "reports",
      "path": "/reports.json",
      "records": { "path": "Reports" },
      "schema": "schemas/reports.json",
      "projection": "passthrough"
    },
    {
      "name": "report_fields",
      "path": "/reports/{{ config.report_hash }}/fields.json",
      "records": { "path": "Fields" },
      "schema": "schemas/report_fields.json",
      "projection": "passthrough",
      "pagination": { "type": "none" }
    },
    {
      "name": "report_entries",
      "path": "/reports/{{ config.report_hash }}/entries.json",
      "records": { "path": "Entries" },
      "schema": "schemas/report_entries.json",
      "projection": "passthrough",
      "pagination": {
        "type": "offset_limit",
        "offset_param": "pageStart",
        "limit_param": "pageSize",
        "page_size": 100
      }
    },
    {
      "name": "report_widgets",
      "path": "/reports/{{ config.report_hash }}/widgets.json",
      "records": { "path": "Widgets" },
      "schema": "schemas/report_widgets.json",
      "projection": "passthrough",
      "pagination": { "type": "none" }
    }
  ]
}
