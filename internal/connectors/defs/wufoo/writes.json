{
  "actions": [
    {
      "name": "submit_entry",
      "kind": "create",
      "method": "POST",
      "path": "/forms/{{ config.form_hash }}/entries.json",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "minProperties": 1,
        "additionalProperties": true
      },
      "risk": "external mutation; creates a live Wufoo form entry; approval required"
    },
    {
      "name": "add_webhook",
      "kind": "create",
      "method": "PUT",
      "path": "/forms/{{ config.form_hash }}/webhooks.json",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" },
          "handshakeKey": { "type": "string" },
          "metadata": { "type": "string" }
        }
      },
      "risk": "external mutation; registers a webhook callback URL on the configured form; approval required"
    },
    {
      "name": "delete_webhook",
      "kind": "delete",
      "method": "DELETE",
      "path": "/forms/{{ config.form_hash }}/webhooks/{{ record.hash }}.json",
      "path_fields": ["hash"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["hash"],
        "properties": {
          "hash": { "type": "string" }
        }
      },
      "delete": { "missing_ok_status": [404] },
      "risk": "irreversible external deletion; removes a registered webhook from the configured form; approval required"
    }
  ]
}
