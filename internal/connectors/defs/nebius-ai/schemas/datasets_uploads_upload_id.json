{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "The object identifier, which can be referenced in the API endpoints."
    },
    "upload_info": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PENDING",
            "COMPLETING",
            "COMPLETED",
            "FAILED",
            "CANCELLED"
          ]
        },
        "dataset": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string",
              "description": "ID of the dataset."
            },
            "schema": {
              "type": "array",
              "description": "Dataset schema definition.",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "enum": [
                          "string",
                          "integer",
                          "boolean",
                          "float",
                          "double",
                          "json",
                          "null"
                        ]
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            },
            "folder": {
              "type": "string",
              "description": "Folder path where the dataset is stored."
            }
          },
          "additionalProperties": true
        },
        "error": {
          "type": "string"
        },
        "created_at": {
          "type": "integer",
          "description": "Unix timestamp when the dataset was created."
        },
        "completed_at": {
          "type": "integer"
        },
        "ai_project_id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "x-primary-key": [
    "id"
  ]
}
