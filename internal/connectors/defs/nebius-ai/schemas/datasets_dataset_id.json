{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "The object identifier, which can be referenced in the API endpoints."
    },
    "name": {
      "type": "string",
      "description": "ID of the dataset."
    },
    "status": {
      "type": "string",
      "enum": [
        "READY",
        "PENDING",
        "FAILED",
        "TEMPORARY",
        "DRAFT"
      ]
    },
    "schema": {
      "type": "array",
      "description": "Dataset schema definition.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "enum": [
                  "string",
                  "integer",
                  "boolean",
                  "float",
                  "double",
                  "json",
                  "null"
                ]
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata associated with the dataset.",
      "properties": {},
      "additionalProperties": true
    },
    "current_version_origin": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "upload",
            "s3",
            "demo"
          ]
        }
      },
      "additionalProperties": true
    },
    "folder": {
      "type": "string",
      "description": "Folder path where the dataset is stored."
    },
    "current_version": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "created_at": {
      "type": "integer",
      "description": "Unix timestamp when the dataset was created."
    },
    "error": {
      "type": "string"
    },
    "ai_project_id": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "x-primary-key": [
    "id"
  ]
}
