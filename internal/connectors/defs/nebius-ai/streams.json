{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}"
      }
    ],
    "check": {
      "method": "GET",
      "path": "/v1/models"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "nebius-ai api_key is missing or invalid; re-run pm credentials add nebius-ai"
      },
      {
        "status": 403,
        "class": "permission_denied",
        "hint": "nebius-ai token lacks permission for this endpoint or project"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "nebius-ai rate limit exceeded; retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "models",
      "path": "/v1/models",
      "query": {
        "limit": "{{ config.limit }}"
      },
      "records": {
        "path": "data"
      },
      "pagination": {
        "type": "cursor",
        "cursor_param": "after",
        "last_record_field": "id",
        "stop_path": "has_more"
      },
      "schema": "schemas/models.json"
    },
    {
      "name": "files",
      "path": "/v1/files",
      "query": {
        "limit": "{{ config.limit }}"
      },
      "records": {
        "path": "data"
      },
      "pagination": {
        "type": "cursor",
        "cursor_param": "after",
        "last_record_field": "id",
        "stop_path": "has_more"
      },
      "schema": "schemas/files.json"
    },
    {
      "name": "batches",
      "path": "/v1/batches",
      "query": {
        "limit": "{{ config.limit }}"
      },
      "records": {
        "path": "data"
      },
      "pagination": {
        "type": "cursor",
        "cursor_param": "after",
        "last_record_field": "id",
        "stop_path": "has_more"
      },
      "schema": "schemas/batches.json"
    },
    {
      "name": "files_file_id",
      "path": "/v1/files/{{ config.file_id }}",
      "records": {
        "path": ""
      },
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/files_file_id.json",
      "projection": "passthrough"
    },
    {
      "name": "files_file_id_content",
      "path": "/v1/files/{{ config.file_id }}/content",
