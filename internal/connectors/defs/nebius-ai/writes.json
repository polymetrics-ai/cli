            "properties": {
              "effort": {
                "type": "string",
                "enum": [
                  "none",
                  "minimal",
                  "low",
                  "medium",
                  "high",
                  "xhigh"
                ]
              },
              "generate_summary": {
                "type": "string",
                "enum": [
                  "auto",
                  "concise",
                  "detailed"
                ]
              },
              "summary": {
                "type": "string",
                "enum": [
                  "auto",
                  "concise",
                  "detailed"
                ]
              }
            },
            "additionalProperties": true
          },
          "service_tier": {
            "type": "string",
            "description": "Represents the service tier for requests.\n\nAttributes:\n    Auto: Automatically choose the best available tier for the request (Default or OverLimit).\n    Analyze response to determine which tier was used.\n    Default: Return 429 errors on hitting the rate limit, do not exceed to the OverLimit tier.\n    OverLimit: Indicate that the request was over the user limit.\n            This tier cannot be set by user in the request, but us used in a response for tier=Auto.\n    Flex: Do not consume rate-lim",
            "enum": [
              "auto",
              "default",
              "over-limit",
              "flex",
              "no-limit"
            ]
          },
          "store": {
            "type": "boolean"
          },
          "stream": {
            "type": "boolean"
          },
          "temperature": {
            "type": "number"
          },
          "text": {
            "type": "object",
            "description": "Configuration options for a text response from the model.\n\nCan be plain\ntext or structured JSON data. Learn more:\n- [Text inputs and outputs](https://platform.openai.com/docs/guides/text)\n- [Structured Outputs](https://platform.openai.com/docs/guides/structured-outputs)",
            "properties": {
              "format": {
                "type": "object",
                "description": "Default response format. Used to generate text responses.",
                "properties": {
                  "type": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "verbosity": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              }
            },
            "additionalProperties": true
          },
          "tool_choice": {
            "type": "string",
            "enum": [
              "none",
              "auto",
              "required"
            ]
          },
          "tools": {
            "type": "array",
            "description": "An array of tools the model may call while generating a response.",
            "items": {
              "type": "object",
              "description": "Defines a function in your own code the model can choose to call.\n\nLearn more about [function calling](https://platform.openai.com/docs/guides/function-calling).",
              "properties": {
                "name": {
                  "type": "string"
                },
                "parameters": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                },
                "strict": {
                  "type": "boolean"
                },
                "type": {
                  "type": "string"
                },
                "defer_loading": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "top_logprobs": {
            "type": "integer"
          },
          "top_p": {
            "type": "number"
          },
          "truncation": {
            "type": "string",
