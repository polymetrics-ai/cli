      "method": "POST",
      "path": "/v1/completions",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "model": {
            "type": "string",
            "description": "ID of the model to use."
          },
          "prompt": {
            "type": "string"
          },
          "stream": {
            "type": "boolean"
          },
          "stream_options": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "max_tokens": {
            "type": "integer"
          },
          "temperature": {
            "type": "number"
          },
          "top_p": {
            "type": "number"
          },
          "n": {
            "type": "integer"
          },
          "logprobs": {
            "type": "integer"
          },
          "echo": {
            "type": "boolean"
          },
          "stop": {
            "type": "string"
          },
          "presence_penalty": {
            "type": "number"
          },
          "frequency_penalty": {
            "type": "number"
          },
          "logit_bias": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "user": {
            "type": "string"
          },
          "extra_body": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "service_tier": {
            "type": "string",
            "description": "Represents the service tier for requests.\n\nAttributes:\n    Auto: Automatically choose the best available tier for the request (Default or OverLimit).\n    Analyze response to determine which tier was used.\n    Default: Return 429 errors on hitting the rate limit, do not exceed to the OverLimit tier.\n    OverLimit: Indicate that the request was over the user limit.\n            This tier cannot be set by user in the request, but us used in a response for tier=Auto.\n    Flex: Do not consume rate-lim",
            "enum": [
              "auto",
              "default",
              "over-limit",
              "flex",
              "no-limit"
            ]
          }
        },
        "required": [
          "model",
          "prompt"
        ]
      },
      "risk": "high: external Nebius API side effect or mutation; approval required"
    },
    {
      "name": "create_chat_completions",
      "kind": "create",
      "method": "POST",
      "path": "/v1/chat/completions",
      "body_type": "json",
