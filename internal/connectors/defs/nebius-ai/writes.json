            "enum": [
              "auto",
              "disabled"
            ]
          },
          "user": {
            "type": "string"
          },
          "prompt_cache_key": {
            "type": "string"
          }
        },
        "required": [
          "input",
          "model"
        ]
      },
      "risk": "high: external Nebius API side effect or mutation; approval required"
