                    },
                    "description": {
                      "type": "string"
                    },
                    "parameters": {
                      "type": "object",
                      "properties": {},
                      "additionalProperties": true
                    },
                    "strict": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          },
          "tool_choice": {
            "type": "string"
          },
          "reasoning_effort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh"
            ]
          },
          "n": {
            "type": "integer"
          },
          "stream": {
            "type": "boolean"
          },
          "stream_options": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "stop": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "presence_penalty": {
            "type": "number"
          },
          "frequency_penalty": {
            "type": "number"
          },
          "logit_bias": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "logprobs": {
            "type": "boolean"
          },
          "top_logprobs": {
            "type": "integer"
          },
          "user": {
            "type": "string"
          },
          "response_format": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "text",
                  "json_object",
                  "json_schema"
                ]
              },
              "json_schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "schema": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": true
                  },
                  "strict": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          },
          "extra_body": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "service_tier": {
            "type": "string",
            "description": "Represents the service tier for requests.\n\nAttributes:\n    Auto: Automatically choose the best available tier for the request (Default or OverLimit).\n    Analyze response to determine which tier was used.\n    Default: Return 429 errors on hitting the rate limit, do not exceed to the OverLimit tier.\n    OverLimit: Indicate that the request was over the user limit.\n            This tier cannot be set by user in the request, but us used in a response for tier=Auto.\n    Flex: Do not consume rate-lim",
            "enum": [
              "auto",
              "default",
              "over-limit",
              "flex",
              "no-limit"
            ]
          }
        },
        "required": [
          "model",
          "messages"
        ]
