{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "basic",
        "username": "{{ config.username }}",
        "password": "{{ secrets.password }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page[page]",
      "size_param": "page[limit]",
      "start_page": 0,
      "page_size": 500
    },
    "check": {
      "method": "GET",
      "path": "/users",
      "query": {
        "page[limit]": "1",
        "page[page]": "0"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "nutshell username/password is missing or invalid; re-run pm credentials add nutshell"
      },
      {
        "status": 403,
        "hint": "nutshell account lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "nutshell rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
