{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "STATSIG-API-KEY", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/gates", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "statsig api_key is missing or invalid; re-run pm credentials add statsig" },
      { "status": 429, "class": "rate_limited", "hint": "statsig rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "feature_gates",
      "path": "/gates",
      "records": { "path": "data" },
      "schema": "schemas/feature_gates.json"
    },
    {
      "name": "dynamic_configs",
      "path": "/dynamic_configs",
      "records": { "path": "data" },
      "schema": "schemas/dynamic_configs.json"
    },
    {
      "name": "experiments",
      "path": "/experiments",
      "records": { "path": "data" },
      "schema": "schemas/experiments.json"
    },
    {
      "name": "segments",
      "path": "/segments",
      "records": { "path": "data" },
      "schema": "schemas/segments.json"
    },
    {
      "name": "target_apps",
      "path": "/target_app",
      "records": { "path": "data" },
      "schema": "schemas/target_apps.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "records": { "path": "data" },
      "schema": "schemas/tags.json"
    },
    {
      "name": "keys",
      "path": "/keys",
      "records": { "path": "data" },
      "schema": "schemas/keys.json"
    },
    {
      "name": "holdouts",
      "path": "/holdouts",
      "records": { "path": "data" },
      "schema": "schemas/holdouts.json"
    },
    {
      "name": "layers",
      "path": "/layers",
      "records": { "path": "data" },
      "schema": "schemas/layers.json"
    },
    {
      "name": "users",
      "path": "/users",
      "records": { "path": "data" },
      "schema": "schemas/users.json"
    },
    {
      "name": "audit_logs",
      "path": "/audit_logs",
      "records": { "path": "data" },
      "schema": "schemas/audit_logs.json"
    },
    {
      "name": "environments",
      "path": "/environments",
      "records": { "path": "data.environments" },
      "pagination": { "type": "none" },
      "schema": "schemas/environments.json"
    }
  ]
}
