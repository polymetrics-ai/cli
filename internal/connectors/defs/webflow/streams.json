{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Accept-Version": "{{ config.accept_version }}"
    },
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/v2/sites/{{ config.site_id }}/collections" },
    "error_map": [
      { "status": 401, "hint": "webflow api_key is missing or invalid; re-run pm credentials add webflow" },
      { "status": 403, "hint": "webflow account lacks access for this site" },
      { "status": 429, "class": "rate_limited", "hint": "webflow rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "collections",
      "path": "/v2/sites/{{ config.site_id }}/collections",
      "records": { "path": "collections" },
      "schema": "schemas/collections.json"
    },
    {
      "name": "pages",
      "path": "/v2/sites/{{ config.site_id }}/pages",
      "records": { "path": "pages" },
      "schema": "schemas/pages.json"
    },
    {
      "name": "forms",
      "path": "/v2/sites/{{ config.site_id }}/forms",
      "records": { "path": "forms" },
      "schema": "schemas/forms.json"
    }
  ]
}
