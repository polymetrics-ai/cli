  "title": "webhooks",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "triggerType": { "type": ["string", "null"] },
    "siteId": { "type": ["string", "null"] },
    "workspaceId": { "type": ["string", "null"] },
    "url": { "type": ["string", "null"] },
    "createdOn": { "type": ["string", "null"], "format": "date-time" },
    "lastTriggered": { "type": ["string", "null"], "format": "date-time" },
    "filter": { "type": ["object", "null"] }
  }
}
