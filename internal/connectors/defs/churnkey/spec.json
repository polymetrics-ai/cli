{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Churnkey Connection Specification",
  "type": "object",
  "required": ["api_key", "app_id"],
  "properties": {
    "api_key": {
      "type": "string",
      "x-secret": true,
      "description": "Churnkey Data API key. Sent as the x-ck-api-key header; never logged."
    },
    "app_id": {
      "type": "string",
      "description": "Churnkey application id. Sent as the x-ck-app header on every request."
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "default": "https://api.churnkey.co/v1/data",
      "description": "Churnkey Data API base URL."
    }
  }
}
