{
  "actions": [
    {
      "name": "create_customer",
      "kind": "create",
      "method": "POST",
      "path": "/v2/customers",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "number": { "type": "string" },
          "active": { "type": "boolean" },
          "billable_default": { "type": "boolean" },
          "note": { "type": "string" }
        }
      },
      "risk": "external mutation; creates a live Clockodo customer; approval required"
    },
    {
      "name": "update_customer",
      "kind": "update",
      "method": "PUT",
      "path": "/v2/customers/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "number": { "type": "string" },
          "active": { "type": "boolean" },
          "billable_default": { "type": "boolean" },
          "note": { "type": "string" }
        }
      },
      "risk": "external mutation; overwrites a live Clockodo customer's fields; approval required"
    },
    {
      "name": "delete_customer",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v2/customers/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer" }
        }
      },
      "risk": "external mutation; irreversibly deletes a live Clockodo customer; approval required"
