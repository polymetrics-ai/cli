{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "daily",
  "type": "object",
  "x-primary-key": ["lat", "lon", "dt"],
  "x-cursor-field": "dt",
  "required": ["dt"],
  "properties": {
    "lat": { "type": "string" },
    "lon": { "type": "string" },
    "timezone": { "type": "string" },
    "dt": { "type": "integer" },
    "sunrise": { "type": ["integer", "null"] },
    "sunset": { "type": ["integer", "null"] },
    "summary": { "type": ["string", "null"] },
    "temp_day": { "type": ["number", "null"] },
    "temp_min": { "type": ["number", "null"] },
    "temp_max": { "type": ["number", "null"] },
    "pressure": { "type": ["integer", "null"] },
    "humidity": { "type": ["integer", "null"] },
    "wind_speed": { "type": ["number", "null"] },
    "wind_deg": { "type": ["integer", "null"] },
    "pop": { "type": ["number", "null"] },
    "uvi": { "type": ["number", "null"] },
    "weather": { "type": ["array", "null"] }
  }
}
