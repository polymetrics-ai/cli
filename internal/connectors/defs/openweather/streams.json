{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "appid", "value": "{{ secrets.appid }}" }
    ],
    "check": {
      "method": "GET",
      "path": "/onecall?lat={{ config.lat }}&lon={{ config.lon }}&exclude=minutely,hourly,daily,alerts"
    },
    "error_map": [
      { "status": 401, "hint": "openweather appid is missing or invalid; re-run pm credentials add openweather" },
      { "status": 429, "class": "rate_limited", "hint": "openweather rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "current",
      "path": "/onecall",
      "query": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}",
        "units": { "template": "{{ config.units }}", "omit_when_absent": true },
        "lang": { "template": "{{ config.lang }}", "omit_when_absent": true }
      },
      "records": { "path": "current" },
      "computed_fields": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}"
      },
      "schema": "schemas/current.json"
    },
    {
      "name": "hourly",
      "path": "/onecall",
      "query": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}",
        "units": { "template": "{{ config.units }}", "omit_when_absent": true },
        "lang": { "template": "{{ config.lang }}", "omit_when_absent": true }
      },
      "records": { "path": "hourly" },
      "computed_fields": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}"
      },
      "schema": "schemas/hourly.json"
    },
    {
      "name": "daily",
      "path": "/onecall",
      "query": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}",
        "units": { "template": "{{ config.units }}", "omit_when_absent": true },
        "lang": { "template": "{{ config.lang }}", "omit_when_absent": true }
      },
      "records": { "path": "daily" },
      "computed_fields": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}",
        "temp_day": "{{ record.temp.day }}",
        "temp_min": "{{ record.temp.min }}",
        "temp_max": "{{ record.temp.max }}"
      },
      "schema": "schemas/daily.json"
    },
    {
      "name": "alerts",
      "path": "/onecall",
      "query": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}",
        "units": { "template": "{{ config.units }}", "omit_when_absent": true },
        "lang": { "template": "{{ config.lang }}", "omit_when_absent": true }
      },
      "records": { "path": "alerts" },
      "computed_fields": {
        "lat": "{{ config.lat }}",
        "lon": "{{ config.lon }}"
      },
      "schema": "schemas/alerts.json"
    }
  ]
}
