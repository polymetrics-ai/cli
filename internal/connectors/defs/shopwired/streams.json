{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "basic",
        "username": "{{ secrets.api_key }}",
        "password": "{{ secrets.api_secret }}",
        "when": "{{ secrets.api_secret }}"
      },
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}",
        "when": "{{ secrets.access_token }}"
      },
      {
        "mode": "api_key_header",
        "header": "X-API-Key",
        "value": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "count",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/products",
      "query": {
        "count": "1",
        "offset": "0"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "shopwired credentials are missing or invalid; re-run pm credentials add shopwired"
      },
      {
        "status": 403,
        "hint": "shopwired credentials lack access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "shopwired rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
