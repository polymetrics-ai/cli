{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-API-Key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/products", "query": { "page": "1", "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "shopwired api_key is missing or invalid; re-run pm credentials add shopwired" },
      { "status": 403, "hint": "shopwired api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "shopwired rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "products",
      "path": "/products",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id }}",
        "name": "{{ record.name }}",
        "sku": "{{ record.sku }}",
        "email": "{{ record.email }}",
        "status": "{{ record.status }}",
        "updated_at": "{{ record.updated_at }}"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "orders",
      "path": "/orders",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id }}",
        "name": "{{ record.name }}",
        "sku": "{{ record.sku }}",
        "email": "{{ record.email }}",
        "status": "{{ record.status }}",
        "updated_at": "{{ record.updated_at }}"
      },
      "schema": "schemas/orders.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id }}",
        "name": "{{ record.name }}",
        "sku": "{{ record.sku }}",
        "email": "{{ record.email }}",
        "status": "{{ record.status }}",
        "updated_at": "{{ record.updated_at }}"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "categories",
      "path": "/categories",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id }}",
        "name": "{{ record.name }}",
        "sku": "{{ record.sku }}",
        "email": "{{ record.email }}",
        "status": "{{ record.status }}",
        "updated_at": "{{ record.updated_at }}"
      },
      "schema": "schemas/categories.json"
    }
  ]
}
