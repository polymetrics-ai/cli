{
  "api": "GitBook API v1 (https://api.gitbook.com/v1)",
  "docs": "https://developer.gitbook.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only (users, organizations, org_members, content); the full GitBook surface (spaces CRUD, content editing, integrations, webhooks, change requests) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/user", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/orgs", "covered_by": { "stream": "organizations" } },
    { "method": "GET", "path": "/orgs/{organizationId}/members", "covered_by": { "stream": "org_members" } },
    { "method": "GET", "path": "/spaces/{spaceId}/content/pages", "covered_by": { "stream": "content" } },
    { "method": "GET", "path": "/spaces/{spaceId}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/spaces", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/orgs/{organizationId}/spaces", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/spaces/{spaceId}/content/page/{pageId}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/spaces/{spaceId}/content", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/orgs/{organizationId}/integrations", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/orgs/{organizationId}/change-requests", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
