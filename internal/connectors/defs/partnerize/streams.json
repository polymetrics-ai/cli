{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.application_key }}", "password": "{{ secrets.user_api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/conversions", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "partnerize application_key/user_api_key are missing or invalid; re-run pm credentials add partnerize" },
      { "status": 403, "hint": "partnerize credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "partnerize rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "conversions",
      "path": "/conversions",
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/conversions.json"
    },
    {
      "name": "campaigns",
      "path": "/campaigns",
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "publishers",
      "path": "/publishers",
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/publishers.json"
    }
  ]
}
