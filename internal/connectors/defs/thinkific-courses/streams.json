      }
    },
    {
      "name": "product_publish_requests",
      "path": "/product_publish_requests",
      "records": {
        "path": "items"
      },
      "schema": "schemas/product_publish_requests.json",
      "projection": "passthrough"
    },
    {
      "name": "product_publish_request",
      "path": "/product_publish_requests/{{ config.product_publish_request_id }}",
      "records": {
        "single_object": true
      },
      "schema": "schemas/product_publish_request.json",
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      }
    },
    {
      "name": "products",
      "path": "/products",
      "records": {
        "path": "items"
      },
      "schema": "schemas/products.json",
      "projection": "passthrough"
    },
    {
