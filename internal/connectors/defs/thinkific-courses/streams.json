      }
    },
    {
      "name": "related_products",
      "path": "/products/{{ config.product_id }}/related",
      "records": {
        "path": "items"
      },
      "schema": "schemas/related_products.json",
      "projection": "passthrough"
    },
    {
      "name": "promotions",
      "path": "/promotions",
      "records": {
        "path": "items"
      },
      "schema": "schemas/promotions.json",
      "projection": "passthrough"
    },
    {
      "name": "promotion",
      "path": "/promotions/{{ config.promotion_id }}",
      "records": {
        "single_object": true
      },
      "schema": "schemas/promotion.json",
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      }
    },
    {
      "name": "promotion_by_coupon",
      "path": "/promotions/by_coupon",
      "records": {
        "single_object": true
      },
      "schema": "schemas/promotion_by_coupon.json",
      "projection": "passthrough",
      "query": {
        "product_id": "{{ config.product_id }}",
        "coupon_code": "{{ config.coupon_code }}"
      },
      "pagination": {
        "type": "none"
      }
    },
    {
      "name": "course_reviews",
      "path": "/course_reviews",
      "records": {
        "path": "items"
      },
      "schema": "schemas/course_reviews.json",
      "projection": "passthrough",
      "query": {
        "course_id": "{{ config.course_id }}"
      }
    },
    {
      "name": "course_review",
      "path": "/course_reviews/{{ config.course_review_id }}",
      "records": {
        "single_object": true
      },
      "schema": "schemas/course_review.json",
