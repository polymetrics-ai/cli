      }
    },
    {
      "name": "user_authentication",
      "path": "/users/{{ config.user_id }}/authentications/{{ config.provider }}",
      "records": {
        "single_object": true
      },
      "schema": "schemas/user_authentication.json",
      "projection": "passthrough",
      "pagination": {
