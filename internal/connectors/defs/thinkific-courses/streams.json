{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "X-Auth-Subdomain": "{{ config.subdomain }}"
    },
    "auth": [
      { "mode": "api_key_header", "header": "X-Auth-API-Key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/courses" },
    "error_map": [
      { "status": 401, "hint": "thinkific api_key is missing or invalid; re-run pm credentials add thinkific-courses" },
      { "status": 403, "hint": "thinkific account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "thinkific rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "courses",
      "path": "/courses",
      "records": { "path": "items" },
      "schema": "schemas/courses.json"
    },
    {
      "name": "chapters",
      "path": "/chapters",
      "records": { "path": "items" },
      "schema": "schemas/chapters.json"
    },
    {
      "name": "lessons",
      "path": "/lessons",
      "records": { "path": "items" },
      "schema": "schemas/lessons.json"
    },
    {
      "name": "enrollments",
      "path": "/enrollments",
      "records": { "path": "items" },
      "schema": "schemas/enrollments.json"
    }
  ]
}
