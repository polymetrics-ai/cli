{
  "api": "Gainsight PX (aptrinsic) REST API v1 (https://api.aptrinsic.com/v1)",
  "docs": "https://support.gainsight.com/PX/API_for_Developers/02Usage_of_Different_APIs",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only; the full Gainsight PX surface (custom events ingest, engagements, journeys, NPS surveys, webhooks) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/v1/accounts", "covered_by": { "stream": "accounts" } },
    { "method": "GET", "path": "/v1/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/v1/feature", "covered_by": { "stream": "feature" } },
    { "method": "GET", "path": "/v1/segment", "covered_by": { "stream": "segments" } },
    { "method": "POST", "path": "/v1/user/track/event", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/engagements", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/journeys", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/nps/surveys", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v1/webhooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
