{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-APTRINSIC-API-KEY", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "scrollId",
      "token_path": "scrollId"
    },
    "check": { "method": "GET", "path": "/accounts" },
    "error_map": [
      { "status": 401, "hint": "gainsight-px api_key is missing or invalid; re-run pm credentials add gainsight-px" },
      { "status": 403, "hint": "gainsight-px account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "gainsight-px rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "accounts",
      "path": "/accounts",
      "query": { "pageSize": "100" },
      "records": { "path": "accounts" },
      "schema": "schemas/accounts.json"
    },
    {
      "name": "users",
      "path": "/users",
      "query": { "pageSize": "100" },
      "records": { "path": "users" },
      "schema": "schemas/users.json"
    },
    {
      "name": "feature",
      "path": "/feature",
      "query": { "pageSize": "100" },
      "records": { "path": "features" },
      "schema": "schemas/feature.json"
    },
    {
      "name": "segments",
      "path": "/segment",
      "query": { "pageSize": "100" },
      "records": { "path": "segments" },
      "schema": "schemas/segments.json"
    }
  ]
}
