{
  "api": "Jotform REST API (https://api.jotform.com/docs/)",
  "docs": "https://api.jotform.com/docs/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only (forms, submissions, reports, folders, user); Jotform's write endpoints (form/submission create/update/delete) are out of scope for this wave (legacy itself ships no writes; capabilities.write is false).",
  "endpoints": [
