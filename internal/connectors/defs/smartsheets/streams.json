{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1
    },
    "check": {
      "method": "GET",
      "path": "/sheets",
      "query": {
        "pageSize": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "smartsheets access_token is missing, expired, or invalid; re-run pm credentials add smartsheets"
      },
      {
        "status": 403,
        "hint": "smartsheets token lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "smartsheets rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "sheets",
      "path": "/sheets",
      "records": {
        "path": "data"
      },
      "projection": "passthrough",
      "schema": "schemas/sheets.json"
    },
    {
      "name": "sheet_rows",
      "path": "/sheets/{{ config.spreadsheet_id }}",
      "query": {
        "include": "rows"
      },
      "records": {
        "path": "rows"
      },
      "schema": "schemas/sheet_rows.json",
      "conformance": {
        "skip_dynamic": true,
        "reason": "StreamHook-handled (per-row cell flattening keyed by the page sibling columns[] array, which the declarative records/computed_fields dialect cannot express); hook-covered by internal/connectors/hooks/smartsheets/hooks_test.go"
      }
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "records": {
        "path": "data"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "contact",
      "path": "/contacts/{{ config.contact_id }}",
      "records": {
        "single_object": true
      },
      "schema": "schemas/contact.json",
      "pagination": {
        "type": "none"
      }
    },
    {
      "name": "events",
      "path": "/events",
      "query": {
        "maxCount": "100"
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/events.json",
      "pagination": {
        "type": "cursor",
        "cursor_param": "streamPosition",
        "token_path": "nextStreamPosition",
        "stop_path": "moreAvailable"
      }
    },
    {
      "name": "favorites",
      "path": "/favorites",
      "records": {
        "path": "data"
