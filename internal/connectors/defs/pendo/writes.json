    {
      "name": "create_feedback",
      "kind": "create",
      "method": "POST",
      "path": "/feedback",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "accountId",
          "visitorId",
          "title"
        ],
        "properties": {
          "accountId": {
            "type": "string"
          },
          "visitorId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      },
