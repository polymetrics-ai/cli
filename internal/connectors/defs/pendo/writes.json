    },
    {
      "name": "reset_staged_guide",
      "kind": "update",
      "method": "POST",
      "path": "/guide/{{ record.guideId }}/reset",
      "body_type": "none",
      "path_fields": [
        "guideId"
      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "guideId"
