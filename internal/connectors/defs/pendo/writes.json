{
  "actions": [
    {
      "name": "start_segment_visitor_export",
      "kind": "create",
      "method": "POST",
      "path": "/segment/{{ record.segmentId }}/visitors",
      "body_type": "none",
      "path_fields": [
        "segmentId"
      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "segmentId"
        ],
        "properties": {
          "segmentId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          }
        }
      },
      "risk": "starts an asynchronous Pendo segment visitor export job; approval required"
    },
    {
      "name": "create_segment",
      "kind": "create",
      "method": "POST",
      "path": "/segment/upload",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "visitors"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "visitors": {
            "type": "array"
          }
        }
      },
      "risk": "creates a shared Pendo segment from visitor ids; approval required"
    },
    {
      "name": "update_segment",
      "kind": "update",
      "method": "PUT",
      "path": "/segment/{{ record.segmentId }}",
      "body_type": "json",
      "path_fields": [
        "segmentId"
      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "segmentId",
          "name",
          "visitors"
        ],
        "properties": {
          "segmentId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          },
          "name": {
            "type": "string"
          },
          "visitors": {
            "type": "array"
          }
        }
      },
      "risk": "replaces the visitor membership for a Pendo segment; approval required"
    },
    {
      "name": "delete_segment",
      "kind": "delete",
      "method": "DELETE",
      "path": "/segment/{{ record.segmentId }}",
      "body_type": "none",
      "path_fields": [
        "segmentId"
      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "segmentId"
        ],
        "properties": {
          "segmentId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          }
        }
      },
      "delete": {
        "idempotent": true,
        "missing_ok_status": [
          404
        ]
      },
      "confirm": "destructive",
      "risk": "deletes a Pendo segment; destructive external mutation"
    },
    {
      "name": "add_segment_visitor",
      "kind": "update",
      "method": "PUT",
      "path": "/segment/{{ record.segmentId }}/visitor/{{ record.visitorId }}",
      "body_type": "none",
      "path_fields": [
        "segmentId",
        "visitorId"
      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "segmentId",
          "visitorId"
        ],
        "properties": {
          "segmentId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          },
          "visitorId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          }
        }
      },
      "risk": "adds a visitor to a Pendo segment; approval required"
    },
    {
      "name": "remove_segment_visitor",
      "kind": "delete",
      "method": "DELETE",
      "path": "/segment/{{ record.segmentId }}/visitor/{{ record.visitorId }}",
      "body_type": "none",
      "path_fields": [
        "segmentId",
        "visitorId"
      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "segmentId",
          "visitorId"
        ],
        "properties": {
          "segmentId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          },
          "visitorId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          }
        }
      },
      "delete": {
        "idempotent": true,
        "missing_ok_status": [
          404
        ]
      },
      "confirm": "destructive",
      "risk": "removes a visitor from a Pendo segment; destructive membership mutation"
    },
    {
      "name": "patch_segment_visitors",
      "kind": "update",
      "method": "PATCH",
      "path": "/segment/{{ record.segmentId }}/visitor",
      "body_type": "json",
      "path_fields": [
        "segmentId"
      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "segmentId",
          "patch"
        ],
        "properties": {
          "segmentId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          },
          "patch": {
            "type": "array"
          }
        }
      },
      "risk": "adds/removes a small batch of visitors for a Pendo segment; approval required"
    },
    {
      "name": "reset_guide_for_visitor",
      "kind": "update",
