      ],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [
          "guideId",
          "state"
        ],
        "properties": {
          "guideId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          },
          "state": {
            "type": "string"
          }
