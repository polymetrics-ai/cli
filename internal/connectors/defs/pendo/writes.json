        ],
        "properties": {
          "guideId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          },
          "visitorId": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          }
        }
      },
      "risk": "resets guide-seen state for one visitor; approval required"
    },
    {
      "name": "reset_all_guides_for_visitor",
      "kind": "update",
      "method": "POST",
      "path": "/guide/all/visitor/{{ record.visitorId }}/reset",
      "body_type": "none",
      "path_fields": [
        "visitorId"
