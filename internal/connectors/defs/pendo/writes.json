    },
    {
      "name": "reset_all_staged_guides",
      "kind": "update",
      "method": "POST",
      "path": "/guide/staged/reset",
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "required": [],
        "properties": {}
