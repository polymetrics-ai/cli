{
  "actions": [
    {
      "name": "publish_flow",
      "kind": "update",
      "method": "POST",
      "path": "/accounts/{{ config.account_id }}/flows/{{ record.id }}/publish",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "publishes a flow, making it live to end users immediately"
    },
    {
      "name": "unpublish_flow",
      "kind": "update",
      "method": "POST",
      "path": "/accounts/{{ config.account_id }}/flows/{{ record.id }}/unpublish",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "unpublishes a live flow, immediately hiding it from end users"
    },
    {
      "name": "publish_flow_v2",
