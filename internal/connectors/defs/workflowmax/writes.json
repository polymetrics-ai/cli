{
  "actions": [
    {
      "name": "create_client",
      "kind": "create",
      "method": "POST",
      "path": "/v2/clients",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "minProperties": 1,
        "properties": {
          "name": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "website": { "type": "string" },
          "referralSource": { "type": "string" },
          "clientManagerUuid": { "type": "string" },
          "jobManagerUuid": { "type": "string" },
          "favorite": { "type": "boolean" },
          "exportCode": { "type": "string" }
        }
      },
      "risk": "creates a WorkflowMax client record; approval required"
    },
    {
      "name": "update_client",
      "kind": "update",
      "method": "PUT",
      "path": "/v2/clients/{{ record.uuid }}",
      "path_fields": ["uuid"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["uuid"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "website": { "type": "string" },
          "referralSource": { "type": "string" },
          "clientManagerUUID": { "type": "string" },
          "jobManagerUUID": { "type": "string" },
          "favorite": { "type": "boolean" },
          "exportCode": { "type": "string" }
        }
      },
      "risk": "updates a WorkflowMax client record; approval required"
    },
    {
      "name": "delete_client",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v2/clients/{{ record.uuid }}",
      "path_fields": ["uuid"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["uuid"],
        "properties": {
          "uuid": { "type": "string" }
        }
      },
      "risk": "permanently deletes a WorkflowMax client record; approval required"
    },
    {
      "name": "create_job",
      "kind": "create",
      "method": "POST",
      "path": "/v2/jobs",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["clientUUID", "jobName", "statusUUID", "startDate", "dueDate", "priority"],
        "properties": {
          "clientUUID": { "type": "string" },
          "contactUUID": { "type": "string" },
          "jobNumber": { "type": "string" },
          "jobName": { "type": "string" },
          "clientOrderNumber": { "type": "string" },
          "budget": { "type": "number" },
          "description": { "type": "string" },
          "statusUUID": { "type": "string" },
          "jobCategoryUUID": { "type": "string" },
          "startDate": { "type": "string" },
          "dueDate": { "type": "string" },
          "priority": { "type": "string" },
          "clientManagerUUID": { "type": "string" },
          "jobManagerUUID": { "type": "string" }
        }
      },
      "risk": "creates a WorkflowMax job; approval required"
    },
    {
      "name": "delete_job",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v2/jobs/{{ record.uuid }}",
      "path_fields": ["uuid"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["uuid"],
        "properties": {
          "uuid": { "type": "string" }
        }
      },
      "risk": "permanently deletes a WorkflowMax job; approval required"
    },
    {
      "name": "create_client_contact",
      "kind": "create",
      "method": "POST",
      "path": "/v2/clients/contacts",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["firstName"],
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "salutation": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "mobile": { "type": "string" },
          "favourite": { "type": "boolean" }
        }
      },
      "risk": "creates a WorkflowMax client-contact record (not attached to any client until linked); approval required"
    },
    {
      "name": "update_client_contact",
      "kind": "update",
      "method": "PUT",
      "path": "/v2/clients/contacts/{{ record.uuid }}",
      "path_fields": ["uuid"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["uuid"],
        "properties": {
          "uuid": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "mobile": { "type": "string" }
        }
      },
      "risk": "updates a WorkflowMax client-contact record; approval required"
    },
    {
      "name": "delete_client_contact",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v2/clients/contacts/{{ record.uuid }}",
      "path_fields": ["uuid"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["uuid"],
        "properties": {
          "uuid": { "type": "string" }
        }
      },
      "risk": "permanently deletes a WorkflowMax client-contact record; approval required"
    }
  ]
}
