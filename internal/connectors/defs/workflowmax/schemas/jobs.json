  "title": "jobs",
  "type": "object",
  "x-primary-key": ["uuid"],
  "required": ["uuid"],
  "properties": {
    "uuid": { "type": "string" },
    "jobNumber": { "type": ["string", "null"] },
    "name": { "type": ["string", "null"] },
    "clientUUID": { "type": ["string", "null"] },
    "clientContactUUID": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "clientOrderNumber": { "type": ["string", "null"] },
    "budget": { "type": ["number", "null"] },
