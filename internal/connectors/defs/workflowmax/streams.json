{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "page_size",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/jobs",
      "query": { "page_size": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "workflowmax access_token is missing or invalid; re-run pm credentials add workflowmax" },
      { "status": 403, "hint": "workflowmax account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "workflowmax rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "jobs",
      "path": "/jobs",
      "records": { "path": "data" },
      "schema": "schemas/jobs.json",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "page_size",
        "start_page": 1,
        "page_size": 2
      }
    },
    {
      "name": "clients",
      "path": "/clients",
      "records": { "path": "data" },
      "schema": "schemas/clients.json"
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "data" },
      "schema": "schemas/contacts.json"
    }
  ]
}
