{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "headers": {
      "account-id": "{{ config.account_id }}"
    },
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100,
      "max_pages": 1
    },
    "check": {
      "method": "GET",
      "path": "/v2/jobs",
      "query": { "pageSize": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "workflowmax access_token is missing or invalid; re-run pm credentials add workflowmax" },
      { "status": 403, "hint": "workflowmax account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "workflowmax rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "jobs",
      "path": "/v2/jobs",
      "query": {
        "updatedSince": { "template": "{{ config.updated_since }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "projection": "passthrough",
      "schema": "schemas/jobs.json"
    },
    {
      "name": "clients",
      "path": "/v2/clients",
      "query": {
        "updatedSince": { "template": "{{ config.updated_since }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "projection": "passthrough",
      "schema": "schemas/clients.json"
    }
  ]
}
