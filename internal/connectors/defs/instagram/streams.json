{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "check": { "method": "GET", "path": "/{{ config.ig_user_id }}" },
    "error_map": [
      { "status": 401, "hint": "instagram access_token is missing or invalid; re-run pm credentials add instagram" },
      { "status": 403, "hint": "instagram account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "instagram rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/{{ config.ig_user_id }}",
      "query": {
        "fields": "id,username,name,biography,website,profile_picture_url,followers_count,follows_count,media_count"
      },
      "records": { "path": "", "single_object": true },
      "schema": "schemas/users.json"
    },
    {
      "name": "media",
      "path": "/{{ config.ig_user_id }}/media",
      "query": {
        "fields": "id,caption,media_type,media_product_type,media_url,permalink,thumbnail_url,timestamp,username,like_count,comments_count",
        "limit": "100"
      },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "paging.next"
      },
      "schema": "schemas/media.json"
    },
    {
      "name": "stories",
      "path": "/{{ config.ig_user_id }}/stories",
      "query": {
        "fields": "id,caption,media_type,media_product_type,media_url,permalink,thumbnail_url,timestamp,username",
        "limit": "100"
      },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "paging.next"
      },
      "schema": "schemas/stories.json"
    }
  ]
}
