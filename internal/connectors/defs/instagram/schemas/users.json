{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Instagram User Profile",
  "type": "object",
  "x-primary-key": ["id"],
  "properties": {
    "id": { "type": "string" },
    "username": { "type": ["string", "null"] },
    "name": { "type": ["string", "null"] },
    "biography": { "type": ["string", "null"] },
    "website": { "type": ["string", "null"] },
    "profile_picture_url": { "type": ["string", "null"] },
    "followers_count": { "type": ["integer", "null"] },
    "follows_count": { "type": ["integer", "null"] },
    "media_count": { "type": ["integer", "null"] }
  },
  "required": ["id"]
}
