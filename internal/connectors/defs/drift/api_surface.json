{
  "api": "Drift REST API (https://driftapi.com)",
  "docs": "https://devdocs.drift.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 migration: the 4 legacy-parity read streams only; the full Drift surface (playbooks, messages send, widget config, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/users/list", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/accounts", "covered_by": { "stream": "accounts" } },
    { "method": "GET", "path": "/conversations/list", "covered_by": { "stream": "conversations" } },
    { "method": "GET", "path": "/contacts", "covered_by": { "stream": "contacts" } },
    { "method": "POST", "path": "/conversations/{id}/messages", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/playbooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
