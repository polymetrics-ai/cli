{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.api_username }}", "password": "{{ secrets.api_password }}" }
    ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "api/campaign.php" },
    "error_map": [
      { "status": 401, "hint": "smaily api_username/api_password is missing or invalid" },
      { "status": 429, "class": "rate_limited", "hint": "smaily rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "campaigns",
      "path": "api/campaign.php",
      "records": { "path": "" },
      "schema": "schemas/campaigns.json",
      "projection": "passthrough"
    },
    {
      "name": "segments",
      "path": "api/segment.php",
      "records": { "path": "" },
      "schema": "schemas/segments.json",
      "projection": "passthrough"
    },
    {
      "name": "subscribers",
      "path": "api/contact.php",
      "records": { "path": "" },
      "schema": "schemas/subscribers.json",
      "projection": "passthrough"
    },
    {
      "name": "templates",
      "path": "api/template.php",
      "records": { "path": "" },
      "schema": "schemas/templates.json",
      "projection": "passthrough"
    },
    {
      "name": "automations",
      "path": "api/autoresponder.php",
      "records": { "path": "" },
      "schema": "schemas/automations.json",
      "projection": "passthrough"
    }
  ]
}
