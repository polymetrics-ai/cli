{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "distillery_data",
  "type": "object",
  "x-primary-key": ["slug", "dt"],
  "required": ["slug", "dt"],
  "properties": {
    "dt": { "type": "string", "description": "First day of the aggregation month, YYYY-MM-DD." },
    "slug": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "winning_bid_max": { "type": ["number", "null"] },
    "winning_bid_min": { "type": ["number", "null"] },
    "winning_bid_mean": { "type": ["number", "null"] },
    "trading_volume": { "type": ["number", "null"] },
    "lots_count": { "type": ["integer", "null"] }
  }
}
