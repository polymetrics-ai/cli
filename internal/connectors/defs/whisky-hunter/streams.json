{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "none" }
    ],
    "check": { "method": "GET", "path": "/api/auctions_data/" },
    "error_map": [
      { "status": 429, "class": "rate_limited", "hint": "whisky-hunter rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "auctions",
      "path": "/api/auctions_data/",
      "records": { "path": "." },
      "schema": "schemas/auctions.json"
    },
    {
      "name": "distilleries",
      "path": "/api/distilleries_info/",
      "records": { "path": "." },
      "schema": "schemas/distilleries.json"
    }
  ]
}
