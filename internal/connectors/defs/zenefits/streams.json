{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.token }}" }
    ],
    "error_map": [
      { "status": 401, "hint": "zenefits token is missing or invalid; re-run pm credentials add zenefits" },
      { "status": 403, "hint": "zenefits account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "zenefits rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "people",
      "path": "/people",
      "records": { "path": "data" },
      "schema": "schemas/people.json"
    },
    {
      "name": "companies",
      "path": "/companies",
      "records": { "path": "data" },
      "schema": "schemas/companies.json"
    },
    {
      "name": "departments",
      "path": "/departments",
      "records": { "path": "data" },
      "schema": "schemas/departments.json"
    }
  ]
}
