{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "guilds",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "owner_id": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "icon": { "type": ["string", "null"] },
    "approximate_member_count": { "type": ["integer", "null"] },
    "approximate_presence_count": { "type": ["integer", "null"] },
    "premium_tier": { "type": ["integer", "null"] },
    "preferred_locale": { "type": ["string", "null"] }
  }
}
