{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_token }}", "prefix": "Token " }
    ],
    "check": { "method": "GET", "path": "/docs/" },
    "error_map": [
      { "status": 401, "hint": "zapsign api_token is missing or invalid; re-run pm credentials add zapsign" },
      { "status": 403, "hint": "zapsign account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "zapsign rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "documents",
      "path": "/docs/",
      "records": { "path": "results" },
      "computed_fields": {
        "id": "{{ record.token }}"
      },
      "schema": "schemas/documents.json"
    },
    {
      "name": "signers",
      "path": "/signers/",
      "records": { "path": "results" },
      "computed_fields": {
        "id": "{{ record.token }}"
      },
      "schema": "schemas/signers.json"
    },
    {
      "name": "templates",
      "path": "/templates/",
      "records": { "path": "results" },
      "computed_fields": {
        "id": "{{ record.token }}"
      },
      "schema": "schemas/templates.json"
    }
  ]
}
