{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "webhooks",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "url": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"], "description": "Event type this webhook subscribes to (e.g. doc_signed, doc_created)." },
    "enabled": { "type": ["boolean", "null"] }
  }
}
