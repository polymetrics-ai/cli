    { "method": "GET", "path": "/v1/calendar", "covered_by": { "stream": "calendar" } },
    { "method": "GET", "path": "/v1/clock", "covered_by": { "stream": "clock" } },
    { "method": "GET", "path": "/v1/country_info", "covered_by": { "stream": "country_info" } },
    { "method": "POST", "path": "/v1/accounts", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/trading/accounts/{account_id}/orders", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v1/trading/accounts/{account_id}/orders", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/trading/accounts/{account_id}/positions", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v1/accounts/{account_id}/transfers", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/events/accounts/status", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/events/trades", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/events/journals/status", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v1/journals", "excluded": { "category": "destructive_admin", "reason": "moves funds between accounts; not a safe reverse-ETL target" } }
  ]
}
