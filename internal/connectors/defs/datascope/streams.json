{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 2
    },
    "check": { "method": "GET", "path": "/locations" },
    "error_map": [
      { "status": 401, "hint": "datascope api_key is missing or invalid; re-run pm credentials add datascope" },
      { "status": 403, "hint": "datascope credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "datascope rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "locations",
      "path": "/locations",
      "records": { "path": "." },
      "schema": "schemas/locations.json"
    },
    {
      "name": "answers",
      "path": "/v2/answers",
      "records": { "path": "." },
      "schema": "schemas/answers.json"
    },
    {
      "name": "lists",
      "path": "/metadata_objects",
      "records": { "path": "." },
      "schema": "schemas/lists.json"
    },
    {
      "name": "notifications",
      "path": "/notifications",
      "records": { "path": "." },
      "schema": "schemas/notifications.json"
    }
  ]
}
