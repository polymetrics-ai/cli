      "summary": "List conversations",
      "intent": "etl",
      "availability": "implemented",
      "stream": "conversations",
      "source_url": "https://dev.frontapp.com/reference/list-conversations",
      "flags": [
        {
          "name": "limit",
          "type": "integer",
          "summary": "Records per page; maps to the connector page_limit setting.",
          "maps_to": "query.limit"
        }
      ],
      "examples": [
        "pm front conversations list --json"
