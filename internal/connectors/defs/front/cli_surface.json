{
  "tagline": "Work with Front conversations, contacts, inboxes, teammates, tags, and channels from the command line.",
  "usage": "pm front <command> <subcommand> [flags]",
  "groups": [
    {
      "id": "core",
      "title": "Core read commands",
      "commands": [
        "conversations",
        "contacts",
        "inboxes",
        "teammates",
        "tags",
        "channels"
      ]
    },
    {
      "id": "planned_reads",
      "title": "Planned read commands",
      "commands": [
        "accounts",
        "messages",
        "comments",
        "analytics",
        "events",
        "links",
        "views"
      ]
    },
    {
      "id": "planned_writes",
      "title": "Planned reverse-ETL commands",
      "commands": [
        "message",
        "conversation",
        "contact",
        "tag",
        "account",
        "channel"
      ]
    },
    {
      "id": "binary_and_local",
      "title": "Binary and local-workflow commands",
      "commands": [
        "attachments"
      ]
    }
  ],
  "global_flags": [
    {
      "name": "json",
      "type": "boolean",
      "summary": "Write machine-readable JSON output."
    },
    {
      "name": "connection",
      "type": "string",
      "summary": "Use a saved Front connector credential and account scope.",
      "maps_to": "connection"
    }
  ],
  "commands": [
