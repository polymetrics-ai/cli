{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "_pagination.next"
    },
    "check": { "method": "GET", "path": "/inboxes" },
    "error_map": [
      { "status": 401, "hint": "front api key is missing or invalid; re-run pm credentials add front" },
      { "status": 403, "hint": "front account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "front rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "query": { "limit": "{{ config.page_limit }}" },
      "records": { "path": "_results" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "conversations",
      "path": "/conversations",
      "query": { "limit": "{{ config.page_limit }}" },
      "records": { "path": "_results" },
      "schema": "schemas/conversations.json"
    },
    {
      "name": "inboxes",
      "path": "/inboxes",
      "query": { "limit": "{{ config.page_limit }}" },
      "records": { "path": "_results" },
      "schema": "schemas/inboxes.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "query": { "limit": "{{ config.page_limit }}" },
      "records": { "path": "_results" },
      "schema": "schemas/tags.json"
    },
    {
      "name": "teammates",
      "path": "/teammates",
      "query": { "limit": "{{ config.page_limit }}" },
      "records": { "path": "_results" },
      "schema": "schemas/teammates.json"
    },
    {
      "name": "channels",
      "path": "/channels",
      "query": { "limit": "{{ config.page_limit }}" },
      "records": { "path": "_results" },
      "schema": "schemas/channels.json"
    }
  ]
}
