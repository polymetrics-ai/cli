{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Front Connection Specification",
  "type": "object",
  "required": ["api_key"],
  "properties": {
    "api_key": {
      "type": "string",
      "x-secret": true,
      "description": "Front API token, sent as a Bearer token (Authorization: Bearer <api_key>). Never logged."
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "default": "https://api2.frontapp.com",
      "description": "Front API base URL override for tests or proxies."
    },
    "page_limit": {
      "type": "string",
      "default": "50",
      "description": "Records per page (1-100)."
    }
  }
}
