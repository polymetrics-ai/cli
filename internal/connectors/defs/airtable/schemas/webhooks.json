{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "webhooks",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "notificationUrl": { "type": ["string", "null"] },
    "isHookEnabled": { "type": "boolean" },
    "areNotificationsEnabled": { "type": "boolean" },
    "cursorForNextPayload": { "type": "integer" },
    "expirationTime": { "type": ["string", "null"] },
    "lastSuccessfulNotificationTime": { "type": ["string", "null"] },
    "specification": { "type": ["object", "null"] }
  }
}
