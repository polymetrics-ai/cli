{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "avatars/list" },
    "error_map": [
      { "status": 401, "hint": "smartengage api_key is missing or invalid" },
      { "status": 429, "class": "rate_limited", "hint": "smartengage rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "avatars",
      "path": "avatars/list",
      "query": {
        "avatar_id": { "template": "{{ config.avatar_id }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "schema": "schemas/avatars.json",
      "projection": "passthrough"
    },
    {
      "name": "tags",
      "path": "tags/list/",
      "query": {
        "avatar_id": { "template": "{{ config.avatar_id }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "schema": "schemas/tags.json",
      "projection": "passthrough"
    },
    {
      "name": "custom_fields",
      "path": "customfields/list/",
      "query": {
        "avatar_id": { "template": "{{ config.avatar_id }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "schema": "schemas/custom_fields.json",
      "projection": "passthrough"
    },
    {
      "name": "sequences",
      "path": "sequences/list/",
      "query": {
        "avatar_id": { "template": "{{ config.avatar_id }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "schema": "schemas/sequences.json",
      "projection": "passthrough"
    },
    {
      "name": "subscribers",
      "path": "subscribers/list/",
      "query": {
        "avatar_id": { "template": "{{ config.avatar_id }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "schema": "schemas/subscribers.json",
      "projection": "passthrough"
    }
  ]
}
