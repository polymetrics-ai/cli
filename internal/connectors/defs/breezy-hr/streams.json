{
  "base": {
    "url": "{{ config.base_url }}/company/{{ secrets.company_id }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/positions" },
    "error_map": [
      { "status": 401, "hint": "breezy-hr api_key is missing or invalid; re-run pm credentials add breezy-hr" },
      { "status": 403, "hint": "breezy-hr api_key lacks access for this company_id" },
      { "status": 429, "class": "rate_limited", "hint": "breezy-hr rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "positions",
      "path": "/positions",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "limit",
        "start_page": 1,
        "page_size": 100
      },
      "records": { "path": "." },
      "computed_fields": {
        "position_id": "{{ record._id }}",
        "type": "{{ record.type.name }}",
        "country_id": "{{ record.location.country.id }}",
        "country_name": "{{ record.location.country.name }}"
      },
      "schema": "schemas/positions.json"
    },
    {
      "name": "pipelines",
      "path": "/pipelines",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record._id }}"
      },
      "schema": "schemas/pipelines.json"
    },
    {
      "name": "candidates",
      "path": "/position/{{ fanout.id }}/candidates",
      "query": { "sort": "updated_date" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "limit",
        "start_page": 1,
        "page_size": 100
      },
      "records": { "path": "." },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/positions", "records_path": "", "id_field": "_id" }
        },
        "into": { "path_var": "position_id" },
        "stamp_field": "position_id"
      },
      "computed_fields": {
        "id": "{{ record._id }}",
        "stage": "{{ record.stage.name }}"
      },
      "schema": "schemas/candidates.json"
    }
  ]
}
