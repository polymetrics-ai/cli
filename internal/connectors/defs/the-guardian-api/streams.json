{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "api-key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "page-size",
      "start_page": 1,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/search" },
    "error_map": [
      { "status": 401, "hint": "the-guardian-api api_key is missing or invalid; re-run pm credentials add the-guardian-api" },
      { "status": 429, "class": "rate_limited", "hint": "the-guardian-api rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "search",
      "path": "/search",
      "query": {
        "q": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "response.results" },
      "computed_fields": {
        "title": "{{ record.webTitle }}",
        "published_at": "{{ record.webPublicationDate }}"
      },
      "schema": "schemas/search.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "query": {
        "q": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "response.results" },
      "schema": "schemas/tags.json"
    },
    {
      "name": "sections",
      "path": "/sections",
      "query": {
        "q": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "response.results" },
      "pagination": { "type": "none" },
      "schema": "schemas/sections.json"
    },
    {
      "name": "editions",
      "path": "/editions",
      "query": {
        "q": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "response.results" },
      "pagination": { "type": "none" },
      "schema": "schemas/editions.json"
    },
    {
      "name": "content",
      "path": "/{{ config.content_id }}",
      "records": { "path": "response.content", "single_object": true },
      "pagination": { "type": "none" },
      "computed_fields": {
        "title": "{{ record.webTitle }}",
        "published_at": "{{ record.webPublicationDate }}"
      },
      "schema": "schemas/content.json"
    }
  ]
}
