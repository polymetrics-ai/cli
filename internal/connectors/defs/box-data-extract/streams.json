{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "oauth2_client_credentials",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "extra_params": {
          "box_subject_type": "{{ config.box_subject_type }}",
          "box_subject_id": "{{ config.box_subject_id }}"
        }
      }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/folders/{{ config.box_folder_id }}/items", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "box-data-extract client_id/client_secret are missing or invalid, or the token-scoping subject is misconfigured; re-run pm credentials add box-data-extract" },
      { "status": 403, "hint": "box-data-extract subject lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "box-data-extract rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "files",
      "path": "/folders/{{ config.box_folder_id }}/items",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "entries" },
      "schema": "schemas/files.json"
    },
    {
      "name": "file_details",
      "path": "/files/{{ fanout.id }}",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": {
            "path": "/folders/{{ config.box_folder_id }}/items",
            "records_path": "entries",
            "id_field": "id"
          }
        },
        "into": { "path_var": "id" },
        "stamp_field": "file_id"
      },
      "schema": "schemas/file_details.json"
    }
  ]
}
