{
  "api": "Capsule CRM API v2 (https://api.capsulecrm.com/api/v2)",
  "docs": "https://developer.capsulecrm.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; Capsule CRM has no allow-listed reverse-ETL writes in legacy, so no write actions are in scope",
  "endpoints": [
    { "method": "GET", "path": "/parties", "covered_by": { "stream": "parties" } },
    { "method": "GET", "path": "/opportunities", "covered_by": { "stream": "opportunities" } },
    { "method": "GET", "path": "/kases", "covered_by": { "stream": "kases" } },
    { "method": "GET", "path": "/tasks", "covered_by": { "stream": "tasks" } },
    { "method": "GET", "path": "/users", "covered_by": { "stream": "users" } },
    { "method": "POST", "path": "/parties", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "PUT", "path": "/parties/{id}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "DELETE", "path": "/parties/{id}", "excluded": { "category": "destructive_admin", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/tags", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/users/current", "excluded": { "category": "duplicate_of", "reason": "covered by the users stream" } }
  ]
}
