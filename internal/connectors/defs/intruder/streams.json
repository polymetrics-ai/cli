{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/targets", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "intruder access_token is missing or invalid; re-run pm credentials add intruder" },
      { "status": 403, "hint": "intruder credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "intruder rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "issues",
      "path": "/issues",
      "records": { "path": "results" },
      "schema": "schemas/issues.json"
    },
    {
      "name": "scans",
      "path": "/scans",
      "records": { "path": "results" },
      "schema": "schemas/scans.json"
    },
    {
      "name": "targets",
      "path": "/targets",
      "records": { "path": "results" },
      "schema": "schemas/targets.json"
    },
    {
      "name": "occurrences",
      "path": "/issues/{{ fanout.id }}/occurrences",
      "records": { "path": "results" },
      "fan_out": {
        "ids_from": { "request": { "path": "/issues", "records_path": "results", "id_field": "id" } },
        "into": { "path_var": "issue_id" },
        "stamp_field": "issue_id"
      },
      "schema": "schemas/occurrences.json"
    }
  ]
}
