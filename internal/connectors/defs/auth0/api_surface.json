{
  "api": "Auth0 Management API v2 (https://<tenant>.auth0.com/api/v2)",
  "docs": "https://auth0.com/docs/api/management/v2",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only, bearer/access_token auth only (see docs.md's Known limits for the blocked M2M client-credentials auth mode); the full Management API surface (rules, actions, hooks, tenants settings, logs, device credentials, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/api/v2/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/api/v2/clients", "covered_by": { "stream": "clients" } },
    { "method": "GET", "path": "/api/v2/connections", "covered_by": { "stream": "connections" } },
    { "method": "GET", "path": "/api/v2/roles", "covered_by": { "stream": "roles" } },
    { "method": "GET", "path": "/api/v2/organizations", "covered_by": { "stream": "organizations" } },
    { "method": "POST", "path": "/oauth/token", "excluded": { "category": "out_of_scope", "reason": "M2M client-credentials token exchange is an ENGINE_GAP for this bundle (audience param not expressible); see docs.md Known limits" } },
    { "method": "GET", "path": "/api/v2/logs", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v2/rules", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v2/actions/actions", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "PATCH", "path": "/api/v2/tenants/settings", "excluded": { "category": "destructive_admin", "reason": "tenant-wide settings mutation, not a syncable read" } },
    { "method": "DELETE", "path": "/api/v2/users/{id}", "excluded": { "category": "destructive_admin", "reason": "deletes user data; not a syncable read" } }
  ]
}
