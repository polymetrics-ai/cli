{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/api/v2/clients" },
    "error_map": [
      { "status": 401, "hint": "auth0 access_token is missing or invalid; re-run pm credentials add auth0" },
      { "status": 429, "class": "rate_limited", "hint": "auth0 rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/api/v2/users",
      "query": { "include_totals": "true" },
      "records": { "path": "users" },
      "schema": "schemas/users.json"
    },
    {
      "name": "clients",
      "path": "/api/v2/clients",
      "query": { "include_totals": "true" },
      "records": { "path": "clients" },
      "schema": "schemas/clients.json"
    },
    {
      "name": "connections",
      "path": "/api/v2/connections",
      "query": { "include_totals": "true" },
      "records": { "path": "connections" },
      "schema": "schemas/connections.json"
    },
    {
      "name": "roles",
      "path": "/api/v2/roles",
      "query": { "include_totals": "true" },
      "records": { "path": "roles" },
      "schema": "schemas/roles.json"
    },
    {
      "name": "organizations",
      "path": "/api/v2/organizations",
      "query": { "include_totals": "true" },
      "records": { "path": "organizations" },
      "schema": "schemas/organizations.json"
    }
  ]
}
