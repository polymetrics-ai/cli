{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-API-Key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/countries", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "openaq api_key is missing or invalid; re-run pm credentials add openaq" },
      { "status": 403, "hint": "openaq api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "openaq rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "countries",
      "path": "/countries",
      "query": {
        "countries_id": { "template": "{{ config.countries_id }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/countries.json"
    },
    {
      "name": "parameters",
      "path": "/parameters",
      "records": { "path": "results" },
      "schema": "schemas/parameters.json"
    },
    {
      "name": "locations",
      "path": "/locations",
      "query": {
        "countries_id": { "template": "{{ config.countries_id }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/locations.json"
    },
    {
      "name": "instruments",
      "path": "/instruments",
      "records": { "path": "results" },
      "schema": "schemas/instruments.json"
    },
    {
      "name": "manufacturers",
      "path": "/manufacturers",
      "records": { "path": "results" },
      "schema": "schemas/manufacturers.json"
    }
  ]
}
