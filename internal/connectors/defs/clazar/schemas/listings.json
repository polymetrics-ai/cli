{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "listings",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "last_modified_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "cloud": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "cloud_id": { "type": ["string", "null"] },
    "cloud_url": { "type": ["string", "null"] },
    "eula_type": { "type": ["string", "null"] },
    "short_description": { "type": ["string", "null"] },
    "long_description": { "type": ["string", "null"] },
    "last_modified_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
