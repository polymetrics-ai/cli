    { "method": "GET", "path": "/client", "covered_by": { "stream": "clients" } },
    { "method": "GET", "path": "/event", "covered_by": { "stream": "events" } },
    { "method": "GET", "path": "/holiday", "covered_by": { "stream": "holidays" } },
    { "method": "GET", "path": "/booking", "covered_by": { "stream": "bookings" } },
    { "method": "GET", "path": "/billingrate", "covered_by": { "stream": "billing_rates" } }
  ]
}
