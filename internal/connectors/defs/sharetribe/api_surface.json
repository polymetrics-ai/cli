{
  "api": "Sharetribe Integration API v1 (https://flex-api.sharetribe.com/v1)",
  "docs": "https://www.sharetribe.com/api-reference/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only (listings, users, transactions, events); legacy is read-only, so there are no write endpoints in or out of scope",
  "endpoints": [
    { "method": "GET", "path": "/integration_api/listings/query", "covered_by": { "stream": "listings" } },
    { "method": "GET", "path": "/integration_api/users/query", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/integration_api/transactions/query", "covered_by": { "stream": "transactions" } },
    { "method": "GET", "path": "/integration_api/events/query", "covered_by": { "stream": "events" } },
    { "method": "GET", "path": "/integration_api/listings/show", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion; single-record fetch not implemented by legacy" } },
    { "method": "GET", "path": "/integration_api/marketplace/show", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion; not implemented by legacy" } },
    { "method": "POST", "path": "/integration_api/listings/update", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion; legacy is read-only" } }
  ]
}
