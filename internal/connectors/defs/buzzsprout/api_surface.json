    { "method": "GET", "path": "/api/{podcast_id}/episodes/{episode_id}.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/{podcast_id}/episodes.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "PUT", "path": "/api/{podcast_id}/episodes/{episode_id}.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "DELETE", "path": "/api/{podcast_id}/episodes/{episode_id}.json", "excluded": { "category": "destructive_admin", "reason": "destructive delete; legacy connector never implemented writes" } }
