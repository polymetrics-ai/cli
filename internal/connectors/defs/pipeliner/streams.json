{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.username }}", "password": "{{ secrets.password }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/spaces/{{ config.space_id }}/entities/Accounts",
      "query": { "limit": "1", "offset": "0" }
    },
    "error_map": [
      { "status": 401, "hint": "pipeliner username/password is missing or invalid; re-run pm credentials add pipeliner" },
      { "status": 403, "hint": "pipeliner credentials lack access for this space" },
      { "status": 429, "class": "rate_limited", "hint": "pipeliner rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "accounts",
      "path": "/spaces/{{ config.space_id }}/entities/Accounts",
      "records": { "path": "data" },
      "computed_fields": {
        "updated_at": "{{ record.modified }}"
      },
      "schema": "schemas/accounts.json"
    },
    {
      "name": "contacts",
      "path": "/spaces/{{ config.space_id }}/entities/Contacts",
      "records": { "path": "data" },
      "computed_fields": {
        "updated_at": "{{ record.modified }}"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "opportunities",
      "path": "/spaces/{{ config.space_id }}/entities/Opportunities",
      "records": { "path": "data" },
      "computed_fields": {
        "updated_at": "{{ record.modified }}"
      },
      "schema": "schemas/opportunities.json"
    },
    {
      "name": "leads",
      "path": "/spaces/{{ config.space_id }}/entities/Leads",
      "records": { "path": "data" },
      "computed_fields": {
        "updated_at": "{{ record.modified }}"
      },
      "schema": "schemas/leads.json"
    }
  ]
}
