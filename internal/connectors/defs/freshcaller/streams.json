{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}", "prefix": "Token token=" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "page_size",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "calls", "query": { "page": "1", "page_size": "1" } },
    "error_map": [
      { "status": 401, "hint": "freshcaller api_key is missing or invalid; re-run pm credentials add freshcaller" },
      { "status": 403, "hint": "freshcaller api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "freshcaller rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "calls",
      "path": "calls",
      "records": { "path": "calls" },
      "schema": "schemas/calls.json"
    },
    {
      "name": "agents",
      "path": "agents",
      "records": { "path": "agents" },
      "schema": "schemas/agents.json"
    },
    {
      "name": "teams",
      "path": "teams",
      "records": { "path": "teams" },
      "schema": "schemas/teams.json"
    },
    {
      "name": "numbers",
      "path": "numbers",
      "records": { "path": "numbers" },
      "schema": "schemas/numbers.json"
    }
  ]
}
