{
  "actions": [
    {
      "name": "create_project",
      "kind": "create",
      "method": "POST",
      "path": "/v11/projects",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "framework": { "type": "string" },
          "buildCommand": { "type": "string" },
          "installCommand": { "type": "string" },
          "outputDirectory": { "type": "string" },
          "rootDirectory": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "update_project",
      "kind": "update",
      "method": "PATCH",
      "path": "/v9/projects/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "buildCommand": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "delete_project",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v9/projects/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "destructive external mutation; approval required",
      "confirm": "destructive"
    },
    {
      "name": "create_deployment",
      "kind": "create",
      "method": "POST",
      "path": "/v13/deployments",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "target": { "type": "string" },
          "project": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "cancel_deployment",
      "kind": "update",
      "method": "PATCH",
      "path": "/v12/deployments/{{ record.id }}/cancel",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "delete_deployment",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v13/deployments/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "destructive external mutation; approval required",
      "confirm": "destructive"
    },
    {
      "name": "add_project_domain",
      "kind": "create",
      "method": "POST",
      "path": "/v10/projects/{{ record.project_id }}/domains",
      "path_fields": ["project_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["project_id", "name"],
        "properties": {
          "project_id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "remove_project_domain",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v9/projects/{{ record.project_id }}/domains/{{ record.domain }}",
      "path_fields": ["project_id", "domain"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["project_id", "domain"],
        "properties": {
          "project_id": { "type": "string" },
          "domain": { "type": "string" }
        }
      },
      "risk": "destructive external mutation; approval required",
      "confirm": "destructive"
    },
    {
      "name": "create_project_env_var",
      "kind": "create",
      "method": "POST",
      "path": "/v10/projects/{{ record.project_id }}/env",
      "path_fields": ["project_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["project_id", "key", "value", "type"],
        "properties": {
          "project_id": { "type": "string" },
          "key": { "type": "string" },
          "value": { "type": "string" },
          "type": { "type": "string", "enum": ["system", "encrypted", "plain", "sensitive"] },
          "target": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "delete_project_env_var",
      "kind": "delete",
      "method": "DELETE",
      "path": "/v9/projects/{{ record.project_id }}/env/{{ record.id }}",
      "path_fields": ["project_id", "id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["project_id", "id"],
        "properties": {
          "project_id": { "type": "string" },
          "id": { "type": "string" }
        }
      },
      "risk": "destructive external mutation; approval required",
      "confirm": "destructive"
    }
  ]
}
