{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "DD-API-KEY": "{{ secrets.api_key }}",
      "DD-APPLICATION-KEY": "{{ secrets.application_key }}"
    },
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "/api/v1/dashboard" },
    "error_map": [
      { "status": 401, "hint": "datadog api_key/application_key are missing or invalid; re-run pm credentials add datadog" },
      { "status": 403, "hint": "datadog credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "datadog rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "monitors",
      "path": "/api/v1/monitor",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "page_size",
        "start_page": 0,
        "page_size": 100
      },
      "records": { "path": "." },
      "incremental": { "cursor_field": "modified" },
      "schema": "schemas/monitors.json"
    },
    {
      "name": "dashboards",
      "path": "/api/v1/dashboard",
      "records": { "path": "dashboards" },
      "schema": "schemas/dashboards.json"
    },
    {
      "name": "users",
      "path": "/api/v2/users",
      "pagination": {
        "type": "page_number",
        "page_param": "page[number]",
        "size_param": "page[size]",
        "start_page": 0,
        "page_size": 100
      },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.attributes.name }}",
        "email": "{{ record.attributes.email }}",
        "handle": "{{ record.attributes.handle }}",
        "status": "{{ record.attributes.status }}",
        "disabled": "{{ record.attributes.disabled }}",
        "verified": "{{ record.attributes.verified }}",
        "created_at": "{{ record.attributes.created_at }}"
      },
      "schema": "schemas/users.json"
    },
    {
      "name": "slo",
      "path": "/api/v1/slo",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "page_size",
        "start_page": 0,
        "page_size": 100
      },
      "records": { "path": "data" },
      "schema": "schemas/slo.json"
    },
    {
      "name": "downtimes",
      "path": "/api/v1/downtime",
      "records": { "path": "." },
      "schema": "schemas/downtimes.json"
    },
    {
      "name": "dashboard_lists",
      "path": "/api/v1/dashboard/lists/manual",
      "records": { "path": "dashboard_lists" },
      "schema": "schemas/dashboard_lists.json"
    },
    {
      "name": "notebooks",
      "path": "/api/v1/notebooks",
      "pagination": {
        "type": "offset_limit",
        "offset_param": "start",
        "limit_param": "count",
        "page_size": 100
      },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.attributes.name }}",
        "created": "{{ record.attributes.created }}",
        "modified": "{{ record.attributes.modified }}",
        "author_handle": "{{ record.attributes.author.handle }}"
      },
      "schema": "schemas/notebooks.json"
    },
    {
      "name": "organizations",
      "path": "/api/v1/org",
      "records": { "path": "orgs" },
      "schema": "schemas/organizations.json"
    },
    {
      "name": "hosts",
      "path": "/api/v1/hosts",
      "pagination": {
        "type": "offset_limit",
        "offset_param": "start",
        "limit_param": "count",
        "page_size": 100
      },
      "records": { "path": "host_list" },
      "schema": "schemas/hosts.json"
    },
    {
      "name": "slo_corrections",
      "path": "/api/v1/slo/correction",
      "pagination": {
        "type": "offset_limit",
        "offset_param": "offset",
        "limit_param": "limit",
        "page_size": 100
      },
      "records": { "path": "data" },
      "computed_fields": {
        "slo_id": "{{ record.attributes.slo_id }}",
        "category": "{{ record.attributes.category }}",
        "description": "{{ record.attributes.description }}",
        "start": "{{ record.attributes.start }}",
        "end": "{{ record.attributes.end }}",
        "duration": "{{ record.attributes.duration }}",
        "timezone": "{{ record.attributes.timezone }}",
        "created_at": "{{ record.attributes.created_at }}",
        "modified_at": "{{ record.attributes.modified_at }}"
      },
      "schema": "schemas/slo_corrections.json"
    },
    {
      "name": "synthetics_tests",
      "path": "/api/v1/synthetics/tests",
      "pagination": {
        "type": "page_number",
        "page_param": "page_number",
        "size_param": "page_size",
        "start_page": 0,
        "page_size": 100
      },
      "records": { "path": "tests" },
      "schema": "schemas/synthetics_tests.json"
    },
    {
      "name": "synthetics_locations",
      "path": "/api/v1/synthetics/locations",
      "records": { "path": "locations" },
      "schema": "schemas/synthetics_locations.json"
    },
    {
      "name": "synthetics_variables",
      "path": "/api/v1/synthetics/variables",
      "records": { "path": "variables" },
      "schema": "schemas/synthetics_variables.json"
    },
    {
      "name": "api_keys",
      "path": "/api/v1/api_key",
      "records": { "path": "api_keys" },
      "schema": "schemas/api_keys.json"
    },
    {
      "name": "application_keys",
      "path": "/api/v1/application_key",
      "records": { "path": "application_keys" },
      "schema": "schemas/application_keys.json"
    }
  ]
}
