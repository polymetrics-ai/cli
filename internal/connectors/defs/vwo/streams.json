{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}", "prefix": "Token " }
    ],
    "check": { "method": "GET", "path": "/campaigns" },
    "error_map": [
      { "status": 401, "class": "auth_failed", "hint": "vwo api_key is missing or invalid" },
      { "status": 429, "class": "rate_limited", "hint": "vwo rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "campaigns",
      "path": "/campaigns",
      "query": {
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "campaigns" },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/campaigns.json"
    }
  ]
}
