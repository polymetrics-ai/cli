{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tasks",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "related_resource": {
      "type": "object"
    },
    "assignee_id": {
      "type": "integer"
    },
    "due_date": {
      "type": "integer"
    },
    "reminder_date": {
      "type": "integer"
    },
    "completed_date": {
      "type": "integer"
    },
    "priority": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "details": {
      "type": "string"
    },
    "date_created": {
      "type": "integer"
    },
    "date_modified": {
      "type": "integer"
    }
  },
  "x-primary-key": [
    "id"
  ],
  "x-cursor-field": "date_modified"
}
