    },
    "name": {
      "type": "string"
    },
    "assignee_id": {
      "type": "integer"
    },
    "email_domain": {
      "type": "string"
    },
    "phone_numbers": {
      "type": "array"
    },
    "websites": {
      "type": "array"
    },
    "address": {
      "type": "object"
    },
    "details": {
      "type": "string"
    },
    "date_created": {
      "type": "integer"
    },
    "date_modified": {
      "type": "integer"
    }
  },
  "x-primary-key": [
    "id"
  ],
  "x-cursor-field": "date_modified"
}
