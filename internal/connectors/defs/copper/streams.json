{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "people",
      "method": "GET",
      "path": "/__legacy_hook/people",
      "records": {
        "path": "data"
      },
      "schema": "schemas/people.json",
      "incremental": {
        "cursor_field": "date_modified",
        "client_filtered": true
      }
    },
    {
      "name": "companies",
      "method": "GET",
      "path": "/__legacy_hook/companies",
      "records": {
        "path": "data"
      },
      "schema": "schemas/companies.json",
      "incremental": {
        "cursor_field": "date_modified",
        "client_filtered": true
      }
    },
    {
      "name": "opportunities",
      "method": "GET",
      "path": "/__legacy_hook/opportunities",
      "records": {
        "path": "data"
      },
      "schema": "schemas/opportunities.json",
      "incremental": {
        "cursor_field": "date_modified",
        "client_filtered": true
      }
    },
    {
      "name": "leads",
      "method": "GET",
      "path": "/__legacy_hook/leads",
      "records": {
        "path": "data"
      },
      "schema": "schemas/leads.json",
      "incremental": {
        "cursor_field": "date_modified",
        "client_filtered": true
      }
    },
    {
      "name": "tasks",
      "method": "GET",
      "path": "/__legacy_hook/tasks",
      "records": {
        "path": "data"
      },
      "schema": "schemas/tasks.json",
      "incremental": {
        "cursor_field": "date_modified",
        "client_filtered": true
      }
    }
  ]
}
