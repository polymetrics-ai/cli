{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "created": {
      "type": "string",
      "description": "Timestamp when the rule was created",
      "format": "date-time"
    },
    "id": {
      "type": "string",
      "description": "Identifier for the rule"
    },
    "lastUpdated": {
      "type": "string",
      "description": "Timestamp when the rule was last modified",
      "format": "date-time"
    },
    "name": {
      "type": "string",
      "description": "Name of the rule"
    },
    "priority": {
      "type": "integer",
      "description": "Priority of the rule"
    },
    "status": {
      "type": "string",
      "description": "Whether or not the rule is active. Use the `activate` query parameter to set the status of a rule.",
      "enum": [
        "ACTIVE",
        "INACTIVE"
      ]
    },
    "system": {
      "type": "boolean",
      "description": "Specifies whether Okta created the policy rule (`system=true`). You can't delete policy rules that have `system` set to `true`."
    },
    "type": {
      "type": "string",
      "description": "Rule type",
      "enum": [
        "ACCESS_POLICY",
        "DEVICE_SIGNAL_COLLECTION",
        "ENTITY_RISK",
        "IDP_DISCOVERY",
        "MFA_ENROLL",
        "PASSWORD",
        "POST_AUTH_SESSION",
        "PROFILE_ENROLLMENT",
        "SIGN_ON",
        "SESSION_VIOLATION_DETECTION",
        "CLIENT_UPDATE",
        "IDENTITY_CLAIM_SOURCING"
      ]
    },
    "_links": {
      "type": "object",
      "properties": {
        "activate": {
          "type": "object",
          "description": "Link to activate the resource",
          "properties": {
            "hints": {
              "type": "object",
              "description": "Describes allowed HTTP verbs for the `href`",
              "properties": {
                "allow": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "DELETE",
                      "GET",
                      "POST",
                      "PUT"
                    ]
                  }
                }
              },
              "additionalProperties": true
            },
            "href": {
              "type": "string",
              "description": "Link URI"
            },
            "name": {
              "type": "string",
              "description": "Link name"
            },
            "templated": {
              "type": "boolean",
              "description": "Indicates whether the link object's `href` property is a URI template."
            },
            "type": {
              "type": "string",
              "description": "The media type of the link. If omitted, it is implicitly `application/json`."
            }
          },
          "additionalProperties": true
        },
        "deactivate": {
          "type": "object",
          "description": "Link to deactivate the resource",
          "properties": {
            "hints": {
              "type": "object",
              "description": "Describes allowed HTTP verbs for the `href`",
              "properties": {
                "allow": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "DELETE",
                      "GET",
                      "POST",
                      "PUT"
                    ]
                  }
                }
              },
              "additionalProperties": true
            },
            "href": {
              "type": "string",
              "description": "Link URI"
            },
            "name": {
              "type": "string",
              "description": "Link name"
            },
            "templated": {
              "type": "boolean",
              "description": "Indicates whether the link object's `href` property is a URI template."
            },
            "type": {
              "type": "string",
              "description": "The media type of the link. If omitted, it is implicitly `application/json`."
            }
          },
          "additionalProperties": true
        },
        "mappings": {
          "type": "object",
          "description": "Link to the mappings resource",
          "properties": {
            "hints": {
              "type": "object",
              "description": "Describes allowed HTTP verbs for the `href`",
              "properties": {
                "allow": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "DELETE",
                      "GET",
                      "POST",
                      "PUT"
                    ]
                  }
                }
              },
              "additionalProperties": true
            },
            "href": {
              "type": "string",
              "description": "Link URI"
            },
            "name": {
              "type": "string",
              "description": "Link name"
            },
            "templated": {
              "type": "boolean",
              "description": "Indicates whether the link object's `href` property is a URI template."
            },
            "type": {
              "type": "string",
              "description": "The media type of the link. If omitted, it is implicitly `application/json`."
            }
          },
          "additionalProperties": true
        },
        "rules": {
          "type": "object",
          "description": "Link to the rules resource",
          "properties": {
            "hints": {
              "type": "object",
              "description": "Describes allowed HTTP verbs for the `href`",
              "properties": {
                "allow": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "DELETE",
                      "GET",
                      "POST",
                      "PUT"
                    ]
                  }
                }
              },
              "additionalProperties": true
            },
            "href": {
              "type": "string",
              "description": "Link URI"
            },
            "name": {
              "type": "string",
              "description": "Link name"
            },
            "templated": {
              "type": "boolean",
              "description": "Indicates whether the link object's `href` property is a URI template."
            },
            "type": {
              "type": "string",
              "description": "The media type of the link. If omitted, it is implicitly `application/json`."
            }
          },
          "additionalProperties": true
        },
        "self": {
          "type": "object",
          "description": "Link to the resource (self)",
          "properties": {
            "hints": {
              "type": "object",
              "description": "Describes allowed HTTP verbs for the `href`",
              "properties": {
                "allow": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "DELETE",
                      "GET",
                      "POST",
                      "PUT"
                    ]
                  }
                }
              },
              "additionalProperties": true
            },
            "href": {
              "type": "string",
              "description": "Link URI"
            },
            "name": {
              "type": "string",
              "description": "Link name"
            },
            "templated": {
              "type": "boolean",
              "description": "Indicates whether the link object's `href` property is a URI template."
            },
            "type": {
              "type": "string",
              "description": "The media type of the link. If omitted, it is implicitly `application/json`."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "x-primary-key": [
    "id"
  ]
}
