              "description": "Describes allowed HTTP verbs for the `href`",
              "properties": {
                "allow": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "DELETE",
                      "GET",
                      "POST",
                      "PUT"
                    ]
                  }
