                  },
                  "name": {
                    "type": "string",
                    "description": "Link name"
                  },
                  "templated": {
                    "type": "boolean",
                    "description": "Indicates whether the link object's `href` property is a URI template."
                  },
                  "type": {
                    "type": "string",
                    "description": "The media type of the link. If omitted, it is implicitly `application/json`."
