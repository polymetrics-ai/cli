{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "users",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "status": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "login": { "type": ["string", "null"] },
    "created": { "type": ["string", "null"], "format": "date-time" },
    "last_login": { "type": ["string", "null"], "format": "date-time" }
  }
}
