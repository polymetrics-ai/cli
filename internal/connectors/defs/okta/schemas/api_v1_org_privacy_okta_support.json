      "type": "string",
      "description": "Expiration of Okta Support",
      "format": "date-time"
    },
    "support": {
      "type": "string",
      "description": "Status of Okta Support Settings",
      "enum": [
        "DISABLED",
        "ENABLED"
      ]
    },
