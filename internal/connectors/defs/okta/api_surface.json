{
  "api": "Okta Management APIs (https://developer.okta.com/docs/reference/)",
  "docs": "https://developer.okta.com/docs/reference/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 migration: the 3 legacy-parity read streams only (users, groups, system_logs); the full Okta admin surface (apps, policies, factors, roles, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/api/v1/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/api/v1/groups", "covered_by": { "stream": "groups" } },
    { "method": "GET", "path": "/api/v1/logs", "covered_by": { "stream": "system_logs" } },
    { "method": "GET", "path": "/api/v1/apps", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v1/policies", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/v1/users", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/v1/groups", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "DELETE", "path": "/api/v1/users/{id}", "excluded": { "category": "destructive_admin", "reason": "user deactivation/deletion out of scope for a read-only migration" } }
  ]
}
