{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "sitemaps",
  "type": "object",
  "x-primary-key": ["site_url", "path"],
  "required": ["site_url", "path"],
  "properties": {
    "site_url": { "type": "string" },
    "path": { "type": "string" },
    "last_submitted": { "type": ["string", "null"] },
    "last_downloaded": { "type": ["string", "null"] },
    "is_pending": { "type": ["boolean", "null"] },
    "is_sitemaps_index": { "type": ["boolean", "null"] },
    "type": { "type": ["string", "null"] },
    "warnings": { "type": ["string", "null"] },
    "errors": { "type": ["string", "null"] }
  }
}
