{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page_token",
      "token_path": "next_cursor"
    },
    "check": { "method": "GET", "path": "/v3/grants/{{ config.grant_id }}/calendars", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "nylas api_key is missing or invalid; re-run pm credentials add nylas" },
      { "status": 403, "hint": "nylas grant lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "nylas rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "calendars",
      "path": "/v3/grants/{{ config.grant_id }}/calendars",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/calendars.json"
    },
    {
      "name": "contacts",
      "path": "/v3/grants/{{ config.grant_id }}/contacts",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "messages",
      "path": "/v3/grants/{{ config.grant_id }}/messages",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/messages.json"
    },
    {
      "name": "events",
      "path": "/v3/grants/{{ config.grant_id }}/events",
      "query": {
        "limit": "{{ config.page_size }}",
        "calendar_id": "{{ config.calendar_id }}"
      },
      "records": { "path": "data" },
      "schema": "schemas/events.json"
    }
  ]
}
