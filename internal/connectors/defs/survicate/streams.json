{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/surveys", "query": { "page": "1", "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "survicate api_key is missing or invalid; re-run pm credentials add survicate" },
      { "status": 429, "class": "rate_limited", "hint": "survicate rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "surveys",
      "path": "/surveys",
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/surveys.json"
    }
  ]
}
