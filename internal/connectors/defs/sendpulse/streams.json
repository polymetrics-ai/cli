{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "oauth2_client_credentials",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/addressbooks" },
    "error_map": [
      { "status": 401, "hint": "sendpulse client_id/client_secret are missing or invalid; re-run pm credentials add sendpulse" },
      { "status": 429, "class": "rate_limited", "hint": "sendpulse rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "addressbooks",
      "path": "/addressbooks",
      "records": { "path": "." },
      "schema": "schemas/addressbooks.json",
      "projection": "passthrough"
    },
    {
      "name": "campaigns",
      "path": "/campaigns",
      "records": { "path": "." },
      "schema": "schemas/campaigns.json",
      "projection": "passthrough"
    },
    {
      "name": "senders",
      "path": "/senders",
      "records": { "path": "." },
      "schema": "schemas/senders.json",
      "projection": "passthrough"
    }
  ]
}
