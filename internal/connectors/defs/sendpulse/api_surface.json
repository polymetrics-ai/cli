    { "method": "GET", "path": "/senders", "covered_by": { "stream": "senders" } },
    { "method": "POST", "path": "/addressbooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/addressbooks/{id}/emails", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/smtp/emails", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/sms/campaigns", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
