{
  "api": "SendPulse API (https://api.sendpulse.com)",
  "docs": "https://sendpulse.com/integrations/api",
  "reviewed_at": "2026-07-02",
  "scope": "wave2 fan-out migration: the 3 legacy-parity read streams only; SendPulse's much larger surface (SMTP/email sending, SMS, chatbots, push notifications, web push) is out of scope until Pass B",
