{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page_token",
      "token_path": "next"
    },
    "check": { "method": "GET", "path": "/document", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "signnow access token is missing or invalid; re-run pm credentials add signnow" },
      { "status": 403, "hint": "signnow account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "signnow rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "documents",
      "path": "/document",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.document_name }}",
        "updated_at": "{{ record.updated }}"
      },
      "schema": "schemas/documents.json"
    },
    {
      "name": "templates",
      "path": "/template",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.template_name }}",
        "updated_at": "{{ record.updated }}"
      },
      "schema": "schemas/templates.json"
    },
    {
      "name": "users",
      "path": "/user",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "computed_fields": {
        "updated_at": "{{ record.created }}"
      },
      "schema": "schemas/users.json"
    }
  ]
}
