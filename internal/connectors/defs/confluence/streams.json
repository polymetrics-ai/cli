{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "basic",
        "username": "{{ config.email }}",
        "password": "{{ secrets.api_token }}"
      }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "_links.next",
      "allow_cross_host": true
    },
    "check": {
      "method": "GET",
      "path": "/wiki/api/v2/spaces"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "confluence email/api_token is missing or invalid; re-run pm credentials add confluence"
      },
      {
        "status": 403,
        "hint": "confluence account lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "confluence rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "spaces",
      "path": "/wiki/api/v2/spaces",
      "query": {
        "limit": "25"
      },
      "records": {
        "path": "results"
      },
      "schema": "schemas/spaces.json"
    },
    {
      "name": "pages",
      "path": "/wiki/api/v2/pages",
      "query": {
        "limit": "25"
      },
      "records": {
        "path": "results"
      },
      "computed_fields": {
        "version": "{{ record.version.number }}"
      },
      "schema": "schemas/pages.json"
    },
    {
      "name": "blogposts",
      "path": "/wiki/api/v2/blogposts",
      "query": {
        "limit": "25"
      },
      "records": {
        "path": "results"
      },
      "computed_fields": {
        "version": "{{ record.version.number }}"
      },
      "schema": "schemas/blogposts.json"
    },
    {
      "name": "labels",
      "path": "/wiki/api/v2/labels",
      "query": {
        "limit": "25"
      },
      "records": {
        "path": "results"
      },
      "schema": "schemas/labels.json"
    },
    {
      "name": "attachments",
      "path": "/wiki/api/v2/attachments",
      "query": {
        "limit": "25"
      },
      "records": {
        "path": "results"
      },
      "schema": "schemas/attachments.json"
    },
    {
      "name": "footer_comments",
      "path": "/wiki/api/v2/footer-comments",
      "query": {
        "limit": "25",
        "body-format": "storage"
      },
      "records": {
        "path": "results"
      },
      "computed_fields": {
        "version": "{{ record.version.number }}"
      },
      "schema": "schemas/footer_comments.json"
    },
    {
      "name": "inline_comments",
      "path": "/wiki/api/v2/inline-comments",
      "query": {
        "limit": "25",
        "body-format": "storage"
      },
      "records": {
        "path": "results"
      },
      "computed_fields": {
        "version": "{{ record.version.number }}"
      },
      "schema": "schemas/inline_comments.json"
    },
    {
      "name": "tasks",
      "path": "/wiki/api/v2/tasks",
      "query": {
        "limit": "25",
        "body-format": "storage"
      },
      "records": {
        "path": "results"
      },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "custom_content",
      "path": "/wiki/api/v2/custom-content",
      "query": {
        "limit": "25",
        "type": "{{ config.custom_content_type }}"
      },
      "records": {
        "path": "results"
      },
      "computed_fields": {
        "version": "{{ record.version.number }}"
      },
      "schema": "schemas/custom_content.json"
    }
  ]
}
