{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.email }}", "password": "{{ secrets.api_token }}" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "_links.next",
      "allow_cross_host": true
    },
    "check": { "method": "GET", "path": "/spaces" },
    "error_map": [
      { "status": 401, "hint": "confluence email/api_token is missing or invalid; re-run pm credentials add confluence" },
      { "status": 403, "hint": "confluence account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "confluence rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "spaces",
      "path": "/spaces",
      "query": { "limit": "25" },
      "records": { "path": "results" },
      "schema": "schemas/spaces.json"
    },
    {
      "name": "pages",
      "path": "/pages",
      "query": { "limit": "25" },
      "records": { "path": "results" },
      "computed_fields": {
        "version": "{{ record.version.number }}"
      },
      "schema": "schemas/pages.json"
    },
    {
      "name": "blogposts",
      "path": "/blogposts",
      "query": { "limit": "25" },
      "records": { "path": "results" },
      "computed_fields": {
        "version": "{{ record.version.number }}"
      },
      "schema": "schemas/blogposts.json"
    },
    {
      "name": "labels",
      "path": "/labels",
      "query": { "limit": "25" },
      "records": { "path": "results" },
      "schema": "schemas/labels.json"
    },
    {
      "name": "attachments",
      "path": "/attachments",
      "query": { "limit": "25" },
      "records": { "path": "results" },
      "schema": "schemas/attachments.json"
    }
  ]
}
