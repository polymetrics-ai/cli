{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.username }}", "password": "{{ secrets.password }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 25
    },
    "check": { "method": "GET", "path": "/video/v1/assets" },
    "error_map": [
      { "status": 401, "hint": "mux username/password is missing or invalid; re-run pm credentials add mux" },
      { "status": 403, "hint": "mux credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "mux rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "assets",
      "path": "/video/v1/assets",
      "records": { "path": "data" },
      "schema": "schemas/assets.json"
    },
    {
      "name": "live_streams",
      "path": "/video/v1/live-streams",
      "records": { "path": "data" },
      "schema": "schemas/live_streams.json"
    },
    {
      "name": "uploads",
      "path": "/video/v1/uploads",
      "records": { "path": "data" },
      "schema": "schemas/uploads.json"
    },
    {
      "name": "signing_keys",
      "path": "/system/v1/signing-keys",
      "records": { "path": "data" },
      "schema": "schemas/signing_keys.json"
    }
  ]
}
