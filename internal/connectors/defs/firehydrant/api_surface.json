    { "method": "GET", "path": "/v1/services", "covered_by": { "stream": "services" } },
    { "method": "GET", "path": "/v1/teams", "covered_by": { "stream": "teams" } },
    { "method": "GET", "path": "/v1/environments", "covered_by": { "stream": "environments" } },
    { "method": "GET", "path": "/v1/functionalities", "covered_by": { "stream": "functionalities" } },
    { "method": "POST", "path": "/v1/incidents", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion; legacy firehydrant implements no write actions at all" } },
    { "method": "GET", "path": "/v1/retrospectives", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/runbooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/tasks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/changes", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/on_call_schedules", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/incidents/{id}/milestones", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
