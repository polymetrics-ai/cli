{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-Postmark-Server-Token", "value": "{{ secrets.X-Postmark-Server-Token }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "count",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/messages/outbound", "query": { "count": "1", "offset": "0" } },
    "error_map": [
      { "status": 401, "hint": "postmarkapp server token is missing or invalid; re-run pm credentials add postmarkapp" },
      { "status": 422, "hint": "postmarkapp request parameters are invalid" },
      { "status": 429, "class": "rate_limited", "hint": "postmarkapp rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "outbound_messages",
      "path": "/messages/outbound",
      "records": { "path": "Messages" },
      "computed_fields": {
        "id": "{{ record.MessageID }}",
        "subject": "{{ record.Subject }}",
        "from": "{{ record.From }}",
        "to": "{{ record.To }}",
        "status": "{{ record.Status }}",
        "received_at": "{{ record.ReceivedAt }}"
      },
      "schema": "schemas/outbound_messages.json"
    },
    {
      "name": "inbound_messages",
      "path": "/messages/inbound",
      "records": { "path": "InboundMessages" },
      "computed_fields": {
        "id": "{{ record.MessageID }}",
        "subject": "{{ record.Subject }}",
        "from": "{{ record.From }}",
        "to": "{{ record.To }}",
        "status": "{{ record.Status }}"
      },
      "schema": "schemas/inbound_messages.json"
    }
  ]
}
