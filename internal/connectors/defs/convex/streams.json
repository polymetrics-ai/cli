{
  "base": {
    "url": "{{ config.deployment_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_key }}" }
    ],
    "check": { "method": "GET", "path": "api/tables" },
    "error_map": [
      { "status": 401, "hint": "convex access_key is missing or invalid; re-run pm credentials add convex" },
      { "status": 403, "hint": "convex deployment lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "convex rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "tables",
      "path": "api/tables",
      "records": { "path": "tables" },
      "schema": "schemas/tables.json",
      "projection": "passthrough"
    },
    {
      "name": "documents",
      "path": "api/tables/{{ config.table }}/documents",
      "pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "token_path": "cursor"
      },
      "records": { "path": "documents" },
      "computed_fields": {
        "id": "{{ record._id }}"
      },
      "schema": "schemas/documents.json",
      "projection": "passthrough"
    }
  ]
}
