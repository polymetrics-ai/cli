{
  "api": "WordPress REST API v2 (https://developer.wordpress.org/rest-api/)",
  "docs": "https://developer.wordpress.org/rest-api/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 7 legacy-parity read streams only (posts, pages, comments, media, users, categories, tags); legacy ships no writes.",
  "endpoints": [
    { "method": "GET", "path": "/wp-json/wp/v2/posts", "covered_by": { "stream": "posts" } },
    { "method": "GET", "path": "/wp-json/wp/v2/pages", "covered_by": { "stream": "pages" } },
    { "method": "GET", "path": "/wp-json/wp/v2/comments", "covered_by": { "stream": "comments" } },
    { "method": "GET", "path": "/wp-json/wp/v2/media", "covered_by": { "stream": "media" } },
    { "method": "GET", "path": "/wp-json/wp/v2/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/wp-json/wp/v2/categories", "covered_by": { "stream": "categories" } },
    { "method": "GET", "path": "/wp-json/wp/v2/tags", "covered_by": { "stream": "tags" } },
    { "method": "POST", "path": "/wp-json/wp/v2/posts", "excluded": { "category": "out_of_scope", "reason": "legacy connector never implemented content creation; Pass B capability expansion" } },
    { "method": "GET", "path": "/wp-json/wp/v2/plugins", "excluded": { "category": "out_of_scope", "reason": "not modeled by legacy; Pass B capability expansion" } },
    { "method": "GET", "path": "/wp-json", "excluded": { "category": "non_data_endpoint", "reason": "site index/discovery endpoint, not a syncable object stream" } }
  ]
}
