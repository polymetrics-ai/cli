{
  "actions": [
    {
      "name": "create_post",
      "kind": "create",
      "method": "POST",
      "path": "/wp-json/wp/v2/posts",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "minProperties": 1,
        "properties": {
          "title": { "type": "string" },
          "content": { "type": "string" },
          "excerpt": { "type": "string" },
          "status": { "type": "string" },
          "slug": { "type": "string" },
          "author": { "type": "integer" },
          "categories": { "type": "array", "items": { "type": "integer" } },
          "tags": { "type": "array", "items": { "type": "integer" } }
        }
      },
      "risk": "external mutation; publishes/creates public site content; approval required"
    },
    {
      "name": "update_post",
      "kind": "update",
      "method": "POST",
      "path": "/wp-json/wp/v2/posts/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "risk": "external mutation; edits public site content; approval required"
    },
    {
      "name": "delete_post",
      "kind": "delete",
      "method": "DELETE",
      "path": "/wp-json/wp/v2/posts/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "integer" } }
      },
      "delete": { "missing_ok_status": [404] },
      "risk": "external deletion of public site content (moves to trash unless force=true is embedded in the path); approval required",
      "confirm": "destructive"
    },
