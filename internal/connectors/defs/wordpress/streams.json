{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.username }}", "password": "{{ secrets.password }}", "when": "{{ secrets.password }}" },
      { "mode": "none" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100,
      "max_pages": 1
    },
    "check": { "method": "GET", "path": "/wp-json/wp/v2/posts", "query": { "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "wordpress site requires authentication; configure username and password" },
      { "status": 429, "class": "rate_limited", "hint": "wordpress rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "posts",
      "path": "/wp-json/wp/v2/posts",
      "query": {
        "after": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "incremental": {
        "cursor_field": "date",
        "request_param": "after",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/posts.json"
    },
    {
      "name": "pages",
      "path": "/wp-json/wp/v2/pages",
      "query": {
        "after": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "incremental": {
        "cursor_field": "date",
        "request_param": "after",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/pages.json"
    },
    {
      "name": "comments",
      "path": "/wp-json/wp/v2/comments",
      "query": {
        "after": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "incremental": {
        "cursor_field": "date",
        "request_param": "after",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/comments.json"
    },
    {
      "name": "media",
      "path": "/wp-json/wp/v2/media",
      "query": {
        "after": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "incremental": {
        "cursor_field": "date",
        "request_param": "after",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/media.json"
    },
    {
      "name": "users",
      "path": "/wp-json/wp/v2/users",
      "query": {
        "after": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "schema": "schemas/users.json"
    },
    {
      "name": "categories",
      "path": "/wp-json/wp/v2/categories",
      "query": {
        "after": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "schema": "schemas/categories.json"
    },
    {
      "name": "tags",
      "path": "/wp-json/wp/v2/tags",
      "query": {
        "after": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "schema": "schemas/tags.json"
    }
  ]
}
