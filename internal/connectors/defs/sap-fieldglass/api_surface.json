    { "method": "GET", "path": "/api/v1/time_sheets", "covered_by": { "stream": "time_sheets" } },
    { "method": "GET", "path": "/api/v1/assignments", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v1/statements_of_work", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v1/invoices", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/v1/time_sheets", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
