{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "management_events",
      "method": "GET",
      "path": "/__legacy_hook/management_events",
      "records": {
        "path": "data"
      },
      "schema": "schemas/management_events.json",
      "incremental": {
        "cursor_field": "EventTime",
        "client_filtered": true
      }
    },
    {
      "name": "read_only_events",
      "method": "GET",
      "path": "/__legacy_hook/read_only_events",
      "records": {
        "path": "data"
      },
      "schema": "schemas/read_only_events.json",
      "incremental": {
        "cursor_field": "EventTime",
        "client_filtered": true
      }
    },
    {
      "name": "write_only_events",
      "method": "GET",
      "path": "/__legacy_hook/write_only_events",
      "records": {
        "path": "data"
      },
      "schema": "schemas/write_only_events.json",
      "incremental": {
        "cursor_field": "EventTime",
        "client_filtered": true
      }
    },
    {
      "name": "console_logins",
      "method": "GET",
      "path": "/__legacy_hook/console_logins",
      "records": {
        "path": "data"
      },
      "schema": "schemas/console_logins.json",
      "incremental": {
        "cursor_field": "EventTime",
        "client_filtered": true
      }
    }
  ]
}
