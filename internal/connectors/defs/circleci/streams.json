{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Circle-Token", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/me" },
    "error_map": [
      { "status": 401, "hint": "circleci api_key is missing or invalid; re-run pm credentials add circleci" },
      { "status": 403, "hint": "circleci account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "circleci rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/project/{{ config.vcs_type }}/{{ config.org }}/{{ config.repo }}",
      "records": { "path": "" },
      "computed_fields": {
        "default_branch": "{{ record.vcs_info.default_branch }}"
      },
      "schema": "schemas/projects.json"
    },
    {
      "name": "pipelines",
      "path": "/project/{{ config.vcs_type }}/{{ config.org }}/{{ config.repo }}/pipeline",
      "records": { "path": "items" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "page-token",
        "token_path": "next_page_token"
      },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/pipelines.json"
    },
    {
      "name": "workflows",
      "path": "/pipeline/{{ config.pipeline_id }}/workflow",
      "records": { "path": "items" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "page-token",
        "token_path": "next_page_token"
      },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/workflows.json"
    },
    {
      "name": "jobs",
      "path": "/workflow/{{ config.workflow_id }}/job",
      "records": { "path": "items" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "page-token",
        "token_path": "next_page_token"
      },
      "incremental": {
        "cursor_field": "started_at"
      },
      "schema": "schemas/jobs.json"
    }
  ]
}
