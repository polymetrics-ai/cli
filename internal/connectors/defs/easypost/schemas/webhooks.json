  "properties": {
    "id": { "type": "string" },
    "object": { "type": ["string", "null"] },
    "mode": { "type": ["string", "null"] },
    "url": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "disabled_at": { "type": ["string", "null"], "format": "date-time" },
    "custom_headers": { "type": ["array", "null"] }
  }
}
