{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pickups",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "created_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "object": { "type": ["string", "null"] },
    "mode": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "reference": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" },
    "min_datetime": { "type": ["string", "null"] },
    "max_datetime": { "type": ["string", "null"] },
    "is_account_address": { "type": ["boolean", "null"] },
    "instructions": { "type": ["string", "null"] },
    "confirmation": { "type": ["string", "null"] },
    "address": { "type": ["object", "null"] },
    "pickup_rates": { "type": ["array", "null"] }
  }
}
