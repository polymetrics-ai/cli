{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claims",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "created_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "object": { "type": ["string", "null"] },
    "mode": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "status_detail": { "type": ["string", "null"] },
    "tracking_code": { "type": ["string", "null"] },
    "shipment_id": { "type": ["string", "null"] },
    "insurance_id": { "type": ["string", "null"] },
    "requested_amount": { "type": ["string", "null"] },
    "approved_amount": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" },
    "attachments": { "type": ["array", "null"] },
    "history": { "type": ["array", "null"] }
  }
}
