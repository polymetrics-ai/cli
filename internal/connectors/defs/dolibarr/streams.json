{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "DOLAPIKEY", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 0,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/thirdparties", "query": { "limit": "1", "page": "0" } },
    "error_map": [
      { "status": 401, "hint": "dolibarr api_key is missing or invalid; re-run pm credentials add dolibarr" },
      { "status": 403, "hint": "dolibarr account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "dolibarr rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "thirdparties",
      "path": "/thirdparties",
      "query": { "sortfield": "t.rowid", "sortorder": "ASC" },
      "records": { "path": "" },
      "incremental": { "cursor_field": "date_modification" },
      "schema": "schemas/thirdparties.json"
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "query": { "sortfield": "t.rowid", "sortorder": "ASC" },
      "records": { "path": "" },
      "incremental": { "cursor_field": "date_modification" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "products",
      "path": "/products",
      "query": { "sortfield": "t.rowid", "sortorder": "ASC" },
      "records": { "path": "" },
      "incremental": { "cursor_field": "date_modification" },
      "schema": "schemas/products.json"
    },
    {
      "name": "invoices",
      "path": "/invoices",
      "query": { "sortfield": "t.rowid", "sortorder": "ASC" },
      "records": { "path": "" },
      "incremental": { "cursor_field": "date_modification" },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "orders",
      "path": "/orders",
      "query": { "sortfield": "t.rowid", "sortorder": "ASC" },
      "records": { "path": "" },
      "incremental": { "cursor_field": "date_modification" },
      "schema": "schemas/orders.json"
    },
    {
      "name": "thirdparty_detail",
      "path": "/thirdparties/{{ config.thirdparty_id }}",
      "pagination": { "type": "none" },
      "records": { "path": "", "single_object": true },
      "schema": "schemas/thirdparty_detail.json"
    },
    {
      "name": "contact_detail",
      "path": "/contacts/{{ config.contact_id }}",
      "pagination": { "type": "none" },
      "records": { "path": "", "single_object": true },
      "schema": "schemas/contact_detail.json"
    },
    {
      "name": "product_detail",
      "path": "/products/{{ config.product_id }}",
      "pagination": { "type": "none" },
      "records": { "path": "", "single_object": true },
      "schema": "schemas/product_detail.json"
    },
    {
      "name": "invoice_detail",
      "path": "/invoices/{{ config.invoice_id }}",
      "pagination": { "type": "none" },
      "records": { "path": "", "single_object": true },
      "schema": "schemas/invoice_detail.json"
    },
    {
      "name": "order_detail",
      "path": "/orders/{{ config.order_id }}",
      "pagination": { "type": "none" },
      "records": { "path": "", "single_object": true },
      "schema": "schemas/order_detail.json"
    }
  ]
}
