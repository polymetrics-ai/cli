    "description": {
      "type": "string"
    },
    "end_user_description": {
      "type": "string"
    },
    "end_user_label": {
      "type": "string"
    },
    "id": {
      "type": "integer"
    },
    "raw_agent_label": {
      "type": "string"
    },
    "raw_description": {
      "type": "string"
    },
    "raw_end_user_description": {
      "type": "string"
    },
    "raw_end_user_label": {
      "type": "string"
    },
    "status_category": {
      "type": "string",
      "enum": [
        "new",
        "open",
        "pending",
        "hold",
        "solved"
      ]
    },
    "updated_at": {
      "type": "string"
    }
