{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "time_series",
  "type": "object",
  "x-primary-key": ["symbol", "datetime"],
  "x-cursor-field": "datetime",
  "required": ["symbol", "datetime"],
  "properties": {
    "symbol": { "type": "string" },
    "datetime": { "type": "string" },
    "open": { "type": ["string", "null"] },
    "high": { "type": ["string", "null"] },
    "low": { "type": ["string", "null"] },
    "close": { "type": ["string", "null"] },
    "volume": { "type": ["string", "null"] }
  }
}
