{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 50
    },
    "check": {
      "method": "GET",
      "path": "/products",
      "query": {
        "limit": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "katana api_key is missing or invalid; re-run pm credentials add katana"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "katana rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "products",
      "path": "/products",
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "materials",
      "path": "/materials",
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/materials.json"
    },
    {
      "name": "variants",
      "path": "/variants",
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/variants.json"
    },
    {
      "name": "sales_orders",
      "path": "/sales_orders",
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/sales_orders.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/customers.json"
    }
  ]
}
