    { "method": "GET", "path": "/v1/variants", "covered_by": { "stream": "variants" } },
    { "method": "GET", "path": "/v1/sales_orders", "covered_by": { "stream": "sales_orders" } },
    { "method": "GET", "path": "/v1/customers", "covered_by": { "stream": "customers" } },
    { "method": "GET", "path": "/v1/bom_rows", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/purchase_orders", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/stocktakes", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/webhooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v1/products", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion; legacy katana is read-only, no write actions implemented" } }
  ]
