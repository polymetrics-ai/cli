{
  "api": "Grafana HTTP API (instance-hosted, e.g. https://your-grafana.grafana.net)",
  "docs": "https://grafana.com/docs/grafana/latest/developer-resources/api-reference/http-api/api-legacy/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only (dashboards, folders, datasources, org_users, alert_rules); the full Grafana surface (dashboard/datasource/alert-rule create/update/delete, annotations, teams, service accounts, snapshots, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/api/search?type=dash-db", "covered_by": { "stream": "dashboards" } },
    { "method": "GET", "path": "/api/search?type=dash-folder", "covered_by": { "stream": "folders" } },
    { "method": "GET", "path": "/api/datasources", "covered_by": { "stream": "datasources" } },
    { "method": "GET", "path": "/api/org/users", "covered_by": { "stream": "org_users" } },
    { "method": "GET", "path": "/api/v1/provisioning/alert-rules", "covered_by": { "stream": "alert_rules" } },
    { "method": "POST", "path": "/api/dashboards/db", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/datasources", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/annotations", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/teams/search", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/serviceaccounts/search", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/dashboards/uid/{uid}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
