{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "key", "value": "{{ secrets.api_key }}" }
    ],
    "error_map": [
      { "status": 401, "hint": "youtube-data api_key is missing or invalid; re-run pm credentials add youtube-data" },
      { "status": 403, "hint": "youtube-data api key lacks access or quota is exhausted for this request" },
      { "status": 429, "class": "rate_limited", "hint": "youtube-data rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "channels",
      "path": "/channels",
      "query": {
        "part": "snippet,statistics",
        "id": { "template": "{{ config.channel_ids }}", "omit_when_absent": true }
      },
      "records": { "path": "items" },
      "computed_fields": {
        "title": "{{ record.snippet.title }}",
        "view_count": "{{ record.statistics.viewCount }}"
      },
      "schema": "schemas/channels.json"
    },
    {
      "name": "videos",
      "path": "/videos",
      "query": {
        "part": "snippet,statistics",
        "id": { "template": "{{ config.ids }}", "omit_when_absent": true }
      },
      "records": { "path": "items" },
      "computed_fields": {
        "title": "{{ record.snippet.title }}",
        "published_at": "{{ record.snippet.publishedAt }}"
      },
      "schema": "schemas/videos.json"
    },
    {
      "name": "playlists",
      "path": "/playlists",
      "query": {
        "part": "snippet,statistics",
        "id": { "template": "{{ config.ids }}", "omit_when_absent": true }
      },
      "records": { "path": "items" },
      "computed_fields": {
        "title": "{{ record.snippet.title }}",
        "published_at": "{{ record.snippet.publishedAt }}"
      },
      "schema": "schemas/playlists.json"
    }
  ]
}
