{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "products",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "date_modified_gmt",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "slug": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "sku": { "type": ["string", "null"] },
    "price": { "type": ["string", "null"] },
    "regular_price": { "type": ["string", "null"] },
    "sale_price": { "type": ["string", "null"] },
    "stock_status": { "type": ["string", "null"] },
    "stock_quantity": { "type": ["integer", "null"] },
    "total_sales": { "type": ["integer", "null"] },
    "date_created_gmt": { "type": ["string", "null"] },
    "date_modified_gmt": { "type": ["string", "null"] }
  }
}
