{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "{{ secrets.api_secret }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 10
    },
    "check": { "method": "GET", "path": "orders", "query": { "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "woocommerce consumer key/secret is missing or invalid; re-run pm credentials add woocommerce" },
      { "status": 403, "hint": "woocommerce API user lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "woocommerce rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "orders",
      "path": "orders",
      "query": {
        "order": "asc",
        "orderby": "id",
        "after": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "incremental": {
        "cursor_field": "date_modified_gmt",
        "request_param": "modified_after",
        "start_config_key": "start_date"
      },
      "schema": "schemas/orders.json"
    },
    {
      "name": "products",
      "path": "products",
      "query": {
        "order": "asc",
        "orderby": "id",
        "after": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "incremental": {
        "cursor_field": "date_modified_gmt",
        "request_param": "modified_after",
        "start_config_key": "start_date"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "customers",
      "path": "customers",
      "query": {
        "order": "asc",
        "orderby": "id",
        "after": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "incremental": {
        "cursor_field": "date_modified_gmt",
        "request_param": "modified_after",
        "start_config_key": "start_date"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "coupons",
      "path": "coupons",
      "query": {
        "order": "asc",
        "orderby": "id",
        "after": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "incremental": {
        "cursor_field": "date_modified_gmt",
        "request_param": "modified_after",
        "start_config_key": "start_date"
      },
      "schema": "schemas/coupons.json"
    }
  ]
}
