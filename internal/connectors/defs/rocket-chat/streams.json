{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "X-Auth-Token": "{{ secrets.auth_token }}",
      "X-User-Id": "{{ secrets.user_id }}"
    },
    "pagination": {
      "type": "offset_limit",
      "limit_param": "count",
      "offset_param": "offset",
      "page_size": 2
    },
    "check": { "method": "GET", "path": "/me" },
    "error_map": [
      { "status": 401, "hint": "rocket-chat auth_token/user_id are missing or invalid; re-run pm credentials add rocket-chat" },
      { "status": 403, "hint": "rocket-chat account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "rocket-chat rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/users.list",
      "query": {
        "query": { "template": "{{ config.query }}", "omit_when_absent": true },
        "fields": { "template": "{{ config.fields }}", "omit_when_absent": true }
      },
      "records": { "path": "users" },
      "computed_fields": { "id": "{{ record._id }}", "updated_at": "{{ record._updatedAt }}", "stream": "users" },
      "projection": "passthrough",
      "schema": "schemas/users.json"
    },
    {
      "name": "channels",
      "path": "/channels.list",
      "query": {
        "query": { "template": "{{ config.query }}", "omit_when_absent": true },
        "fields": { "template": "{{ config.fields }}", "omit_when_absent": true }
      },
      "records": { "path": "channels" },
      "computed_fields": { "id": "{{ record._id }}", "updated_at": "{{ record._updatedAt }}", "stream": "channels" },
      "projection": "passthrough",
      "schema": "schemas/channels.json"
    },
    {
      "name": "groups",
      "path": "/groups.list",
      "query": {
        "query": { "template": "{{ config.query }}", "omit_when_absent": true },
        "fields": { "template": "{{ config.fields }}", "omit_when_absent": true }
      },
      "records": { "path": "groups" },
      "computed_fields": { "id": "{{ record._id }}", "updated_at": "{{ record._updatedAt }}", "stream": "groups" },
      "projection": "passthrough",
      "schema": "schemas/groups.json"
    },
    {
      "name": "direct_messages",
      "path": "/im.list",
      "query": {
        "query": { "template": "{{ config.query }}", "omit_when_absent": true },
        "fields": { "template": "{{ config.fields }}", "omit_when_absent": true }
      },
      "records": { "path": "ims" },
      "computed_fields": { "id": "{{ record._id }}", "updated_at": "{{ record._updatedAt }}", "stream": "direct_messages" },
      "projection": "passthrough",
      "schema": "schemas/direct_messages.json"
    },
    {
      "name": "rooms",
      "path": "/rooms.get",
      "query": {
        "roomId": { "template": "{{ config.room_id }}", "omit_when_absent": true },
        "updatedSince": { "template": "{{ config.updated_since }}", "omit_when_absent": true }
      },
      "records": { "path": "update" },
      "computed_fields": { "id": "{{ record._id }}", "updated_at": "{{ record._updatedAt }}", "type": "{{ record.t }}", "stream": "rooms" },
      "projection": "passthrough",
      "schema": "schemas/rooms.json"
    }
  ]
}
