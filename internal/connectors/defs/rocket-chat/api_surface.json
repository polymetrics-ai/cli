{
  "api": "Rocket.Chat REST API v1",
  "docs": "https://developer.rocket.chat/apidocs",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; the full Rocket.Chat admin/messaging surface (chat.postMessage, channels.create, user/admin management, settings, integrations, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/api/v1/users.list", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/api/v1/channels.list", "covered_by": { "stream": "channels" } },
    { "method": "GET", "path": "/api/v1/groups.list", "covered_by": { "stream": "groups" } },
    { "method": "GET", "path": "/api/v1/im.list", "covered_by": { "stream": "direct_messages" } },
    { "method": "GET", "path": "/api/v1/rooms.get", "covered_by": { "stream": "rooms" } },
    { "method": "POST", "path": "/api/v1/chat.postMessage", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/v1/channels.create", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/v1/users.create", "excluded": { "category": "requires_elevated_scope", "reason": "Pass B capability expansion; admin-scoped user management" } },
    { "method": "GET", "path": "/api/v1/channels.history", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v1/me", "excluded": { "category": "non_data_endpoint", "reason": "identity/health-check endpoint, used only by check, not a syncable object stream" } }
  ]
}
