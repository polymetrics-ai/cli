{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "posts",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "date",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "date": { "type": "string", "format": "date-time" },
    "category": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "content": { "type": ["string", "null"] },
    "url": { "type": ["string", "null"] },
    "feedbackEnabled": { "type": ["boolean", "null"] },
    "reactionsEnabled": { "type": ["boolean", "null"] },
    "published": { "type": ["boolean", "null"] },
    "clicks": { "type": ["integer", "null"] },
    "views": { "type": ["integer", "null"] }
  }
}
