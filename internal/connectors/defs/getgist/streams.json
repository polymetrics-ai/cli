{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/contacts", "query": { "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "getgist api_key is missing or invalid; re-run pm credentials add getgist" },
      { "status": 429, "class": "rate_limited", "hint": "getgist rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "contacts" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "records": { "path": "tags" },
      "schema": "schemas/tags.json"
    },
    {
      "name": "segments",
      "path": "/segments",
      "records": { "path": "segments" },
      "schema": "schemas/segments.json"
    },
    {
      "name": "campaigns",
      "path": "/campaigns",
      "records": { "path": "campaigns" },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "forms",
      "path": "/forms",
      "records": { "path": "forms" },
      "schema": "schemas/forms.json"
    },
    {
      "name": "teammates",
      "path": "/teammates",
      "records": { "path": "teammates" },
      "schema": "schemas/teammates.json"
    }
  ]
}
