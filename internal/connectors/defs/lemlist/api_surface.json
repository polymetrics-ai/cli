{
  "api": "Lemlist API v2 (https://api.lemlist.com/api)",
  "docs": "https://developer.lemlist.com/api-reference/getting-started/overview",
  "reviewed_at": "2026-07-04",
  "scope": "Pass B review against the official lemlist OpenAPI v2 documentation. This bundle covers legacy streams plus no-required-input JSON GET collections/detail-like singleton resources. Endpoints requiring caller-supplied IDs, required query selectors, async/binary exports, POST-body searches, or mutating outreach/CRM/admin actions are explicitly excluded with closed categories.",
  "endpoints": [
    { "method": "GET", "path": "/team", "covered_by": { "stream": "team" } },
    { "method": "GET", "path": "/team/senders", "covered_by": { "stream": "team_senders" } },
    { "method": "GET", "path": "/team/credits", "covered_by": { "stream": "team_credits" } },
    { "method": "GET", "path": "/team/crmUsers", "covered_by": { "stream": "team_crm_users" } },
    { "method": "GET", "path": "/campaigns", "covered_by": { "stream": "campaigns" } },
    { "method": "GET", "path": "/activities", "covered_by": { "stream": "activities" } },
    { "method": "GET", "path": "/unsubscribes", "covered_by": { "stream": "unsubscribes" } },
    { "method": "GET", "path": "/schedules", "covered_by": { "stream": "schedules" } },
    { "method": "GET", "path": "/database/filters", "covered_by": { "stream": "database_filters" } },
    { "method": "GET", "path": "/tasks", "covered_by": { "stream": "tasks" } },
    { "method": "GET", "path": "/inbox/labels", "covered_by": { "stream": "inbox_labels" } },
    { "method": "GET", "path": "/contacts", "covered_by": { "stream": "contacts" } },
    { "method": "GET", "path": "/contacts/lists", "covered_by": { "stream": "contact_lists" } },
    { "method": "GET", "path": "/companies", "covered_by": { "stream": "companies" } },
    { "method": "GET", "path": "/hooks", "covered_by": { "stream": "webhooks" } },
    { "method": "GET", "path": "/v2/unsubscribes/variables", "covered_by": { "stream": "unsubscribed_variables" } },
    { "method": "GET", "path": "/watchlist/signals", "covered_by": { "stream": "watchlist_signals" } },
    { "method": "GET", "path": "/user/channels", "covered_by": { "stream": "user_channels" } },
    { "method": "GET", "path": "/fields (contact definitions)", "covered_by": { "stream": "fields_contact" } },
    { "method": "GET", "path": "/fields (company definitions)", "covered_by": { "stream": "fields_company" } },
    { "method": "GET", "path": "/campaigns/{campaignId}, /schedules/{scheduleId}, /users/{userId}, /leads, /leads/{email}, /contacts/{idOrEmail}, /inbox/labels/{labelId}, /v2/unsubscribes/variables/{value}, /unsubscribes/{email}, /enrich/{enrichId}", "excluded": { "category": "out_of_scope", "reason": "Detail endpoints require caller-supplied IDs or email values and do not produce global collections without extra connector config or parent fan-out." } },
    { "method": "GET", "path": "/campaigns/{campaignId}/leads/, /campaigns/{campaignId}/schedules/, /campaigns/{campaignId}/sequences, /campaigns/{campaignId}/statutes, /v2/campaigns/{campaignId}/stats, /companies/{companyId}/notes, /lemwarm/{userMailboxId}/settings, /v2/unsubscribes/contacts/{contactId}", "excluded": { "category": "out_of_scope", "reason": "Subresource reads require campaign, company, mailbox, or contact IDs that this legacy source contract does not collect as independent stream parameters." } },
    { "method": "GET", "path": "/campaigns/reports, /crm/filters, /inbox, /inbox/{contactId}, /inbox/{contactId}/drafts, /inbox/{contactId}/drafts/{draftId}", "excluded": { "category": "out_of_scope", "reason": "These GET endpoints require mandatory query selectors or path IDs such as campaignIds, CRM/user IDs, or contact/draft IDs." } },
    { "method": "GET", "path": "/campaigns/{campaignId}/export/start, /campaigns/{campaignId}/export/{exportId}/status", "excluded": { "category": "non_data_endpoint", "reason": "Async export job control/status endpoints do not return stable syncable business-object collections." } },
    { "method": "GET", "path": "/campaigns/{campaignId}/export/leads, /contacts/export, /unsubs/export, /v2/unsubscribes/exports/variables, /v2/unsubscribes/exports/contacts", "excluded": { "category": "binary_payload", "reason": "Export endpoints produce CSV/file-style payloads or export artifacts rather than paginated JSON records." } },
    { "method": "POST", "path": "/database/people, /database/companies", "excluded": { "category": "out_of_scope", "reason": "People/company database search is a read-like POST with request-body filters and body pagination; the declarative read engine does not model POST-body search streams without a StreamHook." } },
    { "method": "POST", "path": "/campaigns, /campaigns/{campaignId}/duplicate, /campaigns/{campaignId}/pause, /campaigns/{campaignId}/start, /campaigns/{campaignId}/schedules/{scheduleId}, /sequences/{sequenceId}/steps", "excluded": { "category": "requires_elevated_scope", "reason": "Campaign, schedule-association, and sequence-step actions create or change outbound campaign behavior and need a dedicated reverse-ETL approval design." } },
    { "method": "PATCH", "path": "/campaigns/{campaignId}, /schedules/{scheduleId}, /sequences/{sequenceId}/steps/{stepId}", "excluded": { "category": "requires_elevated_scope", "reason": "Campaign, schedule, and sequence updates mutate outbound messaging configuration." } },
    { "method": "POST", "path": "/campaigns/{campaignId}/leads/, /campaigns/{campaignId}/leads/import, /leads/start/{leadId}, /leads/pause/{leadId}, /leads/review/{leadId}, /leads/interested/{leadIdOrEmail}, /leads/notinterested/{leadIdOrEmail}, /campaigns/{campaignId}/leads/{leadIdOrEmail}/interested, /campaigns/{campaignId}/leads/{leadIdOrEmail}/notinterested, /leads/{leadId}/variables, /leads/{leadId}/enrich", "excluded": { "category": "requires_elevated_scope", "reason": "Lead creation, launch/pause/review, interest-state, custom-variable, import, and enrichment actions mutate outreach state or consume enrichment credits." } },
    { "method": "PATCH", "path": "/campaigns/{campaignId}/leads/{leadId}, /leads/{leadId}/variables", "excluded": { "category": "requires_elevated_scope", "reason": "Lead update endpoints mutate campaign lead records and custom variables." } },
    { "method": "DELETE", "path": "/campaigns/{campaignId}/leads/, /campaigns/{campaignId}/leads/{leadId}, /campaigns/{campaignId}/leads/{email}, /leads/{leadId}/variables", "excluded": { "category": "destructive_admin", "reason": "Lead delete/unsubscribe and variable erasure endpoints remove or suppress outreach data." } },
    { "method": "POST", "path": "/tasks, /tasks/ignore, /inbox/email, /inbox/linkedin, /inbox/whatsapp, /inbox/labels, /inbox/conversations/labels/{contactId}, /inbox/{contactId}/drafts", "excluded": { "category": "requires_elevated_scope", "reason": "Task and inbox endpoints create/send messages, labels, drafts, or task state changes." } },
    { "method": "PATCH", "path": "/tasks, /inbox/{contactId}/drafts/{draftId}", "excluded": { "category": "requires_elevated_scope", "reason": "Task and draft updates mutate operational outreach workflow state." } },
    { "method": "DELETE", "path": "/inbox/conversations/labels/{contactId}, /inbox/{contactId}/drafts/{draftId}", "excluded": { "category": "destructive_admin", "reason": "Inbox delete/remove actions alter conversation metadata or soft-delete drafts." } },
    { "method": "POST", "path": "/contacts, /contacts/lists, /contacts/lists/{listId}/entities, /companies, /companies/{companyId}/notes", "excluded": { "category": "requires_elevated_scope", "reason": "CRM contact, list, company, and note writes mutate customer relationship data." } },
    { "method": "DELETE", "path": "/companies/{companyId}", "excluded": { "category": "destructive_admin", "reason": "Company deletion removes CRM company data and can detach related contacts." } },
    { "method": "POST", "path": "/schedules, /lemwarm/{userMailboxId}/start, /lemwarm/{userMailboxId}/pause, /hooks, /enrich, /v2/enrichments/bulk, /v2/unsubscribes/variables, /v2/unsubscribes/variables/{value}, /v2/unsubscribes/contacts/{contactId}, /unsubscribes/{email}, /user/email-accounts, /user/email-accounts/{emailAccountId}/test", "excluded": { "category": "requires_elevated_scope", "reason": "Schedule creation, deliverability control, webhook configuration, enrichment, unsubscribe, and email-account actions mutate account state or consume credits." } },
    { "method": "PATCH", "path": "/lemwarm/{userMailboxId}/settings", "excluded": { "category": "requires_elevated_scope", "reason": "lemwarm settings updates mutate mailbox deliverability configuration." } },
    { "method": "PUT", "path": "/campaigns/{campaignId}/export/{exportId}/email/{email}", "excluded": { "category": "requires_elevated_scope", "reason": "Export notification configuration mutates delivery settings for an async export." } },
    { "method": "DELETE", "path": "/schedules/{scheduleId}, /sequences/{sequenceId}/steps/{stepId}, /activities/{activityId}/recording-transcript, /v2/unsubscribes/variables/{value}, /v2/unsubscribes/contacts/{contactId}, /unsubscribes/{email}, /hooks/{hookId}, /user/email-accounts/{emailAccountId}", "excluded": { "category": "destructive_admin", "reason": "Delete/resubscribe/disconnect endpoints remove configuration, recordings/transcripts, webhook/email-account connections, or unsubscribe state." } },
    { "method": "POST", "path": "/leads/audio", "excluded": { "category": "binary_payload", "reason": "Voice-message upload is a binary/multipart payload, outside the JSON write dialect." } }
  ]
}
