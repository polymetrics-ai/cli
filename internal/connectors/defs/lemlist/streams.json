{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "access_token", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/team" },
    "error_map": [
      { "status": 401, "hint": "lemlist api_key is missing or invalid; re-run pm credentials add lemlist" },
      { "status": 403, "hint": "lemlist account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "lemlist rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "campaigns",
      "path": "/campaigns",
      "records": { "path": "" },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "team",
      "path": "/team",
      "records": { "path": "", "single_object": true },
      "pagination": { "type": "none" },
      "schema": "schemas/team.json"
    },
    {
      "name": "activities",
      "path": "/activities",
      "records": { "path": "" },
      "schema": "schemas/activities.json"
    },
    {
      "name": "unsubscribes",
      "path": "/unsubscribes",
      "records": { "path": "" },
      "schema": "schemas/unsubscribes.json"
    }
  ]
}
