{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100,
      "max_pages": 1
    },
    "check": { "method": "GET", "path": "/api/v2/orders" },
    "error_map": [
      { "status": 401, "hint": "tremendous api_key is missing or invalid; re-run pm credentials add tremendous" },
      { "status": 429, "class": "rate_limited", "hint": "tremendous rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "campaigns",
      "path": "/api/v2/campaigns",
      "records": { "path": "campaigns" },
      "computed_fields": {
        "created_at": "{{ coalesce record.created_at record.createdAt }}"
      },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "orders",
      "path": "/api/v2/orders",
      "records": { "path": "orders" },
      "computed_fields": {
        "campaign_id": "{{ coalesce record.campaign_id record.campaignId }}",
        "payment_status": "{{ coalesce record.payment_status record.paymentStatus }}",
        "created_at": "{{ coalesce record.created_at record.createdAt }}"
      },
      "schema": "schemas/orders.json"
    },
    {
      "name": "rewards",
      "path": "/api/v2/rewards",
      "records": { "path": "rewards" },
      "computed_fields": {
        "order_id": "{{ coalesce record.order_id record.orderId }}",
        "created_at": "{{ coalesce record.created_at record.createdAt }}"
      },
      "schema": "schemas/rewards.json"
    },
    {
      "name": "funding_sources",
      "path": "/api/v2/funding_sources",
      "records": { "path": "funding_sources" },
      "computed_fields": {
        "created_at": "{{ coalesce record.created_at record.createdAt }}"
      },
      "schema": "schemas/funding_sources.json"
    },
    {
      "name": "products",
      "path": "/api/v2/products",
      "pagination": { "type": "none" },
      "records": { "path": "products" },
      "schema": "schemas/products.json"
    },
    {
      "name": "invoices",
      "path": "/api/v2/invoices",
      "pagination": {
        "type": "offset_limit",
        "offset_param": "offset",
        "limit_param": "limit",
        "page_size": 100
      },
      "records": { "path": "invoices" },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "members",
      "path": "/api/v2/members",
      "pagination": { "type": "none" },
      "records": { "path": "members" },
      "schema": "schemas/members.json"
    }
  ]
}
