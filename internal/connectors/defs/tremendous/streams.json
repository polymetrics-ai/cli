{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100,
      "max_pages": 1
    },
    "check": { "method": "GET", "path": "/api/v2/orders" },
    "error_map": [
      { "status": 401, "hint": "tremendous api_key is missing or invalid; re-run pm credentials add tremendous" },
      { "status": 429, "class": "rate_limited", "hint": "tremendous rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "campaigns",
      "path": "/api/v2/campaigns",
      "records": { "path": "campaigns" },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "orders",
      "path": "/api/v2/orders",
      "records": { "path": "orders" },
      "schema": "schemas/orders.json"
    },
    {
      "name": "rewards",
      "path": "/api/v2/rewards",
      "records": { "path": "rewards" },
      "schema": "schemas/rewards.json"
    },
    {
      "name": "funding_sources",
      "path": "/api/v2/funding_sources",
      "records": { "path": "funding_sources" },
      "schema": "schemas/funding_sources.json"
    }
  ]
}
