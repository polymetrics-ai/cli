{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "products",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "category": { "type": ["string", "null"] },
    "subcategory": { "type": ["string", "null"] },
    "disclosure": { "type": ["string", "null"] },
    "skus": { "type": ["array", "null"] },
    "currency_codes": { "type": ["array", "null"] },
    "countries": { "type": ["array", "null"] },
    "images": { "type": ["array", "null"] },
    "usage_instructions": { "type": ["string", "null"] },
    "documents": { "type": ["array", "null"] }
  }
}
