{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "item_collection",
      "method": "GET",
      "path": "/__legacy_hook/item_collection",
      "records": {
        "path": "data"
      },
      "schema": "schemas/item_collection.json"
    },
    {
      "name": "dataset_collection",
      "method": "GET",
      "path": "/__legacy_hook/dataset_collection",
      "records": {
        "path": "data"
      },
      "schema": "schemas/dataset_collection.json",
      "incremental": {
        "cursor_field": "createdAt",
        "client_filtered": true
      }
    },
    {
      "name": "dataset",
      "method": "GET",
      "path": "/__legacy_hook/dataset",
      "records": {
        "path": "data"
      },
      "schema": "schemas/dataset.json",
      "incremental": {
        "cursor_field": "modifiedAt",
        "client_filtered": true
      }
    }
  ]
}
