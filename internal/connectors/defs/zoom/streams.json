{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "next_page_token",
      "token_path": "next_page_token"
    },
    "check": { "method": "GET", "path": "/users", "query": { "page_size": "1" } },
    "error_map": [
      { "status": 401, "hint": "zoom access_token is missing or invalid; re-run pm credentials add zoom" },
      { "status": 429, "class": "rate_limited", "hint": "zoom rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/users",
      "query": { "page_size": "{{ config.page_size }}" },
      "records": { "path": "users" },
      "computed_fields": {
        "name": "{{ coalesce record.name record.email record.first_name record.display_name }}",
        "updated_at": "{{ coalesce record.updated_at record.created_at }}"
      },
      "schema": "schemas/users.json",
      "projection": "passthrough"
    },
    {
      "name": "meetings",
      "path": "/users/{{ config.user_id }}/meetings",
      "query": { "page_size": "{{ config.page_size }}" },
      "records": { "path": "meetings" },
      "computed_fields": {
        "id": "{{ coalesce record.id record.uuid }}",
        "name": "{{ coalesce record.name record.topic }}",
        "updated_at": "{{ coalesce record.updated_at record.start_time }}"
      },
      "schema": "schemas/meetings.json",
      "projection": "passthrough"
    },
    {
      "name": "webinars",
      "path": "/users/{{ config.user_id }}/webinars",
      "query": { "page_size": "{{ config.page_size }}" },
      "records": { "path": "webinars" },
      "computed_fields": {
        "id": "{{ coalesce record.id record.uuid }}",
        "name": "{{ coalesce record.name record.topic }}",
        "updated_at": "{{ coalesce record.updated_at record.start_time }}"
      },
      "schema": "schemas/webinars.json",
      "projection": "passthrough"
    }
  ]
}
