{
  "api": "Cloudbeds API v1.2 (https://api.cloudbeds.com/api/v1.2)",
  "docs": "https://hotels.cloudbeds.com/api/docs/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; the full Cloudbeds surface (rate plans, rooms CRUD, payments, webhooks, etc.) is out of scope until Pass B",
  "endpoints": [
