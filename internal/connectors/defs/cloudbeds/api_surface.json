    { "method": "GET", "path": "/getHotels", "covered_by": { "stream": "hotels" } },
    { "method": "GET", "path": "/getRoomBlocks", "covered_by": { "stream": "rooms" } },
    { "method": "GET", "path": "/getReservations", "covered_by": { "stream": "reservations" } },
    { "method": "GET", "path": "/getTransactions", "covered_by": { "stream": "transactions" } },
    { "method": "GET", "path": "/getRatePlans", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/postReservation", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
