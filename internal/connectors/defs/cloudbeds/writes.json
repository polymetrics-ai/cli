      "method": "POST",
      "path": "/postGuest",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "reservationID"],
        "properties": {
          "propertyID": { "type": "string" },
          "reservationID": { "type": "string" },
          "guestFirstName": { "type": "string" },
          "guestLastName": { "type": "string" },
          "guestEmail": { "type": "string" },
          "guestPhone": { "type": "string" },
          "guestAddress1": { "type": "string" },
          "guestCity": { "type": "string" },
          "guestCountry": { "type": "string" },
          "guestZip": { "type": "string" }
        }
      },
      "risk": "adds an additional guest to an existing reservation; no approval required"
    },
    {
      "name": "update_guest",
      "kind": "update",
      "method": "PUT",
      "path": "/putGuest",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "guestID"],
        "properties": {
          "propertyID": { "type": "string" },
          "guestID": { "type": "string" },
          "guestFirstName": { "type": "string" },
          "guestLastName": { "type": "string" },
          "guestEmail": { "type": "string" },
          "guestPhone": { "type": "string" }
        }
      },
      "risk": "overwrites a guest's profile fields; no approval required"
    },
    {
      "name": "create_guest_note",
      "kind": "create",
      "method": "POST",
      "path": "/postGuestNote",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "guestID", "guestNote"],
        "properties": {
          "propertyID": { "type": "string" },
          "guestID": { "type": "string" },
          "guestNote": { "type": "string" },
          "userID": { "type": "string" }
        }
      },
      "risk": "adds a free-text note to a guest profile; no approval required"
    },
    {
      "name": "update_guest_note",
      "kind": "update",
      "method": "PUT",
      "path": "/putGuestNote",
      "body_type": "form",
