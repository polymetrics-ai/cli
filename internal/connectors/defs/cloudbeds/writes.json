      "name": "delete_reservation_note",
      "kind": "delete",
      "method": "DELETE",
      "path": "/deleteReservationNote?propertyID={{ record.propertyID }}&reservationID={{ record.reservationID }}&reservationNoteID={{ record.reservationNoteID }}",
      "path_fields": ["propertyID", "reservationID", "reservationNoteID"],
      "body_type": "none",
      "delete": { "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "reservationID", "reservationNoteID"],
        "properties": {
          "propertyID": { "type": "string" },
          "reservationID": { "type": "string" },
          "reservationNoteID": { "type": "string" }
