        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "guestID", "noteID", "guestNote"],
        "properties": {
          "propertyID": { "type": "string" },
          "guestID": { "type": "string" },
          "noteID": { "type": "string" },
          "guestNote": { "type": "string" }
        }
      },
      "risk": "overwrites an existing guest note's text; no approval required"
    },
    {
      "name": "delete_guest_note",
      "kind": "delete",
      "method": "DELETE",
      "path": "/deleteGuestNote?propertyID={{ record.propertyID }}&guestID={{ record.guestID }}&noteID={{ record.noteID }}",
      "path_fields": ["propertyID", "guestID", "noteID"],
      "body_type": "none",
      "delete": { "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "guestID", "noteID"],
        "properties": {
          "propertyID": { "type": "string" },
          "guestID": { "type": "string" },
          "noteID": { "type": "string" }
        }
      },
      "risk": "irreversibly removes a guest note; approval required"
    },
    {
      "name": "create_reservation",
      "kind": "create",
      "method": "POST",
      "path": "/postReservation",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "startDate", "endDate", "guestFirstName", "guestLastName", "rooms"],
        "properties": {
          "propertyID": { "type": "string" },
          "sourceID": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" },
          "guestFirstName": { "type": "string" },
          "guestLastName": { "type": "string" },
          "guestEmail": { "type": "string" },
          "rooms": { "type": "array" },
          "adults": { "type": "integer" },
          "children": { "type": "integer" },
          "paymentMethod": { "type": "string" },
          "sendEmailConfirmation": { "type": "boolean" }
        }
      },
      "risk": "creates a new, billable reservation (books rooms and may authorize/charge a card depending on paymentMethod); external mutation, no approval required for the booking itself but review payment-capturing config carefully"
    },
    {
      "name": "update_reservation",
      "kind": "update",
      "method": "PUT",
      "path": "/putReservation",
      "body_type": "form",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["propertyID", "reservationID"],
        "properties": {
          "propertyID": { "type": "string" },
          "reservationID": { "type": "string" },
          "status": { "type": "string" },
          "estimatedArrivalTime": { "type": "string" },
          "checkoutDate": { "type": "string" },
          "rooms": { "type": "array" },
          "sendStatusChangeEmail": { "type": "boolean" }
        }
      },
      "risk": "mutates an existing reservation's status/dates/room assignment; a status change to a cancelled/no-show state has real revenue and inventory-release consequences; no approval required (Cloudbeds' own confirmation flow, e.g. sendStatusChangeEmail, is the operator-facing guardrail)"
    },
    {
      "name": "create_reservation_note",
