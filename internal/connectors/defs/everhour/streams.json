{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-Api-Key", "prefix": "", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/team/users" },
    "error_map": [
      { "status": 401, "hint": "everhour api_key is missing or invalid; re-run pm credentials add everhour" },
      { "status": 403, "hint": "everhour account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "everhour rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects",
      "records": { "path": "" },
      "schema": "schemas/projects.json"
    },
    {
      "name": "clients",
      "path": "/clients",
      "records": { "path": "" },
      "schema": "schemas/clients.json"
    },
    {
      "name": "users",
      "path": "/team/users",
      "records": { "path": "" },
      "schema": "schemas/users.json"
    },
    {
      "name": "time",
      "path": "/team/time",
      "records": { "path": "" },
      "schema": "schemas/time.json"
    },
    {
      "name": "tasks",
      "path": "/projects/{{ fanout.id }}/tasks",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/projects", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "project_id" },
        "stamp_field": "project_id"
      },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "sections",
      "path": "/projects/{{ fanout.id }}/sections",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/projects", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "project_id" },
        "stamp_field": "project_id"
      },
      "schema": "schemas/sections.json"
    },
    {
      "name": "time_off_types",
      "path": "/resource-planner/time-off-types",
      "records": { "path": "" },
      "schema": "schemas/time_off_types.json"
    },
    {
      "name": "allocations",
      "path": "/allocations",
      "records": { "path": "" },
      "schema": "schemas/allocations.json"
    },
    {
      "name": "expense_categories",
      "path": "/expenses/categories",
      "records": { "path": "" },
      "schema": "schemas/expense_categories.json"
    },
    {
      "name": "expenses",
      "path": "/expenses",
      "records": { "path": "" },
      "schema": "schemas/expenses.json"
    },
    {
      "name": "invoices",
      "path": "/invoices",
      "records": { "path": "" },
      "schema": "schemas/invoices.json"
    }
  ]
}
