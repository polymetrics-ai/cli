  "title": "users",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "headline": { "type": ["string", "null"] },
    "role": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "capacity": { "type": ["integer", "null"] },
    "isEmailVerified": { "type": ["boolean", "null"] },
