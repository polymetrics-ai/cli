    {
      "method": "GET",
      "path": "/api/v1/projects",
      "covered_by": {
        "stream": "projects"
      }
    },
    {
      "method": "GET",
      "path": "/api/v1/clients",
      "covered_by": {
        "stream": "clients"
      }
    },
    {
      "method": "GET",
      "path": "/api/v1/roles",
      "covered_by": {
        "stream": "roles"
      }
    },
    {
      "method": "POST",
      "path": "/api/v1/projects/{id}/assignments",
      "excluded": {
        "category": "out_of_scope",
        "reason": "Legacy connector never implemented assignment writes"
      }
    },
    {
      "method": "GET",
      "path": "/api/v1/time_entries",
      "excluded": {
