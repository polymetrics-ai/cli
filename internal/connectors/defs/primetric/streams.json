{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "oauth2_client_credentials",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "scopes": "read"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "start_page": 1,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/employees" },
    "error_map": [
      { "status": 401, "hint": "primetric client_id/client_secret are missing or invalid; re-run pm credentials add primetric" },
      { "status": 403, "hint": "primetric account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "primetric rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "employees",
      "path": "/employees",
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.first_name }} {{ record.last_name }}"
      },
      "schema": "schemas/employees.json"
    },
    {
      "name": "projects",
      "path": "/projects",
      "records": { "path": "data" },
      "schema": "schemas/projects.json"
    },
    {
      "name": "clients",
      "path": "/clients",
      "records": { "path": "data" },
      "schema": "schemas/clients.json"
    },
    {
      "name": "roles",
      "path": "/roles",
      "records": { "path": "data" },
      "schema": "schemas/roles.json"
    }
  ]
}
