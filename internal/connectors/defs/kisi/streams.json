{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "prefix": "KISI-LOGIN ", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/members", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "kisi api_key is missing or invalid; re-run pm credentials add kisi" },
      { "status": 429, "class": "rate_limited", "hint": "kisi rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "members",
      "path": "/members",
      "records": { "path": "" },
      "schema": "schemas/members.json"
    },
    {
      "name": "locks",
      "path": "/locks",
      "records": { "path": "" },
      "schema": "schemas/locks.json"
    },
    {
      "name": "groups",
      "path": "/groups",
      "records": { "path": "" },
      "schema": "schemas/groups.json"
    },
    {
      "name": "users",
      "path": "/users",
      "records": { "path": "" },
      "schema": "schemas/users.json"
    },
    {
      "name": "logins",
      "path": "/logins",
      "records": { "path": "" },
      "schema": "schemas/logins.json"
    }
  ]
}
