{
  "actions": [
    {
      "name": "create_customer",
      "kind": "create",
      "method": "POST",
      "path": "/customers",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["data_source_uuid", "external_id"],
        "properties": {
          "data_source_uuid": { "type": "string" },
          "external_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "country": { "type": "string" },
          "city": { "type": "string" },
          "company": { "type": "string" },
          "website_url": { "type": "string" },
          "lead_created_at": { "type": "string" },
          "free_trial_started_at": { "type": "string" },
          "owner": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "update_customer",
      "kind": "update",
      "method": "PUT",
      "path": "/customers/{{ record.uuid }}",
      "path_fields": ["uuid"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["uuid"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "country": { "type": "string" },
          "city": { "type": "string" },
          "company": { "type": "string" },
          "website_url": { "type": "string" },
          "owner": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    }
  ]
}
