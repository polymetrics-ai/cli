      "id": "gong.calls_media_upload",
      "kind": "rest_write",
      "summary": "Add call media (/v2/calls/{id}/media)",
      "description": "Typed Gong multipart media upload operation. Executable through the `upload_call_media` reverse-ETL write action; no generic upload command is exposed.",
      "source_url": "https://gong.app.gong.io/ajax/settings/api/documentation/specs?version=",
      "risk": "high",
      "approval": "reverse ETL plan, preview, approval, execute; destructive confirmation required",
      "output_policy": "gong_bounded_input_redacted",
      "mutation_class": "update",
      "secret_sensitive": true,
      "sensitive_policy": {
        "input_mode": "file",
        "redact_fields": [
          "mediaFile"
        ],
        "transform": "none",
        "approval_mode": "typed_confirmation"
      },
      "rest": {
        "method": "PUT",
        "path": "/v2/calls/{id}/media",
        "content_type": "multipart/form-data",
        "max_bytes": 1610612736,
        "body_schema": {
          "type": "object",
          "properties": {
            "mediaFile": {
              "type": "string",
              "description": "The media file of the recording. You may attach files up to 1.5GB in size."
            }
          },
          "required": [
            "mediaFile"
          ]
        }
      }
    },
