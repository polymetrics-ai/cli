{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "custom",
        "hook": "zoho-bigin",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "token": "{{ secrets.client_refresh_token }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 200
    },
    "check": {
      "method": "GET",
      "path": "/Pipelines"
    },
    "error_map": [
      { "status": 401, "hint": "zoho-bigin OAuth refresh grant failed or access token expired; re-run pm credentials add zoho-bigin" },
      { "status": 403, "hint": "zoho-bigin account lacks access for this request/scope" },
      { "status": 429, "class": "rate_limited", "hint": "zoho-bigin API rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "pipelines",
      "path": "/Pipelines",
      "records": { "path": "data" },
      "schema": "schemas/pipelines.json"
    },
    {
      "name": "records",
      "path": "/{{ config.module_name }}",
      "records": { "path": "data" },
      "schema": "schemas/records.json",
      "projection": "passthrough"
    },
    {
      "name": "fields",
      "path": "/settings/fields",
      "records": { "path": "fields" },
      "schema": "schemas/fields.json",
      "projection": "passthrough",
      "pagination": { "type": "none" }
    },
    {
      "name": "contacts",
      "path": "/Contacts",
      "records": { "path": "data" },
      "schema": "schemas/contacts.json",
      "projection": "passthrough"
    },
    {
      "name": "companies",
      "path": "/Accounts",
      "records": { "path": "data" },
      "schema": "schemas/companies.json",
      "projection": "passthrough"
    },
    {
      "name": "products",
      "path": "/Products",
      "records": { "path": "data" },
      "schema": "schemas/products.json",
      "projection": "passthrough"
    },
    {
      "name": "tasks",
      "path": "/Tasks",
      "records": { "path": "data" },
      "schema": "schemas/tasks.json",
      "projection": "passthrough"
    },
    {
      "name": "events",
      "path": "/Events",
      "records": { "path": "data" },
      "schema": "schemas/events.json",
      "projection": "passthrough"
    },
    {
      "name": "calls",
      "path": "/Calls",
      "records": { "path": "data" },
      "schema": "schemas/calls.json",
      "projection": "passthrough"
    },
    {
      "name": "notes",
      "path": "/Notes",
      "records": { "path": "data" },
      "schema": "schemas/notes.json",
      "projection": "passthrough"
    },
    {
      "name": "users",
      "path": "/users",
      "query": { "type": "AllUsers" },
      "records": { "path": "users" },
      "schema": "schemas/users.json",
      "projection": "passthrough"
    },
    {
      "name": "tags",
      "path": "/settings/tags",
      "query": { "module": "{{ config.module_name }}" },
      "records": { "path": "tags" },
      "schema": "schemas/tags.json",
      "projection": "passthrough",
      "pagination": { "type": "none" }
    },
    {
      "name": "modules",
      "path": "/settings/modules",
      "records": { "path": "modules" },
      "schema": "schemas/modules.json",
      "projection": "passthrough",
      "pagination": { "type": "none" }
    }
  ]
}
