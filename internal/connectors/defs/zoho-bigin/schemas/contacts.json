{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "contacts",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "First_Name": { "type": ["string", "null"] },
    "Last_Name": { "type": ["string", "null"] },
    "Email": { "type": ["string", "null"] },
    "Phone": { "type": ["string", "null"] },
    "Mobile": { "type": ["string", "null"] },
    "Title": { "type": ["string", "null"] },
    "Account_Name": { "type": ["object", "null"], "description": "Lookup object {id, name} to the parent Accounts (Companies) record; passthrough projection preserves the raw nested shape." },
    "Owner": { "type": ["object", "null"] },
    "Created_Time": { "type": ["string", "null"] },
    "Modified_Time": { "type": ["string", "null"] },
    "display_value": { "type": ["string", "null"] }
  }
}
