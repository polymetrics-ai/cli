{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tasks",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "Subject": { "type": ["string", "null"] },
    "Status": { "type": ["string", "null"] },
    "Priority": { "type": ["string", "null"] },
    "Due_Date": { "type": ["string", "null"] },
    "Who_Id": { "type": ["object", "null"], "description": "Lookup object {id, name} to the associated Contact/Company/Pipeline record." },
    "Owner": { "type": ["object", "null"] },
    "Created_Time": { "type": ["string", "null"] },
    "Modified_Time": { "type": ["string", "null"] }
  }
}
