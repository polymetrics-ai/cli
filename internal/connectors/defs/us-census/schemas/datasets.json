{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "datasets",
  "type": "object",
  "x-primary-key": ["identifier"],
  "required": ["identifier"],
  "properties": {
    "identifier": { "type": "string" },
    "title": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "c_vintage": { "type": ["integer", "null"] },
    "c_dataset": { "type": ["array", "null"], "items": { "type": "string" } },
    "dataset_path": { "type": ["string", "null"] },
    "c_variablesLink": { "type": ["string", "null"] },
    "c_geographyLink": { "type": ["string", "null"] },
    "c_isAvailable": { "type": ["boolean", "null"] },
    "accessLevel": { "type": ["string", "null"] },
    "modified": { "type": ["string", "null"] }
  }
}
