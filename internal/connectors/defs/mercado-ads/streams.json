{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "brand_advertisers",
      "method": "GET",
      "path": "/__legacy_hook/brand_advertisers",
      "records": {
        "path": "data"
      },
      "schema": "schemas/brand_advertisers.json"
    },
    {
      "name": "display_advertisers",
      "method": "GET",
      "path": "/__legacy_hook/display_advertisers",
      "records": {
        "path": "data"
      },
      "schema": "schemas/display_advertisers.json"
    },
    {
      "name": "product_advertisers",
      "method": "GET",
      "path": "/__legacy_hook/product_advertisers",
      "records": {
        "path": "data"
      },
      "schema": "schemas/product_advertisers.json"
    },
    {
      "name": "brand_campaigns_metrics",
      "method": "GET",
      "path": "/__legacy_hook/brand_campaigns_metrics",
      "records": {
        "path": "data"
      },
      "schema": "schemas/brand_campaigns_metrics.json",
      "incremental": {
        "cursor_field": "date",
        "client_filtered": true
      }
    },
    {
      "name": "display_campaigns_metrics",
      "method": "GET",
      "path": "/__legacy_hook/display_campaigns_metrics",
      "records": {
        "path": "data"
      },
      "schema": "schemas/display_campaigns_metrics.json",
      "incremental": {
        "cursor_field": "date",
        "client_filtered": true
      }
    },
    {
      "name": "product_campaigns_metrics",
      "method": "GET",
      "path": "/__legacy_hook/product_campaigns_metrics",
      "records": {
        "path": "data"
      },
      "schema": "schemas/product_campaigns_metrics.json",
      "incremental": {
        "cursor_field": "date",
        "client_filtered": true
      }
    }
  ]
}
