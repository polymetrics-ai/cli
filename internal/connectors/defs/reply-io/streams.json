{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.bearer_token }}",
        "when": "{{ secrets.bearer_token }}"
      },
      {
        "mode": "api_key_header",
        "header": "X-Api-Key",
        "value": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/v1/people",
      "query": {
        "limit": "1",
        "page": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "reply.io api key is missing or invalid; re-run pm credentials add reply-io"
      },
      {
        "status": 403,
        "hint": "reply.io account lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "reply.io rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "people",
      "path": "/v1/people",
      "schema": "schemas/people.json",
      "computed_fields": {
        "stream": "people"
      },
      "records": {
        "path": ""
      },
      "query": {
        "updated_after": {
          "template": "{{ config.updated_after }}",
          "omit_when_absent": true
        },
        "created_after": {
          "template": "{{ config.created_after }}",
          "omit_when_absent": true
        },
        "email": {
          "template": "{{ config.email }}",
          "omit_when_absent": true
        },
        "status": {
          "template": "{{ config.status }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "campaigns",
      "path": "/v1/campaigns",
      "schema": "schemas/campaigns.json",
      "computed_fields": {
        "stream": "campaigns"
      },
      "records": {
        "path": ""
      },
      "query": {
        "updated_after": {
          "template": "{{ config.updated_after }}",
          "omit_when_absent": true
        },
        "created_after": {
          "template": "{{ config.created_after }}",
          "omit_when_absent": true
        },
        "email": {
          "template": "{{ config.email }}",
          "omit_when_absent": true
        },
        "status": {
          "template": "{{ config.status }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "tasks",
