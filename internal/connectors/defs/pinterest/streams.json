{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "custom",
        "hook": "pinterest",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "token": "{{ secrets.refresh_token }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "bookmark",
      "token_path": "bookmark"
    },
    "check": {
      "method": "GET",
      "path": "/ad_accounts",
      "query": {
        "page_size": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "pinterest refresh-token exchange failed or access token expired; re-run pm credentials add pinterest"
      },
      {
        "status": 403,
        "hint": "pinterest account lacks access/scope for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "pinterest API rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "ad_accounts",
      "path": "/ad_accounts",
      "query": {
        "page_size": {
          "template": "{{ config.page_size }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "schema": "schemas/ad_accounts.json"
    },
    {
      "name": "boards",
      "path": "/boards",
      "query": {
        "page_size": {
          "template": "{{ config.page_size }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "schema": "schemas/boards.json"
    },
    {
      "name": "campaigns",
      "path": "/ad_accounts/{{ config.account_id }}/campaigns",
      "query": {
        "page_size": {
          "template": "{{ config.page_size }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "ad_groups",
      "path": "/ad_accounts/{{ config.account_id }}/ad_groups",
      "query": {
        "page_size": {
          "template": "{{ config.page_size }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "schema": "schemas/ad_groups.json"
    },
    {
      "name": "audiences",
      "path": "/ad_accounts/{{ config.account_id }}/audiences",
      "query": {
        "page_size": {
          "template": "{{ config.page_size }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "schema": "schemas/audiences.json"
    }
  ]
}
