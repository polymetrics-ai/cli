{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}", "prefix": "Basic " }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "pageToken",
      "token_path": "next_page_token"
    },
    "check": { "method": "GET", "path": "/segments/v2" },
    "error_map": [
      { "status": 401, "hint": "fullstory api_key is missing or invalid; re-run pm credentials add fullstory" },
      { "status": 403, "hint": "fullstory account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "fullstory rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "segments",
      "path": "/segments/v2",
      "query": { "limit": "200" },
      "records": { "path": "results" },
      "schema": "schemas/segments.json"
    },
    {
      "name": "users",
      "path": "/v2/users",
      "query": { "limit": "200" },
      "records": { "path": "results" },
      "schema": "schemas/users.json"
    },
    {
      "name": "events",
      "path": "/v2/events",
      "query": { "limit": "200" },
      "records": { "path": "results" },
      "schema": "schemas/events.json"
    },
    {
      "name": "sessions",
      "path": "/v2/sessions",
      "pagination": { "type": "none" },
      "query": {
        "limit": "200",
        "uid": { "template": "{{ config.session_uid }}", "omit_when_absent": true },
        "email": { "template": "{{ config.session_email }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/sessions.json"
    }
  ]
}
