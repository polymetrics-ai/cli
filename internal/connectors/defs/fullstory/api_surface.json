{
  "api": "FullStory REST API (https://api.fullstory.com)",
  "docs": "https://developer.fullstory.com/reference",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 3 legacy-parity read streams only; the full FullStory surface (custom events ingest, journeys, exports, webhooks, personas) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/segments/v2", "covered_by": { "stream": "segments" } },
