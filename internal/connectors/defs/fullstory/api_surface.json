    { "method": "GET", "path": "/v2/events", "covered_by": { "stream": "events" } },
    { "method": "POST", "path": "/v1/events", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/export/list", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/journeys", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v2/users", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
