{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Persona Connection Specification",
  "type": "object",
  "required": ["api_key"],
  "properties": {
    "api_key": {
      "type": "string",
      "x-secret": true,
      "description": "Persona API key, sent as a Bearer token (Authorization: Bearer <api_key>). Never logged."
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "default": "https://api.withpersona.com/api/v1",
      "description": "Persona API base URL override for tests or proxies."
    },
    "page_size": {
      "type": "string",
      "default": "50",
      "description": "Records per page (1-100)."
    }
  }
}
