{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/inquiries" },
    "error_map": [
      { "status": 401, "hint": "persona api key is missing or invalid; re-run pm credentials add persona" },
      { "status": 429, "class": "rate_limited", "hint": "persona rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "inquiries",
      "path": "/inquiries",
      "query": { "page[size]": "50" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/inquiries.json",
      "projection": "passthrough"
    },
    {
      "name": "accounts",
      "path": "/accounts",
      "query": { "page[size]": "50" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/accounts.json",
      "projection": "passthrough"
    },
    {
      "name": "reports",
      "path": "/reports",
      "query": { "page[size]": "50" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/reports.json",
      "projection": "passthrough"
    },
    {
      "name": "transactions",
      "path": "/transactions",
      "query": { "page[size]": "50" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/transactions.json",
      "projection": "passthrough"
    },
    {
      "name": "cases",
      "path": "/cases",
      "query": { "page[size]": "50" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/cases.json",
      "projection": "passthrough"
    }
  ]
}
