{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/tasks",
      "query": { "pageSize": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "wrike access_token is missing or invalid; re-run pm credentials add wrike" },
      { "status": 403, "hint": "wrike account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "wrike rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "tasks",
      "path": "/tasks",
      "records": { "path": "data" },
      "schema": "schemas/tasks.json",
      "projection": "passthrough"
    },
    {
      "name": "folders",
      "path": "/folders",
      "records": { "path": "data" },
      "schema": "schemas/folders.json",
      "projection": "passthrough"
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "data" },
      "schema": "schemas/contacts.json",
      "projection": "passthrough"
    }
  ]
}
