{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "webhooks",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "uid": { "type": ["string", "null"] },
    "name": { "type": ["string", "null"] },
    "last_item_at": { "type": ["string", "null"], "format": "date-time" },
    "last_item_state": { "type": ["string", "null"] },
    "last_item_error": { "type": ["string", "null"] }
  }
}
