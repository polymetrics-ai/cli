{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page[number]",
      "size_param": "page[size]",
      "start_page": 1,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/api/v2/items" },
    "error_map": [
      { "status": 401, "hint": "opinion-stage api_key is missing or invalid; re-run pm credentials add opinion-stage" },
      { "status": 403, "hint": "opinion-stage account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "opinion-stage rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "items",
      "path": "/api/v2/items",
      "records": { "path": "data" },
      "computed_fields": {
        "title": "{{ record.attributes.title }}",
        "status": "{{ record.attributes.status }}",
        "embed": "{{ record.attributes.embed }}",
        "created": "{{ record.attributes.timestamps.created }}",
        "modified": "{{ record.attributes.timestamps.modified }}"
      },
      "schema": "schemas/items.json"
    },
    {
      "name": "responses",
      "path": "/api/v2/items/{{ fanout.id }}/responses",
      "records": { "path": "data" },
      "computed_fields": {
        "answers": "{{ record.attributes.answers }}",
        "result": "{{ record.attributes.result }}",
        "result_title": "{{ record.attributes.result.title }}",
        "result_text": "{{ record.attributes.result.text }}",
        "created": "{{ record.attributes.timestamps.created }}",
        "duration": "{{ record.attributes.timings.duration }}",
        "utm": "{{ record.attributes.utm }}"
      },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/api/v2/items", "records_path": "data", "id_field": "id" }
        },
        "into": { "path_var": "item_id" },
        "stamp_field": "item_id"
      },
      "schema": "schemas/responses.json",
      "conformance": {
        "skip_dynamic": true,
        "reason": "fan_out-driven stream: the id-listing preliminary request has no single fixed request path for dynamic conformance replay; static validation checks the fan_out path interpolation and fixture replay covers the request sequence."
      }
    },
    {
      "name": "questions",
      "path": "/api/v2/items/{{ fanout.id }}/questions",
      "records": { "path": "data" },
      "computed_fields": {
        "title": "{{ record.attributes.title }}",
        "kind": "{{ record.attributes.kind }}",
        "lead": "{{ record.attributes.lead }}",
        "created": "{{ record.attributes.timestamps.created }}",
        "modified": "{{ record.attributes.timestamps.modified }}"
      },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/api/v2/items", "records_path": "data", "id_field": "id" }
        },
        "into": { "path_var": "item_id" },
        "stamp_field": "item_id"
      },
      "schema": "schemas/questions.json",
      "conformance": {
        "skip_dynamic": true,
        "reason": "fan_out-driven stream: the id-listing preliminary request has no single fixed request path for dynamic conformance replay; static validation checks the fan_out path interpolation and fixture replay covers the request sequence."
      }
    }
  ]
}
