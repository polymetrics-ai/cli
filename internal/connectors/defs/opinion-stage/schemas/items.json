{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "items",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "embed": { "type": ["object", "null"] },
    "created": { "type": ["string", "null"], "description": "Mapped from attributes.timestamps.created via computed_fields." },
    "modified": { "type": ["string", "null"], "description": "Mapped from attributes.timestamps.modified via computed_fields." },
    "links": { "type": ["object", "null"] },
    "relationships": { "type": ["object", "null"] }
  }
}
