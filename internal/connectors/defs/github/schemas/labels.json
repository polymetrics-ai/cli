{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "labels",
  "type": "object",
  "x-primary-key": [
    "name"
  ],
  "required": [
    "name"
  ],
  "properties": {
    "repository": {
      "type": "string",
      "description": "Legacy's config-derived per-record marker field (\"owner/repo\"), restored via computed_fields' now-available config.* reference (ENGINE_GAP G0, RESOLVED)."
    },
    "id": {
      "type": "integer"
    },
    "node_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "color": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "default": {
      "type": "boolean"
    },
    "url": {
      "type": "string"
    }
  }
}
