{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "contributors",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "required": [
    "id"
  ],
  "properties": {
    "repository": {
      "type": "string",
      "description": "Legacy's config-derived per-record marker field (\"owner/repo\"), restored via computed_fields' now-available config.* reference (ENGINE_GAP G0, RESOLVED)."
    },
    "relation": {
      "type": "string"
    },
    "login": {
      "type": "string"
    },
    "id": {
      "type": "integer"
    },
    "node_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "site_admin": {
      "type": "boolean"
    },
    "html_url": {
      "type": "string"
    },
    "contributions": {
      "type": [
        "integer",
        "null"
      ]
    },
    "role_name": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
