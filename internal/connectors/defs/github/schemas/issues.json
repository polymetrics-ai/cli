{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "issues",
  "type": "object",
  "x-primary-key": [
    "node_id"
  ],
  "x-cursor-field": "updated_at",
  "required": [
    "node_id"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "node_id": {
      "type": "string"
    },
    "number": {
      "type": "integer"
    },
    "state": {
      "type": "string"
    },
    "state_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": [
        "string",
        "null"
      ]
    },
    "html_url": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "user_login": {
      "type": [
        "string",
        "null"
      ]
    },
    "user_id": {
      "type": [
        "integer",
        "null",
        "string"
      ],
      "description": "Emitted as a decimal STRING (not a native JSON number) when sourced from a computed_fields nested-path template \u2014 engine/interpolate.go's Interpolate always stringifies its result; see docs.md Known limits."
    },
    "author_association": {
      "type": "string"
    },
    "comments": {
      "type": "integer"
    },
    "locked": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "closed_at": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
