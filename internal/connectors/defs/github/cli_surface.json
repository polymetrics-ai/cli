    {
      "name": "authentication",
      "summary": "Use pm credentials for public, token, or GitHub App repository access. Never print stored tokens."
    },
    {
      "name": "execution-model",
      "summary": "ETL commands map to streams. Reverse ETL commands map to approved write actions and keep plan, preview, approval, execute."
    },
    {
      "name": "local-workflows",
      "summary": "Commands that depend on local git, browser, shell completion, extensions, or gh config are documented but not connector-dispatched."
    },
    {
      "name": "known-gaps",
      "summary": "Projects, Discussions, Search, direct reads, and sensitive/admin surfaces are planned follow-up slices."
    }
  ]
