{
  "tagline": "Work with GitHub repositories from the command line.",
  "usage": "pm github <command> <subcommand> [flags]",
  "source_cli": {
    "name": "gh",
    "docs": "https://cli.github.com/manual/gh",
    "reference": "https://cli.github.com/manual/gh_help_reference",
    "source": "https://github.com/cli/cli"
  },
  "groups": [
    {
      "id": "core",
      "title": "Core Commands",
      "commands": ["issue", "pr", "repo", "release"]
    },
    {
      "id": "actions",
      "title": "GitHub Actions Commands",
      "commands": ["workflow", "run", "cache"]
    },
    {
      "id": "collaboration",
      "title": "Collaboration Commands",
      "commands": ["label", "ruleset", "org", "project", "discussion"]
    },
    {
      "id": "security",
      "title": "Security And Configuration Commands",
      "commands": ["secret", "variable", "gpg-key", "ssh-key", "attestation"]
    },
    {
      "id": "local",
      "title": "Local Workflow Commands",
      "commands": ["auth", "config", "browse", "alias", "extension", "completion"]
    },
    {
      "id": "additional",
      "title": "Additional Commands",
      "commands": ["api", "search", "gist", "codespace", "status", "copilot", "skill", "agent-task"]
    }
  ],
  "global_flags": [
    {
      "name": "json",
      "type": "boolean",
      "summary": "Write machine-readable JSON output."
    },
    {
      "name": "connection",
      "type": "string",
      "summary": "Use a saved GitHub connector credential and repository scope.",
      "maps_to": "connection"
    }
  ],
  "commands": [
    {
      "path": "issue list",
      "summary": "List issues",
      "intent": "etl",
      "availability": "implemented",
      "stream": "issues",
      "source_cli_path": "gh issue list",
      "flags": [
        {
          "name": "state",
          "type": "enum",
          "values": ["open", "closed", "all"],
          "summary": "Filter by issue state.",
          "maps_to": "query.state"
        }
      ],
      "examples": ["pm github issue list --state open --json"],
      "api_surface": [
        {
          "method": "GET",
          "path": "/repos/{owner}/{repo}/issues"
        }
      ]
    },
    {
      "path": "issue view",
      "summary": "View issue details",
      "intent": "etl",
      "availability": "partial",
      "stream": "issues",
      "source_cli_path": "gh issue view",
      "notes": "The connector exposes issue records as an ETL stream; single issue lookup and gh-style field selection are planned for a later direct-read slice."
    },
    {
      "path": "issue create",
      "summary": "Create an issue",
      "intent": "reverse_etl",
      "availability": "implemented",
      "write": "create_issue",
      "source_cli_path": "gh issue create",
      "risk": "Creates a visible issue in the configured repository.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "examples": ["pm github issue create --json"],
      "api_surface": [
        {
          "method": "POST",
          "path": "/repos/{owner}/{repo}/issues"
        }
      ]
    },
    {
      "path": "issue edit",
      "summary": "Edit an issue",
