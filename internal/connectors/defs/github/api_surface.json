{
  "api": "GitHub REST API (https://api.github.com)",
  "docs": "https://docs.github.com/en/rest",
  "reviewed_at": "2026-07-02",
  "scope": "wave1-pilot migration: the 19 legacy-parity read streams and 24 legacy-parity write actions (internal/connectors/github's full stream/write surface) only; the full GitHub REST surface (orgs, teams, projects v2, gists, gists comments, notifications, GraphQL, code scanning, dependabot, secrets, webhooks, apps management, etc.) is out of scope until Pass B capability expansion.",
  "endpoints": [
    { "method": "GET", "path": "/repos/{owner}/{repo}", "covered_by": { "stream": "repository" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/issues", "covered_by": { "stream": "issues" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/pulls", "covered_by": { "stream": "pull_requests" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/branches", "covered_by": { "stream": "branches" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/commits", "covered_by": { "stream": "commits" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/tags", "covered_by": { "stream": "tags" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/releases", "covered_by": { "stream": "releases" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/labels", "covered_by": { "stream": "labels" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/milestones", "covered_by": { "stream": "milestones" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/issues/comments", "covered_by": { "stream": "issue_comments" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/pulls/comments", "covered_by": { "stream": "pull_request_review_comments" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/collaborators", "covered_by": { "stream": "collaborators" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/contributors", "covered_by": { "stream": "contributors" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/stargazers", "covered_by": { "stream": "stargazers" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/subscribers", "covered_by": { "stream": "subscribers" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/actions/workflows", "covered_by": { "stream": "workflows" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/actions/runs", "covered_by": { "stream": "workflow_runs" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/actions/artifacts", "covered_by": { "stream": "workflow_artifacts" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/deployments", "covered_by": { "stream": "deployments" } },

    { "method": "POST", "path": "/repos/{owner}/{repo}/issues", "covered_by": { "write": "create_issue" } },
    { "method": "PATCH", "path": "/repos/{owner}/{repo}/issues/{issue_number}", "covered_by": { "write": "update_issue" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/issues/{issue_number}/comments", "covered_by": { "write": "comment_issue" } },
    { "method": "PATCH", "path": "/repos/{owner}/{repo}/issues/{issue_number} (close)", "covered_by": { "write": "close_issue" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/pulls", "covered_by": { "write": "create_pull_request" } },
    { "method": "PATCH", "path": "/repos/{owner}/{repo}/pulls/{pull_number}", "covered_by": { "write": "update_pull_request" } },
    { "method": "PATCH", "path": "/repos/{owner}/{repo}/pulls/{pull_number} (close)", "covered_by": { "write": "close_pull_request" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/pulls/{pull_number}/requested_reviewers", "covered_by": { "write": "request_reviewers" } },
    { "method": "PUT", "path": "/repos/{owner}/{repo}/pulls/{pull_number}/merge", "covered_by": { "write": "merge_pull_request" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/labels", "covered_by": { "write": "create_label" } },
    { "method": "PATCH", "path": "/repos/{owner}/{repo}/labels/{name}", "covered_by": { "write": "update_label" } },
    { "method": "DELETE", "path": "/repos/{owner}/{repo}/labels/{name}", "covered_by": { "write": "delete_label" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/milestones", "covered_by": { "write": "create_milestone" } },
    { "method": "PATCH", "path": "/repos/{owner}/{repo}/milestones/{milestone_number}", "covered_by": { "write": "update_milestone" } },
    { "method": "DELETE", "path": "/repos/{owner}/{repo}/milestones/{milestone_number}", "covered_by": { "write": "delete_milestone" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/releases", "covered_by": { "write": "create_release" } },
    { "method": "PATCH", "path": "/repos/{owner}/{repo}/releases/{release_id}", "covered_by": { "write": "update_release" } },
    { "method": "DELETE", "path": "/repos/{owner}/{repo}/releases/{release_id}", "covered_by": { "write": "delete_release" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/actions/workflows/{workflow_id}/dispatches", "covered_by": { "write": "dispatch_workflow" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/actions/runs/{run_id}/rerun", "covered_by": { "write": "rerun_workflow_run" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/actions/runs/{run_id}/cancel", "covered_by": { "write": "cancel_workflow_run" } },
    { "method": "DELETE", "path": "/repos/{owner}/{repo}/actions/runs/{run_id}", "covered_by": { "write": "delete_workflow_run" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/pulls/{pull_number}/reviews", "covered_by": { "write": "create_pull_request_review" } },
    { "method": "PUT", "path": "/repos/{owner}/{repo}/contents/{path}", "covered_by": { "write": "create_or_update_file" } },
    { "method": "DELETE", "path": "/repos/{owner}/{repo}/contents/{path}", "covered_by": { "write": "delete_file" } },

    { "method": "POST", "path": "/app/installations/{installation_id}/access_tokens", "excluded": { "category": "non_data_endpoint", "reason": "auth token-exchange endpoint used internally by the github_app AuthHook, not a syncable data stream or a directly caller-invoked write action" } },

    { "method": "GET", "path": "/orgs/{org}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/orgs/{org}/teams", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/projects", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/notifications", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/code-scanning/alerts", "excluded": { "category": "requires_elevated_scope", "reason": "Pass B capability expansion; requires elevated security-events scope" } },
    { "method": "GET", "path": "/repos/{owner}/{repo}/dependabot/alerts", "excluded": { "category": "requires_elevated_scope", "reason": "Pass B capability expansion; requires elevated security-events scope" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/actions/secrets/{secret_name}", "excluded": { "category": "destructive_admin", "reason": "Pass B capability expansion; repository secret administration is out of scope for a reverse-ETL connector" } },
    { "method": "POST", "path": "/repos/{owner}/{repo}/hooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/graphql", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion; GraphQL query/POST-body reads are a distinct escape-hatch pattern (see docs/migration/conventions.md monday note), not exercised by legacy github" } },
    { "method": "DELETE", "path": "/repos/{owner}/{repo}", "excluded": { "category": "destructive_admin", "reason": "repository deletion is not a legacy github write action and is out of scope" } }
  ]
}
