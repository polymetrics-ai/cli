{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "app_id", "value": "{{ secrets.app_id }}" }
    ],
    "check": { "method": "GET", "path": "/usage.json" },
    "error_map": [
      { "status": 401, "hint": "open-exchange-rates app_id is missing or invalid; re-run pm credentials add open-exchange-rates" },
      { "status": 403, "hint": "open-exchange-rates plan lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "open-exchange-rates rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "usage",
      "path": "/usage.json",
      "records": { "path": "data", "single_object": true },
      "computed_fields": {
        "app_id": "{{ record.app_id }}",
        "status": "{{ record.status }}",
        "plan": "{{ record.plan.name }}",
        "requests": "{{ record.usage.requests }}",
        "requests_quota": "{{ record.usage.requests_quota }}",
        "requests_remaining": "{{ record.usage.requests_remaining }}",
        "days_elapsed": "{{ record.usage.days_elapsed }}",
        "days_remaining": "{{ record.usage.days_remaining }}",
        "daily_average": "{{ record.usage.daily_average }}"
      },
      "schema": "schemas/usage.json"
    }
  ]
}
