{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 0,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/users/list", "query": { "page": "0", "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "customerly api_key is missing or invalid; re-run pm credentials add customerly" },
      { "status": 403, "hint": "customerly account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "customerly rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/users/list",
      "query": {
        "sort": "last_update",
        "sort_direction": "desc"
      },
      "records": { "path": "data.users" },
      "schema": "schemas/users.json"
    },
    {
      "name": "leads",
      "path": "/leads/list",
      "query": {
        "sort": "last_update",
        "sort_direction": "desc"
      },
      "records": { "path": "data.leads" },
      "schema": "schemas/leads.json"
    },
    {
      "name": "accounts",
      "path": "/accounts/",
      "pagination": { "type": "none" },
      "records": { "path": "data" },
      "schema": "schemas/accounts.json"
    }
  ]
}
