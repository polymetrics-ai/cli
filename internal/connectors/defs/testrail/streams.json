{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.username }}", "password": "{{ secrets.password }}" }
    ],
    "check": { "method": "GET", "path": "index.php?/api/v2/get_projects" },
    "error_map": [
      { "status": 401, "hint": "testrail username/password is missing or invalid; re-run pm credentials add testrail" },
      { "status": 429, "class": "rate_limited", "hint": "testrail rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "index.php?/api/v2/get_projects",
      "records": { "path": "." },
      "schema": "schemas/projects.json"
    }
  ]
}
