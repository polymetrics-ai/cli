{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "suites",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Stamped by the fan_out dialect from the enclosing project id discovered via the projects listing; always a string regardless of TestRail's own numeric project_id wire type."
    },
    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "is_master": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "is_completed": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
