{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "GoCardless-Version": "{{ config.gocardless_version }}"
    },
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "after",
      "token_path": "meta.cursors.after"
    },
    "check": { "method": "GET", "path": "/payments" },
    "error_map": [
      { "status": 401, "hint": "gocardless access token is missing or invalid; re-run pm credentials add gocardless" },
      { "status": 403, "hint": "gocardless account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "gocardless rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "payments",
      "path": "/payments",
      "query": { "limit": "50" },
      "records": { "path": "payments" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gt]",
        "start_config_key": "start_date"
      },
      "computed_fields": {
        "mandate": "{{ record.links.mandate }}",
        "payout": "{{ record.links.payout }}"
      },
      "schema": "schemas/payments.json"
    },
    {
      "name": "mandates",
      "path": "/mandates",
      "query": { "limit": "50" },
      "records": { "path": "mandates" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gt]",
        "start_config_key": "start_date"
      },
      "computed_fields": {
        "customer_bank_account": "{{ record.links.customer_bank_account }}",
        "creditor": "{{ record.links.creditor }}"
      },
      "schema": "schemas/mandates.json"
    },
    {
      "name": "payouts",
      "path": "/payouts",
      "query": { "limit": "50" },
      "records": { "path": "payouts" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gt]",
        "start_config_key": "start_date"
      },
      "computed_fields": {
        "creditor": "{{ record.links.creditor }}",
        "creditor_bank_account": "{{ record.links.creditor_bank_account }}"
      },
      "schema": "schemas/payouts.json"
    },
    {
      "name": "refunds",
      "path": "/refunds",
      "query": { "limit": "50" },
      "records": { "path": "refunds" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gt]",
        "start_config_key": "start_date"
      },
      "computed_fields": {
        "payment": "{{ record.links.payment }}",
        "mandate": "{{ record.links.mandate }}"
      },
      "schema": "schemas/refunds.json"
    }
  ]
}
