{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "api-key", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/account" },
    "error_map": [
      { "status": 401, "hint": "brevo api_key is missing or invalid; re-run pm credentials add brevo" },
      { "status": 403, "hint": "brevo account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "brevo rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "contacts" },
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 100
      },
      "incremental": {
        "cursor_field": "modifiedAt",
        "request_param": "modifiedSince",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "email_campaigns",
      "path": "/emailCampaigns",
      "records": { "path": "campaigns" },
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 100
      },
      "incremental": {
        "cursor_field": "modifiedAt",
        "request_param": "modifiedSince",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/email_campaigns.json"
    },
    {
      "name": "contacts_lists",
      "path": "/contacts/lists",
      "records": { "path": "lists" },
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 100
      },
      "schema": "schemas/contacts_lists.json"
    },
    {
      "name": "senders",
      "path": "/senders",
      "records": { "path": "senders" },
      "schema": "schemas/senders.json"
    }
  ]
}
