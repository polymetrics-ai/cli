{
  "actions": [
    {
      "name": "remove_customer",
      "kind": "delete",
      "method": "GET",
      "path": "/app/dao/v6/customers?a=delete&customerId={{ record.id }}&apiKey={{ secrets.api_key }}&accessKey={{ secrets.access_key }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "risk": "irreversible external deletion of a CRM customer record; approval required",
      "confirm": "destructive"
    }
  ]
}
