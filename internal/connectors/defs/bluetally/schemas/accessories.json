{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accessories",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "model_number": { "type": ["string", "null"] },
    "category_id": { "type": ["integer", "null"] },
    "manufacturer_id": { "type": ["integer", "null"] },
    "supplier_id": { "type": ["integer", "null"] },
    "location_id": { "type": ["integer", "null"] },
    "department_id": { "type": ["integer", "null"] },
    "quantity": { "type": ["integer", "null"] },
    "available": { "type": ["integer", "null"] },
    "purchase_date": { "type": ["string", "null"] },
    "purchase_cost": { "type": ["number", "null"] },
    "currency": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"] },
