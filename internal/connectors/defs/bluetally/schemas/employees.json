{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "employees",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "location_id": { "type": ["integer", "null"] },
    "department_id": { "type": ["integer", "null"] },
    "manager_id": { "type": ["integer", "null"] },
    "archived": { "type": ["boolean", "null"] },
    "number_of_assets": { "type": ["integer", "null"] },
    "number_of_accessories": { "type": ["integer", "null"] },
    "number_of_consumables": { "type": ["integer", "null"] },
    "number_of_licenses": { "type": ["integer", "null"] },
    "notes": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
