{
  "tagline": "Work with Bitbucket Cloud repositories from the command line.",
  "usage": "pm bitbucket <command> <subcommand> [flags]",
  "source_cli": {
    "name": "bb/Bitbucket Cloud REST",
    "docs": "https://developer.atlassian.com/cloud/bitbucket/rest/",
    "reference": "https://developer.atlassian.com/cloud/bitbucket/rest/",
    "source": "https://api.bitbucket.org/swagger.json"
  },
  "groups": [
    {
      "id": "repositories",
      "title": "Repository Commands",
      "commands": [
        "repo",
        "branch",
        "commit",
        "tag",
        "download"
      ]
    },
    {
      "id": "pull_requests",
      "title": "Pull Request Commands",
      "commands": [
        "pull-request"
      ]
    },
    {
      "id": "issues",
      "title": "Issue Tracker Commands",
      "commands": [
        "issue"
      ]
    },
    {
      "id": "pipelines",
      "title": "Pipelines And Deployments Commands",
      "commands": [
        "pipeline",
        "deployment"
      ]
    },
    {
      "id": "admin",
      "title": "Workspace And Administration Commands",
      "commands": [
        "workspace",
        "project",
        "webhook",
        "branch-restriction",
        "snippet"
      ]
    },
    {
      "id": "local",
      "title": "Local Workflow Commands",
      "commands": [
        "auth",
        "config",
        "api"
      ]
    }
  ],
  "global_flags": [
    {
      "name": "json",
      "type": "boolean",
      "summary": "Write machine-readable JSON output."
    },
    {
      "name": "credential",
      "type": "string",
      "summary": "Use a saved Bitbucket connector credential.",
      "maps_to": "connection"
    },
    {
      "name": "connection",
      "type": "string",
      "summary": "Alias for --credential.",
      "maps_to": "connection"
    },
    {
      "name": "workspace",
      "type": "string",
      "summary": "Bitbucket workspace slug.",
      "maps_to": "config.workspace"
    },
    {
      "name": "repo",
      "type": "string",
      "summary": "Bitbucket repository slug.",
      "maps_to": "config.repo_slug"
    },
    {
      "name": "limit",
      "type": "integer",
      "summary": "Maximum records to emit for stream commands."
    },
    {
      "name": "max-bytes",
      "type": "integer",
      "summary": "Maximum bytes for direct-read JSON responses."
    }
  ],
  "commands": [
    {
      "path": "repo list",
      "summary": "List repositories in a workspace",
      "intent": "etl",
      "availability": "implemented",
      "stream": "repositories",
      "source_url": "https://developer.atlassian.com/cloud/bitbucket/rest/api-group-repositories/",
      "examples": [
        "pm bitbucket repo list --workspace acme --json"
      ],
      "api_surface": [
        {
          "method": "GET",
          "path": "/repositories/{workspace}"
        }
      ]
    },
    {
      "path": "repo view",
      "summary": "View repository details",
      "intent": "direct_read",
      "availability": "implemented",
      "source_url": "https://developer.atlassian.com/cloud/bitbucket/rest/api-group-repositories/",
      "output_policy": "bitbucket_json_object",
      "flags": [
        {
          "name": "repo",
          "type": "string",
          "summary": "Repository slug to inspect.",
          "maps_to": "path.repo_slug"
        }
      ],
      "api_surface": [
        {
          "method": "GET",
          "path": "/repositories/{workspace}/{repo_slug}"
        }
      ]
    },
    {
      "path": "repo create",
      "summary": "Create a repository",
      "intent": "reverse_etl",
      "availability": "implemented",
      "write": "create_repository",
      "source_url": "https://developer.atlassian.com/cloud/bitbucket/rest/api-group-repositories/",
      "risk": "Creates a repository in the configured workspace.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute. Typed confirmation may be required by policy.",
      "flags": [
        {
          "name": "name",
          "type": "string",
          "summary": "Repository display name.",
          "maps_to": "record.name"
        },
        {
          "name": "description",
          "type": "string",
          "summary": "Repository description.",
          "maps_to": "record.description"
        },
        {
          "name": "is-private",
          "type": "boolean",
          "summary": "Whether the repository is private.",
          "maps_to": "record.is_private"
        }
      ],
      "api_surface": [
        {
          "method": "POST",
          "path": "/repositories/{workspace}/{repo_slug}"
        }
      ]
    },
    {
      "path": "repo delete",
      "summary": "Delete a repository",
      "intent": "direct_write",
      "availability": "unsafe_or_disallowed",
      "source_url": "https://developer.atlassian.com/cloud/bitbucket/rest/api-group-repositories/",
      "operation": "bitbucket.delete.repositories_workspace_repo_slug",
      "notes": "Repository deletion is destructive admin behavior and is not exposed as a connector write."
    },
    {
      "path": "repo clone",
      "summary": "Clone a repository locally",
      "intent": "local_workflow",
      "availability": "unsupported_local",
      "notes": "Depends on local git and filesystem state; no local git executor is enabled."
    },
