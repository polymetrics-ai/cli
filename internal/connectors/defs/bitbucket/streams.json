{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Accept": "application/json"
    },
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}",
        "when": "{{ secrets.access_token }}"
      },
      {
        "mode": "none"
      }
    ]
  },
  "streams": []
}
