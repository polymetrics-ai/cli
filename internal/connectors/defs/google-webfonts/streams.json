{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_query",
        "param": "key",
        "value": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "pageToken",
      "token_path": "nextPageToken",
      "max_pages": 100
    },
    "check": {
      "method": "GET",
      "path": "/webfonts"
    },
    "error_map": [
      {
        "status": 403,
        "hint": "google-webfonts api_key is missing, invalid, or lacks Fonts Developer API access"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "google-webfonts rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "webfonts",
      "path": "/webfonts",
      "query": {
        "family": {
          "template": "{{ config.family }}",
          "omit_when_absent": true
        },
        "subset": {
          "template": "{{ config.subset }}",
          "omit_when_absent": true
        },
        "category": {
          "template": "{{ config.category }}",
          "omit_when_absent": true
        },
        "capability": {
          "template": "{{ config.capability }}",
          "omit_when_absent": true
        },
        "alt": {
          "template": "{{ config.alt }}",
          "omit_when_absent": true
        },
        "prettyPrint": {
          "template": "{{ config.pretty_print }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "variant_count": "{{ record.variants | length }}",
        "subset_count": "{{ record.subsets | length }}"
      },
      "schema": "schemas/webfonts.json"
    },
    {
      "name": "popular_fonts",
      "path": "/webfonts",
      "query": {
        "sort": "popularity",
        "family": {
          "template": "{{ config.family }}",
          "omit_when_absent": true
        },
        "subset": {
          "template": "{{ config.subset }}",
          "omit_when_absent": true
        },
        "category": {
          "template": "{{ config.category }}",
          "omit_when_absent": true
        },
        "capability": {
          "template": "{{ config.capability }}",
          "omit_when_absent": true
        },
        "alt": {
          "template": "{{ config.alt }}",
          "omit_when_absent": true
        },
        "prettyPrint": {
          "template": "{{ config.pretty_print }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "variant_count": "{{ record.variants | length }}",
        "subset_count": "{{ record.subsets | length }}"
      },
      "schema": "schemas/popular_fonts.json"
    },
    {
      "name": "trending_fonts",
      "path": "/webfonts",
      "query": {
        "sort": "trending",
        "family": {
          "template": "{{ config.family }}",
          "omit_when_absent": true
        },
        "subset": {
          "template": "{{ config.subset }}",
          "omit_when_absent": true
        },
        "category": {
          "template": "{{ config.category }}",
          "omit_when_absent": true
        },
        "capability": {
          "template": "{{ config.capability }}",
          "omit_when_absent": true
        },
        "alt": {
          "template": "{{ config.alt }}",
          "omit_when_absent": true
        },
        "prettyPrint": {
          "template": "{{ config.pretty_print }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "variant_count": "{{ record.variants | length }}",
        "subset_count": "{{ record.subsets | length }}"
      },
      "schema": "schemas/trending_fonts.json"
    },
    {
      "name": "newest_fonts",
      "path": "/webfonts",
      "query": {
        "sort": "date",
        "family": {
          "template": "{{ config.family }}",
          "omit_when_absent": true
        },
        "subset": {
          "template": "{{ config.subset }}",
          "omit_when_absent": true
        },
        "category": {
          "template": "{{ config.category }}",
          "omit_when_absent": true
        },
        "capability": {
          "template": "{{ config.capability }}",
          "omit_when_absent": true
        },
        "alt": {
          "template": "{{ config.alt }}",
          "omit_when_absent": true
        },
        "prettyPrint": {
          "template": "{{ config.pretty_print }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "variant_count": "{{ record.variants | length }}",
        "subset_count": "{{ record.subsets | length }}"
      },
      "schema": "schemas/newest_fonts.json"
    },
    {
      "name": "alpha_fonts",
      "path": "/webfonts",
      "query": {
        "sort": "alpha",
        "family": {
          "template": "{{ config.family }}",
          "omit_when_absent": true
        },
        "subset": {
          "template": "{{ config.subset }}",
          "omit_when_absent": true
        },
        "category": {
          "template": "{{ config.category }}",
          "omit_when_absent": true
        },
        "capability": {
          "template": "{{ config.capability }}",
          "omit_when_absent": true
        },
        "alt": {
          "template": "{{ config.alt }}",
          "omit_when_absent": true
        },
        "prettyPrint": {
          "template": "{{ config.pretty_print }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "variant_count": "{{ record.variants | length }}",
        "subset_count": "{{ record.subsets | length }}"
      },
      "schema": "schemas/alpha_fonts.json"
    }
  ]
}
