    { "method": "GET", "path": "teams", "covered_by": { "stream": "teams" } },
    { "method": "GET", "path": "email-settings", "covered_by": { "stream": "email_settings" } },
    { "method": "GET", "path": "do-not-contact", "covered_by": { "stream": "do_not_contact" } }
  ]
}
