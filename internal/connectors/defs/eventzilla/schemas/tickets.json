{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tickets",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "event_id": { "type": ["integer", "null"] },
    "title": { "type": ["string", "null"] },
    "ticket_type": { "type": ["string", "null"] },
    "price": { "type": ["number", "null"] },
    "quantity_total": { "type": ["integer", "null"] },
    "is_visible": { "type": ["boolean", "null"] },
    "sales_start_date": { "type": ["string", "null"] },
    "sales_end_date": { "type": ["string", "null"] }
  }
}
