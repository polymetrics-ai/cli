{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-AppFollow-API-Token", "value": "{{ secrets.api_secret }}" }
    ],
    "check": { "method": "GET", "path": "/account/users" },
    "error_map": [
      { "status": 401, "hint": "appfollow api_secret is missing or invalid; re-run pm credentials add appfollow" },
      { "status": 403, "hint": "appfollow api_secret lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "appfollow rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/account/users",
      "records": { "path": "" },
      "schema": "schemas/users.json"
    },
    {
      "name": "app_collections",
      "path": "/account/apps",
      "records": { "path": "apps" },
      "schema": "schemas/app_collections.json"
    },
    {
      "name": "app_lists",
      "path": "/account/apps/app",
      "records": { "path": "apps_app" },
      "fan_out": {
        "ids_from": { "config_key": "app_collection_ids" },
        "into": { "query_param": "apps_id" },
        "stamp_field": "app_collection_id"
      },
      "schema": "schemas/app_lists.json"
    },
    {
      "name": "ratings",
      "path": "/meta/ratings",
      "records": { "path": "ratings.list" },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/ratings.json"
    }
  ]
}
