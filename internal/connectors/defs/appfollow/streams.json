{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-AppFollow-API-Token", "value": "{{ secrets.api_secret }}" }
    ],
    "check": { "method": "GET", "path": "/account/users" },
    "error_map": [
      { "status": 401, "hint": "appfollow api_secret is missing or invalid; re-run pm credentials add appfollow" },
      { "status": 403, "hint": "appfollow api_secret lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "appfollow rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/account/users",
      "records": { "path": "" },
      "schema": "schemas/users.json"
    },
    {
      "name": "app_collections",
      "path": "/account/apps",
      "records": { "path": "apps" },
      "schema": "schemas/app_collections.json"
    },
    {
      "name": "app_lists",
      "path": "/account/apps/app",
      "records": { "path": "apps_app" },
      "fan_out": {
        "ids_from": { "config_key": "app_collection_ids" },
        "into": { "query_param": "apps_id" },
        "stamp_field": "app_collection_id"
      },
      "schema": "schemas/app_lists.json"
    },
    {
      "name": "ratings",
      "path": "/meta/ratings",
      "records": { "path": "ratings.list" },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/ratings.json"
    },
    {
      "name": "reviews",
      "path": "/reviews",
      "records": { "path": "" },
      "query": {
        "from": "{{ config.report_from }}",
        "to": "{{ config.report_to }}"
      },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/reviews.json"
    },
    {
      "name": "reviews_summary",
      "path": "/reviews/summary",
      "records": { "path": "" },
      "query": {
        "from": { "template": "{{ config.report_from }}", "omit_when_absent": true },
        "to": { "template": "{{ config.report_to }}", "omit_when_absent": true }
      },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/reviews_summary.json"
    },
    {
      "name": "keywords",
      "path": "/aso/keywords",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/keywords.json"
    },
    {
      "name": "rankings",
      "path": "/meta/rankings",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/rankings.json"
    },
    {
      "name": "versions",
      "path": "/meta/versions",
      "records": { "path": "" },
      "query": {
        "country": "{{ config.report_country }}"
      },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/versions.json"
    },
    {
      "name": "versions_whatsnew",
      "path": "/meta/versions/whatsnew",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/versions_whatsnew.json"
    },
    {
      "name": "ratings_history",
      "path": "/meta/ratings/history",
      "records": { "path": "" },
      "query": {
        "store": "{{ config.report_store }}"
      },
      "fan_out": {
        "ids_from": { "config_key": "ext_ids" },
        "into": { "query_param": "ext_id" },
        "stamp_field": "ext_id"
      },
      "schema": "schemas/ratings_history.json"
    }
  ]
}
