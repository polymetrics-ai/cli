{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "X-Auth-Hash": "{{ secrets.auth_hash }}",
      "X-Restaurant-ID": "{{ secrets.restid }}"
    },
    "auth": [
      { "mode": "none" }
    ],
    "check": { "method": "GET", "path": "/reservations" },
    "error_map": [
      { "status": 401, "class": "auth_failed", "hint": "invalid auth_hash or restid" },
      { "status": 429, "class": "rate_limited", "hint": "waiteraid rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "reservations",
      "path": "/reservations",
      "query": {
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "reservations" },
      "schema": "schemas/reservations.json"
    }
  ]
}
