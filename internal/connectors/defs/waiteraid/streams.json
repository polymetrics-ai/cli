{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "auth_hash", "value": "{{ secrets.auth_hash }}" }
    ],
    "check": {
      "method": "POST",
      "path": "/wa-api/searchBooking",
      "query": {
        "restid": "{{ config.restid }}"
      }
    },
    "error_map": [
      { "status": 401, "class": "auth_failed", "hint": "invalid auth_hash or restid" },
      { "status": 429, "class": "rate_limited", "hint": "waiteraid rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "reservations",
      "method": "POST",
      "path": "/wa-api/searchBooking",
      "query": {
        "restid": "{{ config.restid }}",
        "date": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "bookings" },
      "computed_fields": {
        "guest_name": "{{ coalesce record.guest_name record.guest.name }}"
      },
      "schema": "schemas/reservations.json"
    },
    {
      "name": "meals",
      "method": "POST",
      "path": "/wa-api/getMeals",
      "query": {
        "restid": "{{ config.restid }}"
      },
      "records": { "path": "meals" },
      "schema": "schemas/meals.json"
    },
    {
      "name": "queue",
      "method": "POST",
      "path": "/wa-api/queue/list",
      "query": {
        "restid": "{{ config.restid }}",
        "date": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "queue" },
      "schema": "schemas/queue.json"
    }
  ]
}
