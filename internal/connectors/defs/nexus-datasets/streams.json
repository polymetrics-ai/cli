{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "custom", "hook": "nexus-datasets" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/datasets/{{ config.dataset_name }}", "query": { "limit": "1", "offset": "0" } },
    "error_map": [
      { "status": 401, "hint": "nexus-datasets HMAC signature rejected or credentials invalid; verify access_key_id/user_id/secret_key/api_key" },
      { "status": 403, "hint": "nexus-datasets account lacks access to the configured dataset_name" },
      { "status": 429, "class": "rate_limited", "hint": "Infor Nexus Data API rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "datasets",
      "path": "/datasets/{{ config.dataset_name }}",
      "records": { "path": "records" },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "modifiedSince",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "computed_fields": {
        "id": "{{ coalesce record.id record.record_id record.key record.uid }}",
        "updated_at": "{{ coalesce record.updated_at record.modified_at record.last_modified record.timestamp }}",
        "dataset_name": "{{ config.dataset_name }}"
      },
      "schema": "schemas/datasets.json"
    }
  ]
}
