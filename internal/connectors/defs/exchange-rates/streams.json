{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "access_key", "value": "{{ secrets.access_key }}" }
    ],
    "check": { "method": "GET", "path": "/symbols" },
    "error_map": [
      { "status": 401, "hint": "exchange-rates access_key is missing or invalid; re-run pm credentials add exchange-rates" },
      { "status": 403, "hint": "exchange-rates account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "exchange-rates rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "latest",
      "path": "/latest",
      "query": {
        "base": { "template": "{{ config.base }}", "omit_when_absent": true }
      },
      "records": { "path": ".", "single_object": true },
      "schema": "schemas/latest.json"
    },
    {
      "name": "convert",
      "path": "/convert",
      "query": {
        "from": "{{ config.convert_from }}",
        "to": "{{ config.convert_to }}",
        "amount": "{{ config.convert_amount }}",
        "date": { "template": "{{ config.convert_date }}", "omit_when_absent": true }
      },
      "records": { "path": ".", "single_object": true },
      "schema": "schemas/convert.json"
    },
    {
      "name": "timeseries",
      "path": "/timeseries",
      "query": {
        "start_date": "{{ config.timeseries_start_date }}",
        "end_date": "{{ config.timeseries_end_date }}",
        "base": { "template": "{{ config.base }}", "omit_when_absent": true }
      },
      "records": { "path": ".", "single_object": true },
      "schema": "schemas/timeseries.json"
    },
    {
      "name": "fluctuation",
      "path": "/fluctuation",
      "query": {
        "start_date": "{{ config.fluctuation_start_date }}",
        "end_date": "{{ config.fluctuation_end_date }}",
        "base": { "template": "{{ config.base }}", "omit_when_absent": true }
      },
      "records": { "path": ".", "single_object": true },
      "schema": "schemas/fluctuation.json"
    }
  ]
}
