{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_token }}" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "metadata.next"
    },
    "check": { "method": "GET", "path": "/accounts", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "tempo api_token is missing or invalid; re-run pm credentials add tempo" },
      { "status": 403, "hint": "tempo account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "tempo rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "accounts",
      "path": "/accounts",
      "query": { "limit": "50", "offset": "0" },
      "records": { "path": "results" },
      "computed_fields": {
        "monthly_budget": "{{ record.monthlyBudget }}"
      },
      "schema": "schemas/accounts.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "query": { "limit": "50", "offset": "0" },
      "records": { "path": "results" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "worklogs",
      "path": "/worklogs",
      "query": { "limit": "50", "offset": "0" },
      "records": { "path": "results" },
      "computed_fields": {
        "tempo_worklog_id": "{{ record.tempoWorklogId }}",
        "jira_worklog_id": "{{ record.jiraWorklogId }}",
        "issue_id": "{{ record.issue.id }}",
        "time_spent_seconds": "{{ record.timeSpentSeconds }}",
        "billable_seconds": "{{ record.billableSeconds }}",
        "start_date": "{{ record.startDate }}",
        "start_time": "{{ record.startTime }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/worklogs.json"
    },
    {
      "name": "workload_schemes",
      "path": "/workload-schemes",
      "query": { "limit": "50", "offset": "0" },
      "records": { "path": "results" },
      "computed_fields": {
        "default_scheme": "{{ record.defaultScheme }}"
      },
      "schema": "schemas/workload_schemes.json"
    }
  ]
}
