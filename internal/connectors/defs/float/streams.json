{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per-page",
      "start_page": 1,
      "page_size": 200
    },
    "check": { "method": "GET", "path": "/departments", "query": { "per-page": "1" } },
    "error_map": [
      { "status": 401, "hint": "float access_token is missing or invalid; re-run pm credentials add float" },
      { "status": 429, "class": "rate_limited", "hint": "float rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "people",
      "path": "/people",
      "records": { "path": "." },
      "schema": "schemas/people.json"
    },
    {
      "name": "projects",
      "path": "/projects",
      "records": { "path": "." },
      "schema": "schemas/projects.json"
    },
    {
      "name": "clients",
      "path": "/clients",
      "records": { "path": "." },
      "schema": "schemas/clients.json"
    },
    {
      "name": "tasks",
      "path": "/tasks",
      "records": { "path": "." },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "departments",
      "path": "/departments",
      "records": { "path": "." },
      "schema": "schemas/departments.json"
    }
  ]
}
