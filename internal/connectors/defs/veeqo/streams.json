{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "x-api-key", "value": "{{ secrets.api_key }}", "prefix": "" }
    ],
    "check": { "method": "GET", "path": "/orders" },
    "error_map": [
      { "status": 401, "class": "auth_failed", "hint": "veeqo api_key is missing or invalid; re-run pm credentials add veeqo" },
      { "status": 403, "hint": "veeqo account lacks access for this request" },
      { "status": 422, "class": "invalid_request", "hint": "veeqo rejected the request body; check required fields" },
      { "status": 429, "class": "rate_limited", "hint": "veeqo rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "orders",
      "path": "/orders",
      "query": {
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}",
        "number": "{{ record.number }}",
        "status": "{{ record.status }}",
        "created_at": "{{ record.created_at }}"
      },
      "schema": "schemas/orders.json"
    },
    {
      "name": "products",
      "path": "/products",
      "pagination": { "type": "page_number", "page_param": "page", "size_param": "page_size", "start_page": 1, "page_size": 100 },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "pagination": { "type": "page_number", "page_param": "page", "size_param": "page_size", "start_page": 1, "page_size": 100 },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "warehouses",
      "path": "/warehouses",
      "pagination": { "type": "page_number", "page_param": "page", "size_param": "page_size", "start_page": 1, "page_size": 100 },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/warehouses.json"
    },
    {
      "name": "suppliers",
      "path": "/suppliers",
      "pagination": { "type": "page_number", "page_param": "page", "size_param": "page_size", "start_page": 1, "page_size": 100 },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/suppliers.json"
    },
    {
      "name": "purchase_orders",
      "path": "/purchase_orders",
      "pagination": { "type": "page_number", "page_param": "page", "size_param": "page_size", "start_page": 1, "page_size": 100 },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/purchase_orders.json"
    },
    {
      "name": "channels",
      "path": "/channels",
      "pagination": { "type": "page_number", "page_param": "page", "size_param": "page_size", "start_page": 1, "page_size": 100 },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/channels.json"
    },
    {
      "name": "delivery_methods",
      "path": "/delivery_methods",
      "pagination": { "type": "page_number", "page_param": "page", "size_param": "page_size", "start_page": 1, "page_size": 100 },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/delivery_methods.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/tags.json"
    }
  ]
}
