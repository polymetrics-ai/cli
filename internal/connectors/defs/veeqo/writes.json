      "name": "create_supplier",
      "kind": "create",
      "method": "POST",
      "path": "/suppliers",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "address_line_1": { "type": "string" },
          "city": { "type": "string" },
          "country": { "type": "string" },
          "post_code": { "type": "string" },
          "currency_code": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "update_supplier",
      "kind": "update",
      "method": "PUT",
      "path": "/suppliers/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "delete_supplier",
      "kind": "delete",
      "method": "DELETE",
      "path": "/suppliers/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
