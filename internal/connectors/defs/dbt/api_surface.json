{
  "api": "dbt Cloud Administrative API v2 (https://cloud.getdbt.com/api/v2)",
  "docs": "https://docs.getdbt.com/dbt-cloud/api-v2",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; the dbt Cloud write/operational surface (triggering runs, job/environment CRUD, service tokens) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/accounts/{account_id}/projects/", "covered_by": { "stream": "projects" } },
    { "method": "GET", "path": "/accounts/{account_id}/runs/", "covered_by": { "stream": "runs" } },
    { "method": "GET", "path": "/accounts/{account_id}/repositories/", "covered_by": { "stream": "repositories" } },
    { "method": "GET", "path": "/accounts/{account_id}/users/", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/accounts/{account_id}/environments/", "covered_by": { "stream": "environments" } },
    { "method": "POST", "path": "/accounts/{account_id}/jobs/{job_id}/run/", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/accounts/{account_id}/jobs/", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/accounts/{account_id}/projects/", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/accounts/{account_id}/service-tokens/", "excluded": { "category": "requires_elevated_scope", "reason": "credential-management endpoint, not a syncable data stream" } }
  ]
}
