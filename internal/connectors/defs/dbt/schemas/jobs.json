{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "jobs",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "account_id": { "type": "integer" },
    "project_id": { "type": ["integer", "null"] },
    "environment_id": { "type": ["integer", "null"] },
    "name": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "dbt_version": { "type": ["string", "null"] },
    "job_type": { "type": ["string", "null"] },
    "execute_steps": { "type": ["array", "null"], "items": { "type": "string" } },
    "generate_docs": { "type": ["boolean", "null"] },
    "run_generate_sources": { "type": ["boolean", "null"] },
    "triggers_on_draft_pr": { "type": ["boolean", "null"] },
    "state": { "type": ["integer", "null"] },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
  }
}
