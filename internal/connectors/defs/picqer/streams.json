    },
    {
      "name": "shipments",
      "path": "/shipments",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idshipment }}" },
      "schema": "schemas/shipments.json"
    },
    {
      "name": "packagings",
      "path": "/packagings",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idpackaging }}" },
      "schema": "schemas/packagings.json"
    },
    {
      "name": "packingstations",
      "path": "/packingstations",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idpacking_station }}" },
      "schema": "schemas/packingstations.json"
    },
    {
      "name": "webshoporders",
      "path": "/webshoporders",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idcompany_webshop_order }}" },
      "schema": "schemas/webshoporders.json"
    },
    {
      "name": "hooks",
      "path": "/hooks",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idhook }}" },
      "schema": "schemas/hooks.json"
    }
  ]
}
