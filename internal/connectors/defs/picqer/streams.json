{
  "base": {
    "url": "https://{{ config.organization_name }}.picqer.com/api/v1",
    "user_agent": "polymetrics-go-cli (polymetrics.ai)",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "{{ secrets.password }}", "when": "{{ secrets.api_key }}" },
      { "mode": "basic", "username": "{{ config.username }}", "password": "{{ secrets.password }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/products", "query": { "offset": "0" } },
    "error_map": [
      { "status": 401, "hint": "picqer api_key/username is missing or invalid; re-run pm credentials add picqer" },
      { "status": 429, "class": "rate_limited", "hint": "picqer rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "products",
      "path": "/products",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idproduct }}" },
      "schema": "schemas/products.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idcustomer }}" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "orders",
      "path": "/orders",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idorder }}" },
      "schema": "schemas/orders.json"
    },
    {
      "name": "picklists",
      "path": "/picklists",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idpicklist }}" },
      "schema": "schemas/picklists.json"
    },
    {
      "name": "warehouses",
      "path": "/warehouses",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idwarehouse }}" },
      "schema": "schemas/warehouses.json"
    },
    {
      "name": "suppliers",
      "path": "/suppliers",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idsupplier }}" },
      "schema": "schemas/suppliers.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idtag }}" },
      "schema": "schemas/tags.json"
    },
    {
      "name": "purchaseorders",
      "path": "/purchaseorders",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idpurchaseorder }}" },
      "schema": "schemas/purchaseorders.json"
    },
    {
      "name": "receipts",
      "path": "/receipts",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idreceipt }}" },
      "schema": "schemas/receipts.json"
    },
    {
      "name": "returns",
      "path": "/returns",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idreturn }}" },
      "schema": "schemas/returns.json"
    },
    {
      "name": "return_statuses",
      "path": "/return_statuses",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idreturn_status }}" },
      "schema": "schemas/return_statuses.json"
    },
    {
      "name": "return_reasons",
      "path": "/return_reasons",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idreturn_reason }}" },
      "schema": "schemas/return_reasons.json"
    },
    {
      "name": "backorders",
      "path": "/backorders",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idbackorder }}" },
      "schema": "schemas/backorders.json"
    },
    {
      "name": "comments",
      "path": "/comments",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idcomment }}" },
      "schema": "schemas/comments.json"
    },
    {
      "name": "stockhistory",
      "path": "/stockhistory",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idproduct_stock_history }}" },
      "schema": "schemas/stockhistory.json"
    },
    {
      "name": "users",
      "path": "/users",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.iduser }}" },
      "schema": "schemas/users.json"
    },
    {
      "name": "product_fields",
      "path": "/productfields",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idproductfield }}" },
      "schema": "schemas/product_fields.json"
    },
    {
      "name": "customer_fields",
      "path": "/customerfields",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idcustomerfield }}" },
      "schema": "schemas/customer_fields.json"
    },
    {
      "name": "order_fields",
      "path": "/orderfields",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idorderfield }}" },
      "schema": "schemas/order_fields.json"
    },
    {
      "name": "pricelists",
      "path": "/pricelists",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idpricelist }}" },
      "schema": "schemas/pricelists.json"
    },
    {
      "name": "shippingproviders",
      "path": "/shippingproviders",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idshippingprovider }}" },
      "schema": "schemas/shippingproviders.json"
    },
    {
      "name": "vatgroups",
      "path": "/vatgroups",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idvatgroup }}" },
      "schema": "schemas/vatgroups.json"
    },
    {
      "name": "locations",
      "path": "/locations",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idlocation }}" },
      "schema": "schemas/locations.json"
    },
    {
      "name": "location_types",
      "path": "/location_types",
      "records": { "path": "." },
      "projection": "passthrough",
      "computed_fields": { "id": "{{ record.idlocation_type }}" },
      "schema": "schemas/location_types.json"
    },
    {
      "name": "picking_containers",
      "path": "/picking-containers",
