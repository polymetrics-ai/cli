{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-Simplesat-Token", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "answers/" },
    "error_map": [
      { "status": 401, "hint": "simplesat api_key is missing or invalid" },
      { "status": 429, "class": "rate_limited", "hint": "simplesat rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "answers",
      "path": "answers/",
      "query": {
        "page_size": { "template": "{{ config.page_size }}", "default": "100" },
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/answers.json"
    },
    {
      "name": "surveys",
      "path": "surveys/",
      "query": {
        "page_size": { "template": "{{ config.page_size }}", "default": "100" },
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/surveys.json"
    },
    {
      "name": "questions",
      "path": "questions/",
      "query": {
        "page_size": { "template": "{{ config.page_size }}", "default": "100" },
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/questions.json"
    },
    {
      "name": "customers",
      "path": "customers/",
      "query": {
        "page_size": { "template": "{{ config.page_size }}", "default": "100" },
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "tickets",
      "path": "tickets/",
      "query": {
        "page_size": { "template": "{{ config.page_size }}", "default": "100" },
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "results" },
      "schema": "schemas/tickets.json"
    }
  ]
}
