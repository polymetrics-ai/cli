{
  "actions": [
    {
      "name": "create_or_update_customer",
      "kind": "upsert",
      "method": "POST",
      "path": "/customers",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "external_id": { "type": "string" },
          "email": { "type": "string" },
          "name": { "type": "string" },
          "company": { "type": "string" },
          "language": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "custom_attributes": { "type": "object" }
        }
      },
      "risk": "creates a new customer or updates the existing one matched by external_id/email; low-risk external mutation, no approval required"
    },
    {
      "name": "update_customer",
      "kind": "update",
      "method": "PUT",
      "path": "/customers/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "external_id": { "type": "string" },
          "name": { "type": "string" },
          "company": { "type": "string" },
          "language": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "custom_attributes": { "type": "object" }
        }
      },
      "risk": "mutates an existing customer's profile fields by id; overwrites tags/custom_attributes wholesale with the submitted value"
    },
    {
      "name": "create_or_update_team_member",
      "kind": "upsert",
      "method": "POST",
      "path": "/team-members",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "external_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "custom_attributes": { "type": "object" }
        }
      },
      "risk": "creates a new team member or updates the existing one matched by external_id/email; low-risk external mutation, no approval required"
    },
    {
      "name": "update_answer",
      "kind": "update",
      "method": "PUT",
      "path": "/answers/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "choice": { "type": "string" },
          "choices": { "type": "array", "items": { "type": "string" } },
          "comment": { "type": ["string", "null"] },
          "follow_up_answer": { "type": ["string", "null"] },
          "follow_up_answer_choice": { "type": ["string", "null"] },
          "follow_up_answer_choices": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "mutates an existing survey answer's recorded choice/comment/follow-up fields; changes the customer-submitted response data an already-collected survey answer represents"
    },
    {
      "name": "create_or_update_response",
      "kind": "upsert",
      "method": "POST",
      "path": "/responses/create-or-update",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["survey_id"],
        "properties": {
          "survey_id": { "type": "integer" },
          "language": { "type": "string" },
          "created": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "answers": { "type": "array", "items": { "type": "object" } },
          "customer": { "type": "object" },
          "team_members": { "type": "array", "items": { "type": "object" } },
          "ticket": { "type": "object" }
        }
      },
      "risk": "creates a new survey response (or updates one matched by the API's own dedup rule) including its nested answers/customer/ticket/team_members sub-objects; commonly used to import or backfill historical survey data with an explicit created timestamp"
    },
    {
      "name": "update_response",
      "kind": "update",
      "method": "PUT",
      "path": "/responses/{{ record.id }}/update",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "survey_id"],
        "properties": {
          "id": { "type": "string" },
          "survey_id": { "type": "integer" },
          "language": { "type": "string" },
          "created": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "answers": { "type": "array", "items": { "type": "object" } },
          "team_members": { "type": "array", "items": { "type": "object" } }
        }
      },
      "risk": "mutates an existing survey response's tags/answers/team_members by id; overwrites the identified response's recorded data"
    },
    {
      "name": "send_survey_email",
      "kind": "custom",
      "method": "POST",
      "path": "/surveys/{{ record.survey_token }}/email",
      "path_fields": ["survey_token"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["survey_token", "customer"],
        "properties": {
          "survey_token": { "type": "string" },
          "customer": {
            "type": "object",
            "required": ["email"],
            "properties": {
              "id": { "type": "string" },
              "email": { "type": "string" },
              "name": { "type": "string" },
              "company": { "type": "string" },
              "language": { "type": "string" },
              "custom_attributes": { "type": "object" }
            }
          },
          "team_member": { "type": "object" },
          "ticket": { "type": "object" }
        }
      },
      "risk": "sends a live survey invitation email to the named customer's real inbox; each call generates one outbound email delivery, not a reversible data mutation"
    }
  ]
}
