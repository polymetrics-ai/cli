{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "oauth2_client_credentials",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "size",
      "start_page": 1,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/mailboxes" },
    "error_map": [
      { "status": 401, "hint": "help-scout client_id/client_secret is missing or invalid; re-run pm credentials add help-scout" },
      { "status": 429, "class": "rate_limited", "hint": "help-scout rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "conversations",
      "path": "/conversations",
      "query": {
        "sortField": "modifiedAt",
        "sortOrder": "asc",
        "modifiedSince": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "_embedded.conversations" },
      "schema": "schemas/conversations.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "query": {
        "sortField": "modifiedAt",
        "sortOrder": "asc",
        "modifiedSince": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "_embedded.customers" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "mailboxes",
      "path": "/mailboxes",
      "query": {
        "sortField": "modifiedAt",
        "sortOrder": "asc",
        "modifiedSince": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "_embedded.mailboxes" },
      "schema": "schemas/mailboxes.json"
    },
    {
      "name": "users",
      "path": "/users",
      "query": {
        "sortField": "modifiedAt",
        "sortOrder": "asc",
        "modifiedSince": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "_embedded.users" },
      "schema": "schemas/users.json"
    }
  ]
}
