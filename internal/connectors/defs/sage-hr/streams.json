{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-Auth-Token", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/employees" },
    "error_map": [
      { "status": 401, "hint": "sage-hr API key is missing or invalid; re-run pm credentials add sage-hr" },
      { "status": 429, "class": "rate_limited", "hint": "sage-hr rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "employees",
      "path": "/employees",
      "records": { "path": "" },
      "schema": "schemas/employees.json",
      "projection": "passthrough"
    },
    {
      "name": "teams",
      "path": "/teams",
      "records": { "path": "" },
      "schema": "schemas/teams.json",
      "projection": "passthrough"
    },
    {
      "name": "timeoff_requests",
      "path": "/timeoff/requests",
      "records": { "path": "" },
      "schema": "schemas/timeoff_requests.json",
      "projection": "passthrough"
    }
  ]
}
