{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "pageToken",
      "token_path": "nextPageToken"
    },
    "check": { "method": "GET", "path": "/catalog" },
    "error_map": [
      { "status": 401, "hint": "dremio api_key is missing or invalid; re-run pm credentials add dremio" },
      { "status": 403, "hint": "dremio api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "dremio rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "catalog",
      "path": "/catalog",
      "query": { "maxResults": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/catalog.json"
    },
    {
      "name": "reflections",
      "path": "/reflections",
      "query": { "maxResults": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/reflections.json"
    },
    {
      "name": "sources",
      "path": "/source",
      "query": { "maxResults": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/sources.json"
    },
    {
      "name": "users",
      "path": "/user",
      "query": { "maxResults": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/users.json"
    },
    {
      "name": "roles",
      "path": "/role",
      "query": { "maxResults": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/roles.json"
    }
  ]
}
