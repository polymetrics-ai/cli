{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.username }}", "password": "{{ secrets.password }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "offset_param": "offset",
      "limit_param": "limit",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/forms", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "surveycto username/password is missing or invalid; re-run pm credentials add surveycto" },
      { "status": 403, "hint": "surveycto credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "surveycto rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "forms",
      "path": "/forms",
      "records": { "path": "forms" },
      "schema": "schemas/forms.json"
    },
    {
      "name": "submissions",
      "path": "/forms/{{ config.form_id }}/submissions",
      "records": { "path": "submissions" },
      "schema": "schemas/submissions.json"
    },
    {
      "name": "datasets",
      "path": "/datasets",
      "records": { "path": "datasets" },
      "schema": "schemas/datasets.json"
    },
    {
      "name": "cases",
      "path": "/cases",
      "records": { "path": "cases" },
      "schema": "schemas/cases.json"
    }
  ]
}
