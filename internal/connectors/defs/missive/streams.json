{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/users" },
    "error_map": [
      { "status": 401, "hint": "missive api_key is missing or invalid; re-run pm credentials add missive" },
      { "status": 429, "class": "rate_limited", "hint": "missive rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "contacts" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "contact_groups",
      "path": "/contact_groups",
      "query": {
        "kind": { "template": "{{ config.kind }}", "omit_when_absent": true }
      },
      "records": { "path": "contact_groups" },
      "schema": "schemas/contact_groups.json"
    },
    {
      "name": "users",
      "path": "/users",
      "records": { "path": "users" },
      "schema": "schemas/users.json"
    },
    {
      "name": "teams",
      "path": "/teams",
      "records": { "path": "teams" },
      "schema": "schemas/teams.json"
    },
    {
      "name": "shared_labels",
      "path": "/shared_labels",
      "records": { "path": "shared_labels" },
      "schema": "schemas/shared_labels.json"
    }
  ]
}
