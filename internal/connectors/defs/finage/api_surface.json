{
  "api": "Finage REST API (https://api.finage.co.uk)",
  "docs": "https://finage.co.uk/docs/api",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration, completed: all 6 legacy streams including the symbol-partitioned market_news stream, now expressible via streams.json's fan_out.ids_from.config_key dialect (S4 engine mini-wave item 2); the full Finage surface (real-time quotes, forex, crypto, per-symbol fundamentals) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/fnd/market-information/us/most-actives", "covered_by": { "stream": "most_active_us_stocks" } },
    { "method": "GET", "path": "/fnd/market-information/us/most-gainers", "covered_by": { "stream": "most_gainers" } },
    { "method": "GET", "path": "/fnd/market-information/us/most-losers", "covered_by": { "stream": "most_losers" } },
    { "method": "GET", "path": "/fnd/market-information/us/sector-performance", "covered_by": { "stream": "sector_performance" } },
    { "method": "GET", "path": "/fnd/delisted-companies/", "covered_by": { "stream": "delisted_companies" } },
    { "method": "GET", "path": "/news/market/{symbol}", "covered_by": { "stream": "market_news" } },
    { "method": "GET", "path": "/last/stock/{symbol}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/agg/stock/{symbol}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
