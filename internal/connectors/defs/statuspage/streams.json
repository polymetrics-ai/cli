{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}", "prefix": "OAuth " }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/pages", "query": { "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "statuspage api_key is missing or invalid; re-run pm credentials add statuspage" },
      { "status": 429, "class": "rate_limited", "hint": "statuspage rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "pages",
      "path": "/pages",
      "records": { "path": "." },
      "schema": "schemas/pages.json"
    },
    {
      "name": "components",
      "path": "/pages/{{ config.page_id }}/components",
      "records": { "path": "." },
      "schema": "schemas/components.json"
    },
    {
      "name": "incidents",
      "path": "/pages/{{ config.page_id }}/incidents",
      "records": { "path": "." },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/incidents.json"
    },
    {
      "name": "subscribers",
      "path": "/pages/{{ config.page_id }}/subscribers",
      "records": { "path": "." },
      "schema": "schemas/subscribers.json"
    }
  ]
}
