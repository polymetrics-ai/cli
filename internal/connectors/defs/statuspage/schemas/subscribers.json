{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "subscribers",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "mode": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "endpoint": { "type": ["string", "null"] },
    "phone_number": { "type": ["string", "null"] },
    "phone_country": { "type": ["string", "null"] },
    "display_phone_number": { "type": ["string", "null"] },
    "skip_confirmation_notification": { "type": ["boolean", "null"] },
    "quarantined_at": { "type": ["string", "null"] },
    "purge_at": { "type": ["string", "null"] },
    "page_access_user_id": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
