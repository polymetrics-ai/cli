    {
      "method": "GET",
      "path": "/v1/events",
      "covered_by": {
        "stream": "events"
      }
    },
    {
      "method": "GET",
      "path": "/v1/tags",
      "covered_by": {
        "stream": "tags"
      }
    },
    {
      "method": "GET",
      "path": "/v1/events/{eventId}/orders",
      "covered_by": {
        "stream": "orders"
      }
    },
    {
      "method": "GET",
      "path": "/v1/events/{eventId}/tickets",
      "covered_by": {
        "stream": "tickets"
      }
    },
    {
      "method": "GET",
      "path": "/v1/events/{eventId}",
      "excluded": {
        "category": "out_of_scope",
        "reason": "Single-event lookup not modeled by legacy (list-only reads)"
      }
    },
    {
      "method": "GET",
      "path": "/v1/events/{eventId}/discount-codes",
      "excluded": {
        "category": "out_of_scope",
        "reason": "Not implemented by legacy"
      }
    }
  ]
}
