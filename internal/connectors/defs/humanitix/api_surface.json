{
  "api": "Humanitix Public API v1 (https://developers.humanitix.com/)",
  "docs": "https://developers.humanitix.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only (events, tags, orders, tickets); Humanitix exposes no safe reverse-ETL writes (legacy itself ships none; capabilities.write is false).",
