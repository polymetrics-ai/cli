{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-N8N-API-KEY", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "nextCursor"
    },
    "check": { "method": "GET", "path": "/workflows" },
    "error_map": [
      { "status": 401, "hint": "n8n api_key is missing or invalid; re-run pm credentials add n8n" },
      { "status": 403, "hint": "n8n api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "n8n rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "workflows",
      "path": "/workflows",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "100" } },
      "records": { "path": "data" },
      "schema": "schemas/workflows.json"
    },
    {
      "name": "executions",
      "path": "/executions",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "100" } },
      "records": { "path": "data" },
      "schema": "schemas/executions.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "100" } },
      "records": { "path": "data" },
      "schema": "schemas/tags.json"
    },
    {
      "name": "users",
      "path": "/users",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "100" } },
      "records": { "path": "data" },
      "schema": "schemas/users.json"
    }
  ]
}
