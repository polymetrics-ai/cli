{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_header",
        "header": "X-N8N-API-KEY",
        "value": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "nextCursor"
    },
    "check": {
      "method": "GET",
      "path": "/workflows"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "n8n api_key is missing or invalid; re-run pm credentials add n8n"
      },
      {
        "status": 403,
        "hint": "n8n api_key lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "n8n rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "workflows",
      "path": "/workflows",
      "query": {
        "active": {
          "template": "{{ config.workflow_active }}",
          "omit_when_absent": true
        },
        "tags": {
          "template": "{{ config.workflow_tags }}",
          "omit_when_absent": true
        },
        "name": {
          "template": "{{ config.workflow_name }}",
          "omit_when_absent": true
        },
        "projectId": {
          "template": "{{ config.project_id }}",
          "omit_when_absent": true
        },
        "excludePinnedData": {
          "template": "{{ config.exclude_pinned_data }}",
          "omit_when_absent": true
        },
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/workflows.json"
    },
    {
      "name": "workflow",
      "path": "/workflows/{{ config.workflow_id }}",
      "query": {
        "excludePinnedData": {
          "template": "{{ config.exclude_pinned_data }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": ".",
        "single_object": true
      },
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/workflow.json"
    },
    {
      "name": "workflow_version",
      "path": "/workflows/{{ config.workflow_id }}/{{ config.workflow_version_id }}",
      "records": {
        "path": ".",
        "single_object": true
      },
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/workflow_version.json"
    },
    {
      "name": "workflow_tags",
      "path": "/workflows/{{ config.workflow_id }}/tags",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/tags.json"
    },
    {
      "name": "executions",
      "path": "/executions",
      "query": {
        "includeData": {
          "template": "{{ config.include_execution_data }}",
          "omit_when_absent": true
        },
        "ignoreDataSizeLimit": {
          "template": "{{ config.ignore_data_size_limit }}",
          "omit_when_absent": true
        },
        "redactExecutionData": {
          "template": "{{ config.redact_execution_data }}",
          "omit_when_absent": true
        },
        "status": {
          "template": "{{ config.execution_status }}",
          "omit_when_absent": true
        },
        "workflowId": {
          "template": "{{ config.workflow_id }}",
          "omit_when_absent": true
        },
        "projectId": {
          "template": "{{ config.project_id }}",
          "omit_when_absent": true
        },
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/executions.json"
    },
    {
      "name": "execution",
      "path": "/executions/{{ config.execution_id }}",
      "query": {
        "includeData": {
          "template": "{{ config.include_execution_data }}",
          "omit_when_absent": true
        },
        "ignoreDataSizeLimit": {
          "template": "{{ config.ignore_data_size_limit }}",
          "omit_when_absent": true
        },
        "redactExecutionData": {
          "template": "{{ config.redact_execution_data }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": ".",
        "single_object": true
      },
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/execution.json"
    },
    {
      "name": "execution_tags",
      "path": "/executions/{{ config.execution_id }}/tags",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/tags.json"
    },
    {
      "name": "tags",
      "path": "/tags",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/tags.json"
    },
    {
      "name": "tag",
      "path": "/tags/{{ config.tag_id }}",
      "records": {
        "path": ".",
        "single_object": true
      },
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/tags.json"
    },
    {
      "name": "users",
      "path": "/users",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        },
        "includeRole": {
          "template": "{{ config.include_role }}",
          "omit_when_absent": true
        },
        "projectId": {
          "template": "{{ config.project_id }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/users.json"
    },
    {
      "name": "user",
      "path": "/users/{{ config.user_id }}",
      "query": {
        "includeRole": {
          "template": "{{ config.include_role }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": ".",
        "single_object": true
      },
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/user.json"
    },
    {
      "name": "variables",
      "path": "/variables",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        },
        "projectId": {
          "template": "{{ config.project_id }}",
          "omit_when_absent": true
        },
        "state": {
          "template": "{{ config.variable_state }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/variables.json"
    },
    {
      "name": "projects",
      "path": "/projects",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/projects.json"
    },
    {
      "name": "project_members",
      "path": "/projects/{{ config.project_id }}/users",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/project_members.json"
    },
    {
      "name": "credentials",
      "path": "/credentials",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/credentials.json"
    },
    {
      "name": "credential",
      "path": "/credentials/{{ config.credential_id }}",
      "records": {
        "path": ".",
        "single_object": true
      },
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/credential.json"
    },
    {
      "name": "credential_schema",
      "path": "/credentials/schema/{{ config.credential_type_name }}",
      "records": {
        "path": ".",
        "single_object": true
      },
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/credential_schema.json"
    },
    {
      "name": "data_tables",
      "path": "/data-tables",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        },
        "filter": {
          "template": "{{ config.data_table_filter }}",
          "omit_when_absent": true
        },
        "sortBy": {
          "template": "{{ config.data_table_sort_by }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "schema": "schemas/data_tables.json"
    },
    {
      "name": "data_table",
      "path": "/data-tables/{{ config.data_table_id }}",
      "records": {
        "path": ".",
        "single_object": true
      },
      "projection": "passthrough",
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/data_table.json"
    },
    {
      "name": "data_table_rows",
      "path": "/data-tables/{{ config.data_table_id }}/rows",
      "query": {
        "limit": {
          "template": "{{ config.page_size }}",
          "default": "100"
        },
        "filter": {
          "template": "{{ config.data_table_filter }}",
          "omit_when_absent": true
        },
        "sortBy": {
          "template": "{{ config.data_table_sort_by }}",
          "omit_when_absent": true
        },
        "search": {
          "template": "{{ config.data_table_search }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "projection": "passthrough",
      "schema": "schemas/data_table_rows.json"
    },
    {
      "name": "data_table_columns",
      "path": "/data-tables/{{ config.data_table_id }}/columns",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/data_table_columns.json"
    }
  ]
}
