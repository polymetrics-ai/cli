        "path": "",
        "single_object": true
      },
      "pagination": {
        "type": "none"
      },
      "computed_fields": {
        "_pm_id": "collaboration_permissions"
      },
      "projection": "passthrough",
      "schema": "schemas/collaboration_permissions.json"
    },
    {
      "name": "departments",
