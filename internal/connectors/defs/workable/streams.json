{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "paging.next"
    },
    "check": {
      "method": "GET",
      "path": "/jobs",
      "query": {
        "limit": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "workable api_key is missing or invalid; re-run pm credentials add workable"
      },
      {
        "status": 403,
        "hint": "workable API token lacks the required scope for this request"
      },
      {
        "status": 404,
        "hint": "workable resource not found or not visible to this token"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "workable rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "jobs",
      "path": "/jobs",
      "records": {
        "path": "jobs"
      },
      "query": {
        "limit": "100",
        "created_after": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        }
      },
      "projection": "passthrough",
      "schema": "schemas/jobs.json"
    },
    {
      "name": "candidates",
      "path": "/candidates",
      "records": {
        "path": "candidates"
      },
      "query": {
        "limit": "100",
        "created_after": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        }
      },
      "projection": "passthrough",
      "schema": "schemas/candidates.json"
    },
    {
      "name": "members",
      "path": "/members",
      "records": {
        "path": "members"
      },
      "query": {
        "limit": "100",
        "created_after": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        }
      },
      "projection": "passthrough",
      "schema": "schemas/members.json"
    },
    {
      "name": "accounts",
      "path": "/accounts",
      "records": {
        "path": "accounts"
      },
      "pagination": {
        "type": "none"
      },
      "projection": "passthrough",
      "schema": "schemas/accounts.json"
    },
    {
      "name": "account",
      "path": "/accounts/{{ config.account_subdomain }}",
