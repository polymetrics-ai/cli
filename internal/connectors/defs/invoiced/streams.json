{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "basic",
        "username": "{{ secrets.api_key }}",
        "password": ""
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/customers",
      "query": {
        "per_page": "1",
        "page": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "invoiced api_key is missing or invalid; re-run pm credentials add invoiced"
      },
      {
        "status": 403,
        "hint": "invoiced credentials lack access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "invoiced rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "customers",
      "path": "/customers",
      "records": {
        "path": ""
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "invoices",
      "path": "/invoices",
      "records": {
        "path": ""
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "payments",
      "path": "/payments",
      "records": {
        "path": ""
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/payments.json"
    },
    {
      "name": "subscriptions",
      "path": "/subscriptions",
      "records": {
        "path": ""
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/subscriptions.json"
    },
    {
      "name": "estimates",
      "path": "/estimates",
      "records": {
        "path": ""
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/estimates.json"
    },
    {
      "name": "customer_contacts",
      "path": "/customers/{{ config.customer_id }}/contacts",
      "records": {
        "path": ""
