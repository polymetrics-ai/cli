{
  "api": "Brex Platform API (https://platform.brexapis.com)",
  "docs": "https://developer.brex.com/openapi/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; the full Brex surface (payments, statements, bill pay, rewards, webhooks, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/v2/transactions/card/primary", "covered_by": { "stream": "transactions" } },
    { "method": "GET", "path": "/v2/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/v1/expenses/card", "covered_by": { "stream": "expenses" } },
    { "method": "GET", "path": "/v1/vendors", "covered_by": { "stream": "vendors" } },
    { "method": "GET", "path": "/v2/budgets", "covered_by": { "stream": "budgets" } },
    { "method": "GET", "path": "/v2/accounts/card/primary", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/payments", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/team", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/statements/card/primary", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v2/webhooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
