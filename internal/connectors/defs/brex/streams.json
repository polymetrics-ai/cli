{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.user_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "next_cursor"
    },
    "check": { "method": "GET", "path": "/v2/users", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "brex user_token is missing or invalid; re-run pm credentials add brex" },
      { "status": 403, "hint": "brex account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "brex rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "transactions",
      "path": "/v2/transactions/card/primary",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "incremental": {
        "cursor_field": "posted_at_date",
        "request_param": "posted_at_start",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/transactions.json"
    },
    {
      "name": "users",
      "path": "/v2/users",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/users.json"
    },
    {
      "name": "expenses",
      "path": "/v1/expenses/card",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "incremental": {
        "cursor_field": "purchased_at",
        "request_param": "purchased_at_start",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/expenses.json"
    },
    {
      "name": "vendors",
      "path": "/v1/vendors",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/vendors.json"
    },
    {
      "name": "budgets",
      "path": "/v2/budgets",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/budgets.json"
    },
    {
      "name": "departments",
      "path": "/v2/departments",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/departments.json"
    },
    {
      "name": "locations",
      "path": "/v2/locations",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/locations.json"
    },
    {
      "name": "titles",
      "path": "/v2/titles",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/titles.json"
    },
    {
      "name": "legal_entities",
      "path": "/v2/legal_entities",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/legal_entities.json"
    },
    {
      "name": "cards",
      "path": "/v2/cards",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/cards.json"
    },
    {
      "name": "accounts_card",
      "path": "/v2/accounts/card",
      "records": { "path": "" },
      "schema": "schemas/accounts_card.json"
    },
    {
      "name": "accounts_cash",
      "path": "/v2/accounts/cash",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/accounts_cash.json"
    },
    {
      "name": "card_statements",
      "path": "/v2/accounts/card/primary/statements",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/card_statements.json"
    },
    {
      "name": "linked_accounts",
      "path": "/v1/linked_accounts",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/linked_accounts.json"
    },
    {
      "name": "transfers",
      "path": "/v1/transfers",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/transfers.json"
    },
    {
      "name": "webhooks",
      "path": "/v1/webhooks",
      "query": { "limit": "100" },
      "records": { "path": "items" },
      "schema": "schemas/webhooks.json"
    }
  ]
}
