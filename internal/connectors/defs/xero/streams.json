{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Xero-tenant-id": "{{ secrets.tenant_id }}"
    },
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "Organisation"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "xero access_token is missing, invalid, or expired; re-run pm credentials add xero"
      },
      {
        "status": 403,
        "hint": "xero tenant_id is missing or the connected app lacks access to this tenant"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "xero rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "invoices",
      "path": "Invoices",
      "records": {
        "path": "Invoices"
      },
      "computed_fields": {
        "id": "{{ record.InvoiceID }}",
        "type": "{{ record.Type }}",
        "status": "{{ record.Status }}",
        "updated_at": "{{ record.UpdatedDateUTC }}",
        "ContactID": "{{ record.Contact.ContactID }}"
      },
      "schema": "schemas/invoices.json"
    },
    {
