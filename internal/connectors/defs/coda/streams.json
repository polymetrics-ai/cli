{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.auth_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "pageToken",
      "token_path": "nextPageToken"
    },
    "check": { "method": "GET", "path": "/docs" },
    "error_map": [
      { "status": 401, "hint": "coda auth_token is missing or invalid; re-run pm credentials add coda" },
      { "status": 403, "hint": "coda account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "coda rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "docs",
      "path": "/docs",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "25" } },
      "records": { "path": "items" },
      "schema": "schemas/docs.json"
    },
    {
      "name": "tables",
      "path": "/docs/{{ config.doc_id }}/tables",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "25" } },
      "records": { "path": "items" },
      "computed_fields": { "doc_id": "{{ config.doc_id }}" },
      "schema": "schemas/tables.json"
    },
    {
      "name": "pages",
      "path": "/docs/{{ config.doc_id }}/pages",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "25" } },
      "records": { "path": "items" },
      "computed_fields": { "doc_id": "{{ config.doc_id }}" },
      "schema": "schemas/pages.json"
    },
    {
      "name": "formulas",
      "path": "/docs/{{ config.doc_id }}/formulas",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "25" } },
      "records": { "path": "items" },
      "computed_fields": { "doc_id": "{{ config.doc_id }}" },
      "schema": "schemas/formulas.json"
    },
    {
      "name": "controls",
      "path": "/docs/{{ config.doc_id }}/controls",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "25" } },
      "records": { "path": "items" },
      "computed_fields": { "doc_id": "{{ config.doc_id }}" },
      "schema": "schemas/controls.json"
    },
    {
      "name": "columns",
      "path": "/docs/{{ config.doc_id }}/tables/{{ fanout.id }}/columns",
      "query": { "limit": { "template": "{{ config.page_size }}", "default": "25" } },
      "records": { "path": "items" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "pageToken",
        "token_path": "nextPageToken"
      },
      "fan_out": {
        "ids_from": {
          "request": {
            "path": "/docs/{{ config.doc_id }}/tables",
            "records_path": "items",
            "id_field": "id"
          }
        },
        "into": { "path_var": "table_id" },
        "stamp_field": "table_id"
      },
      "computed_fields": { "doc_id": "{{ config.doc_id }}" },
      "schema": "schemas/columns.json"
    },
    {
      "name": "rows",
      "path": "/docs/{{ config.doc_id }}/tables/{{ fanout.id }}/rows",
      "query": {
        "limit": { "template": "{{ config.page_size }}", "default": "25" },
        "valueFormat": "simpleWithArrays"
      },
      "records": { "path": "items" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "pageToken",
        "token_path": "nextPageToken"
      },
      "fan_out": {
        "ids_from": {
          "request": {
            "path": "/docs/{{ config.doc_id }}/tables",
            "records_path": "items",
            "id_field": "id"
          }
        },
        "into": { "path_var": "table_id" },
        "stamp_field": "table_id"
      },
      "computed_fields": { "doc_id": "{{ config.doc_id }}" },
      "schema": "schemas/rows.json"
    }
  ]
}
