{
  "actions": [
    {
      "name": "create_product",
      "kind": "create",
      "method": "POST",
      "path": "/product",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["SKU", "Name", "Category", "CostingMethod", "UOM", "Status"],
        "properties": {
          "SKU": { "type": "string" },
          "Name": { "type": "string" },
          "Category": { "type": "string" },
          "Brand": { "type": "string" },
          "Type": { "type": "string" },
          "CostingMethod": { "type": "string" },
          "DefaultLocation": { "type": "string" },
          "UOM": { "type": "string" },
          "Barcode": { "type": "string" },
          "PriceTier1": { "type": "number" },
          "Description": { "type": "string" },
          "Status": { "type": "string" }
        }
      },
      "risk": "external mutation; creates a live Cin7 Core product-catalog entry; approval required"
    },
    {
      "name": "update_product",
      "kind": "update",
      "method": "PUT",
      "path": "/product",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["ID"],
        "properties": {
          "ID": { "type": "string" },
          "SKU": { "type": "string" },
          "Name": { "type": "string" },
          "Category": { "type": "string" },
          "Brand": { "type": "string" },
          "UOM": { "type": "string" },
          "Barcode": { "type": "string" },
          "PriceTier1": { "type": "number" },
          "Description": { "type": "string" },
          "Status": { "type": "string" }
        }
      },
      "risk": "external mutation; overwrites live Cin7 Core product-catalog fields; approval required"
    },
    {
      "name": "create_customer",
      "kind": "create",
