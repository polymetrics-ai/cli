    {
      "name": "create_product_category",
      "kind": "create",
      "method": "POST",
      "path": "/ref/category",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["Name"],
        "properties": {
          "Name": { "type": "string" }
        }
      },
      "risk": "external mutation; creates a live Cin7 Core product category, immediately selectable on any product; approval required"
    },
    {
      "name": "update_product_category",
      "kind": "update",
      "method": "PUT",
      "path": "/ref/category",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["ID", "Name"],
        "properties": {
          "ID": { "type": "string" },
          "Name": { "type": "string" }
        }
      },
      "risk": "external mutation; renames a live Cin7 Core product category referenced by existing products; approval required"
    },
    {
      "name": "delete_product_category",
      "kind": "delete",
      "method": "DELETE",
      "path": "/ref/category?ID={{ record.ID }}",
      "path_fields": ["ID"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["ID"],
        "properties": {
          "ID": { "type": "string" }
        }
      },
      "risk": "external mutation; irreversibly deletes a live Cin7 Core product category; approval required"
    },
    {
