        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["Name", "Currency", "PaymentTerm", "AccountReceivable", "RevenueAccount", "TaxRule"],
        "properties": {
          "Name": { "type": "string" },
          "DisplayName": { "type": "string" },
          "Status": { "type": "string" },
          "Currency": { "type": "string" },
          "PaymentTerm": { "type": "string" },
          "AccountReceivable": { "type": "string" },
          "RevenueAccount": { "type": "string" },
          "TaxRule": { "type": "string" },
          "PriceTier": { "type": "string" },
          "Carrier": { "type": "string" },
          "Location": { "type": "string" },
          "Discount": { "type": "integer" },
          "Comments": { "type": "string" }
        }
      },
      "risk": "external mutation; creates a live Cin7 Core customer record used for future sales; approval required"
    },
    {
      "name": "update_customer",
      "kind": "update",
