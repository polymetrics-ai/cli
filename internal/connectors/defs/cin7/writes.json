          "TaxRule": { "type": "string" },
          "Discount": { "type": "integer" },
          "Comments": { "type": "string" }
        }
      },
      "risk": "external mutation; overwrites live Cin7 Core customer fields (billing terms, tax rule, credit settings); approval required"
