{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "api-auth-accountid": "{{ config.accountid }}"
    },
    "auth": [
      { "mode": "api_key_header", "header": "api-auth-applicationkey", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/product", "query": { "page": "1", "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "cin7 accountid/api_key is missing or invalid; re-run pm credentials add cin7" },
      { "status": 403, "hint": "cin7 account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "cin7 rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "products",
      "path": "/product",
      "query": { "IncludeDeprecated": "true" },
      "records": { "path": "Products" },
      "computed_fields": {
        "id": "{{ record.ID }}",
        "sku": "{{ record.SKU }}",
        "name": "{{ record.Name }}",
        "category": "{{ record.Category }}",
        "brand": "{{ record.Brand }}",
        "type": "{{ record.Type }}",
        "status": "{{ record.Status }}",
        "uom": "{{ record.UOM }}",
        "price_tier1": "{{ record.PriceTier1 }}",
        "cost": "{{ record.AverageCost }}",
        "last_modified": "{{ record.LastModifiedOn }}"
      },
      "incremental": {
        "request_param": "ModifiedSince"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "customers",
      "path": "/customer",
      "query": { "IncludeDeprecated": "true" },
      "records": { "path": "CustomerList" },
      "computed_fields": {
        "id": "{{ record.ID }}",
        "name": "{{ record.Name }}",
        "email": "{{ record.Email }}",
        "phone": "{{ record.Phone }}",
        "status": "{{ record.Status }}",
        "currency": "{{ record.Currency }}",
        "payment_term": "{{ record.PaymentTerm }}",
        "tax_rule": "{{ record.TaxRule }}",
        "last_modified": "{{ record.LastModifiedOn }}"
      },
      "incremental": {
        "request_param": "ModifiedSince"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "suppliers",
      "path": "/supplier",
      "query": { "IncludeDeprecated": "true" },
      "records": { "path": "SupplierList" },
      "computed_fields": {
        "id": "{{ record.ID }}",
        "name": "{{ record.Name }}",
        "email": "{{ record.Email }}",
        "phone": "{{ record.Phone }}",
        "status": "{{ record.Status }}",
        "currency": "{{ record.Currency }}",
        "payment_term": "{{ record.PaymentTerm }}",
        "last_modified": "{{ record.LastModifiedOn }}"
      },
      "incremental": {
        "request_param": "ModifiedSince"
      },
      "schema": "schemas/suppliers.json"
    },
    {
      "name": "sale_list",
      "path": "/saleList",
      "records": { "path": "SaleList" },
      "computed_fields": {
        "id": "{{ record.SaleID }}",
        "order_number": "{{ record.OrderNumber }}",
        "customer": "{{ record.Customer }}",
        "customer_id": "{{ record.CustomerID }}",
        "status": "{{ record.Status }}",
        "order_status": "{{ record.OrderStatus }}",
        "invoice_status": "{{ record.InvoiceStatus }}",
        "order_date": "{{ record.OrderDate }}",
        "invoice_amount": "{{ record.InvoiceAmount }}",
        "last_modified": "{{ record.LastModifiedOn }}"
      },
      "incremental": {
        "request_param": "UpdatedSince"
      },
      "schema": "schemas/sale_list.json"
    },
    {
      "name": "purchase_list",
      "path": "/purchaseList",
      "records": { "path": "PurchaseList" },
      "computed_fields": {
        "id": "{{ record.ID }}",
        "order_number": "{{ record.OrderNumber }}",
        "supplier": "{{ record.Supplier }}",
        "supplier_id": "{{ record.SupplierID }}",
        "status": "{{ record.Status }}",
        "order_status": "{{ record.OrderStatus }}",
        "invoice_amount": "{{ record.InvoiceAmount }}",
        "order_date": "{{ record.OrderDate }}",
        "last_modified": "{{ record.LastModifiedOn }}"
      },
      "incremental": {
        "request_param": "UpdatedSince"
      },
      "schema": "schemas/purchase_list.json"
    },
    {
      "name": "product_families",
      "path": "/productFamily",
      "records": { "path": "ProductFamilies" },
      "computed_fields": {
        "id": "{{ record.ID }}",
        "sku": "{{ record.SKU }}",
        "name": "{{ record.Name }}",
        "category": "{{ record.Category }}",
        "brand": "{{ record.Brand }}",
        "uom": "{{ record.UOM }}",
        "last_modified": "{{ record.LastModifiedOn }}"
      },
      "incremental": {
        "request_param": "ModifiedSince"
      },
      "schema": "schemas/product_families.json"
    },
    {
      "name": "product_availability",
      "path": "/ref/productavailability",
      "records": { "path": "ProductAvailabilityList" },
      "computed_fields": {
        "id": "{{ record.ID }}",
        "sku": "{{ record.SKU }}",
        "name": "{{ record.Name }}",
        "location": "{{ record.Location }}",
        "bin": "{{ record.Bin }}",
        "on_hand": "{{ record.OnHand }}",
        "allocated": "{{ record.Allocated }}",
        "available": "{{ record.Available }}",
        "on_order": "{{ record.OnOrder }}",
        "stock_on_hand": "{{ record.StockOnHand }}",
        "in_transit": "{{ record.InTransit }}"
      },
      "schema": "schemas/product_availability.json"
    },
    {
      "name": "locations",
      "path": "/ref/location",
      "records": { "path": "LocationList" },
      "schema": "schemas/locations.json",
      "projection": "passthrough"
    },
    {
      "name": "product_categories",
      "path": "/ref/category",
      "records": { "path": "CategoryList" },
      "schema": "schemas/product_categories.json",
      "projection": "passthrough"
    },
    {
      "name": "brands",
      "path": "/ref/brand",
      "records": { "path": "BrandList" },
      "schema": "schemas/brands.json",
      "projection": "passthrough"
    },
    {
      "name": "carriers",
      "path": "/ref/carrier",
      "records": { "path": "CarrierList" },
      "schema": "schemas/carriers.json",
      "projection": "passthrough"
    },
    {
      "name": "chart_of_accounts",
      "path": "/ref/account",
      "records": { "path": "AccountsList" },
      "schema": "schemas/chart_of_accounts.json",
      "projection": "passthrough"
    },
    {
      "name": "payment_terms",
      "path": "/ref/paymentterm",
      "records": { "path": "PaymentTermList" },
      "schema": "schemas/payment_terms.json",
      "projection": "passthrough"
    },
    {
      "name": "tax_rules",
      "path": "/ref/tax",
      "records": { "path": "TaxRuleList" },
      "schema": "schemas/tax_rules.json",
      "projection": "passthrough"
    },
    {
      "name": "units_of_measure",
      "path": "/ref/unit",
      "records": { "path": "UnitList" },
      "schema": "schemas/units_of_measure.json",
      "projection": "passthrough"
    },
    {
      "name": "price_tiers",
      "path": "/ref/priceTier",
      "records": { "path": "PriceTiers" },
      "schema": "schemas/price_tiers.json",
      "projection": "passthrough"
    }
  ]
}
