{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "max",
      "offset_param": "start",
      "page_size": 500
    },
    "check": { "method": "GET", "path": "/api/v1/resource/Company", "query": { "max": "1" } },
    "error_map": [
      { "status": 401, "hint": "deputy api_key is missing or invalid; re-run pm credentials add deputy" },
      { "status": 403, "hint": "deputy api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "deputy rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "locations",
      "path": "/api/v1/resource/Company",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "company_name": "{{ record.CompanyName }}",
        "code": "{{ record.Code }}",
        "active": "{{ record.Active }}",
        "address": "{{ record.Address }}",
        "country": "{{ record.Country }}",
        "creator": "{{ record.Creator }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/locations.json"
    },
    {
      "name": "employees",
      "path": "/api/v1/supervise/employee",
      "pagination": { "type": "none" },
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "display_name": "{{ record.DisplayName }}",
        "first_name": "{{ record.FirstName }}",
        "last_name": "{{ record.LastName }}",
        "active": "{{ record.Active }}",
        "company": "{{ record.Company }}",
        "role": "{{ record.Role }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/employees.json"
    },
    {
      "name": "departments",
      "path": "/api/v1/resource/OperationalUnit",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "operational_unit_name": "{{ record.OperationalUnitName }}",
        "company": "{{ record.Company }}",
        "active": "{{ record.Active }}",
        "creator": "{{ record.Creator }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/departments.json"
    },
    {
      "name": "timesheets",
      "path": "/api/v1/my/timesheets",
      "pagination": { "type": "none" },
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "employee": "{{ record.Employee }}",
        "operational_unit": "{{ record.OperationalUnit }}",
        "date": "{{ record.Date }}",
        "start_time": "{{ record.StartTime }}",
        "end_time": "{{ record.EndTime }}",
        "total_time": "{{ record.TotalTime }}",
        "is_in_progress": "{{ record.IsInProgress }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/timesheets.json"
    },
    {
      "name": "tasks",
      "path": "/api/v1/my/tasks",
      "pagination": { "type": "none" },
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "title": "{{ record.Title }}",
        "due_time": "{{ record.DueTime }}",
        "completed": "{{ record.Completed }}",
        "priority": "{{ record.Priority }}",
        "creator": "{{ record.Creator }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "leave",
      "path": "/api/v1/resource/Leave",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "employee": "{{ record.Employee }}",
        "leave_rule": "{{ record.LeaveRule }}",
        "date_start": "{{ record.DateStart }}",
        "date_end": "{{ record.DateEnd }}",
        "days": "{{ record.Days }}",
        "status": "{{ record.Status }}",
        "comment": "{{ record.Comment }}",
        "all_day": "{{ record.AllDay }}",
        "creator": "{{ record.Creator }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/leave.json"
    },
    {
      "name": "rosters",
      "path": "/api/v1/resource/Roster",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "date": "{{ record.Date }}",
        "start_time": "{{ record.StartTime }}",
        "end_time": "{{ record.EndTime }}",
        "operational_unit": "{{ record.OperationalUnit }}",
        "employee": "{{ record.Employee }}",
        "total_time": "{{ record.TotalTime }}",
        "cost": "{{ record.Cost }}",
        "published": "{{ record.Published }}",
        "open": "{{ record.Open }}",
        "creator": "{{ record.Creator }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/rosters.json"
    },
    {
      "name": "webhooks",
      "path": "/api/v1/resource/Webhook",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "topic": "{{ record.Topic }}",
        "address": "{{ record.Address }}",
        "type": "{{ record.Type }}",
        "enabled": "{{ record.Enabled }}",
        "creator": "{{ record.Creator }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/webhooks.json"
    },
    {
      "name": "teams",
      "path": "/api/v1/resource/Team",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.Id }}",
        "name": "{{ record.Name }}",
        "leader_employee": "{{ record.LeaderEmployee }}",
        "creator": "{{ record.Creator }}",
        "created": "{{ record.Created }}",
        "modified": "{{ record.Modified }}"
      },
      "schema": "schemas/teams.json"
    }
  ]
}
