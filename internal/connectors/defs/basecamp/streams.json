{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "projects",
      "method": "GET",
      "path": "/__legacy_hook/projects",
      "records": {
        "path": "data"
      },
      "schema": "schemas/projects.json",
      "incremental": {
        "cursor_field": "updated_at",
        "client_filtered": true
      }
    },
    {
      "name": "people",
      "method": "GET",
      "path": "/__legacy_hook/people",
      "records": {
        "path": "data"
      },
      "schema": "schemas/people.json",
      "incremental": {
        "cursor_field": "updated_at",
        "client_filtered": true
      }
    },
    {
      "name": "events",
      "method": "GET",
      "path": "/__legacy_hook/events",
      "records": {
        "path": "data"
      },
      "schema": "schemas/events.json",
      "incremental": {
        "cursor_field": "created_at",
        "client_filtered": true
      }
    }
  ]
}
