{
  "api": "Harvest API v2 (https://api.harvestapp.com/v2)",
  "docs": "https://help.getharvest.com/api-v2/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; write and Harvest's invoices/estimates/expenses/reports surface is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/clients", "covered_by": { "stream": "clients" } },
    { "method": "GET", "path": "/projects", "covered_by": { "stream": "projects" } },
    { "method": "GET", "path": "/tasks", "covered_by": { "stream": "tasks" } },
    { "method": "GET", "path": "/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/time_entries", "covered_by": { "stream": "time_entries" } },
    { "method": "GET", "path": "/invoices", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/estimates", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/expenses", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/reports/time/clients", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
