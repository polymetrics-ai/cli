{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}", "when": "{{ secrets.access_token }}" },
      {
        "mode": "oauth2_client_credentials",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "when": "{{ config.token_url }}"
      },
      {
        "mode": "oauth2_client_credentials",
        "token_url": "{{ config.base_url }}/login",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}"
      }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/users", "query": { "limit": "1", "offset": "0" } },
    "error_map": [
      { "status": 401, "hint": "looker access_token or client_id/client_secret is missing or invalid; re-run pm credentials add looker" },
      { "status": 403, "hint": "looker account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "looker rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/users",
      "records": { "path": "" },
      "schema": "schemas/users.json"
    },
    {
      "name": "groups",
      "path": "/groups",
      "records": { "path": "" },
      "schema": "schemas/groups.json"
    },
    {
      "name": "folders",
      "path": "/folders",
      "records": { "path": "" },
      "schema": "schemas/folders.json"
    },
    {
      "name": "looks",
      "path": "/looks",
      "records": { "path": "" },
      "schema": "schemas/looks.json"
    },
    {
      "name": "dashboards",
      "path": "/dashboards",
      "records": { "path": "" },
      "schema": "schemas/dashboards.json"
    }
  ]
}
