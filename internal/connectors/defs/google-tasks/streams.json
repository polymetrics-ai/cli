{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "pageToken",
      "token_path": "nextPageToken"
    },
    "check": {
      "method": "GET",
      "path": "/users/@me/lists",
      "query": {
        "maxResults": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "google-tasks api_key is missing, expired, or invalid; re-run pm credentials add google-tasks"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "google-tasks rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "tasklists",
      "path": "/users/@me/lists",
      "query": {
        "maxResults": "{{ config.records_limit }}"
      },
      "records": {
        "path": "items"
      },
      "incremental": {
        "cursor_field": "updated"
      },
      "computed_fields": {
        "self_link": "{{ record.selfLink }}"
      },
      "schema": "schemas/tasklists.json"
    },
    {
      "name": "tasks",
      "path": "/lists/{{ fanout.id }}/tasks",
      "query": {
        "maxResults": "{{ config.records_limit }}"
      },
      "records": {
        "path": "items"
      },
      "fan_out": {
        "ids_from": {
          "request": {
            "path": "/users/@me/lists",
            "records_path": "items",
            "id_field": "id"
          }
        },
        "into": {
          "path_var": "list_id"
        },
        "stamp_field": "tasklist_id"
      },
      "incremental": {
        "cursor_field": "updated"
      },
      "computed_fields": {
        "self_link": "{{ record.selfLink }}"
      },
      "schema": "schemas/tasks.json"
    }
  ]
}
