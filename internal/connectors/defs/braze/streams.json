{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "",
      "start_page": 0,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/campaigns/list", "query": { "page": "0" } },
    "error_map": [
      { "status": 401, "hint": "braze api_key is missing or invalid; re-run pm credentials add braze" },
      { "status": 403, "hint": "braze api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "braze rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "campaigns",
      "path": "/campaigns/list",
      "records": { "path": "campaigns" },
      "incremental": { "cursor_field": "last_edited" },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "canvases",
      "path": "/canvas/list",
      "records": { "path": "canvases" },
      "incremental": { "cursor_field": "last_edited" },
      "schema": "schemas/canvases.json"
    },
    {
      "name": "segments",
      "path": "/segments/list",
      "records": { "path": "segments" },
      "schema": "schemas/segments.json"
    }
  ]
}
