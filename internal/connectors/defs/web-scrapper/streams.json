{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "api_token", "value": "{{ secrets.api_token }}" }
    ],
    "check": { "method": "GET", "path": "/sitemap" },
    "error_map": [
      { "status": 401, "hint": "web-scrapper api_token is missing or invalid; re-run pm credentials add web-scrapper" },
      { "status": 429, "class": "rate_limited", "hint": "web-scrapper rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "sitemaps",
      "path": "/sitemap",
      "records": { "path": "data" },
      "schema": "schemas/sitemaps.json"
    },
    {
      "name": "jobs",
      "path": "/scraping-job",
      "records": { "path": "data" },
      "schema": "schemas/jobs.json"
    }
  ]
}
