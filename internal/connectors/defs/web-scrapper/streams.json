{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "api_token", "value": "{{ secrets.api_token }}" }
    ],
    "check": { "method": "GET", "path": "/sitemap" },
    "error_map": [
      { "status": 401, "hint": "web-scrapper api_token is missing or invalid; re-run pm credentials add web-scrapper" },
      { "status": 429, "class": "rate_limited", "hint": "web-scrapper rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "sitemaps",
      "path": "/sitemap",
      "records": { "path": "data" },
      "schema": "schemas/sitemaps.json",
      "projection": "passthrough"
    },
    {
      "name": "jobs",
      "path": "/scraping-job",
      "records": { "path": "data" },
      "schema": "schemas/jobs.json",
      "projection": "passthrough"
    },
    {
      "name": "sitemaps_list",
      "path": "/sitemaps",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "",
        "start_page": 1,
        "page_size": 100
      },
      "records": { "path": "data" },
      "schema": "schemas/sitemaps_list.json",
      "projection": "passthrough"
    },
    {
      "name": "scraping_jobs_list",
      "path": "/scraping-jobs",
      "query": {
        "sitemap_id": { "template": "{{ config.sitemap_id_filter }}", "omit_when_absent": true }
      },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "",
        "start_page": 1,
        "page_size": 100
      },
      "records": { "path": "data" },
      "schema": "schemas/scraping_jobs_list.json",
      "projection": "passthrough"
    },
    {
      "name": "account",
      "path": "/account",
      "records": { "path": "data" },
      "schema": "schemas/account.json",
      "projection": "passthrough"
    },
    {
      "name": "problematic_urls",
      "path": "/scraping-job/{{ fanout.id }}/problematic-urls",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "",
        "start_page": 1,
        "page_size": 100
      },
      "records": { "path": "data" },
      "fan_out": {
        "ids_from": { "config_key": "scraping_job_ids" },
        "into": { "path_var": "id" },
        "stamp_field": "scraping_job_id"
      },
      "schema": "schemas/problematic_urls.json",
      "projection": "passthrough"
    }
  ]
}
