{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "survey_folders",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "auto_created": { "type": ["boolean", "null"] },
    "visibility": { "type": ["string", "null"] },
    "teams": { "type": ["array", "null"], "items": { "type": "integer" } },
    "users": { "type": ["array", "null"], "items": { "type": "integer" } },
    "parent_survey_folder_id": { "type": ["integer", "null"] }
  }
}
