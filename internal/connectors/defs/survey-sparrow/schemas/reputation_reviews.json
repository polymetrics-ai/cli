{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "reputation_reviews",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "rating": { "type": ["number", "null"] },
    "review_title": { "type": ["string", "null"] },
    "review_content": { "type": ["string", "null"] },
    "review_date": { "type": ["string", "null"], "format": "date-time" },
    "reviewer_name": { "type": ["string", "null"] },
    "reviewer_photo_url": { "type": ["string", "null"] },
    "app_platform_id": { "type": ["integer", "null"] }
  }
}
