{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "responses",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "completed_time",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "completed_time": { "type": ["string", "null"], "format": "date-time" },
    "survey_id": { "type": ["integer", "null"] },
    "contact_id": { "type": ["integer", "null"] },
    "completed": { "type": ["string", "null"] },
    "channel_id": { "type": ["integer", "null"] },
    "language": { "type": ["string", "null"] },
    "question": { "type": ["string", "null"] },
    "question_tags": { "type": ["array", "null"], "items": { "type": "string" } },
    "question_id": { "type": ["integer", "null"] }
  }
}
