{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.secret_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page",
      "token_path": "meta.next"
    },
    "check": { "method": "GET", "path": "/customer", "query": { "perPage": "1" } },
    "error_map": [
      { "status": 401, "hint": "paystack secret_key is missing or invalid; re-run pm credentials add paystack" },
      { "status": 403, "hint": "paystack account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "paystack rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "customers",
      "path": "/customer",
      "query": {
        "perPage": "{{ config.page_size }}",
        "from": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "createdAt",
        "start_config_key": "start_date"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "transactions",
      "path": "/transaction",
      "query": {
        "perPage": "{{ config.page_size }}",
        "from": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "createdAt",
        "start_config_key": "start_date"
      },
      "schema": "schemas/transactions.json"
    },
    {
      "name": "subscriptions",
      "path": "/subscription",
      "query": {
        "perPage": "{{ config.page_size }}",
        "from": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "createdAt",
        "start_config_key": "start_date"
      },
      "schema": "schemas/subscriptions.json"
    },
    {
      "name": "invoices",
      "path": "/paymentrequest",
      "query": {
        "perPage": "{{ config.page_size }}",
        "from": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "createdAt",
        "start_config_key": "start_date"
      },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "disputes",
      "path": "/dispute",
      "query": {
        "perPage": "{{ config.page_size }}",
        "from": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "createdAt",
        "start_config_key": "start_date"
      },
      "schema": "schemas/disputes.json"
    }
  ]
}
