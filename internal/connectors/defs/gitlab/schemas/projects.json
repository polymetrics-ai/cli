{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "projects",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "last_activity_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "path": { "type": ["string", "null"] },
    "path_with_namespace": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "default_branch": { "type": ["string", "null"] },
    "visibility": { "type": ["string", "null"] },
    "web_url": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"] },
    "last_activity_at": { "type": ["string", "null"] },
    "archived": { "type": ["boolean", "null"] },
    "star_count": { "type": ["integer", "null"] },
    "forks_count": { "type": ["integer", "null"] },
    "open_issues_count": { "type": ["integer", "null"] }
  }
}
