      "path": "/api/v3/companies/prices/verbose",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "projection": "passthrough",
      "schema": "schemas/company_prices_verbose.json",
      "query": {
        "id": {
          "template": "{{ config.company_ids }}",
          "omit_when_absent": true
        },
        "ticker": {
          "template": "{{ config.tickers }}",
          "omit_when_absent": true
        },
        "ratios": {
          "template": "{{ config.include_ratios }}",
          "omit_when_absent": true
        },
        "asreported": {
          "template": "{{ config.as_reported }}",
          "omit_when_absent": true
        },
        "start": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        },
        "end": {
          "template": "{{ config.end_date }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "common_shares_outstanding",
      "path": "/api/v3/companies/common-shares-outstanding",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "projection": "passthrough",
      "schema": "schemas/common_shares_outstanding.json",
      "query": {
        "id": {
          "template": "{{ config.company_ids }}",
          "omit_when_absent": true
        },
        "ticker": {
          "template": "{{ config.tickers }}",
          "omit_when_absent": true
        },
        "start": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        },
        "end": {
          "template": "{{ config.end_date }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "weighted_shares_outstanding",
      "path": "/api/v3/companies/weighted-shares-outstanding",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "projection": "passthrough",
      "schema": "schemas/weighted_shares_outstanding.json",
      "query": {
        "id": {
          "template": "{{ config.company_ids }}",
          "omit_when_absent": true
        },
        "ticker": {
          "template": "{{ config.tickers }}",
          "omit_when_absent": true
        },
        "period": {
          "template": "{{ config.periods }}",
          "omit_when_absent": true
        },
        "fyear": {
          "template": "{{ config.fiscal_years }}",
          "omit_when_absent": true
        },
        "start": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        },
        "end": {
          "template": "{{ config.end_date }}",
          "omit_when_absent": true
        },
        "ttm": {
          "template": "{{ config.include_ttm }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "filings_by_company",
      "path": "/api/v3/filings/by-company",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "projection": "passthrough",
      "schema": "schemas/filings_by_company.json",
      "query": {
        "id": {
          "template": "{{ config.filing_company_id }}",
          "omit_when_absent": true
        },
        "ticker": {
          "template": "{{ config.filing_company_ticker }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "filings",
      "path": "/api/v3/filings/list",
      "records": {
        "path": "data"
      },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per-page",
        "start_page": 0,
        "page_size": 100
      },
      "projection": "passthrough",
      "query": {
        "start-date": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        },
        "end-date": {
          "template": "{{ config.end_date }}",
          "omit_when_absent": true
        }
      },
      "schema": "schemas/filings.json"
    },
    {
      "name": "changed_companies",
      "path": "/api/v3/companies/changed-companies",
      "records": {
        "path": "."
      },
      "pagination": {
        "type": "none"
      },
      "projection": "passthrough",
      "schema": "schemas/changed_companies.json",
      "query": {
        "start": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "data_change_log",
      "path": "/api/v3/companies/data-change-log",
      "records": {
        "path": "data"
      },
      "pagination": {
        "type": "page_number",
        "page_param": "pageNumber",
        "size_param": "itemsPerPage",
        "start_page": 0,
        "page_size": 100
      },
      "projection": "passthrough",
      "schema": "schemas/data_change_log.json"
    }
  ]
}
