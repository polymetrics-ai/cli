{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}"
      }
    ],
    "check": {
      "method": "GET",
      "path": "/v3/users/me"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "surveymonkey access_token is missing or invalid; re-run pm credentials add surveymonkey"
      },
      {
        "status": 403,
        "hint": "surveymonkey credentials lack access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "surveymonkey rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "surveys",
      "path": "/v3/surveys",
