{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "check": { "method": "GET", "path": "/users/me" },
    "error_map": [
      { "status": 401, "hint": "surveymonkey access_token is missing or invalid; re-run pm credentials add surveymonkey" },
      { "status": 403, "hint": "surveymonkey credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "surveymonkey rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "surveys",
      "path": "/surveys",
      "query": { "per_page": "100" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/surveys.json"
    },
    {
      "name": "collectors",
      "path": "/surveys/{{ config.survey_id }}/collectors",
      "query": { "per_page": "100" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/collectors.json"
    },
    {
      "name": "survey_responses",
      "path": "/surveys/{{ config.survey_id }}/responses/bulk",
      "query": { "per_page": "100" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/survey_responses.json"
    }
  ]
}
