{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "prefix": "Zoho-oauthtoken ", "value": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 200
    },
    "check": { "method": "GET", "path": "/lists" },
    "error_map": [
      { "status": 401, "hint": "zoho-campaign access_token is missing, expired, or invalid; re-run pm credentials add zoho-campaign" },
      { "status": 403, "hint": "zoho-campaign account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "zoho-campaign rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "lists",
      "path": "/lists",
      "records": { "path": "lists" },
      "computed_fields": {
        "id": "{{ record.listkey }}",
        "name": "{{ record.listname }}",
        "updated_at": "{{ record.modified_time }}"
      },
      "schema": "schemas/lists.json",
      "projection": "passthrough"
    },
    {
      "name": "campaigns",
      "path": "/campaigns",
      "records": { "path": "campaigns" },
      "computed_fields": {
        "id": "{{ record.campaign_key }}",
        "name": "{{ record.campaign_name }}",
        "updated_at": "{{ record.modified_time }}"
      },
      "schema": "schemas/campaigns.json",
      "projection": "passthrough"
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "contacts" },
      "computed_fields": {
        "id": "{{ record.contact_id }}",
        "name": "{{ record.email }}",
        "updated_at": "{{ record.modified_time }}"
      },
      "schema": "schemas/contacts.json",
      "projection": "passthrough"
    }
  ]
}
