{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "custom", "hook": "paypal-transaction" }
    ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "/v1/reporting/balances" },
    "error_map": [
      { "status": 401, "hint": "paypal-transaction client_id/client_secret are missing or invalid; re-run pm credentials add paypal-transaction" },
      { "status": 403, "hint": "paypal-transaction app lacks the required scope for this request" },
      { "status": 429, "class": "rate_limited", "hint": "paypal-transaction rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "transactions",
      "path": "/v1/reporting/transactions",
      "query": {
        "start_date": "{{ incremental.lower_bound }}",
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true },
        "fields": "all"
      },
      "records": { "path": "transaction_details" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "page_size",
        "start_page": 1,
        "page_size": 100
      },
      "incremental": {
        "cursor_field": "transaction_initiation_date",
        "start_config_key": "start_date"
      },
      "computed_fields": {
        "transaction_id": "{{ record.transaction_info.transaction_id }}",
        "transaction_status": "{{ record.transaction_info.transaction_status }}",
        "transaction_event_code": "{{ record.transaction_info.transaction_event_code }}",
        "transaction_initiation_date": "{{ record.transaction_info.transaction_initiation_date }}",
        "transaction_updated_date": "{{ record.transaction_info.transaction_updated_date }}",
        "currency_code": "{{ record.transaction_info.transaction_amount.currency_code }}",
        "amount": "{{ record.transaction_info.transaction_amount.value }}",
        "fee_amount": "{{ record.transaction_info.fee_amount.value }}",
        "paypal_account_id": "{{ record.transaction_info.paypal_account_id }}"
      },
      "schema": "schemas/transactions.json"
    },
    {
      "name": "balances",
      "path": "/v1/reporting/balances",
      "records": { "path": "balances" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "currency": "{{ record.currency }}",
        "primary": "{{ record.primary }}",
        "total_currency_code": "{{ record.total_balance.currency_code }}",
        "total_value": "{{ record.total_balance.value }}",
        "available_value": "{{ record.available_balance.value }}",
        "withheld_value": "{{ record.withheld_balance.value }}"
      },
      "schema": "schemas/balances.json"
    },
    {
      "name": "products",
      "path": "/v1/catalogs/products",
      "records": { "path": "products" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "page_size",
        "start_page": 1,
        "page_size": 20
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "disputes",
      "path": "/v1/customer/disputes",
      "records": { "path": "items" },
      "pagination": { "type": "none" },
      "conformance": {
        "skip_dynamic": true,
        "reason": "StreamHook-handled: PayPal's disputes list returns HATEOAS pagination as links:[{rel,href}], an array of objects matched by rel==\"next\" -- the engine's only body-path next-page-URL pagination type (next_url_path) resolves a single dotted string path via connsdk.StringAt/selectPath, which has no array-element-matching-by-sibling-field grammar (interpolate.go/extract.go), so a bare links.<n>.href index would only ever read one fixed array position, not the record whose rel is \"next\". hook-covered, proven live by internal/connectors/paritytest/paypal-transaction and internal/connectors/hooks/paypal-transaction/hooks_test.go."
      },
      "schema": "schemas/disputes.json"
    }
  ]
}
