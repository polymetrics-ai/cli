{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "pagination.next"
    },
    "check": { "method": "GET", "path": "/partnerships", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "partnerstack api_key is missing or invalid; re-run pm credentials add partnerstack" },
      { "status": 403, "hint": "partnerstack account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "partnerstack rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "partnerships",
      "path": "/partnerships",
      "query": { "limit": "{{ config.limit }}" },
      "records": { "path": "data" },
      "schema": "schemas/partnerships.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "query": { "limit": "{{ config.limit }}" },
      "records": { "path": "data" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "transactions",
      "path": "/transactions",
      "query": { "limit": "{{ config.limit }}" },
      "records": { "path": "data" },
      "schema": "schemas/transactions.json"
    },
    {
      "name": "groups",
      "path": "/groups",
      "query": { "limit": "{{ config.limit }}" },
      "records": { "path": "data" },
      "schema": "schemas/groups.json"
    }
  ]
}
