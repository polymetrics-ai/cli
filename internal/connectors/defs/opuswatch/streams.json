{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-API-Key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page",
      "token_path": "next_page"
    },
    "check": { "method": "GET", "path": "/monitors" },
    "error_map": [
      { "status": 401, "hint": "opuswatch api_key is missing or invalid; re-run pm credentials add opuswatch" },
      { "status": 429, "class": "rate_limited", "hint": "opuswatch rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "monitors",
      "path": "/monitors",
      "query": {
        "per_page": { "template": "{{ config.page_size }}", "default": "100" }
      },
      "records": { "path": "data" },
      "schema": "schemas/monitors.json"
    },
    {
      "name": "incidents",
      "path": "/incidents",
      "query": {
        "per_page": { "template": "{{ config.page_size }}", "default": "100" }
      },
      "records": { "path": "data" },
      "schema": "schemas/incidents.json"
    },
    {
      "name": "checks",
      "path": "/checks",
      "query": {
        "per_page": { "template": "{{ config.page_size }}", "default": "100" }
      },
      "records": { "path": "data" },
      "schema": "schemas/checks.json"
    }
  ]
}
