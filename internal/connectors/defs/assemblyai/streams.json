{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}", "prefix": "" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "page_details.next_url"
    },
    "check": { "method": "GET", "path": "/v2/transcript", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "assemblyai api_key is missing or invalid; re-run pm credentials add assemblyai" },
      { "status": 429, "class": "rate_limited", "hint": "assemblyai rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "transcript",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript.json"
    },
    {
      "name": "transcript_sentences",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript_sentences.json"
    },
    {
      "name": "transcript_paragraphs",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript_paragraphs.json"
    },
    {
      "name": "transcript_subtitle",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript_subtitle.json"
    },
    {
      "name": "transcript_detail",
      "path": "/v2/transcript/{{ fanout.id }}",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/v2/transcript", "records_path": "transcripts", "id_field": "id" }
        },
        "into": { "path_var": "transcript_id" }
      },
      "schema": "schemas/transcript_detail.json"
    },
    {
      "name": "transcript_sentence_items",
      "path": "/v2/transcript/{{ fanout.id }}/sentences",
      "records": { "path": "sentences" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/v2/transcript", "records_path": "transcripts", "id_field": "id" }
        },
        "into": { "path_var": "transcript_id" },
        "stamp_field": "transcript_id"
      },
      "schema": "schemas/transcript_sentence_items.json"
    },
    {
      "name": "transcript_paragraph_items",
      "path": "/v2/transcript/{{ fanout.id }}/paragraphs",
      "records": { "path": "paragraphs" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/v2/transcript", "records_path": "transcripts", "id_field": "id" }
        },
        "into": { "path_var": "transcript_id" },
        "stamp_field": "transcript_id"
      },
      "schema": "schemas/transcript_paragraph_items.json"
    },
    {
      "name": "transcript_word_search_matches",
      "path": "/v2/transcript/{{ fanout.id }}/word-search",
      "query": { "words": "{{ config.word_search_terms }}" },
      "records": { "path": "matches" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/v2/transcript", "records_path": "transcripts", "id_field": "id" }
        },
        "into": { "path_var": "transcript_id" },
        "stamp_field": "transcript_id"
      },
      "schema": "schemas/transcript_word_search_matches.json"
    }
  ]
}
