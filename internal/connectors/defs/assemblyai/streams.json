{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}", "prefix": "" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "page_details.next_url"
    },
    "check": { "method": "GET", "path": "/v2/transcript", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "assemblyai api_key is missing or invalid; re-run pm credentials add assemblyai" },
      { "status": 429, "class": "rate_limited", "hint": "assemblyai rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "transcript",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript.json"
    },
    {
      "name": "transcript_sentences",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript_sentences.json"
    },
    {
      "name": "transcript_paragraphs",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript_paragraphs.json"
    },
    {
      "name": "transcript_subtitle",
      "path": "/v2/transcript",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "transcripts" },
      "schema": "schemas/transcript_subtitle.json"
    }
  ]
}
