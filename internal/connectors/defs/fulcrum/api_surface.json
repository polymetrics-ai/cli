    { "method": "GET", "path": "/api/v2/projects.json", "covered_by": { "stream": "projects" } },
    { "method": "GET", "path": "/api/v2/choice_lists.json", "covered_by": { "stream": "choice_lists" } },
    { "method": "GET", "path": "/api/v2/classification_sets.json", "covered_by": { "stream": "classification_sets" } },
    { "method": "GET", "path": "/api/v2/photos.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v2/videos.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v2/signatures.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v2/memberships.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v2/roles.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/api/v2/webhooks.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/api/v2/records.json", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
