{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-ApiToken", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/forms.json" },
    "error_map": [
      { "status": 401, "hint": "fulcrum api_key is missing or invalid; re-run pm credentials add fulcrum" },
      { "status": 403, "hint": "fulcrum account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "fulcrum rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "forms",
      "path": "/forms.json",
      "records": { "path": "forms" },
      "schema": "schemas/forms.json"
    },
    {
      "name": "records",
      "path": "/records.json",
      "records": { "path": "records" },
      "schema": "schemas/records.json"
    },
    {
      "name": "projects",
      "path": "/projects.json",
      "records": { "path": "projects" },
      "schema": "schemas/projects.json"
    },
    {
      "name": "choice_lists",
      "path": "/choice_lists.json",
      "records": { "path": "choice_lists" },
      "schema": "schemas/choice_lists.json"
    },
    {
      "name": "classification_sets",
      "path": "/classification_sets.json",
      "records": { "path": "classification_sets" },
      "schema": "schemas/classification_sets.json"
    }
  ]
}
