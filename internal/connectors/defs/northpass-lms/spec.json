{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Northpass LMS Connection Specification",
  "type": "object",
  "required": ["api_key"],
  "properties": {
    "api_key": {
      "type": "string",
      "x-secret": true,
      "description": "Northpass API key, sent as the X-Api-Key header. Never logged."
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "default": "https://api.northpass.com/v2",
      "description": "Northpass API base URL override for tests or proxies."
    }
  }
}
