{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.email }}", "password": "{{ secrets.api_token }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "offset_param": "startAt",
      "limit_param": "maxResults",
      "page_size": 2
    },
    "check": { "method": "GET", "path": "/rest/api/3/myself" },
    "error_map": [
      { "status": 401, "hint": "jira credentials are missing or invalid; re-run pm credentials add jira" },
      { "status": 403, "hint": "jira account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "jira rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "issues",
      "path": "/rest/api/3/search",
      "records": { "path": "issues" },
      "computed_fields": {
        "summary": "{{ record.fields.summary }}",
        "created": "{{ record.fields.created }}",
        "updated": "{{ record.fields.updated }}",
        "status": "{{ record.fields.status.name }}",
        "issuetype": "{{ record.fields.issuetype.name }}",
        "priority": "{{ record.fields.priority.name }}",
        "assignee": "{{ record.fields.assignee.displayName }}",
        "reporter": "{{ record.fields.reporter.displayName }}",
        "project": "{{ record.fields.project.key }}"
      },
      "schema": "schemas/issues.json"
    },
    {
      "name": "projects",
      "path": "/rest/api/3/project/search",
      "records": { "path": "values" },
      "schema": "schemas/projects.json"
    },
    {
      "name": "users",
      "path": "/rest/api/3/users/search",
      "records": { "path": "." },
      "schema": "schemas/users.json"
    }
  ]
}
