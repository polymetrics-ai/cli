{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.user_auth_key }}", "prefix": "Basic " }
    ],
    "check": { "method": "GET", "path": "/apps" },
    "error_map": [
      { "status": 401, "hint": "onesignal user_auth_key is missing or invalid; re-run pm credentials add onesignal" },
      { "status": 403, "hint": "onesignal account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "onesignal rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "apps",
      "path": "/apps",
      "records": { "path": "" },
      "schema": "schemas/apps.json"
    }
  ]
}
