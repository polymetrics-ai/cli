{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "page_size",
      "start_page": 1,
      "page_size": 100,
      "max_pages": 1
    },
    "check": { "method": "GET", "path": "/tables" },
    "error_map": [
      { "status": 401, "hint": "secoda API key is missing or invalid; re-run pm credentials add secoda" },
      { "status": 429, "class": "rate_limited", "hint": "secoda rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "tables",
      "path": "/tables",
      "records": { "path": "results" },
      "schema": "schemas/tables.json",
      "projection": "passthrough"
    },
    {
      "name": "documents",
      "path": "/documents",
      "records": { "path": "results" },
      "schema": "schemas/documents.json",
      "projection": "passthrough"
    },
    {
      "name": "collections",
      "path": "/collections",
      "records": { "path": "results" },
      "schema": "schemas/collections.json",
      "projection": "passthrough"
    },
    {
      "name": "questions",
      "path": "/questions",
      "records": { "path": "results" },
      "schema": "schemas/questions.json",
      "projection": "passthrough"
    }
  ]
}
