        "start_date": {
          "template": "{{ config.start_date }}",
          "omit_when_absent": true
        },
        "end_date": {
          "template": "{{ config.end_date }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "pagination": {
        "type": "cursor",
        "cursor_param": "next_token",
        "token_path": "next_token"
      },
      "schema": "schemas/daily_sleep.json"
