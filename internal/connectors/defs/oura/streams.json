{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}"
      }
    ],
    "check": {
      "method": "GET",
      "path": "/usercollection/personal_info"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "oura api_key is missing or invalid; re-run pm credentials add oura"
      },
      {
        "status": 403,
        "hint": "oura token lacks the required Oura scope or the user subscription does not allow the requested data"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "oura rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "personal_info",
      "path": "/usercollection/personal_info",
      "records": {
        "path": "."
      },
      "schema": "schemas/personal_info.json"
    },
    {
      "name": "daily_sleep",
      "path": "/usercollection/daily_sleep",
