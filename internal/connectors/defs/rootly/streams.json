{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "incidents",
      "method": "GET",
      "path": "/__legacy_hook/incidents",
      "records": {
        "path": "data"
      },
      "schema": "schemas/incidents.json"
    },
    {
      "name": "services",
      "method": "GET",
      "path": "/__legacy_hook/services",
      "records": {
        "path": "data"
      },
      "schema": "schemas/services.json"
    },
    {
      "name": "users",
      "method": "GET",
      "path": "/__legacy_hook/users",
      "records": {
        "path": "data"
      },
      "schema": "schemas/users.json"
    }
  ]
}
