{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "_limit",
      "offset_param": "_skip",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/lead/" },
    "error_map": [
      { "status": 401, "hint": "close-com api_key is missing or invalid; re-run pm credentials add close-com" },
      { "status": 403, "hint": "close-com account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "close-com rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "leads",
      "path": "/lead/",
      "records": { "path": "data" },
      "schema": "schemas/leads.json"
    },
    {
      "name": "contacts",
      "path": "/contact/",
      "records": { "path": "data" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "opportunities",
      "path": "/opportunity/",
      "records": { "path": "data" },
      "schema": "schemas/opportunities.json"
    },
    {
      "name": "activities",
      "path": "/activity/",
      "records": { "path": "data" },
      "schema": "schemas/activities.json"
    },
    {
      "name": "users",
      "path": "/user/",
      "records": { "path": "data" },
      "schema": "schemas/users.json"
    },
    {
      "name": "tasks",
      "path": "/task/",
      "records": { "path": "data" },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "lead_statuses",
      "path": "/status/lead/",
      "pagination": { "type": "none" },
      "records": { "path": "data" },
      "schema": "schemas/lead_statuses.json"
    },
    {
      "name": "opportunity_statuses",
      "path": "/status/opportunity/",
      "pagination": { "type": "none" },
      "records": { "path": "data" },
      "schema": "schemas/opportunity_statuses.json"
    },
    {
      "name": "pipelines",
      "path": "/pipeline/",
      "pagination": { "type": "none" },
      "records": { "path": "data" },
      "schema": "schemas/pipelines.json"
    },
    {
      "name": "roles",
      "path": "/role/",
      "pagination": { "type": "none" },
      "records": { "path": "data" },
      "schema": "schemas/roles.json"
    },
    {
      "name": "groups",
      "path": "/group/",
      "pagination": { "type": "none" },
      "records": { "path": "data" },
      "schema": "schemas/groups.json"
    },
    {
      "name": "custom_fields_lead",
      "path": "/custom_field/lead/",
      "records": { "path": "data" },
      "schema": "schemas/custom_fields_lead.json"
    },
    {
      "name": "custom_fields_contact",
      "path": "/custom_field/contact/",
      "records": { "path": "data" },
      "schema": "schemas/custom_fields_contact.json"
    },
    {
      "name": "custom_fields_opportunity",
      "path": "/custom_field/opportunity/",
      "records": { "path": "data" },
      "schema": "schemas/custom_fields_opportunity.json"
    }
  ]
}
