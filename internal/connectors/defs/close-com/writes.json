    {
      "name": "delete_opportunity",
      "kind": "delete",
      "method": "DELETE",
      "path": "/opportunity/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "risk": "external mutation; irreversibly deletes a live Close opportunity; approval required"
    },
    {
      "name": "create_task",
      "kind": "create",
      "method": "POST",
      "path": "/task/",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["_type", "lead_id", "text"],
        "properties": {
          "_type": { "type": "string", "enum": ["lead"] },
          "lead_id": { "type": "string" },
          "text": { "type": "string" },
          "assigned_to": { "type": "string" },
          "contact_id": { "type": "string" },
          "due_date": { "type": "string" },
          "is_complete": { "type": "boolean" }
        }
      },
      "risk": "external mutation; creates a live Close task on a lead; approval required"
    },
    {
      "name": "update_task",
      "kind": "update",
      "method": "PUT",
      "path": "/task/{{ record.id }}",
      "path_fields": ["id"],
