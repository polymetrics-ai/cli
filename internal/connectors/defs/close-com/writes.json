    },
    {
      "name": "delete_task",
      "kind": "delete",
      "method": "DELETE",
      "path": "/task/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "risk": "external mutation; irreversibly deletes a live Close task; approval required"
    }
  ]
