{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "bookings",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "uid": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "start": { "type": ["string", "null"] },
    "end": { "type": ["string", "null"] },
    "duration": { "type": ["integer", "null"] },
    "eventTypeId": { "type": ["integer", "null"] },
    "location": { "type": ["string", "null"] },
    "absentHost": { "type": ["boolean", "null"] },
    "cancellationReason": { "type": ["string", "null"] },
    "cancelledByEmail": { "type": ["string", "null"] },
    "reschedulingReason": { "type": ["string", "null"] },
    "rescheduledByEmail": { "type": ["string", "null"] },
    "rescheduledFromUid": { "type": ["string", "null"] },
    "rescheduledToUid": { "type": ["string", "null"] },
    "hosts": { "type": ["array", "null"] },
    "attendees": { "type": ["array", "null"] },
    "guests": { "type": ["array", "null"], "items": { "type": "string" } },
    "rating": { "type": ["number", "null"] },
    "icsUid": { "type": ["string", "null"] },
    "createdAt": { "type": ["string", "null"] },
    "updatedAt": { "type": ["string", "null"] }
  }
}
