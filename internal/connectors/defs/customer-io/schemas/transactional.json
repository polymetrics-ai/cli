{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "transactional",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "send_to_unsubscribed": { "type": ["boolean", "null"] },
    "link_tracking": { "type": ["boolean", "null"] },
    "open_tracking": { "type": ["boolean", "null"] },
    "hide_message_body": { "type": ["boolean", "null"] },
    "queue_drafts": { "type": ["boolean", "null"] },
    "created_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "updated_at": { "type": ["integer", "null"], "description": "Unix seconds." }
  }
}
