{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "messages",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "customer_id": { "type": ["string", "null"] },
    "recipient": { "type": ["string", "null"] },
    "subject": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "created": { "type": ["integer", "null"], "description": "Unix seconds." },
    "campaign_id": { "type": ["integer", "null"] },
    "action_id": { "type": ["integer", "null"] },
    "newsletter_id": { "type": ["integer", "null"] },
    "broadcast_id": { "type": ["integer", "null"] },
    "content_id": { "type": ["integer", "null"] },
    "failure_message": { "type": ["string", "null"] }
  }
}
