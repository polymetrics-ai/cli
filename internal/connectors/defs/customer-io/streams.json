{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.app_api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "start",
      "token_path": "next"
    },
    "check": { "method": "GET", "path": "/campaigns" },
    "error_map": [
      { "status": 401, "hint": "customer-io app_api_key is missing or invalid; re-run pm credentials add customer-io" },
      { "status": 403, "hint": "customer-io app_api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "customer-io rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "campaigns",
      "path": "/campaigns",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "campaigns" },
      "incremental": { "cursor_field": "updated", "client_filtered": true },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "newsletters",
      "path": "/newsletters",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "newsletters" },
      "incremental": { "cursor_field": "updated", "client_filtered": true },
      "schema": "schemas/newsletters.json"
    },
    {
      "name": "segments",
      "path": "/segments",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "segments" },
      "incremental": { "cursor_field": "updated", "client_filtered": true },
      "schema": "schemas/segments.json"
    },
    {
      "name": "broadcasts",
      "path": "/broadcasts",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "broadcasts" },
      "incremental": { "cursor_field": "updated", "client_filtered": true },
      "schema": "schemas/broadcasts.json"
    }
  ]
}
