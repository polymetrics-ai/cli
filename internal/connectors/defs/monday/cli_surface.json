      "intent": "etl",
      "availability": "planned",
      "source_cli_path": "monday groups query",
      "notes": "Classified in the operation ledger; not implemented in the current read bundle."
    },
    {
      "path": "board create",
      "summary": "Create a board",
      "intent": "reverse_etl",
      "availability": "planned",
      "source_cli_path": "monday create_board mutation",
      "risk": "Creates a monday.com board in the authenticated account or workspace.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute; admin/sensitive variants require typed confirmation.",
      "notes": "Mutation metadata is blocked by default until writes and typed policy are implemented."
    },
    {
      "path": "item create",
      "summary": "Create an item",
      "intent": "reverse_etl",
      "availability": "planned",
      "source_cli_path": "monday create_item mutation",
      "risk": "Creates a visible item on a monday.com board.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "notes": "Mutation metadata is blocked by default until writes and typed policy are implemented."
    },
    {
      "path": "item update",
      "summary": "Change item column values",
      "intent": "reverse_etl",
      "availability": "planned",
      "source_cli_path": "monday change_column_value mutation",
      "risk": "Mutates item data on a monday.com board.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "notes": "Mutation metadata is blocked by default until writes and typed policy are implemented."
    },
    {
      "path": "webhook create",
      "summary": "Create a webhook",
      "intent": "reverse_etl",
      "availability": "planned",
      "source_cli_path": "monday create_webhook mutation",
      "risk": "Creates an outbound webhook and may expose monday.com event data to an external URL.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute plus typed confirmation for external callback targets.",
      "notes": "Blocked by default; requires explicit webhook/output policy before execution."
    }
  ],
  "help_topics": [
    {
      "name": "auth",
      "summary": "Use saved monday credentials; never pass tokens in command text."
    },
    {
      "name": "writes",
      "summary": "Monday mutations are metadata-only in this slice and remain blocked until reverse ETL plan/preview/approval/execute support is implemented."
    }
  ]
}
