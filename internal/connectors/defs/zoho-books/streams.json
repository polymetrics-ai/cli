{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "prefix": "Zoho-oauthtoken ", "value": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 200
    },
    "check": { "method": "GET", "path": "/contacts" },
    "error_map": [
      { "status": 401, "hint": "zoho-books access_token is missing, expired, or invalid; re-run pm credentials add zoho-books" },
      { "status": 403, "hint": "zoho-books account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "zoho-books rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "query": {
        "organization_id": { "template": "{{ config.organization_id }}", "omit_when_absent": true }
      },
      "records": { "path": "contacts" },
      "computed_fields": {
        "id": "{{ record.contact_id }}",
        "name": "{{ record.contact_name }}",
        "updated_at": "{{ record.last_modified_time }}"
      },
      "schema": "schemas/contacts.json",
      "projection": "passthrough"
    },
    {
      "name": "invoices",
      "path": "/invoices",
      "query": {
        "organization_id": { "template": "{{ config.organization_id }}", "omit_when_absent": true }
      },
      "records": { "path": "invoices" },
      "computed_fields": {
        "id": "{{ record.invoice_id }}",
        "name": "{{ record.invoice_number }}",
        "updated_at": "{{ record.last_modified_time }}"
      },
      "schema": "schemas/invoices.json",
      "projection": "passthrough"
    },
    {
      "name": "items",
      "path": "/items",
      "query": {
        "organization_id": { "template": "{{ config.organization_id }}", "omit_when_absent": true }
      },
      "records": { "path": "items" },
      "computed_fields": {
        "id": "{{ record.item_id }}",
        "name": "{{ record.name }}",
        "updated_at": "{{ record.last_modified_time }}"
      },
      "schema": "schemas/items.json",
      "projection": "passthrough"
    }
  ]
}
