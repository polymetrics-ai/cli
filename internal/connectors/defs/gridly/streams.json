{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_header",
        "header": "Authorization",
        "value": "{{ secrets.api_key }}",
        "prefix": "ApiKey "
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "views",
      "query": {
        "page": "1",
        "pageSize": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "gridly api_key is missing or invalid; re-run pm credentials add gridly"
      },
      {
        "status": 403,
        "hint": "gridly api_key lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "gridly rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "views",
      "path": "views",
      "records": {
        "path": ""
      },
      "schema": "schemas/views.json"
    },
    {
      "name": "records",
      "path": "views/{{ fanout.id }}/records",
      "records": {
        "path": ""
      },
      "fan_out": {
        "ids_from": {
          "config_key": "view_ids"
        },
        "into": {
          "path_var": "view"
        },
        "stamp_field": "view_id"
      },
      "schema": "schemas/records.json"
    },
    {
      "name": "branches",
      "path": "views/{{ fanout.id }}/branches",
      "records": {
        "path": ""
      },
      "fan_out": {
        "ids_from": {
          "config_key": "view_ids"
        },
        "into": {
          "path_var": "view"
        },
        "stamp_field": "view_id"
      },
      "schema": "schemas/branches.json"
    }
  ]
}
