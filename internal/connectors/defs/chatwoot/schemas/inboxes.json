{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "inboxes",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "channel_type": { "type": ["string", "null"] },
    "channel_id": { "type": ["integer", "null"] },
    "website_url": { "type": ["string", "null"] },
    "website_token": { "type": ["string", "null"] },
    "avatar_url": { "type": ["string", "null"] },
    "widget_color": { "type": ["string", "null"] },
    "enable_auto_assignment": { "type": ["boolean", "null"] },
