{
  "actions": [
    {
      "name": "create_contact",
      "kind": "create",
      "method": "POST",
      "path": "/contacts",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["inbox_id"],
        "properties": {
          "inbox_id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone_number": { "type": "string" },
          "identifier": { "type": "string" },
          "blocked": { "type": "boolean" },
          "avatar_url": { "type": "string" },
          "additional_attributes": { "type": "object" },
          "custom_attributes": { "type": "object" }
        }
      },
      "risk": "creates a new Chatwoot contact record; low risk, no customer notification"
    },
    {
      "name": "update_contact",
      "kind": "update",
      "method": "PUT",
      "path": "/contacts/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone_number": { "type": "string" },
          "identifier": { "type": "string" },
          "blocked": { "type": "boolean" },
          "avatar_url": { "type": "string" },
          "additional_attributes": { "type": "object" },
          "custom_attributes": { "type": "object" }
        }
      },
      "risk": "updates an existing Chatwoot contact's profile fields; low risk, no customer notification"
    },
    {
      "name": "create_conversation",
      "kind": "create",
      "method": "POST",
      "path": "/conversations",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["source_id"],
        "properties": {
          "source_id": { "type": "string" },
          "inbox_id": { "type": "integer" },
          "contact_id": { "type": "integer" },
          "status": { "type": "string", "enum": ["open", "resolved", "pending"] },
          "assignee_id": { "type": "integer" },
          "team_id": { "type": "integer" },
          "additional_attributes": { "type": "object" },
          "custom_attributes": { "type": "object" }
        }
      },
      "risk": "creates a new conversation in the target inbox; customer-visible once the initial message is delivered through a live channel"
    },
    {
      "name": "send_message",
      "kind": "create",
      "method": "POST",
      "path": "/conversations/{{ record.conversation_id }}/messages",
      "path_fields": ["conversation_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["conversation_id", "content"],
        "properties": {
          "conversation_id": { "type": "integer" },
          "content": { "type": "string" },
          "message_type": { "type": "string", "enum": ["outgoing", "incoming"] },
          "private": { "type": "boolean" },
          "content_type": {
            "type": "string",
            "enum": ["text", "input_email", "cards", "input_select", "form", "article"]
          },
          "content_attributes": { "type": "object" }
        }
      },
      "risk": "sends a message into a conversation; customer-visible unless private is true and may notify the contact through the inbox channel"
    },
    {
      "name": "toggle_conversation_status",
      "kind": "update",
      "method": "POST",
      "path": "/conversations/{{ record.conversation_id }}/toggle_status",
      "path_fields": ["conversation_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["conversation_id", "status"],
        "properties": {
          "conversation_id": { "type": "integer" },
          "status": { "type": "string", "enum": ["open", "resolved", "pending", "snoozed"] },
          "snoozed_until": { "type": "integer" }
        }
      },
      "risk": "changes a conversation's status (open/resolved/pending/snoozed); may affect agent routing and reporting metrics"
    },
    {
      "name": "create_label",
      "kind": "create",
      "method": "POST",
      "path": "/labels",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "color": { "type": "string" },
          "show_on_sidebar": { "type": "boolean" }
        }
      },
      "risk": "creates a new account-wide label; low risk, visible to all agents in the sidebar when show_on_sidebar is true"
    }
  ]
}
