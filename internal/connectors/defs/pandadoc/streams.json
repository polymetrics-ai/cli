{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "prefix": "API-Key ", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "next"
    },
    "check": { "method": "GET", "path": "/documents", "query": { "count": "1", "page": "1" } },
    "error_map": [
      { "status": 401, "hint": "pandadoc api_key is missing or invalid; re-run pm credentials add pandadoc" },
      { "status": 403, "hint": "pandadoc api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "pandadoc rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "documents",
      "path": "/documents",
      "query": { "count": "{{ config.count }}", "page": "1" },
      "records": { "path": "results" },
      "incremental": {
        "cursor_field": "date_created"
      },
      "schema": "schemas/documents.json"
    },
    {
      "name": "templates",
      "path": "/templates",
      "query": { "count": "{{ config.count }}", "page": "1" },
      "records": { "path": "results" },
      "incremental": {
        "cursor_field": "date_created"
      },
      "schema": "schemas/templates.json"
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "query": { "count": "{{ config.count }}", "page": "1" },
      "records": { "path": "results" },
      "incremental": {
        "cursor_field": "created_date"
      },
      "schema": "schemas/contacts.json"
    }
  ]
}
