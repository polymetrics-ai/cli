{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_header",
        "header": "Authorization",
        "prefix": "API-Key ",
        "value": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "next"
    },
    "check": {
      "method": "GET",
      "path": "/public/v1/documents",
      "query": {
        "count": "1",
        "page": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "pandadoc api_key is missing or invalid; re-run pm credentials add pandadoc"
      },
      {
        "status": 403,
        "hint": "pandadoc api_key lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "pandadoc rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "documents",
      "path": "/public/v1/documents",
      "records": {
        "path": "results"
      },
      "schema": "schemas/documents.json",
      "query": {
        "count": "{{ config.count }}",
        "page": "1"
      },
      "incremental": {
        "cursor_field": "date_created"
      }
    },
    {
      "name": "templates",
      "path": "/public/v1/templates",
      "records": {
        "path": "results"
      },
      "schema": "schemas/templates.json",
