{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "trades_historical_data",
  "type": "object",
  "x-primary-key": ["symbol_id", "uuid"],
  "x-cursor-field": "time_exchange",
  "required": ["symbol_id", "uuid"],
  "properties": {
    "symbol_id": { "type": "string", "description": "Stamped from config.symbol_id via computed_fields; not present on the raw wire record." },
    "uuid": { "type": "string" },
    "time_exchange": { "type": "string" },
    "time_coinapi": { "type": ["string", "null"] },
    "price": { "type": ["number", "null"] },
    "size": { "type": ["number", "null"] },
    "taker_side": { "type": ["string", "null"] }
  }
}
