{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "check": { "method": "GET", "path": "/v2/costs" },
    "error_map": [
      { "status": 401, "class": "auth_failed", "hint": "vantage access_token is missing or invalid; re-run pm credentials add vantage" },
      { "status": 403, "hint": "vantage account lacks access for this request" },
      { "status": 422, "class": "invalid_request", "hint": "vantage rejected the request body; check required fields" },
      { "status": 429, "class": "rate_limited", "hint": "vantage rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "costs",
      "path": "/v2/costs",
      "records": { "path": "costs" },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}",
        "service": "{{ record.service }}",
        "amount": "{{ record.amount }}",
        "date": "{{ record.date }}"
      },
      "schema": "schemas/costs.json"
    },
    {
      "name": "cost_reports",
      "path": "/v2/cost_reports",
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "records": { "path": "cost_reports" },
      "schema": "schemas/cost_reports.json"
    },
    {
      "name": "budgets",
      "path": "/v2/budgets",
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "records": { "path": "budgets" },
      "schema": "schemas/budgets.json"
    },
    {
      "name": "folders",
      "path": "/v2/folders",
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "records": { "path": "folders" },
      "schema": "schemas/folders.json"
    },
    {
      "name": "dashboards",
      "path": "/v2/dashboards",
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "records": { "path": "dashboards" },
      "schema": "schemas/dashboards.json"
    },
    {
      "name": "business_metrics",
      "path": "/v2/business_metrics",
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "records": { "path": "business_metrics" },
      "schema": "schemas/business_metrics.json"
    },
    {
      "name": "resource_reports",
      "path": "/v2/resource_reports",
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "records": { "path": "resource_reports" },
      "schema": "schemas/resource_reports.json"
    },
    {
      "name": "recommendations",
      "path": "/v2/recommendations",
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "records": { "path": "recommendations" },
