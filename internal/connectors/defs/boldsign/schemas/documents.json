{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "documents",
  "type": "object",
  "x-primary-key": ["document_id"],
  "x-cursor-field": "created_date",
  "required": ["document_id"],
  "properties": {
    "document_id": { "type": "string" },
    "sender_email": { "type": ["string", "null"] },
    "message_title": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "created_date": { "type": ["integer", "null"] },
    "expiry_date": { "type": ["integer", "null"] },
    "is_deleted": { "type": ["boolean", "null"] },
    "enable_signing_order": { "type": ["boolean", "null"] },
    "sender_detail": { "type": ["object", "null"] },
    "signer_details": { "type": ["array", "null"] },
    "labels": { "type": ["array", "null"] }
  }
}
