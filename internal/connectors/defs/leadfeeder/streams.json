{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_token }}", "prefix": "Token token=" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "links.next"
    },
    "check": { "method": "GET", "path": "/accounts", "query": { "page[size]": "1" } },
    "error_map": [
      { "status": 401, "hint": "leadfeeder api_token is missing or invalid; re-run pm credentials add leadfeeder" },
      { "status": 429, "class": "rate_limited", "hint": "leadfeeder rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "accounts",
      "path": "/accounts",
      "query": { "page[size]": "100" },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.attributes.name }}",
        "industry": "{{ record.attributes.industry }}",
        "status": "{{ record.attributes.status }}",
        "time_zone": "{{ record.attributes.time_zone }}",
        "currency": "{{ record.attributes.currency }}"
      },
      "schema": "schemas/accounts.json"
    },
    {
      "name": "leads",
      "path": "/accounts/{{ config.account_id }}/leads",
      "query": {
        "page[size]": "100",
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.attributes.name }}",
        "industry": "{{ record.attributes.industry }}",
        "website": "{{ record.attributes.website }}",
        "city": "{{ record.attributes.city }}",
        "country": "{{ record.attributes.country }}",
        "employee_count": "{{ record.attributes.employee_count }}",
        "quality": "{{ record.attributes.quality }}",
        "visits": "{{ record.attributes.visits }}",
        "first_visit_date": "{{ record.attributes.first_visit_date }}",
        "last_visit_date": "{{ record.attributes.last_visit_date }}"
      },
      "schema": "schemas/leads.json"
    },
    {
      "name": "visits",
      "path": "/accounts/{{ config.account_id }}/visits",
      "query": {
        "page[size]": "100",
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "computed_fields": {
        "visit_length": "{{ record.attributes.visit_length }}",
        "pageviews": "{{ record.attributes.pageviews }}",
        "source": "{{ record.attributes.source }}",
        "referring_url": "{{ record.attributes.referring_url }}",
        "hostname": "{{ record.attributes.hostname }}",
        "visit_date": "{{ record.attributes.visit_date }}",
        "started_at": "{{ record.attributes.started_at }}",
        "ended_at": "{{ record.attributes.ended_at }}"
      },
      "schema": "schemas/visits.json"
    },
    {
      "name": "custom_feeds",
      "path": "/accounts/{{ config.account_id }}/custom-feeds",
      "query": { "page[size]": "100" },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.attributes.name }}"
      },
      "schema": "schemas/custom_feeds.json"
    }
  ]
}
