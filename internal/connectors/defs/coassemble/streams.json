{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_header",
        "header": "Authorization",
        "value": "COASSEMBLE-V1-SHA256 UserId={{ secrets.user_id }}, UserToken={{ secrets.user_token }}",
        "prefix": ""
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "length",
      "start_page": 1,
      "page_size": 20
    },
    "check": { "method": "GET", "path": "/api/v1/headless/courses" },
    "error_map": [
      { "status": 401, "hint": "coassemble user_id/user_token are missing or invalid; re-run pm credentials add coassemble" },
      { "status": 403, "hint": "coassemble account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "coassemble rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "courses",
      "path": "/api/v1/headless/courses",
      "records": { "path": "" },
      "schema": "schemas/courses.json"
    },
    {
      "name": "screen_types",
      "path": "/api/v1/headless/screen/types",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "schema": "schemas/screen_types.json"
    },
    {
      "name": "trackings",
      "path": "/api/v1/headless/trackings",
      "records": { "path": "" },
      "schema": "schemas/trackings.json"
    }
  ]
}
