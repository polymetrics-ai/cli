{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_header",
        "header": "X-Api-Key",
        "value": "{{ secrets.api_key }}"
      }
    ],
    "check": {
      "method": "GET",
      "path": "/top-headlines/sources"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "news-api api_key is missing or invalid; re-run pm credentials add news-api"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "news-api rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "everything",
      "path": "/everything",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "pageSize",
        "start_page": 1,
        "page_size": 100
      },
      "query": {
        "q": { "template": "{{ config.search_query }}", "omit_when_absent": true },
        "searchIn": { "template": "{{ config.search_in }}", "omit_when_absent": true },
        "sources": { "template": "{{ config.sources }}", "omit_when_absent": true },
        "domains": { "template": "{{ config.domains }}", "omit_when_absent": true },
        "excludeDomains": { "template": "{{ config.exclude_domains }}", "omit_when_absent": true },
        "language": { "template": "{{ config.language }}", "omit_when_absent": true },
        "sortBy": { "template": "{{ config.sort_by }}", "omit_when_absent": true },
        "to": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": {
        "path": "articles"
      },
      "incremental": {
        "cursor_field": "published_at",
        "request_param": "from",
        "start_config_key": "start_date"
      },
      "computed_fields": {
        "source_id": "{{ record.source.id }}",
        "source_name": "{{ record.source.name }}",
        "url_to_image": "{{ record.urlToImage }}",
        "published_at": "{{ record.publishedAt }}"
      },
      "schema": "schemas/everything.json"
    },
    {
      "name": "top_headlines",
      "path": "/top-headlines",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "pageSize",
        "start_page": 1,
        "page_size": 100
      },
      "query": {
        "q": { "template": "{{ config.search_query }}", "omit_when_absent": true },
        "country": { "template": "{{ config.country }}", "omit_when_absent": true },
        "category": { "template": "{{ config.category }}", "omit_when_absent": true },
        "sources": { "template": "{{ config.sources }}", "omit_when_absent": true },
        "language": { "template": "{{ config.language }}", "omit_when_absent": true }
      },
      "records": {
        "path": "articles"
      },
      "computed_fields": {
        "source_id": "{{ record.source.id }}",
        "source_name": "{{ record.source.name }}",
        "url_to_image": "{{ record.urlToImage }}",
        "published_at": "{{ record.publishedAt }}"
      },
      "schema": "schemas/top_headlines.json"
    },
    {
      "name": "sources",
      "path": "/top-headlines/sources",
      "pagination": {
        "type": "none"
      },
      "query": {
        "category": { "template": "{{ config.category }}", "omit_when_absent": true },
        "language": { "template": "{{ config.language }}", "omit_when_absent": true },
        "country": { "template": "{{ config.country }}", "omit_when_absent": true }
      },
      "records": {
        "path": "sources"
      },
      "schema": "schemas/sources.json"
    }
  ]
}
