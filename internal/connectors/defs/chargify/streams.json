{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "basic",
        "username": "{{ config.username }}",
        "password": "{{ secrets.password }}",
        "when": "{{ config.username }}"
      },
      {
        "mode": "basic",
        "username": "{{ secrets.api_key }}",
        "password": "x",
        "when": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/customers.json" },
    "error_map": [
      { "status": 401, "hint": "chargify API key or username/password is missing or invalid; re-run pm credentials add chargify" },
      { "status": 403, "hint": "chargify credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "chargify rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "customers",
      "path": "/customers.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.customer.id }}",
        "first_name": "{{ record.customer.first_name }}",
        "last_name": "{{ record.customer.last_name }}",
        "email": "{{ record.customer.email }}",
        "organization": "{{ record.customer.organization }}",
        "reference": "{{ record.customer.reference }}",
        "phone": "{{ record.customer.phone }}",
        "country": "{{ record.customer.country }}",
        "created_at": "{{ record.customer.created_at }}",
        "updated_at": "{{ record.customer.updated_at }}"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "subscriptions",
      "path": "/subscriptions.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.subscription.id }}",
        "state": "{{ record.subscription.state }}",
        "customer_id": "{{ record.subscription.customer_id }}",
        "product_id": "{{ record.subscription.product_id }}",
        "balance_in_cents": "{{ record.subscription.balance_in_cents }}",
        "total_revenue_in_cents": "{{ record.subscription.total_revenue_in_cents }}",
        "current_period_started_at": "{{ record.subscription.current_period_started_at }}",
        "current_period_ends_at": "{{ record.subscription.current_period_ends_at }}",
        "created_at": "{{ record.subscription.created_at }}",
        "updated_at": "{{ record.subscription.updated_at }}"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/subscriptions.json"
    },
    {
      "name": "products",
      "path": "/products.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.product.id }}",
        "name": "{{ record.product.name }}",
        "handle": "{{ record.product.handle }}",
        "description": "{{ record.product.description }}",
        "price_in_cents": "{{ record.product.price_in_cents }}",
        "interval": "{{ record.product.interval }}",
        "interval_unit": "{{ record.product.interval_unit }}",
        "product_family_id": "{{ record.product.product_family_id }}",
        "created_at": "{{ record.product.created_at }}",
        "updated_at": "{{ record.product.updated_at }}"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "coupons",
      "path": "/coupons.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.coupon.id }}",
        "name": "{{ record.coupon.name }}",
        "code": "{{ record.coupon.code }}",
        "description": "{{ record.coupon.description }}",
        "percentage": "{{ record.coupon.percentage }}",
        "amount_in_cents": "{{ record.coupon.amount_in_cents }}",
        "product_family_id": "{{ record.coupon.product_family_id }}",
        "created_at": "{{ record.coupon.created_at }}",
        "updated_at": "{{ record.coupon.updated_at }}"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/coupons.json"
    },
    {
      "name": "transactions",
      "path": "/transactions.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.transaction.id }}",
        "transaction_type": "{{ record.transaction.transaction_type }}",
        "amount_in_cents": "{{ record.transaction.amount_in_cents }}",
        "subscription_id": "{{ record.transaction.subscription_id }}",
        "customer_id": "{{ record.transaction.customer_id }}",
        "product_id": "{{ record.transaction.product_id }}",
        "success": "{{ record.transaction.success }}",
        "kind": "{{ record.transaction.kind }}",
        "created_at": "{{ record.transaction.created_at }}"
      },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/transactions.json"
    },
    {
      "name": "product_families",
      "path": "/product_families.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.product_family.id }}",
        "name": "{{ record.product_family.name }}",
        "handle": "{{ record.product_family.handle }}",
        "description": "{{ record.product_family.description }}",
        "accounting_code": "{{ record.product_family.accounting_code }}",
        "created_at": "{{ record.product_family.created_at }}",
        "updated_at": "{{ record.product_family.updated_at }}"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/product_families.json"
    },
    {
      "name": "invoices",
      "path": "/invoices.json",
      "records": { "path": "invoices" },
      "computed_fields": {
        "id": "{{ record.uid }}",
        "number": "{{ record.number }}",
        "state": "{{ record.status }}",
        "customer_id": "{{ record.customer.id }}",
        "subscription_id": "{{ record.subscription_id }}",
        "total_amount": "{{ record.total_amount }}",
        "paid_amount": "{{ record.paid_amount }}",
        "due_amount": "{{ record.due_amount }}",
        "currency": "{{ record.currency }}",
        "issue_date": "{{ record.issue_date }}",
        "due_date": "{{ record.due_date }}",
        "created_at": "{{ record.created_at }}",
        "updated_at": "{{ record.updated_at }}"
      },
      "incremental": {
        "cursor_field": "updated_at"
      },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "payment_profiles",
      "path": "/payment_profiles.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.payment_profile.id }}",
        "customer_id": "{{ record.payment_profile.customer_id }}",
        "payment_type": "{{ record.payment_profile.payment_type }}",
        "card_type": "{{ record.payment_profile.card_type }}",
        "last_four": "{{ record.payment_profile.last_four }}",
        "expiration_month": "{{ record.payment_profile.expiration_month }}",
        "expiration_year": "{{ record.payment_profile.expiration_year }}",
        "current_vault": "{{ record.payment_profile.current_vault }}",
        "created_at": "{{ record.payment_profile.created_at }}",
        "updated_at": "{{ record.payment_profile.updated_at }}"
      },
      "schema": "schemas/payment_profiles.json"
    },
    {
      "name": "events",
      "path": "/events.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.event.id }}",
        "key": "{{ record.event.key }}",
        "message": "{{ record.event.message }}",
        "customer_id": "{{ record.event.customer_id }}",
        "subscription_id": "{{ record.event.subscription_id }}",
        "created_at": "{{ record.event.created_at }}"
      },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/events.json"
    },
    {
      "name": "statements",
      "path": "/statements.json",
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.statement.id }}",
        "uid": "{{ record.statement.uid }}",
        "subscription_id": "{{ record.statement.subscription_id }}",
        "customer_id": "{{ record.statement.customer_id }}",
        "settlement_date": "{{ record.statement.settlement_date }}",
        "closing_balance_in_cents": "{{ record.statement.closing_balance_in_cents }}",
        "created_at": "{{ record.statement.created_at }}"
      },
      "schema": "schemas/statements.json"
    }
  ]
}
