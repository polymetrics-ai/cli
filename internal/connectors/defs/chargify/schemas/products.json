{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "products",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": ["string", "null"] },
    "handle": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "price_in_cents": { "type": ["integer", "null"] },
    "interval": { "type": ["integer", "null"] },
    "interval_unit": { "type": ["string", "null"] },
    "product_family_id": { "type": ["integer", "null"] },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
  }
}
