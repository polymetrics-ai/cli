          "product": {
            "type": "object",
            "required": ["name", "price_in_cents", "interval", "interval_unit"],
            "properties": {
              "name": { "type": "string" },
              "handle": { "type": "string" },
              "description": { "type": "string" },
              "price_in_cents": { "type": "integer" },
              "interval": { "type": "integer" },
              "interval_unit": { "type": "string" }
            }
          }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "update_product",
      "kind": "update",
      "method": "PUT",
      "path": "/products/{{ record.id }}.json",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "product"],
        "properties": {
          "id": { "type": "string" },
          "product": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "price_in_cents": { "type": "integer" }
            }
          }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "create_coupon",
      "kind": "create",
      "method": "POST",
      "path": "/product_families/{{ record.product_family_id }}/coupons.json",
      "path_fields": ["product_family_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["product_family_id", "coupon"],
        "properties": {
          "product_family_id": { "type": "string" },
          "coupon": {
            "type": "object",
            "required": ["name", "code"],
            "properties": {
              "name": { "type": "string" },
              "code": { "type": "string" },
              "description": { "type": "string" },
              "percentage": { "type": "string" },
              "amount_in_cents": { "type": "integer" }
            }
          }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "update_coupon",
      "kind": "update",
      "method": "PUT",
      "path": "/coupons/{{ record.id }}.json",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "coupon"],
        "properties": {
          "id": { "type": "string" },
          "coupon": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "percentage": { "type": "string" },
              "amount_in_cents": { "type": "integer" }
            }
          }
        }
      },
      "risk": "external mutation; approval required"
    }
  ]
}
