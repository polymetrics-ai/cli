{
  "actions": [
    {
      "name": "create_customer",
      "kind": "create",
      "method": "POST",
      "path": "/customers.json",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["customer"],
        "properties": {
          "customer": {
            "type": "object",
            "required": ["first_name", "last_name", "email"],
            "properties": {
              "first_name": { "type": "string" },
              "last_name": { "type": "string" },
              "email": { "type": "string" },
              "organization": { "type": "string" },
              "reference": { "type": "string" },
              "phone": { "type": "string" },
              "country": { "type": "string" }
            }
          }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "update_customer",
      "kind": "update",
      "method": "PUT",
      "path": "/customers/{{ record.id }}.json",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "customer"],
        "properties": {
          "id": { "type": "string" },
          "customer": {
            "type": "object",
            "properties": {
              "first_name": { "type": "string" },
              "last_name": { "type": "string" },
              "email": { "type": "string" },
              "organization": { "type": "string" },
              "reference": { "type": "string" },
              "phone": { "type": "string" },
              "country": { "type": "string" }
            }
          }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "create_subscription",
      "kind": "create",
      "method": "POST",
      "path": "/subscriptions.json",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["subscription"],
        "properties": {
          "subscription": {
            "type": "object",
            "required": ["product_handle", "customer_id"],
            "properties": {
              "product_handle": { "type": "string" },
              "customer_id": { "type": "string" },
              "payment_collection_method": { "type": "string" },
              "coupon_code": { "type": "string" }
            }
          }
        }
      },
      "risk": "external mutation with billing side effects; approval required"
    },
    {
      "name": "update_subscription",
      "kind": "update",
      "method": "PUT",
      "path": "/subscriptions/{{ record.id }}.json",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "subscription"],
        "properties": {
          "id": { "type": "string" },
          "subscription": {
            "type": "object",
            "properties": {
              "product_handle": { "type": "string" },
              "coupon_code": { "type": "string" }
            }
          }
        }
      },
      "risk": "external mutation with billing side effects; approval required"
    },
    {
      "name": "cancel_subscription",
      "kind": "update",
      "method": "POST",
      "path": "/subscriptions/{{ record.id }}/cancel.json",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "subscription": {
            "type": "object",
            "properties": {
              "cancellation_message": { "type": "string" }
            }
          }
        }
      },
      "risk": "external mutation with billing side effects; approval required"
    },
    {
      "name": "create_product_family",
      "kind": "create",
      "method": "POST",
      "path": "/product_families.json",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["product_family"],
        "properties": {
          "product_family": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "handle": { "type": "string" },
              "description": { "type": "string" },
              "accounting_code": { "type": "string" }
            }
          }
        }
      },
      "risk": "external mutation; approval required"
    },
    {
      "name": "create_product",
      "kind": "create",
