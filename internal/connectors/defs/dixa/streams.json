{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "conversations",
      "method": "GET",
      "path": "/__legacy_hook/conversations",
      "records": {
        "path": "data"
      },
      "schema": "schemas/conversations.json",
      "incremental": {
        "cursor_field": "updated_at",
        "client_filtered": true
      }
    },
    {
      "name": "conversation_queue",
      "method": "GET",
      "path": "/__legacy_hook/conversation_queue",
      "records": {
        "path": "data"
      },
      "schema": "schemas/conversation_queue.json",
      "incremental": {
        "cursor_field": "updated_at",
        "client_filtered": true
      }
    },
    {
      "name": "conversation_rating",
      "method": "GET",
      "path": "/__legacy_hook/conversation_rating",
      "records": {
        "path": "data"
      },
      "schema": "schemas/conversation_rating.json",
      "incremental": {
        "cursor_field": "updated_at",
        "client_filtered": true
      }
    },
    {
      "name": "conversation_assignment",
      "method": "GET",
      "path": "/__legacy_hook/conversation_assignment",
      "records": {
        "path": "data"
      },
      "schema": "schemas/conversation_assignment.json",
      "incremental": {
        "cursor_field": "updated_at",
        "client_filtered": true
      }
    }
  ]
}
