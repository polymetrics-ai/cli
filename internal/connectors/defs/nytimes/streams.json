{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "api-key", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/mostpopular/v2/viewed/{{ config.period }}.json" },
    "error_map": [
      { "status": 401, "hint": "nytimes api_key is missing or invalid; re-run pm credentials add nytimes" },
      { "status": 429, "class": "rate_limited", "hint": "nytimes rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "most_popular_viewed",
      "path": "/mostpopular/v2/viewed/{{ config.period }}.json",
      "records": { "path": "results" },
      "schema": "schemas/most_popular.json"
    },
    {
      "name": "most_popular_emailed",
      "path": "/mostpopular/v2/emailed/{{ config.period }}.json",
      "records": { "path": "results" },
      "schema": "schemas/most_popular.json"
    },
    {
      "name": "most_popular_shared",
      "path": "/mostpopular/v2/shared/{{ config.period }}.json",
      "records": { "path": "results" },
      "schema": "schemas/most_popular.json"
    }
  ]
}
