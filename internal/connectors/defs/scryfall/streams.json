{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "check": { "method": "GET", "path": "/cards/search" },
    "error_map": [
      { "status": 429, "class": "rate_limited", "hint": "scryfall rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "cards",
      "path": "/cards/search",
      "query": { "q": "{{ config.q }}" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "next_page"
      },
      "schema": "schemas/cards.json"
    },
    {
      "name": "sets",
      "path": "/sets",
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "next_page"
      },
      "schema": "schemas/sets.json"
    }
  ]
}
