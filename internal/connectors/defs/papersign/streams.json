{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "pagination.next_cursor"
    },
    "check": { "method": "GET", "path": "/documents", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "papersign api_key is missing or invalid; re-run pm credentials add papersign" },
      { "status": 403, "hint": "papersign credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "papersign rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "documents",
      "path": "/documents",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/documents.json"
    },
    {
      "name": "templates",
      "path": "/templates",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/templates.json"
    },
    {
      "name": "recipients",
      "path": "/recipients",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at"
      },
      "schema": "schemas/recipients.json"
    }
  ]
}
