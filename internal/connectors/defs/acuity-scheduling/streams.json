{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.username }}", "password": "{{ secrets.password }}" }
    ],
    "check": { "method": "GET", "path": "/calendars" },
    "error_map": [
      { "status": 401, "hint": "acuity-scheduling username/password is missing or invalid; re-run pm credentials add acuity-scheduling" },
      { "status": 403, "hint": "acuity-scheduling credentials lack access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "acuity-scheduling rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "appointments",
      "path": "/appointments",
      "records": { "path": "" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "max",
        "start_page": 1,
        "page_size": 100
      },
      "computed_fields": {
        "first_name": "{{ record.firstName }}",
        "last_name": "{{ record.lastName }}",
        "end_time": "{{ record.endTime }}",
        "appointment_type_id": "{{ record.appointmentTypeID }}",
        "calendar_id": "{{ record.calendarID }}",
        "amount_paid": "{{ record.amountPaid }}",
        "datetime_created": "{{ record.datetimeCreated }}"
      },
      "schema": "schemas/appointments.json"
    },
    {
      "name": "clients",
      "path": "/clients",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "first_name": "{{ record.firstName }}",
        "last_name": "{{ record.lastName }}"
      },
      "schema": "schemas/clients.json"
    },
    {
      "name": "appointment_types",
      "path": "/appointment-types",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "schema": "schemas/appointment_types.json"
    },
    {
      "name": "calendars",
      "path": "/calendars",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "schema": "schemas/calendars.json"
    },
    {
      "name": "forms",
      "path": "/forms",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "schema": "schemas/forms.json"
    }
  ]
}
