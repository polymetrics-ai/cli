{
  "api": "CommCare HQ APIs",
  "docs": "https://commcare-hq.readthedocs.io/api/index.html",
  "reviewed_at": "2026-07-04",
  "scope": "Pass B full-surface expansion for documented CommCare HQ API pages available from the official API index plus legacy v0.5 form/case parity endpoints.",
  "endpoints": [
    { "method": "GET", "path": "/a/{domain}/api/v0.5/form/", "covered_by": { "stream": "forms" } },
    { "method": "GET", "path": "/a/{domain}/api/v0.5/case/", "covered_by": { "stream": "cases" } },
    { "method": "GET", "path": "/a/{domain}/api/application/v1/", "covered_by": { "stream": "applications" } },
    { "method": "GET", "path": "/a/{domain}/api/application/v1/{app_id}", "covered_by": { "stream": "application" } },
    { "method": "POST", "path": "/a/{domain}/apps/api/import_app/", "excluded": { "category": "binary_payload", "reason": "multipart application JSON file upload is not expressible by declarative JSON writes" } },
    { "method": "POST", "path": "/a/{domain}/apps/api/{app_id}/multimedia/", "excluded": { "category": "binary_payload", "reason": "multipart ZIP upload is not expressible by declarative JSON writes" } },
    { "method": "GET", "path": "/a/{domain}/apps/api/{app_id}/multimedia/status/{processing_id}/", "covered_by": { "stream": "multimedia_upload_status" } },
    { "method": "GET", "path": "/a/{domain}/api/form/v1/", "covered_by": { "stream": "forms_v1" } },
    { "method": "GET", "path": "/a/{domain}/api/form/v1/{form_id}/", "covered_by": { "stream": "form" } },
    { "method": "GET", "path": "/a/{domain}/api/form/attachment/{form_id}/{attachment_name}", "excluded": { "category": "binary_payload", "reason": "returns original attachment bytes rather than a JSON record stream" } },
    { "method": "GET", "path": "/a/{domain}/api/case/v1/", "covered_by": { "stream": "cases_v1" } },
    { "method": "GET", "path": "/a/{domain}/api/case/v1/{case_id}/", "covered_by": { "stream": "case_v1" } },
    { "method": "GET", "path": "/a/{domain}/api/case/v2/", "covered_by": { "stream": "cases_v2" } },
    { "method": "GET", "path": "/a/{domain}/api/case/v2/{case_id}", "covered_by": { "stream": "case_v2" } },
    { "method": "GET", "path": "/a/{domain}/api/case/v2/ext/{external_id}/", "covered_by": { "stream": "case_v2_by_external_id" } },
    { "method": "GET", "path": "/a/{domain}/api/case/v2/{case_id},{case_id}...", "covered_by": { "stream": "case_v2_bulk_by_ids" } },
    { "method": "GET", "path": "/a/{domain}/api/case/v2/?indices.parent={parent_case_id}", "covered_by": { "stream": "case_v2_index_children" } },
    { "method": "POST", "path": "/a/{domain}/api/case/v2/bulk_fetch/", "excluded": { "category": "out_of_scope", "reason": "read-style POST requires an arbitrary id-list body; stream reads cannot send request bodies" } },
    { "method": "POST", "path": "/a/{domain}/api/case/v2/", "covered_by": { "write": "create_case_v2" } },
    { "method": "POST", "path": "/a/{domain}/api/case/v2/ (bulk list body)", "excluded": { "category": "out_of_scope", "reason": "bulk case create/update requires a root JSON array; declarative writes send one JSON object per record" } },
    { "method": "PUT", "path": "/a/{domain}/api/case/v2/{case_id}", "covered_by": { "write": "update_case_v2" } },
    { "method": "PUT", "path": "/a/{domain}/api/case/v2/ext/{external_id}/", "covered_by": { "write": "upsert_case_v2_by_external_id" } },
    { "method": "PUT", "path": "/a/{domain}/api/case/v2/", "covered_by": { "write": "upsert_case_v2" } },
    { "method": "POST", "path": "/a/{domain}/importer/excel/bulk_upload_api/", "excluded": { "category": "binary_payload", "reason": "multipart Excel upload is not expressible by declarative JSON writes" } },
    { "method": "GET", "path": "/a/{domain}/api/user/v1/", "covered_by": { "stream": "mobile_workers" } },
    { "method": "GET", "path": "/a/{domain}/api/user/v1/{user_id}", "covered_by": { "stream": "mobile_worker" } },
    { "method": "POST", "path": "/a/{domain}/api/user/v1/", "covered_by": { "write": "create_mobile_worker" } },
    { "method": "PUT", "path": "/a/{domain}/api/user/v1/{id}/", "covered_by": { "write": "update_mobile_worker" } },
    { "method": "DELETE", "path": "/a/{domain}/api/user/v1/{id}/", "covered_by": { "write": "delete_mobile_worker" } },
    { "method": "POST", "path": "/a/{domain}/api/user/v1/{id}/email_password_reset/", "covered_by": { "write": "send_mobile_worker_password_reset" } },
    { "method": "GET", "path": "/a/{domain}/api/bulk-user/v1/", "covered_by": { "stream": "bulk_users" } },
    { "method": "GET", "path": "/a/{domain}/api/web-user/v1/", "covered_by": { "stream": "web_users" } },
    { "method": "GET", "path": "/a/{domain}/api/web-user/v1/{user_id}", "covered_by": { "stream": "web_user" } },
    { "method": "POST", "path": "/a/{domain}/api/invitation/v1/", "covered_by": { "write": "create_web_user_invitation" } },
    { "method": "PATCH", "path": "/a/{domain}/api/web-user/v1/{id}/", "covered_by": { "write": "update_web_user" } },
    { "method": "GET", "path": "/api/identity/v1/", "covered_by": { "stream": "user_identity" } },
    { "method": "POST", "path": "/a/{domain}/api/web-user/v1/{id}/enable", "covered_by": { "write": "enable_web_user" } },
    { "method": "POST", "path": "/a/{domain}/api/web-user/v1/{id}/disable", "covered_by": { "write": "disable_web_user" } },
    { "method": "GET", "path": "/api/user_domains/v1/", "covered_by": { "stream": "user_domains" } },
    { "method": "GET", "path": "/a/{domain}/api/group/v1/", "covered_by": { "stream": "groups" } },
    { "method": "POST", "path": "/a/{domain}/api/group/v1/", "covered_by": { "write": "create_group" } },
    { "method": "PATCH", "path": "/a/{domain}/api/group/v1/", "covered_by": { "write": "create_groups_bulk" } },
    { "method": "GET", "path": "/a/{domain}/api/group/v1/{group_id}/", "covered_by": { "stream": "group" } },
    { "method": "PUT", "path": "/a/{domain}/api/group/v1/{group_id}/", "covered_by": { "write": "update_group" } },
    { "method": "DELETE", "path": "/a/{domain}/api/group/v1/{group_id}/", "covered_by": { "write": "delete_group" } },
    { "method": "GET", "path": "/a/{project}/api/simplereportconfiguration/v1/", "covered_by": { "stream": "reports" } },
    { "method": "GET", "path": "/a/{project}/api/configurablereportdata/v1/{report_id}/", "covered_by": { "stream": "report_data" } },
    { "method": "GET", "path": "/a/{domain}/api/location/v1/", "covered_by": { "stream": "locations_v1" } },
    { "method": "GET", "path": "/a/{domain}/api/location/v1/{location_id}", "covered_by": { "stream": "location_v1" } },
    { "method": "GET", "path": "/a/{domain}/api/location/v2/", "covered_by": { "stream": "locations_v2" } },
    { "method": "GET", "path": "/a/{domain}/api/location/v2/{location_id}", "covered_by": { "stream": "location_v2" } },
    { "method": "POST", "path": "/a/{domain}/api/location/v2/", "covered_by": { "write": "create_location_v2" } },
    { "method": "PUT", "path": "/a/{domain}/api/location/v2/{location_id}", "covered_by": { "write": "update_location_v2" } },
    { "method": "PATCH", "path": "/a/{domain}/api/location/v2/", "covered_by": { "write": "bulk_upsert_locations_v2" } },
    { "method": "GET", "path": "/a/{domain}/api/location_type/v1/", "covered_by": { "stream": "location_types" } },
    { "method": "GET", "path": "/a/{domain}/api/location_type/v1/{id}", "covered_by": { "stream": "location_type" } },
    { "method": "GET", "path": "/a/{domain}/api/fixture/v1/", "covered_by": { "stream": "fixtures" } },
    { "method": "GET", "path": "/a/{domain}/api/fixture/v1/?fixture_type={table}", "covered_by": { "stream": "fixture_table_items" } },
    { "method": "GET", "path": "/a/{domain}/api/fixture/v1/{fixture_item_id}/", "covered_by": { "stream": "fixture_item" } },
    { "method": "POST", "path": "/a/{domain}/fixtures/fixapi/", "excluded": { "category": "binary_payload", "reason": "multipart Excel lookup-table upload is not expressible by declarative JSON writes" } },
    { "method": "GET", "path": "/a/{domain}/api/lookup_table/v1/", "covered_by": { "stream": "lookup_tables" } },
    { "method": "POST", "path": "/a/{domain}/api/lookup_table/v1/", "covered_by": { "write": "create_lookup_table" } },
    { "method": "PUT", "path": "/a/{domain}/api/lookup_table/v1/{lookup_table_id}", "covered_by": { "write": "update_lookup_table" } },
    { "method": "DELETE", "path": "/a/{domain}/api/lookup_table/v1/{lookup_table_id}", "covered_by": { "write": "delete_lookup_table" } },
    { "method": "GET", "path": "/a/{domain}/api/lookup_table_item/v1/", "covered_by": { "stream": "lookup_table_rows" } },
    { "method": "POST", "path": "/a/{domain}/api/lookup_table_item/v1/", "covered_by": { "write": "create_lookup_table_row" } },
    { "method": "PUT", "path": "/a/{domain}/api/lookup_table_item/v1/{lookup_table_item_id}", "covered_by": { "write": "update_lookup_table_row" } },
    { "method": "DELETE", "path": "/a/{domain}/api/lookup_table_item/v1/{lookup_table_item_id}", "covered_by": { "write": "delete_lookup_table_row" } },
    { "method": "GET", "path": "/a/{domain}/phone/restore/", "excluded": { "category": "out_of_scope", "reason": "OTA restore returns XML and requires mobile-worker Basic auth rather than the project API-key JSON engine path" } },
    { "method": "POST", "path": "/a/{domain}/api/sso/v1/", "excluded": { "category": "out_of_scope", "reason": "credential validation endpoint requires username/password form body and is not a sync stream or approved reverse-ETL mutation" } },
    { "method": "POST", "path": "/a/{domain}/receiver/api/", "excluded": { "category": "out_of_scope", "reason": "OpenRosa XForm submission requires XML body construction, not declarative JSON writes" } },
    { "method": "POST", "path": "/a/{domain}/receiver/{application_id}/", "excluded": { "category": "out_of_scope", "reason": "OpenRosa XForm submission requires XML body construction, not declarative JSON writes" } },
    { "method": "POST", "path": "/a/{domain}/receiver/submission/", "excluded": { "category": "out_of_scope", "reason": "OpenRosa XForm submission requires XML body construction, not declarative JSON writes" } },
    { "method": "GET", "path": "/a/{domain}/api/messaging-event/v1/", "covered_by": { "stream": "messaging_events" } },
    { "method": "GET", "path": "/a/{domain}/api/det_export_instance/v1/", "covered_by": { "stream": "det_exports" } }
  ]
}
