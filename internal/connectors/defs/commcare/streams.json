{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "prefix": "ApiKey ", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/a/{{ config.project_space }}/api/v0.5/form/",
      "query": { "limit": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "commcare api_key is missing or invalid; re-run pm credentials add commcare" },
      { "status": 403, "hint": "commcare account lacks access for this project_space" },
      { "status": 429, "class": "rate_limited", "hint": "commcare rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "forms",
      "path": "/a/{{ config.project_space }}/api/v0.5/form/",
      "query": {
        "app_id": { "template": "{{ config.app_id }}", "omit_when_absent": true }
      },
      "records": { "path": "objects" },
      "incremental": {
        "cursor_field": "received_on"
      },
      "schema": "schemas/forms.json",
      "projection": "passthrough"
    },
    {
      "name": "cases",
      "path": "/a/{{ config.project_space }}/api/v0.5/case/",
      "query": {
        "app_id": { "template": "{{ config.app_id }}", "omit_when_absent": true }
      },
      "records": { "path": "objects" },
      "incremental": {
        "cursor_field": "server_modified_on"
      },
      "schema": "schemas/cases.json",
      "projection": "passthrough"
    }
  ]
}
