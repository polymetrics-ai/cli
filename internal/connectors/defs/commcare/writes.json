{
  "actions": [
    {
      "name": "create_case_v2",
      "kind": "create",
      "method": "POST",
      "path": "/a/{{ config.project_space }}/api/case/v2/",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["case_type", "case_name", "owner_id"],
        "properties": {
          "case_type": { "type": "string" },
          "case_name": { "type": "string" },
          "owner_id": { "type": "string" },
          "external_id": { "type": "string" },
          "properties": { "type": "object" },
          "indices": { "type": "object" },
          "close": { "type": "boolean" }
        }
      },
      "risk": "creates a CommCare case by submitting a server-generated XForm"
    },
    {
      "name": "update_case_v2",
      "kind": "update",
      "method": "PUT",
      "path": "/a/{{ config.project_space }}/api/case/v2/{{ record.case_id }}",
      "path_fields": ["case_id"],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["case_id"],
        "properties": {
          "case_id": { "type": "string" },
          "case_type": { "type": "string" },
          "case_name": { "type": "string" },
          "owner_id": { "type": "string" },
          "external_id": { "type": "string" },
          "properties": { "type": "object" },
          "indices": { "type": "object" },
          "close": { "type": "boolean" }
        }
      },
      "risk": "updates an existing CommCare case by id"
    },
    {
      "name": "upsert_case_v2_by_external_id",
      "kind": "upsert",
      "method": "PUT",
      "path": "/a/{{ config.project_space }}/api/case/v2/ext/{{ record.external_id }}/",
      "path_fields": ["external_id"],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["external_id"],
        "properties": {
          "external_id": { "type": "string" },
          "case_type": { "type": "string" },
          "case_name": { "type": "string" },
          "owner_id": { "type": "string" },
          "properties": { "type": "object" },
          "indices": { "type": "object" },
          "close": { "type": "boolean" }
        }
      },
      "risk": "updates or creates a CommCare case matched by external id"
    },
    {
      "name": "upsert_case_v2",
      "kind": "upsert",
      "method": "PUT",
      "path": "/a/{{ config.project_space }}/api/case/v2/",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["external_id"],
        "properties": {
          "external_id": { "type": "string" },
          "case_type": { "type": "string" },
          "case_name": { "type": "string" },
          "owner_id": { "type": "string" },
          "properties": { "type": "object" },
          "indices": { "type": "object" },
          "close": { "type": "boolean" }
        }
      },
      "risk": "updates or creates a CommCare case matched by the request body's external_id"
    },
    {
