{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "after",
      "token_path": "meta.pagination.next"
    },
    "check": { "method": "GET", "path": "/transactions", "query": { "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "paddle api_key is missing or invalid; re-run pm credentials add paddle" },
      { "status": 403, "hint": "paddle account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "paddle rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "transactions",
      "path": "/transactions",
      "query": { "per_page": "100" },
      "records": { "path": "data" },
      "schema": "schemas/transactions.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "query": { "per_page": "100" },
      "records": { "path": "data" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "subscriptions",
      "path": "/subscriptions",
      "query": { "per_page": "100" },
      "records": { "path": "data" },
      "schema": "schemas/subscriptions.json"
    },
    {
      "name": "products",
      "path": "/products",
      "query": { "per_page": "100" },
      "records": { "path": "data" },
      "schema": "schemas/products.json"
    }
  ]
}
