{
  "base": {
    "url": "https://{{ config.domain }}.agilecrm.com/dev/api",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.email }}", "password": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/contacts" },
    "error_map": [
      { "status": 401, "hint": "agilecrm credentials are missing or invalid; re-run pm credentials add agilecrm" },
      { "status": 403, "hint": "agilecrm account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "agilecrm rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "query": { "page_size": "50" },
      "records": { "path": "." },
      "pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "last_record_field": "cursor"
      },
      "computed_fields": {
        "owner_id": "{{ record.owner.id }}"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "deals",
      "path": "/opportunity",
      "query": { "page_size": "50" },
      "records": { "path": "." },
      "pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "last_record_field": "cursor"
      },
      "computed_fields": {
        "owner_id": "{{ record.owner.id }}"
      },
      "schema": "schemas/deals.json"
    },
    {
      "name": "tasks",
      "path": "/tasks",
      "records": { "path": "." },
      "pagination": { "type": "none" },
      "computed_fields": {
        "owner_id": "{{ record.owner.id }}"
      },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "milestone",
      "path": "/milestone/pipelines",
      "records": { "path": "." },
      "pagination": { "type": "none" },
      "schema": "schemas/milestone.json"
    }
  ]
}
