{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgileCRM Task",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "created_time",
  "properties": {
    "id": { "type": "integer" },
    "subject": { "type": "string" },
    "type": { "type": "string" },
    "priority_type": { "type": "string" },
    "status": { "type": "string" },
    "created_time": { "type": "integer" },
    "due": { "type": "integer" },
    "is_complete": { "type": "boolean" },
    "owner_id": { "type": ["string", "null"] }
  }
}
