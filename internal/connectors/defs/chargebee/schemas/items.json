{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "items",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "item_family_id": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "is_shippable": { "type": ["boolean", "null"] },
    "enabled_for_checkout": { "type": ["boolean", "null"] },
    "created_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "updated_at": { "type": ["integer", "null"], "description": "Unix seconds." }
  }
}
