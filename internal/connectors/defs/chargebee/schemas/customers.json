{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "customers",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "first_name": { "type": ["string", "null"] },
    "last_name": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "company": { "type": ["string", "null"] },
    "phone": { "type": ["string", "null"] },
    "auto_collection": { "type": ["string", "null"] },
    "net_term_days": { "type": ["integer", "null"] },
    "taxability": { "type": ["string", "null"] },
    "created_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "updated_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "deleted": { "type": ["boolean", "null"] }
  }
}
