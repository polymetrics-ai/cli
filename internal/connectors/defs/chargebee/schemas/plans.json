{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "plans",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "invoice_name": { "type": ["string", "null"] },
    "price": { "type": ["integer", "null"] },
    "currency_code": { "type": ["string", "null"] },
    "period": { "type": ["integer", "null"] },
    "period_unit": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "created_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "updated_at": { "type": ["integer", "null"], "description": "Unix seconds." }
  }
}
