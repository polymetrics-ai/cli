{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "subscriptions",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "customer_id": { "type": ["string", "null"] },
    "plan_id": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "currency_code": { "type": ["string", "null"] },
    "plan_quantity": { "type": ["integer", "null"] },
    "plan_amount": { "type": ["integer", "null"] },
    "current_term_start": { "type": ["integer", "null"], "description": "Unix seconds." },
    "current_term_end": { "type": ["integer", "null"], "description": "Unix seconds." },
    "created_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "started_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "updated_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "deleted": { "type": ["boolean", "null"] }
  }
}
