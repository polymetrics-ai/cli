{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "invoices",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "customer_id": { "type": ["string", "null"] },
    "subscription_id": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "currency_code": { "type": ["string", "null"] },
    "total": { "type": ["integer", "null"] },
    "amount_paid": { "type": ["integer", "null"] },
    "amount_due": { "type": ["integer", "null"] },
    "date": { "type": ["integer", "null"], "description": "Unix seconds." },
    "due_date": { "type": ["integer", "null"], "description": "Unix seconds." },
    "paid_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "updated_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "deleted": { "type": ["boolean", "null"] }
  }
}
