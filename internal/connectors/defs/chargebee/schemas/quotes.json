{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "quotes",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "customer_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "subscription_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "invoice_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": [
        "string",
        "null"
      ]
    },
    "operation_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "price_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "currency_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "total": {
      "type": [
        "integer",
        "null"
      ]
    },
    "valid_till": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Unix seconds."
    },
    "date": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Unix seconds."
    },
    "updated_at": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Unix seconds. Note: Chargebee's /quotes list endpoint does not support sort_by[asc]=updated_at (only date); updated_at[after] filtering still works for incremental correctness, ordering within a page is not guaranteed."
    }
  },
  "x-cursor-field": "updated_at"
