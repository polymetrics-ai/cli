{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "access_key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 2
    },
    "check": { "method": "GET", "path": "/exchanges" },
    "error_map": [
      { "status": 401, "hint": "marketstack api key is missing or invalid; re-run pm credentials add marketstack" },
      { "status": 429, "class": "rate_limited", "hint": "marketstack rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "exchanges",
      "path": "/exchanges",
      "records": { "path": "data" },
      "computed_fields": {
        "currency_code": "{{ record.currency.code }}",
        "currency_name": "{{ record.currency.name }}",
        "currency_symbol": "{{ record.currency.symbol }}",
        "timezone": "{{ record.timezone.timezone }}",
        "timezone_abbr": "{{ record.timezone.abbr }}"
      },
      "schema": "schemas/exchanges.json"
    },
    {
      "name": "tickers",
      "path": "/tickers",
      "records": { "path": "data" },
      "computed_fields": {
        "stock_exchange_mic": "{{ record.stock_exchange.mic }}",
        "stock_exchange_name": "{{ record.stock_exchange.name }}"
      },
      "schema": "schemas/tickers.json"
    },
    {
      "name": "eod",
      "path": "/eod",
      "query": {
        "symbols": { "template": "{{ config.symbols }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "date",
        "request_param": "date_from",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/eod.json"
    },
    {
      "name": "splits",
      "path": "/splits",
      "query": {
        "symbols": { "template": "{{ config.symbols }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "date",
        "request_param": "date_from",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/splits.json"
    },
    {
      "name": "dividends",
      "path": "/dividends",
      "query": {
        "symbols": { "template": "{{ config.symbols }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "date",
        "request_param": "date_from",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/dividends.json"
    }
  ]
}
