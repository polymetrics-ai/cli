{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tickers",
  "type": "object",
  "x-primary-key": ["symbol"],
  "required": ["symbol"],
  "properties": {
    "symbol": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "has_eod": { "type": ["boolean", "null"] },
    "has_intraday": { "type": ["boolean", "null"] },
    "stock_exchange_mic": { "type": ["string", "null"] },
    "stock_exchange_name": { "type": ["string", "null"] }
  }
}
