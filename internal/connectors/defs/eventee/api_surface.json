{
  "api": "Eventee public API v1 (https://api.eventee.co/public/v1)",
  "docs": "https://eventee.co/api-documentation",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 7 legacy-parity read streams only; the full Eventee surface (participants, feedback, polls, etc.) is out of scope until Pass B",
