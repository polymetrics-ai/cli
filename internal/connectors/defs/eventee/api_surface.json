    { "method": "GET", "path": "/content (speakers)", "covered_by": { "stream": "speakers" } },
    { "method": "GET", "path": "/content (days)", "covered_by": { "stream": "days" } },
    { "method": "GET", "path": "/content (halls)", "covered_by": { "stream": "halls" } },
    { "method": "GET", "path": "/content (tracks)", "covered_by": { "stream": "tracks" } },
    { "method": "GET", "path": "/content (workshops)", "covered_by": { "stream": "workshops" } },
    { "method": "GET", "path": "/partners", "covered_by": { "stream": "partners" } },
    { "method": "GET", "path": "/participants", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/content (pauses)", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
