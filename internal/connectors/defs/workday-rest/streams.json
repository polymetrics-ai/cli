{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100,
      "max_pages": 1
    },
    "check": { "method": "GET", "path": "/ccx/api/hcm/v1/{{ config.tenant }}/workers", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "workday-rest access_token is missing or invalid; re-run pm credentials add workday-rest" },
      { "status": 429, "class": "rate_limited", "hint": "workday-rest rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "workers",
      "path": "/ccx/api/hcm/v1/{{ config.tenant }}/workers",
      "records": { "path": "data" },
      "schema": "schemas/workers.json"
    },
    {
      "name": "organizations",
      "path": "/ccx/api/hcm/v1/{{ config.tenant }}/organizations",
      "records": { "path": "data" },
      "schema": "schemas/organizations.json"
    },
    {
      "name": "jobs",
      "path": "/ccx/api/hcm/v1/{{ config.tenant }}/jobs",
      "records": { "path": "data" },
      "schema": "schemas/jobs.json"
    }
  ]
}
