{
  "actions": [
    {
      "name": "create_webhook_subscription",
      "kind": "create",
      "method": "POST",
      "path": "/webhook_subscriptions",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["endpointUrl"],
        "properties": {
          "endpointUrl": { "type": "string" },
          "topics": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "risk": "registers a new HTTPS endpoint to receive live order/contact/address event notifications; low-risk external mutation, no approval required"
    },
    {
      "name": "delete_webhook_subscription",
      "kind": "delete",
      "method": "DELETE",
      "path": "/webhook_subscriptions/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": {
        "idempotent": true,
        "missing_ok_status": [404]
      },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "risk": "permanently removes a webhook subscription, stopping future event notifications to that endpoint; external mutation, approval required"
    }
  ]
}
