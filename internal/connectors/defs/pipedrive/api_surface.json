    { "method": "GET", "path": "/organizations", "covered_by": { "stream": "organizations" } },
    { "method": "GET", "path": "/activities", "covered_by": { "stream": "activities" } },
    { "method": "GET", "path": "/products", "covered_by": { "stream": "products" } },
    { "method": "GET", "path": "/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/pipelines", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/stages", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/notes", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/files", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/deals", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "DELETE", "path": "/deals/{id}", "excluded": { "category": "destructive_admin", "reason": "Pass B capability expansion" } }
