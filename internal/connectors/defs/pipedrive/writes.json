{
  "actions": [
    {
      "name": "create_lead",
      "kind": "create",
      "method": "POST",
      "path": "/leads",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "owner_id": { "type": "integer" },
          "label_ids": { "type": "array", "items": { "type": "string" } },
          "person_id": { "type": "integer" },
          "organization_id": { "type": "integer" },
          "value": { "type": "object" },
          "expected_close_date": { "type": "string" },
          "visible_to": { "type": "string" },
          "was_seen": { "type": "boolean" },
          "origin_id": { "type": "string" },
          "channel": { "type": "integer" },
          "channel_id": { "type": "string" }
        }
      },
      "risk": "creates a new lead; low-risk external mutation, no approval required"
    },
    {
      "name": "update_lead",
      "kind": "update",
      "method": "PATCH",
      "path": "/leads/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "owner_id": { "type": "integer" },
          "label_ids": { "type": "array", "items": { "type": "string" } },
          "person_id": { "type": "integer" },
          "organization_id": { "type": "integer" },
          "is_archived": { "type": "boolean" },
          "value": { "type": "object" },
          "expected_close_date": { "type": "string" },
          "visible_to": { "type": "string" },
          "was_seen": { "type": "boolean" },
          "channel": { "type": "integer" },
          "channel_id": { "type": "string" }
        }
      },
      "risk": "updates an existing lead's fields (partial patch); external mutation, approval required"
    },
    {
      "name": "delete_lead",
      "kind": "delete",
      "method": "DELETE",
      "path": "/leads/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "permanently deletes a lead; destructive external mutation, approval required",
      "confirm": "destructive"
    },
    {
      "name": "create_note",
      "kind": "create",
      "method": "POST",
      "path": "/notes",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string" },
          "lead_id": { "type": "string" },
          "deal_id": { "type": "integer" },
          "person_id": { "type": "integer" },
          "org_id": { "type": "integer" },
          "project_id": { "type": "integer" },
          "task_id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "pinned_to_deal_flag": { "type": "boolean" },
          "pinned_to_organization_flag": { "type": "boolean" },
          "pinned_to_person_flag": { "type": "boolean" }
        }
      },
      "risk": "creates a new note attached to a deal/person/organization/lead; low-risk external mutation, no approval required"
    },
    {
      "name": "update_note",
      "kind": "update",
      "method": "PUT",
      "path": "/notes/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "content"],
        "properties": {
          "id": { "type": "integer" },
          "content": { "type": "string" }
        }
      },
      "risk": "updates an existing note's content; external mutation, approval required"
    },
    {
      "name": "delete_note",
      "kind": "delete",
      "method": "DELETE",
      "path": "/notes/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "integer" } }
      },
      "risk": "permanently deletes a note; destructive external mutation, approval required",
      "confirm": "destructive"
    },
    {
