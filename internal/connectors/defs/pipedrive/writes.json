      "method": "DELETE",
      "path": "/filters/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "integer" } }
      },
      "risk": "permanently deletes a saved filter; destructive external mutation, approval required",
      "confirm": "destructive"
    },
