{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "" }
    ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "/auth/test" },
    "error_map": [
      { "status": 401, "hint": "onfleet API key is missing or invalid; re-run pm credentials add onfleet" },
      { "status": 429, "class": "rate_limited", "hint": "onfleet rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "tasks",
      "path": "/tasks/all",
      "records": { "path": "tasks" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "lastId",
        "token_path": "lastId"
      },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "workers",
      "path": "/workers",
      "records": { "path": "." },
      "schema": "schemas/workers.json"
    },
    {
      "name": "teams",
      "path": "/teams",
      "records": { "path": "." },
      "schema": "schemas/teams.json"
    },
    {
      "name": "hubs",
      "path": "/hubs",
      "records": { "path": "." },
      "schema": "schemas/hubs.json"
    },
    {
      "name": "administrators",
      "path": "/admins",
      "records": { "path": "." },
      "schema": "schemas/administrators.json"
    }
  ]
}
