{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "pagination_metadata.next_cursor",
      "stop_path": "pagination_metadata.has_more"
    },
    "check": { "method": "GET", "path": "/customers" },
    "error_map": [
      { "status": 401, "hint": "orb api_key is missing or invalid; re-run pm credentials add orb" },
      { "status": 429, "class": "rate_limited", "hint": "orb rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "customers",
      "path": "/customers",
      "query": {
        "limit": { "template": "{{ config.page_size }}", "default": "100" }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gte]",
        "start_config_key": "start_date"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "subscriptions",
      "path": "/subscriptions",
      "query": {
        "limit": { "template": "{{ config.page_size }}", "default": "100" }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gte]",
        "start_config_key": "start_date"
      },
      "schema": "schemas/subscriptions.json"
    },
    {
      "name": "plans",
      "path": "/plans",
      "query": {
        "limit": { "template": "{{ config.page_size }}", "default": "100" }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gte]",
        "start_config_key": "start_date"
      },
      "schema": "schemas/plans.json"
    },
    {
      "name": "invoices",
      "path": "/invoices",
      "query": {
        "limit": { "template": "{{ config.page_size }}", "default": "100" }
      },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "created_at",
        "request_param": "created_at[gte]",
        "start_config_key": "start_date"
      },
      "schema": "schemas/invoices.json"
    }
  ]
}
