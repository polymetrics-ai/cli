{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "X-Access-Token": "{{ config.account_id }}"
    },
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 50
    },
    "check": { "method": "GET", "path": "/projects", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "codefresh api_key is missing or invalid; re-run pm credentials add codefresh" },
      { "status": 403, "hint": "codefresh account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "codefresh rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects",
      "records": { "path": "projects" },
      "computed_fields": {
        "id": "{{ record.id }}",
        "project_name": "{{ record.projectName }}",
        "favorite": "{{ record.favorite }}",
        "pipelines_number": "{{ record.pipelinesNumber }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/projects.json"
    },
    {
      "name": "pipelines",
      "path": "/pipelines",
      "records": { "path": "docs" },
      "computed_fields": {
        "id": "{{ record._id }}",
        "name": "{{ record.metadata.name }}",
        "project": "{{ record.metadata.project }}",
        "is_public": "{{ record.metadata.isPublic }}",
        "created_at": "{{ record.metadata.created_at }}",
        "updated_at": "{{ record.metadata.updated_at }}"
      },
      "schema": "schemas/pipelines.json"
    },
    {
      "name": "agents",
      "path": "/agents",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record._id }}",
        "name": "{{ record.name }}",
        "version": "{{ record.version }}",
        "status": "{{ record.status }}",
        "created_at": "{{ record.created_at }}"
      },
      "schema": "schemas/agents.json"
    },
    {
      "name": "contexts",
      "path": "/contexts",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.metadata.name }}",
        "name": "{{ record.metadata.name }}",
        "type": "{{ record.type }}",
        "owner": "{{ record.owner }}"
      },
      "schema": "schemas/contexts.json"
    },
    {
      "name": "builds",
      "path": "/workflow",
      "records": { "path": "workflows.docs" },
      "computed_fields": {
        "id": "{{ record.id }}",
        "project": "{{ record.project }}",
        "project_id": "{{ record.projectId }}",
        "pipeline_name": "{{ record.pipelineName }}",
        "repo_owner": "{{ record.repoOwner }}",
        "repo_name": "{{ record.repoName }}",
        "status": "{{ record.status }}",
        "progress": "{{ record.progress }}",
        "trigger": "{{ record.trigger }}",
        "trigger_type": "{{ record.triggerType }}",
        "triggered_by": "{{ record.triggeredBy }}",
        "branch_name": "{{ record.branchName }}",
        "revision": "{{ record.revision }}",
        "commit_message": "{{ record.commitMessage }}",
        "committer": "{{ record.committer }}",
        "provider": "{{ record.provider }}",
        "created": "{{ record.created }}",
        "finished": "{{ record.finished }}"
      },
      "schema": "schemas/builds.json"
    },
    {
      "name": "images",
      "path": "/images",
      "records": { "path": "docs" },
      "pagination": {
        "type": "offset_limit",
        "offset_param": "offset",
        "limit_param": "limit",
        "page_size": 50
      },
      "computed_fields": {
        "id": "{{ record._id }}",
        "image_name": "{{ record.imageName }}",
        "image_display_name": "{{ record.imageDisplayName }}",
        "branch": "{{ record.branch }}",
        "sha": "{{ record.sha }}",
        "commit": "{{ record.commit }}",
        "commit_url": "{{ record.commitURL }}",
        "size": "{{ record.size }}",
        "repo": "{{ record.repo }}",
        "created": "{{ record.created }}"
      },
      "schema": "schemas/images.json"
    },
    {
      "name": "registries",
      "path": "/registries",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "id": "{{ record._id }}",
        "name": "{{ record.name }}",
        "provider": "{{ record.provider }}",
        "kind": "{{ record.kind }}",
        "domain": "{{ record.domain }}",
        "primary": "{{ record.primary }}",
        "default": "{{ record.default }}",
        "internal": "{{ record.internal }}",
        "behind_firewall": "{{ record.behindFirewall }}"
      },
      "schema": "schemas/registries.json"
    },
    {
      "name": "triggers",
      "path": "/hermes/triggers",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "event": "{{ record.event }}",
        "pipeline": "{{ record.pipeline }}",
        "filter_tag": "{{ record.filters.tag }}",
        "event_type": "{{ record.event-data.type }}",
        "event_status": "{{ record.event-data.status }}",
        "event_description": "{{ record.event-data.description }}"
      },
      "schema": "schemas/triggers.json"
    },
    {
      "name": "trigger_events",
      "path": "/hermes/events",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "uri": "{{ record.uri }}",
        "type": "{{ record.type }}",
        "kind": "{{ record.kind }}",
        "account": "{{ record.account }}",
        "endpoint": "{{ record.endpoint }}",
        "status": "{{ record.status }}",
        "description": "{{ record.description }}"
      },
      "schema": "schemas/trigger_events.json"
    },
    {
      "name": "annotations",
      "path": "/annotations",
      "records": { "path": "" },
      "pagination": { "type": "none" },
      "computed_fields": {
        "id": "{{ record._id }}",
        "account_id": "{{ record.accountId }}",
        "entity_id": "{{ record.entityId }}",
        "entity_type": "{{ record.entityType }}",
        "key": "{{ record.key }}",
        "value": "{{ record.value }}",
        "type": "{{ record.type }}"
      },
      "schema": "schemas/annotations.json"
    }
  ]
}
