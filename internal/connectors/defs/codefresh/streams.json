{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "X-Access-Token": "{{ config.account_id }}"
    },
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 2
    },
    "check": { "method": "GET", "path": "/projects", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "codefresh api_key is missing or invalid; re-run pm credentials add codefresh" },
      { "status": 403, "hint": "codefresh account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "codefresh rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects",
      "records": { "path": "projects" },
      "computed_fields": {
        "id": "{{ record.id }}",
        "project_name": "{{ record.projectName }}",
        "favorite": "{{ record.favorite }}",
        "pipelines_number": "{{ record.pipelinesNumber }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/projects.json"
    },
    {
      "name": "pipelines",
      "path": "/pipelines",
      "records": { "path": "docs" },
      "computed_fields": {
        "id": "{{ record._id }}",
        "name": "{{ record.metadata.name }}",
        "project": "{{ record.metadata.project }}",
        "is_public": "{{ record.metadata.isPublic }}",
        "created_at": "{{ record.metadata.created_at }}",
        "updated_at": "{{ record.metadata.updated_at }}"
      },
      "schema": "schemas/pipelines.json"
    },
    {
      "name": "agents",
      "path": "/agents",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record._id }}",
        "name": "{{ record.name }}",
        "version": "{{ record.version }}",
        "status": "{{ record.status }}",
        "created_at": "{{ record.created_at }}"
      },
      "schema": "schemas/agents.json"
    },
    {
      "name": "contexts",
      "path": "/contexts",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.metadata.name }}",
        "name": "{{ record.metadata.name }}",
        "type": "{{ record.type }}",
        "owner": "{{ record.owner }}"
      },
      "schema": "schemas/contexts.json"
    }
  ]
}
