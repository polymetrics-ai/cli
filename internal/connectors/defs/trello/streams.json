{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "key", "value": "{{ secrets.key }}" }
    ],
    "pagination": { "type": "none" },
    "check": {
      "method": "GET",
      "path": "/members/me",
      "query": {
        "fields": "id",
        "token": "{{ secrets.token }}"
      }
    },
    "error_map": [
      { "status": 401, "hint": "trello key/token is missing or invalid; re-run pm credentials add trello" },
      { "status": 429, "class": "rate_limited", "hint": "trello rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "boards",
      "path": "/members/me/boards",
      "query": { "token": "{{ secrets.token }}" },
      "records": { "path": "" },
      "schema": "schemas/boards.json"
    },
    {
      "name": "lists",
      "path": "/boards/{{ fanout.id }}/lists",
      "query": { "token": "{{ secrets.token }}" },
      "records": { "path": "" },
      "fan_out": {
        "ids_from": { "config_key": "board_ids" },
        "into": { "path_var": "board_id" },
        "stamp_field": "idBoard"
      },
      "schema": "schemas/lists.json"
    },
    {
      "name": "checklists",
      "path": "/boards/{{ fanout.id }}/checklists",
      "query": { "token": "{{ secrets.token }}" },
      "records": { "path": "" },
      "fan_out": {
        "ids_from": { "config_key": "board_ids" },
        "into": { "path_var": "board_id" },
        "stamp_field": "idBoard"
      },
      "schema": "schemas/checklists.json"
    }
  ]
}
