{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "perPage",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/account/~" },
    "error_map": [
      { "status": 401, "hint": "ringcentral access_token is missing, expired, or invalid; re-run pm credentials add ringcentral" },
      { "status": 403, "hint": "ringcentral account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "ringcentral rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "extensions",
      "path": "/account/~/extension",
      "records": { "path": "records" },
      "query": {
        "dateFrom": { "template": "{{ config.dateFrom }}", "omit_when_absent": true },
        "dateTo": { "template": "{{ config.dateTo }}", "omit_when_absent": true },
        "type": { "template": "{{ config.type }}", "omit_when_absent": true },
        "messageType": { "template": "{{ config.messageType }}", "omit_when_absent": true },
        "direction": { "template": "{{ config.direction }}", "omit_when_absent": true }
      },
      "computed_fields": {
        "extension_number": "{{ record.extensionNumber }}",
        "stream": "extensions"
      },
      "schema": "schemas/extensions.json"
    },
    {
      "name": "call_log",
      "path": "/account/~/extension/~/call-log",
      "records": { "path": "records" },
      "query": {
        "dateFrom": { "template": "{{ config.dateFrom }}", "omit_when_absent": true },
        "dateTo": { "template": "{{ config.dateTo }}", "omit_when_absent": true },
        "type": { "template": "{{ config.type }}", "omit_when_absent": true },
        "messageType": { "template": "{{ config.messageType }}", "omit_when_absent": true },
        "direction": { "template": "{{ config.direction }}", "omit_when_absent": true }
      },
      "computed_fields": {
        "start_time": "{{ record.startTime }}",
        "stream": "call_log"
      },
      "schema": "schemas/call_log.json"
    },
    {
      "name": "messages",
      "path": "/account/~/extension/~/message-store",
      "records": { "path": "records" },
      "query": {
        "dateFrom": { "template": "{{ config.dateFrom }}", "omit_when_absent": true },
        "dateTo": { "template": "{{ config.dateTo }}", "omit_when_absent": true },
        "type": { "template": "{{ config.type }}", "omit_when_absent": true },
        "messageType": { "template": "{{ config.messageType }}", "omit_when_absent": true },
        "direction": { "template": "{{ config.direction }}", "omit_when_absent": true }
      },
      "computed_fields": {
        "creation_time": "{{ record.creationTime }}",
        "stream": "messages"
      },
      "schema": "schemas/messages.json"
    },
    {
      "name": "contacts",
      "path": "/account/~/extension/~/address-book/contact",
      "records": { "path": "records" },
      "query": {
        "dateFrom": { "template": "{{ config.dateFrom }}", "omit_when_absent": true },
        "dateTo": { "template": "{{ config.dateTo }}", "omit_when_absent": true },
        "type": { "template": "{{ config.type }}", "omit_when_absent": true },
        "messageType": { "template": "{{ config.messageType }}", "omit_when_absent": true },
        "direction": { "template": "{{ config.direction }}", "omit_when_absent": true }
      },
      "computed_fields": {
        "first_name": "{{ record.firstName }}",
        "last_name": "{{ record.lastName }}",
        "stream": "contacts"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "devices",
      "path": "/account/~/device",
      "records": { "path": "records" },
      "query": {
        "dateFrom": { "template": "{{ config.dateFrom }}", "omit_when_absent": true },
        "dateTo": { "template": "{{ config.dateTo }}", "omit_when_absent": true },
        "type": { "template": "{{ config.type }}", "omit_when_absent": true },
        "messageType": { "template": "{{ config.messageType }}", "omit_when_absent": true },
        "direction": { "template": "{{ config.direction }}", "omit_when_absent": true }
      },
      "computed_fields": { "stream": "devices" },
      "schema": "schemas/devices.json"
    }
  ]
}
