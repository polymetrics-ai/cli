{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "none" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100,
      "max_pages": 3
    },
    "check": { "method": "GET", "path": "/pokemon", "query": { "limit": "1", "offset": "0" } },
    "error_map": [
      { "status": 429, "class": "rate_limited", "hint": "pokeapi rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "pokemon",
      "path": "/pokemon",
      "records": { "path": "results" },
      "computed_fields": {
        "id": "{{ record.url | last_path_segment }}"
      },
      "schema": "schemas/pokemon.json"
    },
    {
      "name": "types",
      "path": "/type",
      "records": { "path": "results" },
      "computed_fields": {
        "id": "{{ record.url | last_path_segment }}"
      },
      "schema": "schemas/types.json"
    },
    {
      "name": "abilities",
      "path": "/ability",
      "records": { "path": "results" },
      "computed_fields": {
        "id": "{{ record.url | last_path_segment }}"
      },
      "schema": "schemas/abilities.json"
    },
    {
      "name": "moves",
      "path": "/move",
      "records": { "path": "results" },
      "computed_fields": {
        "id": "{{ record.url | last_path_segment }}"
      },
      "schema": "schemas/moves.json"
    }
  ]
}
