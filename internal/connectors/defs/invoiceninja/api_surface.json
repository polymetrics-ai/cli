{
  "api": "Invoice Ninja v5 API (https://invoicing.co/api/v1)",
  "docs": "https://api-docs.invoicing.co/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; the full Invoice Ninja surface (invoice sending/reminders, recurring invoices, tasks, expenses, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/clients", "covered_by": { "stream": "clients" } },
    { "method": "GET", "path": "/invoices", "covered_by": { "stream": "invoices" } },
    { "method": "GET", "path": "/products", "covered_by": { "stream": "products" } },
    { "method": "GET", "path": "/payments", "covered_by": { "stream": "payments" } },
    { "method": "GET", "path": "/quotes", "covered_by": { "stream": "quotes" } },
    { "method": "POST", "path": "/invoices/{id}/email", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/tasks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/expenses", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "DELETE", "path": "/clients/{id}", "excluded": { "category": "destructive_admin", "reason": "destructive delete, not part of a read-only source migration" } }
  ]
}
