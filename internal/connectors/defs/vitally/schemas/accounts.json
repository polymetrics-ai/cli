{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accounts",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updatedAt",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "createdAt": { "type": ["string", "null"], "format": "date-time" },
    "updatedAt": { "type": ["string", "null"], "format": "date-time" },
    "externalId": { "type": ["string", "null"] },
    "name": { "type": ["string", "null"] },
    "traits": { "type": ["object", "null"], "description": "Arbitrary Vitally account trait bag, passed through unchanged (legacy: vitally.go:84 maps traits verbatim, no per-field projection)." },
    "organizationId": { "type": ["string", "null"] },
    "accountOwnerId": { "type": ["string", "null"] },
    "csmId": { "type": ["string", "null"] },
    "accountExecutiveId": { "type": ["string", "null"] },
    "healthScore": { "type": ["number", "null"] },
    "npsScore": { "type": ["number", "null"] },
    "npsDetractorCount": { "type": ["integer", "null"] },
    "npsPassiveCount": { "type": ["integer", "null"] },
    "npsPromoterCount": { "type": ["integer", "null"] },
    "usersCount": { "type": ["integer", "null"] },
    "firstSeenTimestamp": { "type": ["string", "null"], "format": "date-time" },
    "lastSeenTimestamp": { "type": ["string", "null"], "format": "date-time" },
    "lastInboundMessageTimestamp": { "type": ["string", "null"], "format": "date-time" },
    "lastOutboundMessageTimestamp": { "type": ["string", "null"], "format": "date-time" },
    "trialEndDate": { "type": ["string", "null"], "format": "date-time" },
    "nextRenewalDate": { "type": ["string", "null"], "format": "date-time" },
    "churnedAt": { "type": ["string", "null"], "format": "date-time" },
    "keyRoles": { "type": ["array", "null"], "description": "Array of {vitallyUser, keyRole} objects, passed through unchanged." },
    "segments": { "type": ["array", "null"], "description": "Array of {id, name} segment objects, passed through unchanged." }
  }
}
