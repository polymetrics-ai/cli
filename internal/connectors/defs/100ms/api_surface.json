    { "method": "GET", "path": "/v2/recordings", "covered_by": { "stream": "recordings" } },
    { "method": "GET", "path": "/v2/templates", "covered_by": { "stream": "templates" } },
    { "method": "POST", "path": "/v2/rooms", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v2/rooms/{room_id}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v2/room-codes/room/{room_id}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/active-rooms", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v2/webhooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/policy", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
