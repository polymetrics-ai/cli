{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.management_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "start",
      "token_path": "last"
    },
    "check": { "method": "GET", "path": "/rooms" },
    "error_map": [
      { "status": 401, "hint": "100ms management token is missing or invalid; re-run pm credentials add 100ms" },
      { "status": 403, "hint": "100ms management token lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "100ms rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "rooms",
      "path": "/rooms",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/rooms.json"
    },
    {
      "name": "sessions",
      "path": "/sessions",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/sessions.json"
    },
    {
      "name": "recordings",
      "path": "/recordings",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/recordings.json"
    },
    {
      "name": "templates",
      "path": "/templates",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/templates.json"
    }
  ]
}
