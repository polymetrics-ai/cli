{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.management_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "start",
      "token_path": "last"
    },
    "check": { "method": "GET", "path": "/rooms" },
    "error_map": [
      { "status": 401, "hint": "100ms management token is missing or invalid; re-run pm credentials add 100ms" },
      { "status": 403, "hint": "100ms management token lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "100ms rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "rooms",
      "path": "/rooms",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/rooms.json"
    },
    {
      "name": "sessions",
      "path": "/sessions",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/sessions.json"
    },
    {
      "name": "recordings",
      "path": "/recordings",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/recordings.json"
    },
    {
      "name": "templates",
      "path": "/templates",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/templates.json"
    },
    {
      "name": "live_streams",
      "path": "/live-streams",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/live_streams.json"
    },
    {
      "name": "external_streams",
      "path": "/external-streams",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/external_streams.json"
    },
    {
      "name": "recording_assets",
      "path": "/recording-assets",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/recording_assets.json"
    },
    {
      "name": "webhook_events",
      "path": "/analytics/webhooks",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "limit",
        "start_page": 1,
        "page_size": 100
      },
      "records": { "path": "events" },
      "schema": "schemas/webhook_events.json"
    }
  ]
}
