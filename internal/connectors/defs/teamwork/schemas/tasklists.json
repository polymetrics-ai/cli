{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tasklists",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "project_id": {
      "type": ["string", "null"],
      "description": "Stamped by the fan_out dialect from the enclosing project id discovered via the projects listing."
    },
    "milestone-id": { "type": ["string", "null"] },
    "complete": { "type": ["boolean", "null"] }
  }
}
