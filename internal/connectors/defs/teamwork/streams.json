{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.username }}", "password": "{{ secrets.password }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/projects.json" },
    "error_map": [
      { "status": 401, "hint": "teamwork username/password is missing or invalid; re-run pm credentials add teamwork" },
      { "status": 429, "class": "rate_limited", "hint": "teamwork rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects.json",
      "records": { "path": "projects" },
      "computed_fields": {
        "created_at": "{{ record.created-on }}"
      },
      "schema": "schemas/projects.json"
    }
  ]
}
