{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.username }}", "password": "{{ secrets.password }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/projects.json" },
    "error_map": [
      { "status": 401, "hint": "teamwork username/password is missing or invalid; re-run pm credentials add teamwork" },
      { "status": 429, "class": "rate_limited", "hint": "teamwork rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects.json",
      "records": { "path": "projects" },
      "computed_fields": {
        "created_at": "{{ record.created-on }}"
      },
      "schema": "schemas/projects.json"
    },
    {
      "name": "people",
      "path": "/people.json",
      "records": { "path": "people" },
      "computed_fields": {
        "first_name": "{{ record.first-name }}",
        "last_name": "{{ record.last-name }}"
      },
      "schema": "schemas/people.json"
    },
    {
      "name": "companies",
      "path": "/companies.json",
      "records": { "path": "companies" },
      "schema": "schemas/companies.json"
    },
    {
      "name": "tags",
      "path": "/tags.json",
      "records": { "path": "tags" },
      "schema": "schemas/tags.json"
    },
    {
      "name": "time_entries",
      "path": "/time_entries.json",
      "records": { "path": "time-entries" },
      "computed_fields": {
        "created_at": "{{ record.created-at }}",
        "person_id": "{{ record.person-id }}",
        "project_id": "{{ record.project-id }}",
        "todo_item_id": "{{ record.todo-item-id }}"
      },
      "schema": "schemas/time_entries.json"
    },
    {
      "name": "tasklists",
      "path": "/projects/{{ fanout.id }}/tasklists.json",
      "records": { "path": "todo-lists" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/projects.json", "records_path": "projects", "id_field": "id" }
        },
        "into": { "path_var": "project_id" },
        "stamp_field": "project_id"
      },
      "schema": "schemas/tasklists.json"
    },
    {
      "name": "milestones",
      "path": "/projects/{{ fanout.id }}/milestones.json",
      "records": { "path": "milestones" },
      "computed_fields": {
        "created_at": "{{ record.created-on }}"
      },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/projects.json", "records_path": "projects", "id_field": "id" }
        },
        "into": { "path_var": "project_id" },
        "stamp_field": "project_id"
      },
      "schema": "schemas/milestones.json"
    },
    {
      "name": "tasks",
      "path": "/tasks.json",
      "records": { "path": "todo-items" },
      "computed_fields": {
        "created_at": "{{ record.created-on }}"
      },
      "schema": "schemas/tasks.json"
    }
  ]
}
