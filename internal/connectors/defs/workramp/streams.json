{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/v1/users",
      "query": { "limit": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "workramp api_key is missing or invalid; re-run pm credentials add workramp" },
      { "status": 403, "hint": "workramp account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "workramp rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/v1/users",
      "records": { "path": "data" },
      "schema": "schemas/users.json"
    },
    {
      "name": "groups",
      "path": "/v1/groups",
      "records": { "path": "data" },
      "schema": "schemas/groups.json"
    },
    {
      "name": "courses",
      "path": "/v1/courses",
      "records": { "path": "data" },
      "schema": "schemas/courses.json"
    }
  ]
}
