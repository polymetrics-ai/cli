{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 0,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/api/v1/users",
      "query": { "limit": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "workramp api_key is missing or invalid; re-run pm credentials add workramp" },
      { "status": 403, "hint": "workramp account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "workramp rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/api/v1/users",
      "records": { "path": "" },
      "projection": "passthrough",
      "schema": "schemas/users.json"
    },
    {
      "name": "groups",
      "path": "/api/v1/groups",
      "pagination": { "type": "none" },
      "records": { "path": "" },
      "projection": "passthrough",
      "schema": "schemas/groups.json"
    },
    {
      "name": "courses",
      "path": "/api/v1/guides",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 20
      },
      "records": { "path": "data.guides" },
      "projection": "passthrough",
      "schema": "schemas/courses.json"
    },
    {
      "name": "resources",
      "path": "/api/v1/resources",
      "pagination": { "type": "none" },
      "records": { "path": "resources" },
      "projection": "passthrough",
      "schema": "schemas/resources.json"
    },
    {
      "name": "scorm_courses",
      "path": "/api/v1/scorms",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 20
      },
      "records": { "path": "data.scorms" },
      "projection": "passthrough",
      "schema": "schemas/scorm_courses.json"
    }
  ]
}
