{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "courses",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": ["string", "null"] },
    "num_total_tasks": { "type": ["integer", "null"] },
    "num_total_test_questions": { "type": ["integer", "null"] },
    "created_at": { "type": ["number", "null"] },
    "updated_at": { "type": ["number", "null"] },
    "tags": { "type": ["array", "null"], "items": { "type": "string" } }
  }
}
