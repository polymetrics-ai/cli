{
  "api": "WorkRamp API (https://developers.workramp.com/)",
  "docs": "https://developers.workramp.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 3 legacy-parity read streams only, matching internal/connectors/workramp's exact endpoint set; the full WorkRamp surface (user/group/course mutation, enrollments, assessments) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/v1/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/v1/groups", "covered_by": { "stream": "groups" } },
    { "method": "GET", "path": "/v1/courses", "covered_by": { "stream": "courses" } },
    { "method": "POST", "path": "/v1/users", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v1/groups", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/enrollments", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/assessments", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
