{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "docs_groups",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "handle": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "displayOrder": {
      "type": "integer"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published"
      ]
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Summary of a documentation page (used in lists)",
        "properties": {
          "id": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "depth": {
            "type": "integer"
          },
          "displayOrder": {
            "type": "integer"
          },
          "publishedAt": {
            "type": "string",
            "format": "date-time"
          },
          "children": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "A documentation group within a collection"
}
