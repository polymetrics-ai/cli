{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "apps",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "required": [
    "id",
    "name",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "iconUrl": {
      "type": "string",
      "format": "uri"
    },
    "slug": {
      "type": "string"
    },
    "development": {
      "type": "boolean"
    },
    "apiClientId": {
      "type": "string",
      "description": "The client ID for the app on the platform (such as Shopify)."
    },
    "platform": {
      "type": "string",
      "description": "The platform type (e.g., 'shopify', 'web')."
    }
  }
}
