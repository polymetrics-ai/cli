{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "synced_emails_id_messages",
  "type": "object",
  "properties": {
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "externalId": {
            "type": "string",
            "description": "External message ID from the email provider."
          },
          "fromEmail": {
            "type": "string"
          },
          "fromName": {
            "type": "string"
          },
          "toEmails": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "ccEmails": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "bccEmails": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "subject": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "bodyText": {
            "type": "string",
            "description": "Plain text body of the email."
          },
          "bodyHtml": {
            "type": "string",
            "description": "HTML body of the email."
          },
          "date": {
            "type": "string",
            "description": "When the email was sent/received.",
            "format": "date-time"
          },
          "isInbound": {
            "type": "boolean",
            "description": "Whether the email was received (true) or sent (false)."
          },
          "labelIds": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
