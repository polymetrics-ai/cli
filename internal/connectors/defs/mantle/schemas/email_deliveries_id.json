{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "email_deliveries_id",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "emailId": {
      "type": "string"
    },
    "email": {
      "type": "object"
    },
    "status": {
      "type": "string"
    },
    "audienceSize": {
      "type": "integer"
    },
    "audienceCriteria": {
      "type": "object"
    },
    "error": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "stats": {
      "type": "object",
      "properties": {
        "total": {
          "type": "integer"
        },
        "sent": {
          "type": "integer"
        },
        "delivered": {
          "type": "integer"
        },
        "failed": {
          "type": "integer"
        },
        "pending": {
          "type": "integer"
        },
        "opened": {
          "type": "integer"
        },
        "clicked": {
          "type": "integer"
        },
        "bounced": {
          "type": "integer"
        },
        "unsubscribed": {
          "type": "integer"
        },
        "complained": {
          "type": "integer"
        }
      }
    },
    "recentEvents": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recentDeliveries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
