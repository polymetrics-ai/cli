  "title": "docs_pages",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "handle": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "depth": {
      "type": "integer"
    },
    "displayOrder": {
      "type": "integer"
    },
    "publishedAt": {
      "type": "string",
