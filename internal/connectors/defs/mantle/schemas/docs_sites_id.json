{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "docs_sites_id",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "handle": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "description": "The public URL where this site is hosted"
    },
    "defaultLocale": {
      "type": "string"
    },
    "supportedLocales": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "title": {
      "type": "string"
    },
    "shortDescription": {
      "type": "string"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "internal"
      ]
    },
    "customDomain": {
      "type": [
        "string",
        "null"
      ]
    },
    "useCustomDomain": {
      "type": "boolean"
    },
    "customDomainVerifiedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "widgetId": {
      "type": [
        "string",
        "null"
      ]
    },
    "config": {
      "type": "object",
      "description": "Site layout and theme configuration"
    },
    "locales": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "shortDescription": {
            "type": "string"
          }
        }
      }
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "A repository attached to a docs site",
        "properties": {
          "id": {
            "type": "string"
          },
          "repositoryId": {
            "type": "string"
          },
          "position": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "repository": {
            "type": "object",
            "description": "Minimal repository summary (only present when includeRepository=true)",
            "properties": {
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "handle": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "A documentation site grouping one or more documentation repositories"
}
