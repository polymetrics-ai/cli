{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "docs_sites_id_repositories",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "repositoryId": {
      "type": "string"
    },
    "position": {
      "type": "integer"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "object",
      "description": "Minimal repository summary (only present when includeRepository=true)",
      "properties": {
        "id": {
          "type": "string"
        },
        "handle": {
          "type": "string"
        }
      }
    }
  },
  "description": "A repository attached to a docs site"
}
