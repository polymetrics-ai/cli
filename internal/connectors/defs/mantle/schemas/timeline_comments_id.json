{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "timeline_comments_id",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "comment": {
      "type": "string",
      "description": "Plain text version of the comment"
    },
    "commentHtml": {
      "type": "string",
      "description": "HTML version of the comment"
    },
    "appInstallationId": {
      "type": [
        "string",
        "null"
      ]
    },
    "customerId": {
      "type": [
        "string",
        "null"
      ]
    },
    "dealId": {
      "type": [
        "string",
        "null"
      ]
    },
    "userId": {
      "type": [
        "string",
        "null"
      ]
    },
    "user": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "originalCommentId": {
      "type": [
        "string",
        "null"
      ],
      "description": "ID of the original comment if this is an edited version"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fileName": {
            "type": "string"
          },
          "fileType": {
            "type": "string"
          },
          "fileSize": {
            "type": "integer"
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "taggedUsers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
