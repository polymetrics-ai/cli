{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "synced_emails_id",
  "type": "object",
  "x-primary-key": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique identifier for the synced email thread."
    },
    "externalId": {
      "type": "string",
      "description": "External thread ID from the email provider (e.g., Gmail thread ID)."
    },
    "subject": {
      "type": "string",
      "description": "Email thread subject line."
    },
    "snippet": {
      "type": "string",
      "description": "Preview snippet of the email thread."
    },
    "source": {
      "type": "string",
      "description": "Source of the synced email (gmail, outlook, manual)."
    },
    "lastMessageAt": {
      "type": "string",
      "description": "Timestamp of the most recent message in the thread.",
      "format": "date-time"
    },
    "messageCount": {
      "type": "integer",
      "description": "Number of messages in the thread."
    },
    "contact": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "customer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "deal": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "syncedBy": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "externalId": {
            "type": "string",
            "description": "External message ID from the email provider."
          },
          "fromEmail": {
            "type": "string"
          },
          "fromName": {
            "type": "string"
          },
          "toEmails": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "ccEmails": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "bccEmails": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "subject": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "bodyText": {
            "type": "string",
            "description": "Plain text body of the email."
          },
          "bodyHtml": {
            "type": "string",
            "description": "HTML body of the email."
          },
          "date": {
            "type": "string",
            "description": "When the email was sent/received.",
            "format": "date-time"
          },
          "isInbound": {
            "type": "boolean",
            "description": "Whether the email was received (true) or sent (false)."
          },
          "labelIds": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "description": "Creation timestamp.",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "description": "Last update timestamp.",
      "format": "date-time"
    }
  }
}
