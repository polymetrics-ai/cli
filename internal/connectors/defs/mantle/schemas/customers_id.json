                "type": [
                  "number",
                  "null"
                ]
              },
              "appliedDiscount": {
                "type": "object"
              },
              "subtotal": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "total": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "presentmentSubtotal": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "presentmentTotal": {
                "type": [
                  "number",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "companyId": {
      "type": "string",
      "description": "The ID of the company this customer belongs to, if any."
    },
    "industry": {
      "type": [
        "string",
        "null"
      ],
      "description": "The industry classification of the customer. Falls back to ShopifyShop industry if not set directly."
    },
    "createdAt": {
      "type": "string",
      "description": "The date and time of the creation of the customer.",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "description": "The date and time of the last update to the customer.",
      "format": "date-time"
    },
    "contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "The label for the contact for this customer. Only set in customer API objects."
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "jobTitle": {
            "type": "string"
          },
          "customers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "The customer ID"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          },
          "notes": {
            "type": "string"
          },
          "socialProfiles": {
            "type": "array",
            "description": "Array of JSON objects containing social links or profiles.",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string",
                  "description": "The type of social profile.",
                  "enum": [
                    "linkedin",
                    "x",
                    "facebook",
                    "instagram",
                    "website"
                  ]
                },
                "value": {
                  "type": "string",
                  "description": "The URL of the social profile."
                }
              }
            }
          },
          "secondaryEmails": {
            "type": "array",
            "description": "Array of secondary email addresses for the contact.",
            "items": {
              "type": "string",
              "format": "email"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      }
    },
    "accountOwners": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "description": "The type of account owner relationship",
            "enum": [
              "account_manager",
              "sales",
              "customer_support"
            ]
          },
          "hasCommission": {
            "type": "boolean",
            "description": "Whether this account owner has commission enabled"
          },
          "commissionPercentage": {
            "type": [
              "number",
              "null"
            ],
            "description": "The commission percentage for this account owner"
          },
          "commissionEndsAt": {
            "type": [
              "string",
              "null"
            ],
            "description": "When the commission ends for this account owner",
            "format": "date-time"
          },
          "managementFeePercentage": {
            "type": [
              "number",
              "null"
            ],
            "description": "The management fee percentage for this account owner. When set, the owner earns this percentage of MRR as a management fee when not actively earning commission."
          },
          "appCommissions": {
            "type": "array",
            "description": "Per-app commission overrides. When set, these rates apply instead of the customer-level commission for transactions from the specified app.",
            "items": {
              "type": "object"
            }
          },
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "email": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "deals": {
      "type": "array",
      "description": "Lightweight summaries of the customer's non-archived deals. Use the Deals endpoints for full details.",
      "items": {
        "type": "object",
        "description": "A lightweight deal summary embedded in customer responses. For full deal details, use the Deals endpoints.",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "format": "float"
          },
          "amountCurrencyCode": {
            "type": "string"
          },
          "firstInteractionAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "closingAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "closedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "dealStage": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "stage": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
