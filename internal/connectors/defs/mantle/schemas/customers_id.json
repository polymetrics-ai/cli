                "type": [
                  "string",
                  "null"
                ]
              },
              "trialExpiresAt": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "activatedAt": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "canceledAt": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "frozenAt": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "features": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "featuresOrder": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "createdAt": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "confirmationUrl": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "shopifySubscription": {
                "type": "object"
              },
              "usageCappedAmount": {
                "type": [
                  "number",
                  "null"
                ]
              },
