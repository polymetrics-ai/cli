            "type": "object",
            "properties": {
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "displayName": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "createdAt": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "iconUrl": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "slug": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "development": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "apiClientId": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "platform": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "id",
              "name",
              "createdAt"
            ]
          },
          "averageMonthlyRevenue": {
            "type": "number"
          },
          "lifetimeValue": {
            "type": "number"
          },
          "last30Revenue": {
            "type": "number"
          },
          "customFields": {
            "type": "object",
            "description": "An object of custom fields, keyed by the custom field name."
          },
          "churnPrediction": {
            "type": "number",
            "description": "The churn prediction for the customer. 0 being high risk, 3 being low risk."
          },
          "churnPredictionLabel": {
            "type": "object",
            "description": "A label lookup for the churnPrediction, such as { label: \"0 - 2 weeks\", status: \"critical\" } for churnPrediction 0."
          },
          "platformId": {
            "type": "string",
            "description": "The ID of the customer on the platform, such as the Shopify Shop ID."
          },
          "trafficSource": {
            "type": "string",
            "description": "The original traffic source of the customer, if available."
          },
          "subscription": {
            "type": "object",
            "properties": {
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "plan": {
                "type": "object"
              },
              "lineItems": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "active": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "cancelOn": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "billingCycleAnchor": {
                "type": [
