{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "next_token",
      "token_path": "meta.next_token"
    },
    "check": { "method": "GET", "path": "/tweets/search/recent", "query": { "query": "{{ config.query }}", "max_results": "10" } },
    "error_map": [
      { "status": 401, "hint": "twitter API bearer token is missing or invalid; re-run pm credentials add twitter" },
      { "status": 403, "hint": "twitter account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "twitter rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "tweets",
      "path": "/tweets/search/recent",
      "query": {
        "query": "{{ config.query }}",
        "max_results": "{{ config.page_size }}",
        "tweet.fields": "id,text,author_id,created_at,conversation_id,lang,source,in_reply_to_user_id,possibly_sensitive,public_metrics",
        "expansions": "author_id",
        "user.fields": "id,name,username,created_at,description,location,verified,protected,url,public_metrics",
        "start_time": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_time": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "schema": "schemas/tweets.json"
    },
    {
      "name": "authors",
      "path": "/tweets/search/recent",
      "query": {
        "query": "{{ config.query }}",
        "max_results": "{{ config.page_size }}",
        "tweet.fields": "id,text,author_id,created_at,conversation_id,lang,source,in_reply_to_user_id,possibly_sensitive,public_metrics",
        "expansions": "author_id",
        "user.fields": "id,name,username,created_at,description,location,verified,protected,url,public_metrics",
        "start_time": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_time": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "includes.users" },
      "schema": "schemas/authors.json"
    }
  ]
}
