{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "weather_current",
  "type": "object",
  "x-primary-key": ["datetime", "latitude", "longitude"],
  "x-cursor-field": "datetime",
  "required": ["datetime", "latitude", "longitude"],
  "properties": {
    "datetime": { "type": "string" },
    "latitude": { "type": "string" },
    "longitude": { "type": "string" },
    "data_available": { "type": ["boolean", "null"] },
    "temperature": { "type": ["object", "null"] },
    "feels_like_temperature": { "type": ["object", "null"] },
    "relative_humidity": { "type": ["integer", "null"] },
    "wind": { "type": ["object", "null"] },
    "precipitation": { "type": ["object", "null"] },
    "weather_condition": { "type": ["object", "null"] }
  }
}
