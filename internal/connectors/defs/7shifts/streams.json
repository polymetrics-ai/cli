{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "meta.cursor.next"
    },
    "check": { "method": "GET", "path": "/v2/companies", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "7shifts access_token is missing or invalid; re-run pm credentials add 7shifts" },
      { "status": 403, "hint": "7shifts account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "7shifts rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "companies",
      "path": "/v2/companies",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/companies.json"
    },
    {
      "name": "locations",
      "path": "/v2/company/{{ config.company_id }}/locations",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/locations.json"
    },
    {
      "name": "departments",
      "path": "/v2/company/{{ config.company_id }}/departments",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/departments.json"
    },
    {
      "name": "roles",
      "path": "/v2/company/{{ config.company_id }}/roles",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/roles.json"
    },
    {
      "name": "users",
      "path": "/v2/company/{{ config.company_id }}/users",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/users.json"
    },
    {
      "name": "shifts",
      "path": "/v2/company/{{ config.company_id }}/shifts",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/shifts.json"
    },
    {
      "name": "time_punches",
      "path": "/v2/company/{{ config.company_id }}/time_punches",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/time_punches.json"
    }
  ]
}
