{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "cursor",
      "token_path": "meta.cursor.next"
    },
    "check": {
      "method": "GET",
      "path": "/v2/companies",
      "query": {
        "limit": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "7shifts access_token is missing or invalid; re-run pm credentials add 7shifts"
      },
      {
        "status": 403,
        "hint": "7shifts account lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "7shifts rate limit exceeded; retry after the API limit resets"
      }
    ]
  },
  "streams": [
    {
      "name": "companies",
      "path": "/v2/companies",
      "query": {
        "limit": "100"
      },
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "modified",
        "request_param": "modified_since",
        "param_format": "date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/companies.json"
    },
