{
  "api": "7shifts API v2 (https://api.7shifts.com/v2)",
  "docs": "https://developers.7shifts.com/reference",
  "reviewed_at": "2026-07-03",
  "scope": "migration parity: the 7 legacy-parity read streams only, matching internal/connectors/7shifts capability-for-capability; 7shifts is read-only in this connector (no reverse-ETL write surface implemented) and the broader 7shifts surface (schedules, time-off, availability, wage/labor cost endpoints, punch edit requests, etc.) is out of scope until a future capability-expansion pass",
  "endpoints": [
    { "method": "GET", "path": "/v2/companies", "covered_by": { "stream": "companies" } },
    { "method": "GET", "path": "/v2/company/{company_id}/locations", "covered_by": { "stream": "locations" } },
    { "method": "GET", "path": "/v2/company/{company_id}/departments", "covered_by": { "stream": "departments" } },
    { "method": "GET", "path": "/v2/company/{company_id}/roles", "covered_by": { "stream": "roles" } },
    { "method": "GET", "path": "/v2/company/{company_id}/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/v2/company/{company_id}/shifts", "covered_by": { "stream": "shifts" } },
    { "method": "GET", "path": "/v2/company/{company_id}/time_punches", "covered_by": { "stream": "time_punches" } },
    { "method": "GET", "path": "/v2/company/{company_id}/schedules", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/company/{company_id}/time_off", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/company/{company_id}/availability", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/company/{company_id}/wages", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/company/{company_id}/punch_edit_requests", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/v2/company/{company_id}/shifts", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
