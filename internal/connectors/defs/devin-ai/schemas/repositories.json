{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "repositories",
  "type": "object",
  "x-primary-key": ["repo_path"],
  "required": ["repo_path"],
  "properties": {
    "repo_path": { "type": "string" },
    "repo_name": { "type": ["string", "null"] },
    "provider_repository_id": { "type": ["string", "null"] },
    "git_connection_id": { "type": ["string", "null"] },
    "git_connection_host": { "type": ["string", "null"] },
    "repo_description": { "type": ["string", "null"] },
    "repo_language": { "type": ["string", "null"] },
    "last_updated_at": { "type": ["integer", "null"] },
    "indexing_status": { "type": ["object", "null"] }
  }
}
