{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "", "query": { "domain": "{{ config.domains }}" } },
    "error_map": [
      { "status": 401, "hint": "ip2whois api_key is missing or invalid; re-run pm credentials add ip2whois" },
      { "status": 429, "class": "rate_limited", "hint": "ip2whois rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "whois",
      "path": "",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": { "config_key": "domains" },
        "into": { "query_param": "domain" }
      },
      "computed_fields": {
        "registrar_iana_id": "{{ record.registrar.iana_id }}",
        "registrar_name": "{{ record.registrar.name }}",
        "registrar_url": "{{ record.registrar.url }}",
        "registrant_name": "{{ record.registrant.name }}",
        "registrant_organization": "{{ record.registrant.organization }}",
        "registrant_email": "{{ record.registrant.email }}",
        "registrant_country": "{{ record.registrant.country }}",
        "admin_name": "{{ record.admin.name }}",
        "admin_email": "{{ record.admin.email }}",
        "tech_name": "{{ record.tech.name }}",
        "tech_email": "{{ record.tech.email }}",
        "billing_name": "{{ record.billing.name }}",
        "billing_email": "{{ record.billing.email }}",
        "nameservers": "{{ record.nameservers | join:, }}"
      },
      "schema": "schemas/whois.json"
    },
    {
      "name": "contacts_registrant",
      "path": "",
      "records": { "path": "registrant" },
      "fan_out": {
        "ids_from": { "config_key": "domains" },
        "into": { "query_param": "domain" },
        "stamp_field": "domain"
      },
      "computed_fields": {
        "role": "registrant"
      },
      "schema": "schemas/contacts_registrant.json"
    },
    {
      "name": "contacts_admin",
      "path": "",
      "records": { "path": "admin" },
      "fan_out": {
        "ids_from": { "config_key": "domains" },
        "into": { "query_param": "domain" },
        "stamp_field": "domain"
      },
      "computed_fields": {
        "role": "admin"
      },
      "schema": "schemas/contacts_admin.json"
    },
    {
      "name": "contacts_tech",
      "path": "",
      "records": { "path": "tech" },
      "fan_out": {
        "ids_from": { "config_key": "domains" },
        "into": { "query_param": "domain" },
        "stamp_field": "domain"
      },
      "computed_fields": {
        "role": "tech"
      },
      "schema": "schemas/contacts_tech.json"
    },
    {
      "name": "contacts_billing",
      "path": "",
      "records": { "path": "billing" },
      "fan_out": {
        "ids_from": { "config_key": "domains" },
        "into": { "query_param": "domain" },
        "stamp_field": "domain"
      },
      "computed_fields": {
        "role": "billing"
      },
      "schema": "schemas/contacts_billing.json"
    }
  ]
}
