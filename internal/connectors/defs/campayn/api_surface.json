{
  "api": "Campayn REST API v1 (https://<sub_domain>.campayn.com/api/v1)",
  "docs": "https://github.com/nebojsac/Campayn-API",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration, completed: all 5 legacy streams (lists, emails, reports, forms, contacts) are now migrated; forms/contacts use the engine's fan_out dialect to reproduce legacy's per-list sub-resource fan-out read",
  "endpoints": [
    { "method": "GET", "path": "/lists.json", "covered_by": { "stream": "lists" } },
    { "method": "GET", "path": "/emails.json", "covered_by": { "stream": "emails" } },
    { "method": "GET", "path": "/reports/calendar.json", "covered_by": { "stream": "reports" } },
    { "method": "GET", "path": "/lists/{id}/forms.json", "covered_by": { "stream": "forms" } },
    { "method": "GET", "path": "/lists/{id}/contacts.json", "covered_by": { "stream": "contacts" } }
  ]
}
