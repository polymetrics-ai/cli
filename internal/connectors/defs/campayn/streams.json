{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}", "prefix": "TRUEREST apikey=" }
    ],
    "check": { "method": "GET", "path": "/lists.json" },
    "error_map": [
      { "status": 401, "hint": "campayn api_key is missing or invalid; re-run pm credentials add campayn" },
      { "status": 403, "hint": "campayn account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "campayn rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "lists",
      "path": "/lists.json",
      "records": { "path": "" },
      "schema": "schemas/lists.json"
    },
    {
      "name": "emails",
      "path": "/emails.json",
      "records": { "path": "" },
      "schema": "schemas/emails.json"
    },
    {
      "name": "reports",
      "path": "/reports/calendar.json",
      "records": { "path": "" },
      "schema": "schemas/reports.json"
    },
    {
      "name": "forms",
      "path": "/lists/{{ fanout.id }}/forms.json",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/lists.json", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "list_id" },
        "stamp_field": "list_id"
      },
      "schema": "schemas/forms.json"
    },
    {
      "name": "contacts",
      "path": "/lists/{{ fanout.id }}/contacts.json",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/lists.json", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "list_id" },
        "stamp_field": "list_id"
      },
      "schema": "schemas/contacts.json"
    }
  ]
}
