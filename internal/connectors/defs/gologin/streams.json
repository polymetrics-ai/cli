{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "browser/v2" },
    "error_map": [
      { "status": 401, "hint": "gologin api_key is missing or invalid; re-run pm credentials add gologin" },
      { "status": 403, "hint": "gologin account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "gologin rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "profiles",
      "path": "browser/v2",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "",
        "start_page": 1,
        "page_size": 30
      },
      "records": { "path": "profiles" },
      "computed_fields": {
        "id": "{{ record.id }}",
        "name": "{{ record.name }}",
        "notes": "{{ record.notes }}",
        "role": "{{ record.role }}",
        "os": "{{ record.os }}",
        "browserType": "{{ record.browserType }}",
        "folderName": "{{ record.folderName }}",
        "createdAt": "{{ record.createdAt }}",
        "updatedAt": "{{ record.updatedAt }}"
      },
      "schema": "schemas/profiles.json"
    },
    {
      "name": "folders",
      "path": "folders",
      "pagination": { "type": "none" },
      "records": { "path": "." },
      "computed_fields": {
        "id": "{{ record.id }}",
        "name": "{{ record.name }}",
        "profilesCount": "{{ record.profilesCount }}"
      },
      "schema": "schemas/folders.json"
    },
    {
      "name": "user",
      "path": "user",
      "pagination": { "type": "none" },
      "records": { "path": ".", "single_object": true },
      "computed_fields": {
        "_id": "{{ record._id }}",
        "email": "{{ record.email }}",
        "firstName": "{{ record.firstName }}",
        "lastName": "{{ record.lastName }}",
        "plan": "{{ record.plan }}",
        "profilesCount": "{{ record.profilesCount }}",
        "createdAt": "{{ record.createdAt }}"
      },
      "schema": "schemas/user.json"
    },
    {
      "name": "tags",
      "path": "tags/all",
      "pagination": { "type": "none" },
      "records": { "path": "tags" },
      "computed_fields": {
        "_id": "{{ record._id }}",
        "title": "{{ record.title }}",
        "color": "{{ record.color }}",
        "field": "{{ record.field }}"
      },
      "schema": "schemas/tags.json"
    }
  ]
}
