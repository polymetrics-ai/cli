{
  "actions": [
    {
      "name": "send_message",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/messages/send",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["raw"],
        "properties": {
          "raw": { "type": "string", "description": "Entire RFC 2822 message, base64url-encoded, including headers and MIME body." },
          "threadId": { "type": "string", "description": "Existing thread to append this message to; the References/In-Reply-To headers and Subject inside raw must already satisfy Gmail's threading rules." }
        }
      },
      "risk": "sends a real outbound email on behalf of the mailbox owner; irreversible once delivered"
    },
    {
      "name": "insert_message",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/messages",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["raw"],
        "properties": {
          "raw": { "type": "string", "description": "Entire RFC 2822 message, base64url-encoded." },
          "threadId": { "type": "string" },
          "labelIds": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "inserts a message directly into the mailbox without sending it (no SMTP delivery, no notifications) -- still a real, visible mailbox mutation"
    },
    {
      "name": "import_message",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/messages/import",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["raw"],
        "properties": {
          "raw": { "type": "string", "description": "Entire RFC 2822 message, base64url-encoded." },
          "threadId": { "type": "string" },
          "labelIds": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "imports a message into the mailbox from an external mail migration source, bypassing spam classification by default"
    },
    {
      "name": "modify_message",
      "kind": "update",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/messages/{{ record.id }}/modify",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "minProperties": 2,
        "properties": {
          "id": { "type": "string" },
          "addLabelIds": { "type": "array", "items": { "type": "string" } },
          "removeLabelIds": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "changes label state on an existing message (e.g. moving in/out of INBOX/TRASH/UNREAD), visible to the mailbox owner"
    },
    {
      "name": "trash_message",
      "kind": "update",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/messages/{{ record.id }}/trash",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "moves a message to Trash; auto-purged by Gmail after 30 days"
    },
    {
      "name": "untrash_message",
      "kind": "update",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/messages/{{ record.id }}/untrash",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "restores a trashed message back to its prior labels"
    },
    {
      "name": "delete_message",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/messages/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "permanently deletes a message immediately, bypassing Trash; irreversible",
      "confirm": "destructive"
    },
    {
      "name": "modify_thread",
      "kind": "update",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/threads/{{ record.id }}/modify",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "minProperties": 2,
        "properties": {
          "id": { "type": "string" },
          "addLabelIds": { "type": "array", "items": { "type": "string" } },
          "removeLabelIds": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "changes label state on every message in an existing thread"
    },
    {
      "name": "trash_thread",
      "kind": "update",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/threads/{{ record.id }}/trash",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "moves an entire thread to Trash; auto-purged by Gmail after 30 days"
    },
    {
      "name": "untrash_thread",
      "kind": "update",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/threads/{{ record.id }}/untrash",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "restores a trashed thread back to its prior labels"
    },
    {
      "name": "delete_thread",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/threads/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "permanently deletes every message in a thread immediately, bypassing Trash; irreversible",
      "confirm": "destructive"
    },
    {
      "name": "create_draft",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/drafts",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "object",
            "required": ["raw"],
            "properties": {
              "raw": { "type": "string", "description": "Entire RFC 2822 draft message, base64url-encoded." },
              "threadId": { "type": "string" }
            }
          }
        }
      },
      "risk": "creates a new unsent draft, visible to the mailbox owner"
    },
    {
      "name": "update_draft",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/drafts/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "message"],
        "properties": {
          "id": { "type": "string" },
          "message": {
            "type": "object",
            "required": ["raw"],
            "properties": {
              "raw": { "type": "string" },
              "threadId": { "type": "string" }
            }
          }
        }
      },
      "risk": "replaces the entire content of an existing draft"
    },
    {
      "name": "send_draft",
      "kind": "custom",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/drafts/send",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "description": "The draft ID to send (Gmail's drafts.send accepts { \"id\": \"<draftId>\" } as its full request body)." }
        }
      },
      "risk": "sends a real outbound email from an existing draft on behalf of the mailbox owner; irreversible once delivered"
    },
    {
      "name": "delete_draft",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/drafts/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "permanently deletes a draft; irreversible"
    },
    {
      "name": "create_label",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/labels",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "labelListVisibility": { "type": "string", "enum": ["labelShow", "labelShowIfUnread", "labelHide"] },
          "messageListVisibility": { "type": "string", "enum": ["show", "hide"] },
          "color": { "type": "object" }
        }
      },
      "risk": "creates a new custom label visible in the mailbox owner's label list"
    },
    {
      "name": "update_label",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/labels/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "labelListVisibility": { "type": "string", "enum": ["labelShow", "labelShowIfUnread", "labelHide"] },
          "messageListVisibility": { "type": "string", "enum": ["show", "hide"] },
          "color": { "type": "object" }
        }
      },
      "risk": "replaces the full definition of an existing label (name/visibility/color); a system label's name cannot actually be changed by Gmail even though the request is accepted"
    },
    {
      "name": "patch_label",
      "kind": "update",
      "method": "PATCH",
      "path": "/users/{{ config.user_id }}/labels/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "minProperties": 2,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "labelListVisibility": { "type": "string", "enum": ["labelShow", "labelShowIfUnread", "labelHide"] },
          "messageListVisibility": { "type": "string", "enum": ["show", "hide"] },
          "color": { "type": "object" }
        }
      },
      "risk": "partially updates an existing label's fields, leaving unset fields unchanged"
    },
    {
      "name": "delete_label",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/labels/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "removes a user label from the account and from every message/thread that carried it; system labels reject deletion with an error"
    },
    {
      "name": "create_filter",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/settings/filters",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["criteria"],
        "properties": {
          "criteria": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "subject": { "type": "string" },
              "query": { "type": "string" },
              "negatedQuery": { "type": "string" },
              "hasAttachment": { "type": "boolean" },
              "excludeChats": { "type": "boolean" },
              "size": { "type": "integer" },
              "sizeComparison": { "type": "string", "enum": ["unspecified", "smaller", "larger"] }
            }
          },
          "action": {
            "type": "object",
            "properties": {
              "addLabelIds": { "type": "array", "items": { "type": "string" } },
              "removeLabelIds": { "type": "array", "items": { "type": "string" } },
              "forward": { "type": "string" }
            }
          }
        }
      },
      "risk": "creates a mail filter that automatically acts on future incoming messages matching its criteria (may auto-forward mail externally)"
    },
    {
      "name": "delete_filter",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/settings/filters/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      },
      "risk": "removes an existing mail filter; future messages stop being auto-actioned by it"
    },
    {
      "name": "create_send_as",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/settings/sendAs",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["sendAsEmail"],
        "properties": {
          "sendAsEmail": { "type": "string" },
          "displayName": { "type": "string" },
          "replyToAddress": { "type": "string" },
          "signature": { "type": "string" },
          "treatAsAlias": { "type": "boolean" },
          "smtpMsa": { "type": "object" }
        }
      },
      "risk": "adds a new custom From: alias; Google emails a verification link to the new address before it can send mail"
    },
    {
      "name": "update_send_as",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/settings/sendAs/{{ record.sendAsEmail }}",
      "path_fields": ["sendAsEmail"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["sendAsEmail"],
        "properties": {
          "sendAsEmail": { "type": "string" },
          "displayName": { "type": "string" },
          "replyToAddress": { "type": "string" },
          "signature": { "type": "string" },
          "treatAsAlias": { "type": "boolean" },
          "isDefault": { "type": "boolean" },
          "smtpMsa": { "type": "object" }
        }
      },
      "risk": "replaces the full send-as alias configuration, including which alias is the account default"
    },
    {
      "name": "patch_send_as",
      "kind": "update",
      "method": "PATCH",
      "path": "/users/{{ config.user_id }}/settings/sendAs/{{ record.sendAsEmail }}",
      "path_fields": ["sendAsEmail"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["sendAsEmail"],
        "minProperties": 2,
        "properties": {
          "sendAsEmail": { "type": "string" },
          "displayName": { "type": "string" },
          "replyToAddress": { "type": "string" },
          "signature": { "type": "string" },
          "treatAsAlias": { "type": "boolean" },
          "isDefault": { "type": "boolean" },
          "smtpMsa": { "type": "object" }
        }
      },
      "risk": "partially updates an existing send-as alias, leaving unset fields unchanged"
    },
    {
      "name": "delete_send_as",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/settings/sendAs/{{ record.sendAsEmail }}",
      "path_fields": ["sendAsEmail"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["sendAsEmail"],
        "properties": { "sendAsEmail": { "type": "string" } }
      },
      "risk": "removes a custom From: alias (the account's primary address cannot be deleted; Gmail rejects that request)"
    },
    {
      "name": "verify_send_as",
      "kind": "custom",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/settings/sendAs/{{ record.sendAsEmail }}/verify",
      "path_fields": ["sendAsEmail"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["sendAsEmail"],
        "properties": { "sendAsEmail": { "type": "string" } }
      },
      "risk": "re-sends the verification email for a pending custom From: alias"
    },
    {
      "name": "create_delegate",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/settings/delegates",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["delegateEmail"],
        "properties": { "delegateEmail": { "type": "string" } }
      },
      "risk": "grants another account read/send/delete access to this mailbox (Google Workspace accounts only); a significant access-control change"
    },
    {
      "name": "delete_delegate",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/settings/delegates/{{ record.delegateEmail }}",
      "path_fields": ["delegateEmail"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["delegateEmail"],
        "properties": { "delegateEmail": { "type": "string" } }
      },
      "risk": "revokes another account's delegated access to this mailbox"
    },
    {
      "name": "create_forwarding_address",
      "kind": "create",
      "method": "POST",
      "path": "/users/{{ config.user_id }}/settings/forwardingAddresses",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["forwardingEmail"],
        "properties": { "forwardingEmail": { "type": "string" } }
      },
      "risk": "proposes a new external forwarding address; Google emails a verification link before it can be used by update_auto_forwarding"
    },
    {
      "name": "delete_forwarding_address",
      "kind": "delete",
      "method": "DELETE",
      "path": "/users/{{ config.user_id }}/settings/forwardingAddresses/{{ record.forwardingEmail }}",
      "path_fields": ["forwardingEmail"],
      "body_type": "none",
      "delete": { "idempotent": true, "missing_ok_status": [404] },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["forwardingEmail"],
        "properties": { "forwardingEmail": { "type": "string" } }
      },
      "risk": "removes a forwarding address; if it is the account's current auto-forwarding target, forwarding stops"
    },
    {
      "name": "update_auto_forwarding",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/settings/autoForwarding",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["enabled"],
        "properties": {
          "enabled": { "type": "boolean" },
          "emailAddress": { "type": "string", "description": "Must already be a verified forwarding address (see create_forwarding_address) when enabled is true." },
          "disposition": { "type": "string", "enum": ["dispositionUnspecified", "leaveInInbox", "archive", "trash", "markRead"] }
        }
      },
      "risk": "changes the account-wide auto-forwarding singleton; when enabled, silently copies all future incoming mail to an external address"
    },
    {
      "name": "update_vacation",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/settings/vacation",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "enableAutoReply": { "type": "boolean" },
          "responseSubject": { "type": "string" },
          "responseBodyPlainText": { "type": "string" },
          "responseBodyHtml": { "type": "string" },
          "restrictToContacts": { "type": "boolean" },
          "restrictToDomain": { "type": "boolean" },
          "startTime": { "type": "string", "description": "Epoch milliseconds, as a string (Gmail's int64 wire format)." },
          "endTime": { "type": "string", "description": "Epoch milliseconds, as a string (Gmail's int64 wire format)." }
        }
      },
      "risk": "changes the account-wide vacation-responder singleton; when enabled, auto-replies to external senders with the configured message"
    },
    {
      "name": "update_language",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/settings/language",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["displayLanguage"],
        "properties": { "displayLanguage": { "type": "string" } }
      },
      "risk": "changes the Gmail web interface display language for the account"
    },
    {
      "name": "update_imap",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/settings/imap",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "autoExpunge": { "type": "boolean" },
          "expungeBehavior": { "type": "string", "enum": ["expungeBehaviorUnspecified", "archive", "trash", "deleteForever"] },
          "maxFolderSize": { "type": "integer" }
        }
      },
      "risk": "changes the account-wide IMAP-access singleton; disabling breaks any external IMAP client currently connected"
    },
    {
      "name": "update_pop",
      "kind": "update",
      "method": "PUT",
      "path": "/users/{{ config.user_id }}/settings/pop",
