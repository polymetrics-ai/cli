{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "api_key", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/planetary/apod" },
    "error_map": [
      { "status": 401, "hint": "nasa api_key is missing or invalid; re-run pm credentials add nasa" },
      { "status": 403, "hint": "nasa api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "nasa rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "apod",
      "path": "/planetary/apod",
      "query": {
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true },
        "count": { "template": "{{ config.count }}", "omit_when_absent": true },
        "thumbs": { "template": "{{ config.thumbs }}", "omit_when_absent": true }
      },
      "records": { "path": "" },
      "schema": "schemas/apod.json"
    },
    {
      "name": "neo_feed",
      "path": "/neo/rest/v1/feed",
      "query": {
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true },
        "end_date": { "template": "{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "near_earth_objects" },
      "schema": "schemas/neo_feed.json"
    },
    {
      "name": "neo_browse",
      "path": "/neo/rest/v1/neo/browse",
      "records": { "path": "near_earth_objects" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "",
        "start_page": 0,
        "page_size": 20
      },
      "schema": "schemas/neo_browse.json"
    },
    {
      "name": "epic",
      "path": "/EPIC/api/natural",
      "records": { "path": "" },
      "schema": "schemas/epic.json"
    },
    {
      "name": "mars_photos",
      "path": "/mars-photos/api/v1/rovers/curiosity/photos",
      "query": {
        "sol": { "template": "{{ config.sol }}", "default": "1000" }
      },
      "records": { "path": "photos" },
      "computed_fields": {
        "camera": "{{ record.camera.full_name }}",
        "rover": "{{ record.rover.name }}"
      },
      "schema": "schemas/mars_photos.json"
    }
  ]
}
