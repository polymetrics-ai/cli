{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "calendar_list",
      "method": "GET",
      "path": "/__legacy_hook/calendar_list",
      "records": {
        "path": "data"
      },
      "schema": "schemas/calendar_list.json"
    },
    {
      "name": "events",
      "method": "GET",
      "path": "/__legacy_hook/events",
      "records": {
        "path": "data"
      },
      "schema": "schemas/events.json",
      "incremental": {
        "cursor_field": "updated",
        "client_filtered": true
      }
    },
    {
      "name": "settings",
      "method": "GET",
      "path": "/__legacy_hook/settings",
      "records": {
        "path": "data"
      },
      "schema": "schemas/settings.json"
    },
    {
      "name": "acl",
      "method": "GET",
      "path": "/__legacy_hook/acl",
      "records": {
        "path": "data"
      },
      "schema": "schemas/acl.json"
    }
  ]
}
