{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-Finnhub-Token", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/stock/symbol", "query": { "exchange": "US" } },
    "error_map": [
      { "status": 401, "hint": "finnhub api key is missing or invalid; re-run pm credentials add finnhub" },
      { "status": 403, "hint": "finnhub account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "finnhub rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "stock_symbols",
      "path": "/stock/symbol",
      "query": { "exchange": "{{ config.exchange }}" },
      "records": { "path": "" },
      "schema": "schemas/stock_symbols.json"
    },
    {
      "name": "market_news",
      "path": "/news",
      "query": { "category": "{{ config.market_news_category }}" },
      "records": { "path": "" },
      "computed_fields": {
        "symbol": "{{ record.related }}"
      },
      "schema": "schemas/market_news.json"
    }
  ]
}
