{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "domains",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "dkim": { "type": ["boolean", "null"] },
    "spf": { "type": ["boolean", "null"] },
    "tracking": { "type": ["boolean", "null"] },
    "is_verified": { "type": ["boolean", "null"] },
    "is_dns_active": { "type": ["boolean", "null"] },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
  }
}
