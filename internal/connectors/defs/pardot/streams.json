{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Pardot-Business-Unit-Id": "{{ config.business_unit_id }}"
    },
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}"
      }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "nextPageUrl"
    },
    "check": {
      "method": "GET",
      "path": "/api/v5/objects/prospects",
      "query": {
        "limit": "1",
        "fields": "id,email"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "pardot access_token is missing, invalid, or expired; re-issue an OAuth access token and re-run pm credentials add pardot"
      },
      {
        "status": 403,
        "hint": "pardot business_unit_id or credentials lack access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "pardot rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
