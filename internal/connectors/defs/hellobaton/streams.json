{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "api_key", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/projects", "query": { "page_size": "1" } },
    "error_map": [
      { "status": 401, "hint": "hellobaton api_key is missing or invalid; re-run pm credentials add hellobaton" },
      { "status": 429, "class": "rate_limited", "hint": "hellobaton rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects",
      "query": { "page_size": "100" },
      "records": { "path": "results" },
      "pagination": { "type": "next_url", "next_url_path": "next" },
      "schema": "schemas/projects.json"
    },
    {
      "name": "milestones",
      "path": "/milestones",
      "query": { "page_size": "100" },
      "records": { "path": "results" },
      "pagination": { "type": "next_url", "next_url_path": "next" },
      "schema": "schemas/milestones.json"
    },
    {
      "name": "tasks",
      "path": "/tasks",
      "query": { "page_size": "100" },
      "records": { "path": "results" },
      "pagination": { "type": "next_url", "next_url_path": "next" },
      "schema": "schemas/tasks.json"
    },
    {
      "name": "phases",
      "path": "/phases",
      "query": { "page_size": "100" },
      "records": { "path": "results" },
      "pagination": { "type": "next_url", "next_url_path": "next" },
      "schema": "schemas/phases.json"
    },
    {
      "name": "companies",
      "path": "/companies",
      "query": { "page_size": "100" },
      "records": { "path": "results" },
      "pagination": { "type": "next_url", "next_url_path": "next" },
      "schema": "schemas/companies.json"
    },
    {
      "name": "users",
      "path": "/users",
      "query": { "page_size": "100" },
      "records": { "path": "results" },
      "pagination": { "type": "next_url", "next_url_path": "next" },
      "schema": "schemas/users.json"
    }
  ]
}
