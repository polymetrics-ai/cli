      "covered_by": {
        "stream": "customers"
      }
    },
    {
      "method": "GET",
      "path": "/api/v2/feedback",
      "covered_by": {
        "stream": "responses"
      }
    },
    {
      "method": "GET",
      "path": "/api/v2/campaigns",
      "covered_by": {
        "stream": "surveys"
      }
    },
    {
      "method": "GET",
      "path": "/api/v2/campaigns",
      "covered_by": {
        "stream": "campaigns"
      }
    },
    {
      "method": "POST",
      "path": "/api/v2/customers",
      "excluded": {
        "category": "out_of_scope",
        "reason": "Legacy connector never implemented customer create/update"
      }
    },
    {
      "method": "DELETE",
      "path": "/api/v2/customers",
      "excluded": {
        "category": "destructive_admin",
        "reason": "bulk customer deletion; legacy never implemented writes"
