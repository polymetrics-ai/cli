{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.username }}", "password": "{{ secrets.password }}" }
    ],
    "check": { "method": "GET", "path": "/profiles" },
    "error_map": [
      { "status": 401, "hint": "hibob username/password is missing or invalid; re-run pm credentials add hibob" },
      { "status": 429, "class": "rate_limited", "hint": "hibob rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "profiles",
      "path": "/profiles",
      "records": { "path": "employees" },
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "offset",
        "page_size": 50
      },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}",
        "personal_pronouns": "{{ record.personal.pronouns }}",
        "work_title": "{{ record.work.title }}",
        "work_department": "{{ record.work.department }}",
        "work_site": "{{ record.work.site }}",
        "work_startDate": "{{ record.work.startDate }}",
        "work_isManager": "{{ record.work.isManager }}"
      },
      "schema": "schemas/profiles.json"
    },
    {
      "name": "named_lists",
      "path": "/company/named-lists",
      "records": { "path": "values" },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/named_lists.json"
    },
    {
      "name": "company_lists",
      "path": "/company/people/fields",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/company_lists.json"
    }
  ]
}
