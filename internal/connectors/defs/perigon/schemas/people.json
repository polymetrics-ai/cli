{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "people",
  "type": "object",
  "x-primary-key": ["wikidataId"],
  "required": ["wikidataId"],
  "properties": {
    "wikidataId": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "aliases": { "type": ["array", "null"] },
    "abstract": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "gender": { "type": ["object", "null"] },
    "image": { "type": ["object", "null"] },
    "occupation": { "type": ["array", "null"] },
    "position": { "type": ["array", "null"] },
    "politicalParty": { "type": ["array", "null"] },
    "dateOfBirth": { "type": ["object", "null"] },
    "dateOfDeath": { "type": ["object", "null"] },
    "createdAt": { "type": ["string", "null"] },
    "updatedAt": { "type": ["string", "null"] }
  }
}
