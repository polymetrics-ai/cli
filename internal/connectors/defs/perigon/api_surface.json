{
  "api": "Perigon News API v1 (https://api.perigon.io)",
  "docs": "https://docs.goperigon.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 2 legacy-parity read streams only (articles, stories); the full Perigon surface (journalists, sources, companies, people, topics entity endpoints) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/v1/articles/all", "covered_by": { "stream": "articles" } },
    { "method": "GET", "path": "/v1/stories/all", "covered_by": { "stream": "stories" } },
    { "method": "GET", "path": "/v1/journalists/all", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/sources/all", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/companies/all", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/people/all", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/topics/all", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
