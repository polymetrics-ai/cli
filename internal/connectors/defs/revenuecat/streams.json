      "name": "revenue_metric",
      "path": "/projects/{{ config.project_id }}/metrics/revenue",
      "records": {
        "path": ".",
        "single_object": true
      },
      "computed_fields": {
        "project_id": "{{ config.project_id }}",
        "stream": "revenue_metric"
      },
      "projection": "passthrough",
      "schema": "schemas/revenue_metric.json"
    },
    {
      "name": "offering",
      "path": "/projects/{{ config.project_id }}/offerings/{{ config.offering_id }}",
      "records": {
        "path": ".",
        "single_object": true
      },
      "computed_fields": {
