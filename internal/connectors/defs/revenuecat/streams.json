{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/projects",
      "query": {
        "limit": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "revenuecat api_key is missing or invalid; re-run pm credentials add revenuecat"
      },
      {
        "status": 403,
        "hint": "revenuecat api_key lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "revenuecat rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects",
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "id": "{{ coalesce record.id record.uuid record.app_user_id record.identifier record.name }}",
        "stream": "projects"
      },
      "projection": "passthrough",
      "schema": "schemas/projects.json",
      "query": {
        "starting_after": {
          "template": "{{ config.starting_after }}",
          "omit_when_absent": true
        },
        "created_after": {
          "template": "{{ config.created_after }}",
          "omit_when_absent": true
        },
        "updated_after": {
          "template": "{{ config.updated_after }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "apps",
      "path": "/projects/{{ config.project_id }}/apps",
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "id": "{{ coalesce record.id record.uuid record.app_user_id record.identifier record.name }}",
        "stream": "apps"
      },
      "projection": "passthrough",
      "schema": "schemas/apps.json",
      "query": {
        "starting_after": {
          "template": "{{ config.starting_after }}",
          "omit_when_absent": true
        },
        "created_after": {
          "template": "{{ config.created_after }}",
          "omit_when_absent": true
        },
        "updated_after": {
          "template": "{{ config.updated_after }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "products",
      "path": "/projects/{{ config.project_id }}/products",
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "id": "{{ coalesce record.id record.uuid record.app_user_id record.identifier record.name }}",
        "stream": "products"
      },
      "projection": "passthrough",
      "schema": "schemas/products.json",
      "query": {
        "starting_after": {
          "template": "{{ config.starting_after }}",
          "omit_when_absent": true
        },
        "created_after": {
          "template": "{{ config.created_after }}",
          "omit_when_absent": true
        },
        "updated_after": {
          "template": "{{ config.updated_after }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "offerings",
      "path": "/projects/{{ config.project_id }}/offerings",
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "id": "{{ coalesce record.id record.uuid record.app_user_id record.identifier record.name }}",
        "stream": "offerings"
      },
      "projection": "passthrough",
      "schema": "schemas/offerings.json",
      "query": {
        "starting_after": {
          "template": "{{ config.starting_after }}",
          "omit_when_absent": true
        },
        "created_after": {
          "template": "{{ config.created_after }}",
          "omit_when_absent": true
        },
        "updated_after": {
          "template": "{{ config.updated_after }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "customers",
      "path": "/projects/{{ config.project_id }}/customers",
      "records": {
        "path": "items"
      },
      "computed_fields": {
        "id": "{{ coalesce record.id record.uuid record.app_user_id record.identifier record.name }}",
        "stream": "customers"
      },
      "projection": "passthrough",
      "schema": "schemas/customers.json",
      "query": {
        "starting_after": {
          "template": "{{ config.starting_after }}",
          "omit_when_absent": true
        },
        "created_after": {
          "template": "{{ config.created_after }}",
          "omit_when_absent": true
        },
        "updated_after": {
          "template": "{{ config.updated_after }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "app",
      "path": "/projects/{{ config.project_id }}/apps/{{ config.app_id }}",
      "records": {
        "path": ".",
        "single_object": true
      },
      "computed_fields": {
        "stream": "app"
      },
      "projection": "passthrough",
      "schema": "schemas/app.json"
    },
    {
