{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "apikey", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "perPage",
      "start_page": 1,
      "page_size": 100,
      "max_pages": 1
    },
    "check": { "method": "GET", "path": "/v1/business-units/{{ config.business_unit_id }}/reviews", "query": { "perPage": "1", "page": "1" } },
    "error_map": [
      { "status": 401, "hint": "trustpilot api_key is missing or invalid; re-run pm credentials add trustpilot" },
      { "status": 403, "hint": "trustpilot account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "trustpilot rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "reviews",
      "path": "/v1/business-units/{{ config.business_unit_id }}/reviews",
      "records": { "path": "reviews" },
      "computed_fields": {
        "created_at": "{{ record.createdAt }}"
      },
      "schema": "schemas/reviews.json"
    },
    {
      "name": "invitations",
      "path": "/v1/private/business-units/{{ config.business_unit_id }}/invitations",
      "records": { "path": "invitations" },
      "computed_fields": {
        "created_at": "{{ record.createdAt }}"
      },
      "schema": "schemas/invitations.json"
    },
    {
      "name": "business_units",
      "path": "/v1/business-units/{{ config.business_unit_id }}",
      "records": { "path": "." },
      "computed_fields": {
        "display_name": "{{ record.displayName }}"
      },
      "schema": "schemas/business_units.json"
    },
    {
      "name": "categories",
      "path": "/v1/business-units/{{ config.business_unit_id }}/categories",
      "pagination": { "type": "none" },
      "records": { "path": "categories" },
      "computed_fields": {
        "category_id": "{{ record.categoryId }}",
        "display_name": "{{ record.displayName }}",
        "is_primary": "{{ record.isPrimary }}"
      },
      "schema": "schemas/categories.json"
    }
  ]
}
