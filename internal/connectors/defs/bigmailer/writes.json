{
  "actions": [
    {
      "name": "create_brand",
      "kind": "create",
      "method": "POST",
      "path": "/brands",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name", "from_name", "from_email", "connection_id"],
        "properties": {
          "name": { "type": "string" },
          "from_name": { "type": "string" },
          "from_email": { "type": "string" },
          "connection_id": { "type": "string" },
          "bounce_danger_percent": { "type": "integer" },
          "max_soft_bounces": { "type": "integer" },
          "url": { "type": "string" },
          "unsubscribe_text": { "type": "string" },
          "contact_limit": { "type": "integer" },
          "logo": { "type": "string" }
        }
      },
      "risk": "external mutation; creates a new BigMailer brand (sending identity); approval required"
    },
    {
      "name": "update_brand",
      "kind": "update",
      "method": "POST",
      "path": "/brands/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "from_name": { "type": "string" },
          "from_email": { "type": "string" },
          "connection_id": { "type": "string" },
          "bounce_danger_percent": { "type": "integer" },
          "max_soft_bounces": { "type": "integer" },
          "url": { "type": "string" },
          "unsubscribe_text": { "type": "string" },
          "contact_limit": { "type": "integer" },
          "logo": { "type": "string" }
        }
      },
      "risk": "external mutation; approval required"
    },
