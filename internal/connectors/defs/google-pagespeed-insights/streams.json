{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "pagespeed_reports",
      "method": "GET",
      "path": "/__legacy_hook/pagespeed_reports",
      "records": {
        "path": "data"
      },
      "schema": "schemas/pagespeed_reports.json"
    }
  ]
}
