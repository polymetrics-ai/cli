{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "contacts",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "integer" },
    "first_name": { "type": ["string", "null"] },
    "last_name": { "type": ["string", "null"] },
    "name": { "type": ["string", "null"] },
    "primary_email": { "type": ["string", "null"] },
    "secondary_email": { "type": ["string", "null"] },
    "home_phone": { "type": ["string", "null"] },
    "cell_phone": { "type": ["string", "null"] },
    "work_phone": { "type": ["string", "null"] },
    "street_address": { "type": ["string", "null"] },
    "locality": { "type": ["string", "null"] },
    "region": { "type": ["string", "null"] },
    "postal_code": { "type": ["string", "null"] },
    "country": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },
    "is_vip": { "type": ["boolean", "null"] },
    "is_owner_contact": { "type": ["boolean", "null"] },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
  }
}
