{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "ZANALYTICS-ORGID": "{{ config.org_id }}"
    },
    "auth": [
      {
        "mode": "custom",
        "hook": "zoho-analytics-metadata-api",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "token": "{{ secrets.refresh_token }}"
      }
    ],
    "pagination": { "type": "none" },
    "check": {
      "method": "GET",
      "path": "/workspaces"
    },
    "error_map": [
      { "status": 401, "hint": "zoho-analytics-metadata-api OAuth refresh grant failed or access token expired; re-run pm credentials add zoho-analytics-metadata-api" },
      { "status": 403, "hint": "zoho-analytics-metadata-api account lacks access for this request/scope" },
      { "status": 429, "class": "rate_limited", "hint": "zoho-analytics-metadata-api API rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "workspaces",
      "path": "/workspaces",
      "records": { "path": "data" },
      "computed_fields": {
        "created_time": "{{ record.createdTime }}"
      },
      "schema": "schemas/workspaces.json",
      "projection": "passthrough"
    },
    {
      "name": "views",
      "path": "/views",
      "records": { "path": "data" },
      "schema": "schemas/views.json",
      "projection": "passthrough"
    },
    {
      "name": "tables",
      "path": "/tables",
      "records": { "path": "data" },
      "schema": "schemas/tables.json",
      "projection": "passthrough"
    },
    {
      "name": "organizations",
      "path": "/orgs",
      "records": { "path": "data.orgs" },
      "schema": "schemas/organizations.json",
      "projection": "passthrough"
    },
    {
      "name": "recent_views",
      "path": "/recentviews",
      "records": { "path": "data.views" },
      "schema": "schemas/recent_views.json",
      "projection": "passthrough"
    },
    {
      "name": "shared_workspaces",
      "path": "/workspaces/shared",
      "records": { "path": "data.workspaces" },
      "schema": "schemas/shared_workspaces.json",
      "projection": "passthrough"
    },
    {
      "name": "shared_dashboards",
      "path": "/dashboards/shared",
      "records": { "path": "data.views" },
      "schema": "schemas/shared_dashboards.json",
      "projection": "passthrough"
    },
    {
      "name": "folders",
      "path": "/workspaces/{{ config.workspace_id }}/folders",
      "records": { "path": "data.folders" },
      "schema": "schemas/folders.json",
      "projection": "passthrough"
    },
    {
      "name": "query_tables",
      "path": "/workspaces/{{ config.workspace_id }}/querytables",
      "records": { "path": "data.queryTables" },
      "schema": "schemas/query_tables.json",
      "projection": "passthrough"
    },
    {
      "name": "datasources",
      "path": "/workspaces/{{ config.workspace_id }}/datasources",
      "records": { "path": "data.dataSources" },
      "schema": "schemas/datasources.json",
      "projection": "passthrough"
    }
  ]
}
