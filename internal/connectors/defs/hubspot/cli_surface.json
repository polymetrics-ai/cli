  "global_flags": [
    {
      "name": "json",
      "type": "boolean",
      "summary": "Write machine-readable JSON output."
    },
    {
      "name": "connection",
      "type": "string",
      "summary": "Use a saved HubSpot connector credential.",
      "maps_to": "connection"
    },
    {
      "name": "batch-size",
      "type": "integer",
      "summary": "Bound ETL reads with an explicit batch size.",
      "maps_to": "read.batch_size"
    }
  ],
  "commands": [
    {
      "path": "crm contacts list",
      "summary": "List CRM contacts",
      "intent": "etl",
      "availability": "planned",
      "operation": "hubspot.crm.contacts.list",
      "source_url": "https://developers.hubspot.com/docs/api/crm/contacts",
      "flags": [
        {
          "name": "properties",
          "type": "string_array",
          "summary": "Contact properties to include.",
          "maps_to": "query.properties"
        },
        {
          "name": "limit",
          "type": "integer",
          "summary": "Maximum records to read in this command invocation.",
          "maps_to": "read.limit"
        }
      ],
      "examples": [
        "pm hubspot crm contacts list --properties email,firstname --json"
      ],
      "notes": "Planned stream-backed command; issue #136 owns executable stream coverage."
    },
    {
      "path": "crm contacts view",
      "summary": "View one CRM contact",
      "intent": "direct_read",
      "availability": "planned",
      "operation": "hubspot.crm.contacts.view",
      "source_url": "https://developers.hubspot.com/docs/api/crm/contacts",
      "flags": [
        {
          "name": "contact-id",
          "type": "string",
          "summary": "HubSpot contact ID.",
          "maps_to": "path.contactId"
        },
        {
          "name": "properties",
          "type": "string_array",
          "summary": "Contact properties to include.",
          "maps_to": "query.properties"
        }
      ],
      "notes": "Planned bounded direct-read command; issue #138 owns output policy and redaction."
    },
    {
      "path": "crm contacts search",
