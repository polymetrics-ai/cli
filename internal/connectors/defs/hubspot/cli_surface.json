      "path": "crm contacts create",
      "summary": "Create a CRM contact",
      "intent": "reverse_etl",
      "availability": "planned",
      "source_url": "https://developers.hubspot.com/docs/api/crm/contacts",
      "risk": "Creates a contact record in the configured HubSpot portal.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "flags": [
        {
          "name": "email",
          "type": "string",
          "summary": "Contact email.",
          "maps_to": "record.email"
        },
        {
          "name": "firstname",
          "type": "string",
          "summary": "Contact first name.",
          "maps_to": "record.firstname"
        },
        {
          "name": "lastname",
          "type": "string",
          "summary": "Contact last name.",
          "maps_to": "record.lastname"
        }
      ],
      "notes": "Planned named reverse ETL action; no direct write execution is exposed."
    },
