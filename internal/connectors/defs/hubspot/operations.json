      "source_url": "https://developers.hubspot.com/docs/api/files/files",
      "risk": "medium",
      "approval": "binary file transfers require max-bytes and explicit safe destination approval",
      "output_policy": "file_manifest",
      "binary": {
        "method": "GET",
        "path": "/files/v3/files/{fileId}/signed-url",
