{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/v1/events" },
    "error_map": [
      { "status": 401, "hint": "savvycal API key is missing or invalid; re-run pm credentials add savvycal" },
      { "status": 429, "class": "rate_limited", "hint": "savvycal rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "events",
      "path": "/v1/events",
      "query": { "page": "1", "per_page": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/events.json"
    },
    {
      "name": "links",
      "path": "/v1/links",
      "query": { "page": "1", "per_page": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/links.json"
    },
    {
      "name": "contacts",
      "path": "/v1/contacts",
      "query": { "page": "1", "per_page": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "links.next"
      },
      "schema": "schemas/contacts.json"
    }
  ]
}
