{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "facebook_posts",
  "type": "object",
  "x-primary-key": ["blogId", "postId"],
  "required": ["blogId", "postId"],
  "properties": {
    "blogId": { "type": "string" },
    "postId": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "publishDate": { "type": ["string", "null"] },
    "text": { "type": ["string", "null"] },
    "interactions": { "type": ["number", "null"] },
    "impressions": { "type": ["number", "null"] },
    "reach": { "type": ["number", "null"] },
    "likes": { "type": ["number", "null"] },
    "comments": { "type": ["number", "null"] },
    "shares": { "type": ["number", "null"] },
    "url": { "type": ["string", "null"] }
  }
}
