{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "license", "value": "{{ secrets.api_key }}" }
    ],
    "error_map": [
      { "status": 401, "hint": "interzoid api_key is missing or invalid; re-run pm credentials add interzoid" },
      { "status": 429, "class": "rate_limited", "hint": "interzoid rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "company_name_matching",
      "path": "/getcompanymatchadvanced",
      "query": {
        "company": "{{ config.company }}",
        "algorithm": { "template": "{{ config.company_match_algorithm }}", "omit_when_absent": true }
      },
      "records": { "path": "", "single_object": true },
      "computed_fields": {
        "query_company": "{{ config.company }}"
      },
      "schema": "schemas/company_name_matching.json"
    },
    {
      "name": "individual_name_matching",
      "path": "/getfullnamematch",
      "query": {
        "fullname": "{{ config.fullname }}"
      },
      "records": { "path": "", "single_object": true },
      "computed_fields": {
        "query_fullname": "{{ config.fullname }}"
      },
      "schema": "schemas/individual_name_matching.json"
    },
    {
      "name": "street_address_matching",
      "path": "/getaddressmatchadvanced",
      "query": {
        "address": "{{ config.address }}",
        "algorithm": { "template": "{{ config.address_match_algorithm }}", "omit_when_absent": true }
      },
      "records": { "path": "", "single_object": true },
      "computed_fields": {
        "query_address": "{{ config.address }}"
      },
      "schema": "schemas/street_address_matching.json"
    },
    {
      "name": "standardize_company_names",
      "path": "/getorgstandard",
      "query": {
        "org": "{{ config.org }}"
      },
      "records": { "path": "", "single_object": true },
      "computed_fields": {
        "query_org": "{{ config.org }}"
      },
      "schema": "schemas/standardize_company_names.json"
    }
  ]
}
