{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "oauth2_client_credentials",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "extra_params": {
          "box_subject_type": "{{ config.box_subject_type }}",
          "box_subject_id": "{{ config.box_subject_id }}"
        }
      }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/users", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "box client_id/client_secret are missing or invalid, or the token-scoping subject is misconfigured; re-run pm credentials add box" },
      { "status": 403, "hint": "box subject lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "box rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/users",
      "records": { "path": "entries" },
      "schema": "schemas/users.json"
    },
    {
      "name": "groups",
      "path": "/groups",
      "records": { "path": "entries" },
      "schema": "schemas/groups.json"
    },
    {
      "name": "collections",
      "path": "/collections",
      "records": { "path": "entries" },
      "schema": "schemas/collections.json"
    },
    {
      "name": "folder_items",
      "path": "/folders/{{ config.folder_id }}/items",
      "records": { "path": "entries" },
      "schema": "schemas/folder_items.json"
    },
    {
      "name": "webhooks",
      "path": "/webhooks",
      "records": { "path": "entries" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "marker",
        "token_path": "next_marker"
      },
      "schema": "schemas/webhooks.json"
    },
    {
      "name": "retention_policies",
      "path": "/retention_policies",
      "records": { "path": "entries" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "marker",
        "token_path": "next_marker"
      },
      "schema": "schemas/retention_policies.json"
    },
    {
      "name": "legal_hold_policies",
      "path": "/legal_hold_policies",
      "records": { "path": "entries" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "marker",
        "token_path": "next_marker"
      },
      "schema": "schemas/legal_hold_policies.json"
    },
    {
      "name": "storage_policies",
      "path": "/storage_policies",
      "records": { "path": "entries" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "marker",
        "token_path": "next_marker"
      },
      "schema": "schemas/storage_policies.json"
    },
    {
      "name": "sign_requests",
      "path": "/sign_requests",
      "records": { "path": "entries" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "marker",
        "token_path": "next_marker"
      },
      "schema": "schemas/sign_requests.json"
    },
    {
      "name": "terms_of_services",
      "path": "/terms_of_services",
      "records": { "path": "entries" },
      "pagination": { "type": "none" },
      "schema": "schemas/terms_of_services.json"
    },
    {
      "name": "metadata_templates",
      "path": "/metadata_templates/enterprise",
      "records": { "path": "entries" },
      "pagination": {
        "type": "cursor",
        "cursor_param": "marker",
        "token_path": "next_marker"
      },
      "computed_fields": {
        "template_key": "{{ record.templateKey }}",
        "display_name": "{{ record.displayName }}",
        "copy_instance_on_item_copy": "{{ record.copyInstanceOnItemCopy }}"
      },
      "schema": "schemas/metadata_templates.json"
    },
    {
      "name": "pending_collaborations",
      "path": "/collaborations",
      "query": { "status": "pending" },
      "records": { "path": "entries" },
      "schema": "schemas/pending_collaborations.json"
    }
  ]
}
