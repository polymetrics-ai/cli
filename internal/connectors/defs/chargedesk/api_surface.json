{
  "api": "ChargeDesk API v1 (https://api.chargedesk.com/v1)",
  "docs": "https://chargedesk.com/api-docs",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only; ChargeDesk's much larger surface (refunds, disputes, notes, mutating charge/customer/subscription actions) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/charges", "covered_by": { "stream": "charges" } },
    { "method": "GET", "path": "/customers", "covered_by": { "stream": "customers" } },
    { "method": "GET", "path": "/subscriptions", "covered_by": { "stream": "subscriptions" } },
    { "method": "GET", "path": "/products", "covered_by": { "stream": "products" } },
    { "method": "GET", "path": "/refunds", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/disputes", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/charges/{id}/refund", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/customers", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/charges/{id}/notes", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
