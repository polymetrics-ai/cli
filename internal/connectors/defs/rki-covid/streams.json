{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/germany"
    },
    "error_map": [
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "corona-zahlen.org rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "germany",
      "path": "/germany",
      "query": {
        "days": {
          "template": "{{ config.days }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": ""
      },
      "projection": "passthrough",
      "computed_fields": {
        "id": "germany",
        "stream": "germany"
      },
      "schema": "schemas/germany.json"
    },
    {
      "name": "states",
      "path": "/states",
      "query": {
        "days": {
          "template": "{{ config.days }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data",
        "keyed_object": true,
        "key_field": "abbreviation"
      },
      "projection": "passthrough",
      "computed_fields": {
        "stream": "states"
      },
      "schema": "schemas/states.json"
    },
