{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/forms" },
    "error_map": [
      { "status": 401, "hint": "fillout api_key is missing or invalid; re-run pm credentials add fillout" },
      { "status": 429, "class": "rate_limited", "hint": "fillout rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "forms",
      "path": "/forms",
      "records": { "path": "" },
      "computed_fields": {
        "id": "{{ record.formId }}"
      },
      "schema": "schemas/forms.json"
    }
  ]
}
