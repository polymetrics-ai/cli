{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shortcut Connection Specification",
  "type": "object",
  "required": [],
  "properties": {
    "base_url": {
      "type": "string",
      "format": "uri",
      "description": "Shortcut API base URL.",
      "default": "https://api.app.shortcut.com"
    },
    "api_token": {
      "type": "string",
      "x-secret": true,
      "description": "Shortcut API token, sent as the Shortcut-Token header."
    },
    "page_size": {
      "type": "integer",
      "description": "Records requested per page (legacy default 100, max 500).",
      "default": 100
    }
  }
}
