{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}",
        "when": "{{ secrets.access_token }}"
      },
      {
        "mode": "basic",
        "username": "{{ secrets.email }}/token",
        "password": "{{ secrets.api_token }}",
        "when": "{{ secrets.api_token }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page[after]",
      "token_path": "meta.after_cursor",
      "stop_path": "meta.has_more"
    },
    "check": {
      "method": "GET",
      "path": "/api/v2/groups"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "zendesk-support credentials are missing or invalid; re-run pm credentials add zendesk-support"
      },
      {
        "status": 403,
        "hint": "zendesk-support account lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "zendesk-support rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "tickets",
      "path": "/api/v2/tickets",
      "query": {
        "page[size]": "100"
      },
      "records": {
        "path": "tickets"
      },
      "schema": "schemas/tickets.json"
    },
    {
      "name": "users",
