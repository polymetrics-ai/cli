{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-API-KEY", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "paging.next"
    },
    "check": { "method": "GET", "path": "/contacts", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "omnisend api_key is missing or invalid; re-run pm credentials add omnisend" },
      { "status": 429, "class": "rate_limited", "hint": "omnisend rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "contacts" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "campaigns",
      "path": "/campaigns",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "campaign" },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "carts",
      "path": "/carts",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "carts" },
      "schema": "schemas/carts.json"
    },
    {
      "name": "orders",
      "path": "/orders",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "orders" },
      "schema": "schemas/orders.json"
    },
    {
      "name": "products",
      "path": "/products",
      "query": { "limit": "{{ config.page_size }}" },
      "records": { "path": "products" },
      "schema": "schemas/products.json"
    }
  ]
}
