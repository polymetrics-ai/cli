{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "api/affiliates" },
    "error_map": [
      { "status": 401, "hint": "uppromote api_key is missing or invalid; re-run pm credentials add uppromote" },
      { "status": 429, "class": "rate_limited", "hint": "uppromote rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "affiliates",
      "path": "api/affiliates",
      "query": {
        "start_date": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "affiliates" },
      "schema": "schemas/affiliates.json"
    },
    {
      "name": "programs",
      "path": "api/v2/programs",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 10
      },
      "records": { "path": "data" },
      "schema": "schemas/programs.json"
    },
    {
      "name": "coupons",
      "path": "api/v2/coupons",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 10
      },
      "records": { "path": "data" },
      "schema": "schemas/coupons.json"
    },
    {
      "name": "referrals",
      "path": "api/v2/referrals",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 10
      },
      "records": { "path": "data" },
      "schema": "schemas/referrals.json"
    },
    {
      "name": "unpaid_payments",
      "path": "api/v2/payments/unpaid",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 10
      },
      "records": { "path": "data" },
      "schema": "schemas/unpaid_payments.json"
    },
    {
      "name": "paid_payments",
      "path": "api/v2/payments/paid",
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 10
      },
      "records": { "path": "data" },
      "schema": "schemas/paid_payments.json"
    }
  ]
}
