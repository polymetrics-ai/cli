{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "iterator",
      "token_path": "iterator"
    },
    "check": { "method": "GET", "path": "/app" },
    "error_map": [
      { "status": 401, "hint": "svix api_key is missing or invalid; re-run pm credentials add svix" },
      { "status": 429, "class": "rate_limited", "hint": "svix rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "applications",
      "path": "/app",
      "query": { "limit": "50" },
      "records": { "path": "data" },
      "computed_fields": {
        "created_at": "{{ record.createdAt }}"
      },
      "schema": "schemas/applications.json"
    }
  ]
}
