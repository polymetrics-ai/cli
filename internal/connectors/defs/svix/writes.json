{
  "actions": [
    {
      "name": "create_application",
      "kind": "create",
      "method": "POST",
      "path": "/app",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "uid": { "type": "string" },
          "metadata": { "type": "object" },
          "throttleRate": { "type": "integer" }
        }
      },
      "risk": "creates a new Svix application (a webhook-sending namespace); low-risk external mutation, no approval required"
    },
    {
      "name": "update_application",
      "kind": "update",
      "method": "PUT",
      "path": "/app/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "uid": { "type": "string" },
          "metadata": { "type": "object" },
          "throttleRate": { "type": "integer" }
        }
      },
      "risk": "replaces an existing application's metadata/name/throttle rate; external mutation, no approval required"
    },
    {
      "name": "delete_application",
      "kind": "delete",
      "method": "DELETE",
      "path": "/app/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": {
        "idempotent": true,
        "missing_ok_status": [404]
      },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "risk": "irreversibly deletes an application and all its endpoints, messages, and delivery history; approval required"
    },
    {
      "name": "create_endpoint",
      "kind": "create",
      "method": "POST",
      "path": "/app/{{ record.app_id }}/endpoint",
      "path_fields": ["app_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["app_id", "url"],
        "properties": {
          "app_id": { "type": "string" },
          "url": { "type": "string" },
          "uid": { "type": "string" },
          "description": { "type": "string" },
          "disabled": { "type": "boolean" },
          "channels": { "type": "array", "items": { "type": "string" } },
          "filterTypes": { "type": "array", "items": { "type": "string" } },
          "metadata": { "type": "object" }
        }
      },
      "risk": "creates a new webhook delivery endpoint on an application; the endpoint immediately starts receiving future events; low-risk external mutation, no approval required"
    },
    {
      "name": "update_endpoint",
      "kind": "update",
      "method": "PUT",
      "path": "/app/{{ record.app_id }}/endpoint/{{ record.id }}",
      "path_fields": ["app_id", "id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["app_id", "id", "url"],
        "properties": {
          "app_id": { "type": "string" },
          "id": { "type": "string" },
          "url": { "type": "string" },
          "uid": { "type": "string" },
          "description": { "type": "string" },
          "disabled": { "type": "boolean" },
          "channels": { "type": "array", "items": { "type": "string" } },
          "filterTypes": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "replaces an existing endpoint's delivery URL/filters/disabled state; changing url redirects all future webhook deliveries for that endpoint; external mutation, no approval required"
    },
    {
      "name": "delete_endpoint",
      "kind": "delete",
      "method": "DELETE",
      "path": "/app/{{ record.app_id }}/endpoint/{{ record.id }}",
      "path_fields": ["app_id", "id"],
      "body_type": "none",
      "delete": {
        "idempotent": true,
        "missing_ok_status": [404]
      },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["app_id", "id"],
        "properties": {
          "app_id": { "type": "string" },
          "id": { "type": "string" }
        }
      },
      "risk": "irreversibly deletes a webhook delivery endpoint and stops all future deliveries to it; approval required"
    },
    {
      "name": "create_event_type",
      "kind": "create",
      "method": "POST",
      "path": "/event-type",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "groupName": { "type": "string" },
          "archived": { "type": "boolean" },
          "deprecated": { "type": "boolean" },
          "schemas": { "type": "object" }
        }
      },
      "risk": "creates a new event type definition; low-risk external mutation, no approval required"
    },
    {
      "name": "update_event_type",
      "kind": "update",
      "method": "PUT",
      "path": "/event-type/{{ record.name }}",
      "path_fields": ["name"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "groupName": { "type": "string" },
          "archived": { "type": "boolean" },
          "deprecated": { "type": "boolean" },
          "schemas": { "type": "object" }
        }
      },
      "risk": "replaces an existing event type's description/schema/archived state; external mutation, no approval required"
    },
    {
      "name": "delete_event_type",
      "kind": "delete",
      "method": "DELETE",
      "path": "/event-type/{{ record.name }}",
      "path_fields": ["name"],
      "body_type": "none",
      "delete": {
        "idempotent": true,
        "missing_ok_status": [404]
      },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" }
        }
      },
      "risk": "archives (soft-deletes) an event type definition; approval required"
    },
    {
      "name": "send_message",
      "kind": "create",
      "method": "POST",
      "path": "/app/{{ record.app_id }}/msg",
      "path_fields": ["app_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["app_id", "eventType", "payload"],
        "properties": {
          "app_id": { "type": "string" },
          "eventType": { "type": "string" },
          "payload": { "type": "object" },
          "eventId": { "type": "string" },
          "channels": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "sends a real outgoing webhook message that Svix immediately attempts to deliver to every matching endpoint on the application; approval required"
    },
    {
      "name": "create_connector",
      "kind": "create",
      "method": "POST",
      "path": "/connector",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name", "transformation"],
        "properties": {
          "name": { "type": "string" },
          "transformation": { "type": "string" },
          "description": { "type": "string" },
          "kind": { "type": "string" },
          "productType": { "type": "string" },
          "instructions": { "type": "string" },
          "logo": { "type": "string" },
          "allowedEventTypes": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "creates a new outgoing-webhook payload-transformation connector template; low-risk external mutation, no approval required"
    },
    {
      "name": "update_connector",
      "kind": "update",
      "method": "PUT",
      "path": "/connector/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "name", "transformation"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "transformation": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "risk": "replaces an existing connector's transformation JS/description; changes the payload shape delivered to every endpoint using this connector; external mutation, no approval required"
    },
    {
      "name": "delete_connector",
      "kind": "delete",
      "method": "DELETE",
      "path": "/connector/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": {
        "idempotent": true,
        "missing_ok_status": [404]
      },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "risk": "irreversibly deletes a connector transformation template; approval required"
    },
    {
      "name": "create_operational_webhook_endpoint",
      "kind": "create",
      "method": "POST",
      "path": "/operational-webhook/endpoint",
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" },
          "uid": { "type": "string" },
          "description": { "type": "string" },
          "disabled": { "type": "boolean" },
          "filterTypes": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "creates a new operational webhook endpoint (Svix account-level events, e.g. message.attempt.exhausted); low-risk external mutation, no approval required"
    },
    {
      "name": "update_operational_webhook_endpoint",
      "kind": "update",
      "method": "PUT",
      "path": "/operational-webhook/endpoint/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id", "url"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string" },
          "description": { "type": "string" },
          "disabled": { "type": "boolean" },
          "filterTypes": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "replaces an existing operational webhook endpoint's delivery URL/filters/disabled state; external mutation, no approval required"
    },
    {
      "name": "delete_operational_webhook_endpoint",
      "kind": "delete",
      "method": "DELETE",
      "path": "/operational-webhook/endpoint/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "delete": {
        "idempotent": true,
        "missing_ok_status": [404]
      },
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "risk": "irreversibly deletes an operational webhook endpoint and stops all future account-level event deliveries to it; approval required"
    }
  ]
}
