{
  "api": "Clockify API v1 (https://api.clockify.me/api)",
  "docs": "https://docs.clockify.me/",
  "reviewed_at": "2026-07-04",
  "scope": "Pass B full-surface expansion: every documented Clockify v1 endpoint is enumerated below, covered by a stream/write or explicitly excluded with a specific reason. Scheduling and Invoicing are separate paid Clockify add-on modules not guaranteed enabled on every workspace plan.",
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/file/image",
      "excluded": {
        "category": "binary_payload",
        "reason": "multipart image upload for profile photos; no dialect-expressible binary body support"
      }
    },
    {
      "method": "GET",
      "path": "/v1/shared-reports/{id}",
      "excluded": {
        "category": "requires_elevated_scope",
        "reason": "shared-report link view requires a report-sharing token distinct from the workspace api_key scope, not a workspace-scoped read"
      }
    },
    {
      "method": "GET",
      "path": "/v1/user",
      "covered_by": {
        "stream": "current_user"
      }
    },
    {
      "method": "GET",
      "path": "/v1/workspaces",
      "covered_by": {
        "stream": "workspaces"
      }
    },
    {
      "method": "POST",
      "path": "/v1/workspaces",
      "excluded": {
        "category": "destructive_admin",
        "reason": "creates a brand-new Clockify workspace (an org-level admin action, not per-record data), and API-key-scoped connections are conventionally already bound to one workspace"
      }
    },
    {
      "method": "GET",
      "path": "/v1/workspaces/{workspaceId}",
      "excluded": {
