{
  "api": "Algolia Search REST API (https://<application_id>.algolia.net)",
  "docs": "https://www.algolia.com/doc/rest-api/search/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 gap-loop repair: all 3 legacy-parity read streams now migrated (indices, api_keys, index_settings) following the S4 engine mini-wave's start_page:0 support; index records/search, ACL mutation, and analytics endpoints remain out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/1/indexes", "covered_by": { "stream": "indices" } },
    { "method": "GET", "path": "/1/keys", "covered_by": { "stream": "api_keys" } },
    { "method": "GET", "path": "/1/indexes/{indexName}/settings", "covered_by": { "stream": "index_settings" } },
    { "method": "POST", "path": "/1/indexes/{indexName}/settings", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/1/indexes/{indexName}/query", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/1/keys", "excluded": { "category": "requires_elevated_scope", "reason": "API key creation is an admin mutation, not a read stream" } },
    { "method": "DELETE", "path": "/1/keys/{key}", "excluded": { "category": "destructive_admin", "reason": "API key deletion is a destructive admin action" } },
    { "method": "GET", "path": "/1/indexes/{indexName}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
