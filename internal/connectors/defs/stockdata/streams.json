{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_query", "param": "api_token", "value": "{{ secrets.api_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "limit",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/news/all", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "stockdata api_token is missing or invalid; re-run pm credentials add stockdata" },
      { "status": 429, "class": "rate_limited", "hint": "stockdata rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "tickers",
      "path": "/data/tickers",
      "records": { "path": "data" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "limit",
        "start_page": 1,
        "page_size": 2
      },
      "schema": "schemas/tickers.json"
    },
    {
      "name": "eod_prices",
      "path": "/data/eod",
      "query": {
        "symbols": "{{ config.symbols }}",
        "date_from": { "template": "{{ config.date_from }}", "omit_when_absent": true },
        "date_to": { "template": "{{ config.date_to }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "schema": "schemas/eod_prices.json"
    },
    {
      "name": "intraday_prices",
      "path": "/data/intraday",
      "query": {
        "symbols": "{{ config.symbols }}",
        "date_from": { "template": "{{ config.date_from }}", "omit_when_absent": true },
        "date_to": { "template": "{{ config.date_to }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "schema": "schemas/intraday_prices.json"
    },
    {
      "name": "news",
      "path": "/news/all",
      "records": { "path": "data" },
      "schema": "schemas/news.json"
    }
  ]
}
