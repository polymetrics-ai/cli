        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
      "schema": "schemas/organization_policy_objects.json"
    },
    {
      "name": "organization_branding_policies",
      "path": "/organizations/{{ fanout.id }}/brandingPolicies",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/organizations?perPage={{ config.page_size }}", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
