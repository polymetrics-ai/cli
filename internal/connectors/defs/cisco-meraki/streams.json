{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "link_header"
    },
    "check": { "method": "GET", "path": "/organizations", "query": { "perPage": "1" } },
    "error_map": [
      { "status": 401, "hint": "cisco-meraki api_key is missing or invalid; re-run pm credentials add cisco-meraki" },
      { "status": 403, "hint": "cisco-meraki account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "cisco-meraki rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "organizations",
      "path": "/organizations",
      "query": { "perPage": "{{ config.page_size }}" },
      "records": { "path": "" },
      "schema": "schemas/organizations.json"
    },
    {
      "name": "organization_networks",
      "path": "/organizations/{{ fanout.id }}/networks",
      "query": { "perPage": "{{ config.page_size }}" },
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/organizations?perPage={{ config.page_size }}", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
      "schema": "schemas/organization_networks.json"
    },
    {
      "name": "organization_devices",
      "path": "/organizations/{{ fanout.id }}/devices",
      "query": { "perPage": "{{ config.page_size }}" },
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/organizations?perPage={{ config.page_size }}", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
      "schema": "schemas/organization_devices.json"
    },
    {
      "name": "organization_admins",
      "path": "/organizations/{{ fanout.id }}/admins",
      "query": { "perPage": "{{ config.page_size }}" },
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/organizations?perPage={{ config.page_size }}", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
      "schema": "schemas/organization_admins.json"
    },
    {
      "name": "organization_licenses",
      "path": "/organizations/{{ fanout.id }}/licenses",
      "query": { "perPage": "{{ config.page_size }}" },
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/organizations?perPage={{ config.page_size }}", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
      "schema": "schemas/organization_licenses.json"
    },
    {
      "name": "organization_config_templates",
      "path": "/organizations/{{ fanout.id }}/configTemplates",
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/organizations?perPage={{ config.page_size }}", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
      "schema": "schemas/organization_config_templates.json"
    },
    {
      "name": "organization_policy_objects",
      "path": "/organizations/{{ fanout.id }}/policyObjects",
      "query": { "perPage": "{{ config.page_size }}" },
      "records": { "path": "" },
