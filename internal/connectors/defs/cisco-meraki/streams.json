      },
      "schema": "schemas/organization_configuration_changes.json"
    },
    {
      "name": "organization_api_requests",
      "path": "/organizations/{{ fanout.id }}/apiRequests",
      "query": { "perPage": "{{ config.page_size }}" },
      "records": { "path": "" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/organizations?perPage={{ config.page_size }}", "records_path": "", "id_field": "id" }
        },
        "into": { "path_var": "organization_id" },
        "stamp_field": "organizationId"
      },
      "schema": "schemas/organization_api_requests.json"
    }
  ]
}
