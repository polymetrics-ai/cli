{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "next_page.uri"
    },
    "check": { "method": "GET", "path": "/users/me" },
    "error_map": [
      { "status": 401, "hint": "asana access token is missing or invalid; re-run pm credentials add asana" },
      { "status": 403, "hint": "asana account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "asana rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "workspaces",
      "path": "/workspaces",
      "query": {
        "limit": "100",
        "opt_fields": "gid,name,resource_type"
      },
      "records": { "path": "data" },
      "schema": "schemas/workspaces.json"
    },
    {
      "name": "projects",
      "path": "/projects",
      "query": {
        "limit": "100",
        "opt_fields": "gid,name,resource_type,created_at,modified_at",
        "workspace": { "template": "{{ config.workspace_id }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "schema": "schemas/projects.json"
    },
    {
      "name": "tasks",
      "path": "/tasks",
      "query": {
        "limit": "100",
        "opt_fields": "gid,name,resource_type,created_at,modified_at,completed",
        "workspace": { "template": "{{ config.workspace_id }}", "omit_when_absent": true },
        "project": { "template": "{{ config.project_id }}", "omit_when_absent": true },
        "assignee": { "template": "{{ config.assignee }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "schema": "schemas/tasks.json"
    }
  ]
}
