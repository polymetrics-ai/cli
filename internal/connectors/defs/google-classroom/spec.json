{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Google Classroom Connection Specification",
  "type": "object",
  "required": [
    "client_id",
    "client_refresh_token",
    "client_secret"
  ],
  "properties": {
    "client_id": {
      "type": "string",
      "x-secret": true
    },
    "client_refresh_token": {
      "type": "string",
      "x-secret": true
    },
    "client_secret": {
      "type": "string",
      "x-secret": true
    },
    "base_url": {
      "type": "string",
      "default": "https://example.invalid",
      "description": "Placeholder base URL used only to construct the engine runtime before the Tier-2 hook delegates to the legacy connector."
    },
    "mode": {
      "type": "string",
      "description": "Set to fixture for credential-free legacy fixture tests."
    }
  }
}
