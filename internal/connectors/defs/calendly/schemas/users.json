{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "users",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id", "uri"],
  "properties": {
    "id": { "type": "string", "description": "Legacy's derived primary key: uri's trailing path segment (idFromURI), reproduced here via computed_fields' last_path_segment filter." },
    "uri": { "type": "string", "description": "Calendly's stable resource identifier; see scheduled_events.json's uri description." },
    "name": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "slug": { "type": ["string", "null"] },
    "timezone": { "type": ["string", "null"] },
    "avatar_url": { "type": ["string", "null"] },
    "scheduling_url": { "type": ["string", "null"] },
    "current_organization": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
