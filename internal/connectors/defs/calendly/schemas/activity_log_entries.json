{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "activity_log_entries",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "occurred_at",
  "required": ["id", "uri"],
  "properties": {
    "id": { "type": "string", "description": "Derived from uri's trailing path segment via computed_fields' last_path_segment filter, matching every other stream in this bundle." },
    "uri": { "type": "string", "description": "Calendly's stable resource identifier; see scheduled_events.json's uri description." },
    "occurred_at": { "type": "string", "format": "date-time" },
    "organization": { "type": ["string", "null"] },
    "actor": { "type": ["object", "null"] },
    "action": { "type": ["string", "null"] },
    "namespace": { "type": ["string", "null"] },
    "details": { "type": ["object", "null"] }
  }
}
