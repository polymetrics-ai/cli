{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "scheduled_events",
  "type": "object",
  "x-primary-key": ["uri"],
  "x-cursor-field": "start_time",
  "required": ["uri"],
  "properties": {
    "uri": { "type": "string", "description": "Calendly's stable resource identifier (also this bundle's primary key; legacy derives a convenience \"id\" field as this URI's trailing path segment, not reproduced here — see docs.md Known limits)." },
    "name": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "start_time": { "type": "string", "format": "date-time" },
    "end_time": { "type": ["string", "null"], "format": "date-time" },
    "event_type": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
