    { "method": "GET", "path": "/companies", "covered_by": { "stream": "companies" } },
    { "method": "GET", "path": "/payslips", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/absences", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
