{
  "base": {
    "url": "https://{{ config.subdomain }}.bamboohr.com",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Accept": "application/json"
    },
    "auth": [
      {
        "mode": "basic",
        "username": "{{ secrets.api_key }}",
        "password": "x"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/api/v1/meta/fields"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "bamboo-hr api_key is missing or invalid; re-run pm credentials add bamboo-hr"
      },
      {
        "status": 403,
        "hint": "bamboo-hr account lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "bamboo-hr rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "employees",
      "path": "/api/v1/employees/directory",
      "records": {
        "path": "employees"
      },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "limit",
        "start_page": 1,
        "page_size": 100
      },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}",
        "display_name": "{{ record.displayName }}",
        "first_name": "{{ record.firstName }}",
        "last_name": "{{ record.lastName }}",
        "preferred_name": "{{ record.preferredName }}",
        "job_title": "{{ record.jobTitle }}",
        "work_email": "{{ record.workEmail }}",
        "work_phone": "{{ record.workPhone }}",
        "mobile_phone": "{{ record.mobilePhone }}",
        "photo_url": "{{ record.photoUrl }}"
      },
      "schema": "schemas/employees.json"
    },
    {
      "name": "meta_fields",
      "path": "/api/v1/meta/fields",
      "records": {
        "path": ""
      },
      "pagination": {
        "type": "none"
      },
      "computed_fields": {
        "id": "{{ record.id | last_path_segment }}"
      },
      "schema": "schemas/meta_fields.json"
    },
    {
      "name": "meta_lists",
      "path": "/api/v1/meta/lists",
