{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "member_benefits",
  "type": "object",
  "x-primary-key": [
    "memberId"
  ],
  "properties": {
    "memberId": {
      "type": "string"
    },
    "plans": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dateRanges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "endDate": {
                  "type": [
                    "null",
                    "string"
                  ]
                },
                "startDate": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "ENROLLED",
                    "WAIVED",
                    "TERMINATED",
                    "WITHDREW",
                    "ELIGIBLE",
                    "INELIGIBLE"
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "planId": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "subscriberId": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
