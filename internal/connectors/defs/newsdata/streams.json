{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "api_key_query",
        "param": "apikey",
        "value": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page",
      "token_path": "nextPage",
      "max_pages": 5
    },
    "check": {
      "method": "GET",
      "path": "/latest"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "newsdata api_key is missing or invalid; re-run pm credentials add newsdata"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "newsdata rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "latest",
      "path": "/latest",
      "query": {
        "category": { "template": "{{ config.category }}", "omit_when_absent": true },
        "country": { "template": "{{ config.country }}", "omit_when_absent": true },
        "language": { "template": "{{ config.language }}", "omit_when_absent": true },
        "domain": { "template": "{{ config.domain }}", "omit_when_absent": true },
        "q": { "template": "{{ config.query }}", "omit_when_absent": true },
        "qInTitle": { "template": "{{ config.query_in_title }}", "omit_when_absent": true },
        "size": { "template": "{{ config.size }}", "omit_when_absent": true }
      },
      "records": {
        "path": "results"
      },
      "schema": "schemas/latest.json"
    },
    {
      "name": "crypto",
      "path": "/crypto",
      "query": {
        "category": { "template": "{{ config.category }}", "omit_when_absent": true },
        "country": { "template": "{{ config.country }}", "omit_when_absent": true },
        "language": { "template": "{{ config.language }}", "omit_when_absent": true },
        "domain": { "template": "{{ config.domain }}", "omit_when_absent": true },
        "q": { "template": "{{ config.query }}", "omit_when_absent": true },
        "qInTitle": { "template": "{{ config.query_in_title }}", "omit_when_absent": true },
        "size": { "template": "{{ config.size }}", "omit_when_absent": true }
      },
      "records": {
        "path": "results"
      },
      "schema": "schemas/crypto.json"
    },
    {
      "name": "sources",
      "path": "/sources",
      "pagination": {
        "type": "none"
      },
      "query": {
        "category": { "template": "{{ config.category }}", "omit_when_absent": true },
        "country": { "template": "{{ config.country }}", "omit_when_absent": true },
        "language": { "template": "{{ config.language }}", "omit_when_absent": true },
        "domain": { "template": "{{ config.domain }}", "omit_when_absent": true },
        "q": { "template": "{{ config.query }}", "omit_when_absent": true },
        "qInTitle": { "template": "{{ config.query_in_title }}", "omit_when_absent": true },
        "size": { "template": "{{ config.size }}", "omit_when_absent": true }
      },
      "records": {
        "path": "results"
      },
      "schema": "schemas/sources.json"
    }
  ]
}
