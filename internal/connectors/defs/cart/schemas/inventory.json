  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "product_id": { "type": ["string", "null"] },
    "sku": { "type": ["string", "null"] },
    "quantity": { "type": ["integer", "number", "null"] },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
