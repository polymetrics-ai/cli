{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.access_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page",
      "token_path": "meta.next_page"
    },
    "check": {
      "method": "GET",
      "path": "/orders",
      "query": { "page_size": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "cart access_token is missing or invalid; re-run pm credentials add cart" },
      { "status": 403, "hint": "cart account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "cart rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "orders",
      "path": "/orders",
      "query": { "page_size": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/orders.json",
      "projection": "passthrough"
    },
    {
      "name": "customers",
      "path": "/customers",
      "query": { "page_size": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/customers.json",
      "projection": "passthrough"
    },
    {
      "name": "products",
      "path": "/products",
      "query": { "page_size": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/products.json",
      "projection": "passthrough"
    },
    {
      "name": "inventory",
      "path": "/inventory",
      "query": { "page_size": "{{ config.page_size }}" },
      "records": { "path": "data" },
      "schema": "schemas/inventory.json",
      "projection": "passthrough"
    }
  ]
}
