{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Intercom Conversation",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "properties": {
    "id": { "type": "string" },
    "type": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "state": { "type": ["string", "null"] },
    "open": { "type": ["boolean", "null"] },
    "read": { "type": ["boolean", "null"] },
    "priority": { "type": ["string", "null"] },
    "created_at": { "type": ["integer", "null"] },
    "updated_at": { "type": ["integer", "null"] },
    "waiting_since": { "type": ["integer", "null"] },
    "snoozed_until": { "type": ["integer", "null"] },
    "admin_assignee_id": { "type": ["integer", "null"] }
  },
  "required": ["id"]
}
