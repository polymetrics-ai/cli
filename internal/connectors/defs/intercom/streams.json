{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Intercom-Version": "{{ config.api_version }}"
    },
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "starting_after",
      "token_path": "pages.next.starting_after",
      "page_size": 50
    },
    "check": {
      "method": "GET",
      "path": "/admins"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "intercom access_token is missing or invalid; re-run pm credentials add intercom"
      },
      {
        "status": 403,
        "hint": "intercom token lacks access to this Intercom workspace operation"
      },
      {
        "status": 404,
        "hint": "intercom resource not found or not visible to the configured token"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "intercom rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "records": {
        "path": "data"
      },
      "schema": "schemas/contacts.json",
      "query": {
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
      }
    },
    {
      "name": "companies",
      "path": "/companies",
      "records": {
        "path": "data"
      },
      "schema": "schemas/companies.json",
      "query": {
        "name": {
          "template": "{{ query.name }}",
          "omit_when_absent": true
        },
        "company_id": {
          "template": "{{ query.company_id }}",
          "omit_when_absent": true
        },
        "tag_id": {
          "template": "{{ query.tag_id }}",
          "omit_when_absent": true
        },
        "segment_id": {
          "template": "{{ query.segment_id }}",
          "omit_when_absent": true
        },
        "page": {
          "template": "{{ query.page }}",
          "default": "1"
        },
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
      }
    },
    {
      "name": "conversations",
      "path": "/conversations",
      "records": {
        "path": "conversations"
      },
      "schema": "schemas/conversations.json",
      "query": {
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        },
        "starting_after": {
          "template": "{{ query.starting_after }}",
          "omit_when_absent": true
        }
      }
    },
    {
      "name": "admins",
      "path": "/admins",
      "records": {
        "path": "admins"
      },
      "schema": "schemas/admins.json",
      "query": {
        "display_avatar": {
          "template": "{{ query.display_avatar }}",
          "omit_when_absent": true
        },
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
      }
    },
    {
      "name": "tags",
      "path": "/tags",
      "records": {
        "path": "data"
      },
      "schema": "schemas/tags.json",
      "query": {
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
      }
    },
    {
      "name": "admin_activity_log",
      "path": "/admins/activity_logs",
      "records": {
        "path": "activity_logs"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "query": {
        "created_at_after": {
          "template": "{{ query.created_at_after }}",
          "omit_when_absent": true
        },
        "created_at_before": {
          "template": "{{ query.created_at_before }}",
          "omit_when_absent": true
        },
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
      }
    },
    {
      "name": "ai_content_import_source",
      "path": "/ai/content_import_sources",
      "records": {
        "path": "data"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "query": {
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
      }
    },
    {
      "name": "ai_external_page",
      "path": "/ai/external_pages",
      "records": {
        "path": "data"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "query": {
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
