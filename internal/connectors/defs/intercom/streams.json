      }
    },
    {
      "name": "article_search",
      "path": "/articles/search",
      "records": {
        "path": "data"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "query": {
        "phrase": {
          "template": "{{ query.phrase }}",
          "omit_when_absent": true
        },
        "state": {
          "template": "{{ query.state }}",
          "omit_when_absent": true
        },
        "help_center_id": {
          "template": "{{ query.help_center_id }}",
          "omit_when_absent": true
        },
        "highlight": {
          "template": "{{ query.highlight }}",
          "omit_when_absent": true
        },
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
