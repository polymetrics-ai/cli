      }
    },
    {
      "name": "call",
      "path": "/calls",
      "records": {
        "path": "data"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "query": {
        "page": {
          "template": "{{ query.page }}",
          "default": "1"
        },
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        }
      }
    },
    {
      "name": "call_search_search",
      "path": "/calls/search",
      "records": {
        "path": "data"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "method": "POST",
      "body": {
        "conversation_ids": [
          {
            "template": "{{ query.conversation_id }}",
            "default": "synthetic-conversation"
          }
        ]
      }
    },
    {
      "name": "company_list",
      "path": "/companies/list",
      "records": {
        "path": "data"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "method": "POST",
      "query": {
        "page": {
          "template": "{{ query.page }}",
          "default": "1"
        },
        "per_page": {
          "template": "{{ query.per_page }}",
          "default": "50"
        },
        "order": {
          "template": "{{ query.order }}",
          "omit_when_absent": true
        }
      },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 1,
        "page_size": 50
      }
    },
    {
      "name": "contact_search_search",
      "path": "/contacts/search",
      "records": {
        "path": "data"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "method": "POST",
      "body": {
        "query": {
          "operator": "AND",
          "value": [
            {
              "field": {
                "template": "{{ query.query_field }}",
                "default": "created_at"
              },
              "operator": {
                "template": "{{ query.query_operator }}",
                "default": ">"
              },
              "value": {
                "template": "{{ query.query_value }}",
                "default": "0"
              }
            }
          ]
        },
        "pagination": {
          "per_page": {
            "template": "{{ query.per_page }}",
            "default": "50",
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "conversation_search_search",
      "path": "/conversations/search",
      "records": {
        "path": "conversations"
      },
      "schema": "schemas/passthrough.json",
      "projection": "passthrough",
      "method": "POST",
      "body": {
        "query": {
          "operator": "AND",
          "value": [
