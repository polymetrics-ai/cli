{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "page_size",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/account" },
    "error_map": [
      { "status": 401, "hint": "dropbox-sign API key is missing or invalid; re-run pm credentials add dropbox-sign" },
      { "status": 403, "hint": "dropbox-sign account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "dropbox-sign rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "signature_requests",
      "path": "/signature_request/list",
      "records": { "path": "signature_requests" },
      "schema": "schemas/signature_requests.json"
    },
    {
      "name": "templates",
      "path": "/template/list",
      "records": { "path": "templates" },
      "schema": "schemas/templates.json"
    },
    {
      "name": "team_members",
      "path": "/team/members",
      "records": { "path": "team_members" },
      "schema": "schemas/team_members.json"
    },
    {
      "name": "account",
      "path": "/account",
      "pagination": { "type": "none" },
      "records": { "path": "account" },
      "schema": "schemas/account.json"
    }
  ]
}
