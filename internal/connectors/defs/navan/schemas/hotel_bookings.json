{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hotel_bookings",
  "type": "object",
  "x-primary-key": ["uuid"],
  "x-cursor-field": "last_modified",
  "required": ["uuid"],
  "properties": {
    "uuid": { "type": "string" },
    "booking_id": { "type": ["string", "null"] },
    "booking_type": { "type": ["string", "null"] },
    "booking_status": { "type": ["string", "null"] },
    "booking_method": { "type": ["string", "null"] },
    "approval_status": { "type": ["string", "null"] },
    "confirmation_number": { "type": ["string", "null"] },
    "currency": { "type": ["string", "null"] },
    "grand_total": { "type": ["number", "null"] },
    "base_price": { "type": ["number", "null"] },
    "booking_fee": { "type": ["number", "null"] },
    "destination": { "type": ["string", "null"] },
    "start_date": { "type": ["string", "null"], "format": "date-time" },
    "end_date": { "type": ["string", "null"], "format": "date-time" },
    "created": { "type": ["string", "null"], "format": "date-time" },
    "last_modified": { "type": ["string", "null"], "format": "date-time" },
    "cancelled_at": { "type": ["string", "null"], "format": "date-time" },
    "domestic": { "type": ["boolean", "null"] },
    "expensed": { "type": ["boolean", "null"] }
  }
}
