{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/groups" },
    "error_map": [
      { "status": 401, "hint": "bitly access token is missing or invalid; re-run pm credentials add bitly" },
      { "status": 429, "class": "rate_limited", "hint": "bitly rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "organizations",
      "path": "/organizations",
      "records": { "path": "organizations" },
      "schema": "schemas/organizations.json"
    },
    {
      "name": "groups",
      "path": "/groups",
      "records": { "path": "groups" },
      "schema": "schemas/groups.json"
    },
    {
      "name": "campaigns",
      "path": "/campaigns",
      "records": { "path": "campaigns" },
      "schema": "schemas/campaigns.json"
    },
    {
      "name": "channels",
      "path": "/channels",
      "records": { "path": "channels" },
      "schema": "schemas/channels.json"
    },
    {
      "name": "bsds",
      "path": "/bsds",
      "records": { "path": "" },
      "computed_fields": {
        "account": "self"
      },
      "schema": "schemas/bsds.json"
    },
    {
      "name": "webhooks",
      "path": "/webhooks",
      "records": { "path": "webhooks" },
      "schema": "schemas/webhooks.json"
    },
    {
      "name": "qr_codes",
      "path": "/qr-codes",
      "records": { "path": "qr_codes" },
      "schema": "schemas/qr_codes.json"
    },
    {
      "name": "group_tags",
      "path": "/groups/{{ config.group_guid }}/tags",
      "records": { "path": "" },
      "computed_fields": {
        "group_guid": "{{ config.group_guid }}"
      },
      "schema": "schemas/group_tags.json"
    },
    {
      "name": "bitlinks",
      "path": "/groups/{{ config.group_guid }}/bitlinks",
      "query": { "size": "50" },
      "records": { "path": "links" },
      "pagination": {
        "type": "next_url",
        "next_url_path": "pagination.next"
      },
      "schema": "schemas/bitlinks.json"
    }
  ]
}
