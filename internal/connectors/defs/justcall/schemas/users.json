  "title": "users",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "role": { "type": ["string", "null"] },
