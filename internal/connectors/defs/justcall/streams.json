{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key_2 }}" }
    ],
    "check": { "method": "GET", "path": "/v2.1/users" },
    "error_map": [
      { "status": 401, "hint": "justcall api_key_2 is missing or invalid; re-run pm credentials add justcall" },
      { "status": 403, "hint": "justcall account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "justcall rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "users",
      "path": "/v2.1/users",
      "records": { "path": "data" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 0,
        "page_size": 100
      },
      "schema": "schemas/users.json"
    },
    {
      "name": "calls",
      "path": "/v2.1/calls",
      "query": {
        "from_datetime": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 0,
        "page_size": 100
      },
      "incremental": {
        "cursor_field": "call_date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/calls.json"
    },
    {
      "name": "sms",
      "path": "/v2.1/texts",
      "query": {
        "from_datetime": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "per_page",
        "start_page": 0,
        "page_size": 100
      },
      "incremental": {
        "cursor_field": "sms_date",
        "start_config_key": "start_date"
      },
      "schema": "schemas/sms.json"
    }
  ]
}
