{
  "api": "OnceHub API v2 (https://api.oncehub.com)",
  "docs": "https://developers.oncehub.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; the full OnceHub surface (booking mutations, availability, webhooks) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/v2/bookings", "covered_by": { "stream": "bookings" } },
    { "method": "GET", "path": "/v2/contacts", "covered_by": { "stream": "contacts" } },
    { "method": "GET", "path": "/v2/booking-pages", "covered_by": { "stream": "booking_pages" } },
    { "method": "GET", "path": "/v2/users", "covered_by": { "stream": "users" } },
    { "method": "GET", "path": "/v2/event-types", "covered_by": { "stream": "event_types" } },
    { "method": "POST", "path": "/v2/bookings", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "DELETE", "path": "/v2/bookings/{id}", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/availability", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/v2/webhooks", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
