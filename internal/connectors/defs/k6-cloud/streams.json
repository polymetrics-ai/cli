{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_token }}" }
    ],
    "check": { "method": "GET", "path": "/v3/organizations" },
    "error_map": [
      { "status": 401, "hint": "k6-cloud api_token is missing or invalid; re-run pm credentials add k6-cloud" },
      { "status": 403, "hint": "k6-cloud account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "k6 Cloud rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "organizations",
      "path": "/v3/organizations",
      "records": { "path": "organizations" },
      "schema": "schemas/organizations.json"
    },
    {
      "name": "k6_tests",
      "path": "loadtests/v2/tests",
      "query": {
        "page_size": { "template": "{{ config.page_size }}", "default": "32" }
      },
      "records": { "path": "k6-tests" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "",
        "start_page": 1,
        "page_size": 32
      },
      "schema": "schemas/k6_tests.json"
    },
    {
      "name": "projects",
      "path": "/v3/organizations/{{ fanout.id }}/projects",
      "query": {
        "page_size": { "template": "{{ config.page_size }}", "default": "32" }
      },
      "records": { "path": "projects" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "",
        "start_page": 1,
        "page_size": 32
      },
      "fan_out": {
        "ids_from": {
          "request": {
            "path": "/v3/organizations",
            "records_path": "organizations",
            "id_field": "id"
          }
        },
        "into": {
          "path_var": "organization_id"
        }
      },
      "schema": "schemas/projects.json"
    }
  ]
}
