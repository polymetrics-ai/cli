{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.email }}/token", "password": "{{ secrets.api_token }}" }
    ],
    "check": { "method": "GET", "path": "/objects/types" },
    "error_map": [
      { "status": 401, "hint": "zendesk-sunshine credentials are missing or invalid; re-run pm credentials add zendesk-sunshine" },
      { "status": 403, "hint": "zendesk-sunshine account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "zendesk-sunshine rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "object_types",
      "path": "/objects/types",
      "records": { "path": "data" },
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "computed_fields": {
        "id": "{{ record.key }}"
      },
      "schema": "schemas/object_types.json"
    },
    {
      "name": "relationship_types",
      "path": "/relationships/types",
      "records": { "path": "data" },
      "computed_fields": {
        "id": "{{ record.key }}"
      },
      "schema": "schemas/relationship_types.json"
    },
    {
      "name": "objects",
      "path": "/objects/records",
      "records": { "path": "data" },
      "query": {
        "type": { "template": "{{ config.object_type }}", "omit_when_absent": true }
      },
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "schema": "schemas/objects.json"
    },
    {
      "name": "relationships",
      "path": "/relationships/records",
      "records": { "path": "data" },
      "query": {
        "type": { "template": "{{ config.relationship_type }}", "omit_when_absent": true }
      },
      "pagination": { "type": "next_url", "next_url_path": "links.next" },
      "schema": "schemas/relationships.json"
    }
  ]
}
