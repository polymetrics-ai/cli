{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stablecoins",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "symbol": { "type": ["string", "null"] },
    "gecko_id": { "type": ["string", "null"] },
    "pegType": { "type": ["string", "null"] },
    "pegMechanism": { "type": ["string", "null"] },
    "price": { "type": ["number", "null"] },
    "circulating": { "type": ["object", "null"] }
  }
}
