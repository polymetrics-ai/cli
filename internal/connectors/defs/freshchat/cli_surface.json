      "path": "conversation create",
      "summary": "Create a Freshchat conversation",
      "intent": "reverse_etl",
      "availability": "partial",
      "write": "create_conversation",
      "source_url": "https://developers.freshchat.com/api/",
      "risk": "Creates a Freshchat conversation.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
