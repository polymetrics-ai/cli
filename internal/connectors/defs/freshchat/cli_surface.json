      "source_url": "https://developers.freshchat.com/api/",
      "risk": "Sends a visible message into an existing Freshchat conversation.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "notes": "The write action supports structured message_parts records; full command flag mapping for nested message payloads is deferred.",
      "api_surface": [
        { "method": "POST", "path": "/conversations/{conversation_id}/messages" }
      ]
    },
