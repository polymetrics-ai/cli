    {
      "path": "conversation update",
      "summary": "Update routing, status, or properties on a Freshchat conversation",
      "intent": "reverse_etl",
      "availability": "implemented",
      "write": "update_conversation",
      "source_url": "https://developers.freshchat.com/api/",
      "risk": "Updates routing, status, priority, or properties on an existing Freshchat conversation.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "flags": [
        { "name": "conversation-id", "type": "string", "summary": "Freshchat conversation id.", "maps_to": "record.conversation_id" },
        { "name": "status", "type": "string", "summary": "Conversation status.", "maps_to": "record.status" },
        { "name": "assigned-agent-id", "type": "string", "summary": "Assigned agent id.", "maps_to": "record.assigned_agent_id" },
        { "name": "assigned-group-id", "type": "string", "summary": "Assigned group id.", "maps_to": "record.assigned_group_id" },
        { "name": "priority", "type": "string", "summary": "Conversation priority.", "maps_to": "record.priority" }
