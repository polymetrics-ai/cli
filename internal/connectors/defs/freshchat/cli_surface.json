{
  "tagline": "Work with Freshchat conversations, users, agents, reports, and metrics from the command line.",
  "usage": "pm freshchat <command> [flags]",
  "groups": [
    {
      "id": "account",
      "title": "Account Commands",
      "commands": ["account", "business-hours"]
    },
    {
      "id": "users",
      "title": "User Commands",
      "commands": ["user"]
    },
    {
      "id": "conversations",
      "title": "Conversation Commands",
      "commands": ["conversation", "csat"]
    },
    {
      "id": "agents",
      "title": "Agent Commands",
      "commands": ["agent"]
    },
    {
      "id": "directory",
      "title": "Directory Commands",
      "commands": ["group", "channel", "role"]
    },
    {
      "id": "outbound",
      "title": "Outbound Messaging Commands",
      "commands": ["outbound"]
    },
    {
      "id": "reports",
      "title": "Report And Metric Commands",
      "commands": ["report", "metrics"]
    },
    {
      "id": "files",
      "title": "File Commands",
      "commands": ["file", "image"]
    }
  ],
  "global_flags": [
    {
      "name": "json",
      "type": "boolean",
      "summary": "Write machine-readable JSON output."
    },
    {
      "name": "credential",
      "type": "string",
      "summary": "Use a saved Freshchat connector credential.",
      "maps_to": "credential"
    },
    {
      "name": "connection",
      "type": "string",
      "summary": "Alias for --credential.",
      "maps_to": "connection"
    }
  ],
  "commands": [
    {
      "path": "account configuration",
      "summary": "Read Freshchat account configuration",
      "intent": "etl",
      "availability": "implemented",
      "stream": "account_configuration",
      "source_url": "https://developers.freshchat.com/api/",
      "examples": ["pm freshchat account configuration --json"],
      "api_surface": [
        { "method": "GET", "path": "/accounts/configuration" }
      ]
    },
    {
      "path": "business-hours status",
      "summary": "Check whether a Freshchat group is within business hours",
      "intent": "etl",
      "availability": "implemented",
      "stream": "business_hours_status",
      "source_url": "https://developers.freshchat.com/api/",
      "notes": "Requires business_hours_group_id in connector config; use --config business_hours_group_id=<group_id> with the generic connector command runner.",
      "examples": ["pm freshchat business-hours status --config business_hours_group_id=group_123 --json"],
      "api_surface": [
        { "method": "GET", "path": "/business-hours/within-bh" }
      ]
    },
    {
      "path": "user list",
      "summary": "List Freshchat users",
      "intent": "etl",
      "availability": "implemented",
      "stream": "users",
      "source_url": "https://developers.freshchat.com/api/",
      "examples": ["pm freshchat user list --limit 50 --json"],
      "api_surface": [
        { "method": "GET", "path": "/users" }
      ]
    },
    {
      "path": "user fetch",
      "summary": "Fetch Freshchat users by id list",
      "intent": "direct_read",
      "availability": "implemented",
      "source_url": "https://developers.freshchat.com/api/",
      "api_surface": [
        { "method": "POST", "path": "/users/fetch" }
      ],
      "output_policy": "freshchat_users_fetch",
      "flags": [
        { "name": "id", "type": "string_array", "summary": "Freshchat user ids. Repeat or comma-separate to fetch multiple users.", "maps_to": "body.ids" }
      ],
      "examples": ["pm freshchat user fetch --id user_123 --id user_456 --json"],
      "notes": "Typed direct-read body support is limited to the Freshchat users/fetch ids array; this is not a raw HTTP POST escape hatch."
    },
    {
      "path": "user view",
      "summary": "Read one Freshchat user",
      "intent": "etl",
      "availability": "implemented",
      "stream": "user_details",
      "source_url": "https://developers.freshchat.com/api/",
      "notes": "Requires user_id in connector config; use --config user_id=<user_id> until direct-read path flags are implemented.",
      "examples": ["pm freshchat user view --config user_id=user_123 --json"],
      "api_surface": [
        { "method": "GET", "path": "/users/{user_id}" }
      ]
    },
    {
      "path": "user conversations",
      "summary": "List conversations for one Freshchat user",
      "intent": "etl",
      "availability": "implemented",
      "stream": "user_conversations",
      "source_url": "https://developers.freshchat.com/api/",
      "notes": "Requires user_id in connector config; use --config user_id=<user_id> until direct-read path flags are implemented.",
      "examples": ["pm freshchat user conversations --config user_id=user_123 --json"],
      "api_surface": [
        { "method": "GET", "path": "/users/{user_id}/conversations" }
      ]
    },
    {
      "path": "user create",
      "summary": "Create a Freshchat user",
      "intent": "reverse_etl",
      "availability": "implemented",
      "write": "create_user",
      "source_url": "https://developers.freshchat.com/api/",
      "risk": "Creates a Freshchat user/contact visible to agents.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "flags": [
        { "name": "email", "type": "string", "summary": "User email address.", "maps_to": "record.email" },
        { "name": "first-name", "type": "string", "summary": "User first name.", "maps_to": "record.first_name" },
        { "name": "last-name", "type": "string", "summary": "User last name.", "maps_to": "record.last_name" },
        { "name": "phone", "type": "string", "summary": "User phone number.", "maps_to": "record.phone" },
        { "name": "reference-id", "type": "string", "summary": "External reference id.", "maps_to": "record.reference_id" }
      ],
      "examples": ["pm freshchat user create --email user@example.invalid --first-name Ada --json"],
      "api_surface": [
        { "method": "POST", "path": "/users" }
      ]
    },
    {
      "path": "user update",
      "summary": "Update a Freshchat user",
      "intent": "reverse_etl",
      "availability": "implemented",
      "write": "update_user",
      "source_url": "https://developers.freshchat.com/api/",
      "risk": "Updates an existing Freshchat user/contact.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute.",
      "flags": [
        { "name": "user-id", "type": "string", "summary": "Freshchat user id.", "maps_to": "record.user_id" },
        { "name": "email", "type": "string", "summary": "User email address.", "maps_to": "record.email" },
        { "name": "first-name", "type": "string", "summary": "User first name.", "maps_to": "record.first_name" },
        { "name": "last-name", "type": "string", "summary": "User last name.", "maps_to": "record.last_name" },
        { "name": "phone", "type": "string", "summary": "User phone number.", "maps_to": "record.phone" },
        { "name": "reference-id", "type": "string", "summary": "External reference id.", "maps_to": "record.reference_id" }
      ],
      "examples": ["pm freshchat user update --user-id user_123 --first-name Grace --json"],
      "api_surface": [
        { "method": "PUT", "path": "/users/{user_id}" }
      ]
    },
    {
      "path": "user delete",
      "summary": "Delete a Freshchat user",
      "intent": "reverse_etl",
      "availability": "implemented",
      "write": "delete_user",
      "source_url": "https://developers.freshchat.com/api/",
      "risk": "Deletes a Freshchat user/contact.",
      "approval": "Reverse ETL writes require plan, preview, approval, execute and destructive confirmation.",
      "flags": [
        { "name": "user-id", "type": "string", "summary": "Freshchat user id.", "maps_to": "record.user_id" }
      ],
      "api_surface": [
        { "method": "DELETE", "path": "/users/{user_id}" }
      ]
    },
