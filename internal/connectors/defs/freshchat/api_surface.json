{
  "api": "Freshchat REST API v2",
  "docs": "https://developers.freshchat.com/api/",
  "reviewed_at": "2026-07-03",
  "scope": "Pass B expansion of the Freshchat v2 API reference. JSON GET list/detail endpoints are covered as streams. Plain JSON resource mutations are exposed as write actions. Multipart uploads, binary/download-style report artifacts, and POST search endpoints whose request-body read semantics are not modeled by the engine read path are excluded with endpoint-specific reasons.",
  "endpoints": [
    { "method": "GET", "path": "/accounts/configuration", "covered_by": { "stream": "account_configuration" } },

    { "method": "GET", "path": "/agents", "covered_by": { "stream": "agents" } },
    { "method": "POST", "path": "/agents", "covered_by": { "write": "create_agent" } },
    { "method": "GET", "path": "/agents/{agent_id}", "covered_by": { "stream": "agent_details" } },
    { "method": "PUT", "path": "/agents/{agent_id}", "covered_by": { "write": "update_agent" } },
    { "method": "GET", "path": "/agents/status", "covered_by": { "stream": "agent_statuses" } },
    { "method": "PATCH", "path": "/agents/{agent_id}", "covered_by": { "write": "update_agent_status" } },
    { "method": "DELETE", "path": "/agents/{agent_id}", "covered_by": { "write": "delete_agent" } },

    { "method": "GET", "path": "/users", "covered_by": { "stream": "users" } },
    { "method": "POST", "path": "/users", "covered_by": { "write": "create_user" } },
    { "method": "POST", "path": "/users/fetch", "excluded": { "category": "out_of_scope", "reason": "read-like subset fetch requires request-body search criteria; engine read streams currently do not send declared stream.body payloads" } },
    { "method": "GET", "path": "/users/{user_id}", "covered_by": { "stream": "user_details" } },
    { "method": "PUT", "path": "/users/{user_id}", "covered_by": { "write": "update_user" } },
    { "method": "GET", "path": "/users/{user_id}/conversations", "covered_by": { "stream": "user_conversations" } },
    { "method": "DELETE", "path": "/users/{user_id}", "covered_by": { "write": "delete_user" } },

    { "method": "POST", "path": "/conversations", "covered_by": { "write": "create_conversation" } },
    { "method": "GET", "path": "/conversations/{conversation_id}", "covered_by": { "stream": "conversation_detail" } },
    { "method": "PUT", "path": "/conversations/{conversation_id}", "covered_by": { "write": "update_conversation" } },
    { "method": "GET", "path": "/conversations/{conversation_id}/messages", "covered_by": { "stream": "conversation_messages" } },
    { "method": "POST", "path": "/conversations/{conversation_id}/messages", "covered_by": { "write": "send_conversation_message" } },
    { "method": "GET", "path": "/conversations/fields", "covered_by": { "stream": "conversation_fields" } },

    { "method": "GET", "path": "/groups", "covered_by": { "stream": "groups" } },
    { "method": "GET", "path": "/channels", "covered_by": { "stream": "channels" } },
    { "method": "GET", "path": "/roles", "covered_by": { "stream": "roles" } },

    { "method": "POST", "path": "/csat/{conversation_id}", "covered_by": { "write": "create_csat_rating" } },
    { "method": "POST", "path": "/files/upload", "excluded": { "category": "binary_payload", "reason": "file upload is multipart/binary transfer and is not expressible by the JSON/form write dialect without a hook" } },
    { "method": "POST", "path": "/images/upload", "excluded": { "category": "binary_payload", "reason": "image upload is multipart/binary transfer and is not expressible by the JSON/form write dialect without a hook" } },

    { "method": "POST", "path": "/outbound-messages/whatsapp", "covered_by": { "write": "send_outbound_whatsapp_message" } },
    { "method": "GET", "path": "/outbound-messages", "covered_by": { "stream": "outbound_messages" } },

    { "method": "POST", "path": "/reports/raw", "covered_by": { "write": "extract_report" } },
    { "method": "GET", "path": "/reports/raw/{id}", "covered_by": { "stream": "report_status" } },

    { "method": "GET", "path": "/metrics/historical", "covered_by": { "stream": "historical_metrics" } },
    { "method": "GET", "path": "/metrics/instant", "covered_by": { "stream": "instant_metrics" } },
    { "method": "GET", "path": "/business-hours/within-bh", "covered_by": { "stream": "business_hours_status" } }
  ]
}
