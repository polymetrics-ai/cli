{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page_index",
      "size_param": "items_per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/organisations", "query": { "page_index": "1", "items_per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "employment-hero api_key is missing or invalid; re-run pm credentials add employment-hero" },
      { "status": 429, "class": "rate_limited", "hint": "employment-hero rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "organisations",
      "path": "/organisations",
      "records": { "path": "data.items" },
      "schema": "schemas/organisations.json"
    },
    {
      "name": "employees",
      "path": "/organisations/{{ config.organization_id }}/employees",
      "records": { "path": "data.items" },
      "schema": "schemas/employees.json"
    },
    {
      "name": "leave_requests",
      "path": "/organisations/{{ config.organization_id }}/leave_requests",
      "records": { "path": "data.items" },
      "schema": "schemas/leave_requests.json"
    },
    {
      "name": "teams",
      "path": "/organisations/{{ config.organization_id }}/teams",
      "records": { "path": "data.items" },
      "schema": "schemas/teams.json"
    }
  ]
}
