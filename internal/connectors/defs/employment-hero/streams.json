{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "Accept": "application/json"
    },
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}"
      }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page_index",
      "size_param": "items_per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/v1/organisations",
      "query": {
        "page_index": "1",
        "items_per_page": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "employment-hero api_key is missing or invalid; re-run pm credentials add employment-hero"
      },
      {
        "status": 403,
        "hint": "employment-hero token lacks the required scope for this organisation or endpoint"
      },
      {
        "status": 404,
        "hint": "employment-hero resource not found or token lacks access"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "employment-hero rate limit exceeded; retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "organisations",
      "path": "/v1/organisations",
      "records": {
        "path": "data.items"
      },
      "schema": "schemas/organisations.json"
    },
    {
      "name": "organisation",
      "path": "/v1/organisations/{{ config.organization_id }}",
      "records": {
        "path": "data",
        "single_object": true
      },
      "pagination": {
        "type": "none"
      },
      "schema": "schemas/organisation.json"
    },
