{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.private_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "continuation",
      "token_path": "pagination.continuation",
      "stop_path": "pagination.has_more_items"
    },
    "check": { "method": "GET", "path": "/users/me/organizations/" },
    "error_map": [
      { "status": 401, "hint": "eventbrite private_token is missing or invalid; re-run pm credentials add eventbrite" },
      { "status": 403, "hint": "eventbrite account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "eventbrite rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "organizations",
      "path": "/users/me/organizations/",
      "query": { "expand": "venue,ticket_classes" },
      "records": { "path": "organizations" },
      "schema": "schemas/organizations.json"
    },
    {
      "name": "events",
      "path": "/organizations/{{ config.organization_id }}/events/",
      "query": {
        "expand": "venue,ticket_classes",
        "changed_since": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "events" },
      "computed_fields": {
        "name": "{{ record.name.text }}",
        "description": "{{ record.description.text }}",
        "start": "{{ record.start.utc }}",
        "end": "{{ record.end.utc }}"
      },
      "incremental": {
        "cursor_field": "changed",
        "request_param": "changed_since",
        "start_config_key": "start_date"
      },
      "schema": "schemas/events.json"
    },
    {
      "name": "attendees",
      "path": "/events/{{ config.event_id }}/attendees/",
      "query": {
        "expand": "venue,ticket_classes",
        "changed_since": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "attendees" },
      "computed_fields": {
        "name": "{{ record.profile.name }}",
        "email": "{{ record.profile.email }}"
      },
      "incremental": {
        "cursor_field": "changed",
        "request_param": "changed_since",
        "start_config_key": "start_date"
      },
      "schema": "schemas/attendees.json"
    },
    {
      "name": "orders",
      "path": "/events/{{ config.event_id }}/orders/",
      "query": {
        "expand": "venue,ticket_classes",
        "changed_since": { "template": "{{ incremental.lower_bound }}", "omit_when_absent": true }
      },
      "records": { "path": "orders" },
      "incremental": {
        "cursor_field": "changed",
        "request_param": "changed_since",
        "start_config_key": "start_date"
      },
      "schema": "schemas/orders.json"
    },
    {
      "name": "ticket_classes",
      "path": "/events/{{ config.event_id }}/ticket_classes/",
      "query": {
        "expand": "venue,ticket_classes",
        "changed_since": { "template": "{{ config.start_date }}", "omit_when_absent": true }
      },
      "records": { "path": "ticket_classes" },
      "computed_fields": {
        "name": "{{ record.name.text }}",
        "description": "{{ record.description.text }}",
        "cost": "{{ record.cost.display }}",
        "fee": "{{ record.fee.display }}"
      },
      "schema": "schemas/ticket_classes.json"
    }
  ]
}
