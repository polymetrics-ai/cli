{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_token }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page",
      "token_path": "next_page"
    },
    "check": {
      "method": "GET",
      "path": "/reports-service/report",
      "query": { "limit": "1" }
    },
    "error_map": [
      { "status": 401, "hint": "adjust api_token is missing or invalid; re-run pm credentials add adjust" },
      { "status": 403, "hint": "adjust account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "adjust rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "reports",
      "path": "/reports-service/report",
      "query": {
        "dimensions": "{{ config.dimensions }}",
        "metrics": "{{ config.metrics }}",
        "additional_metrics": { "template": "{{ config.additional_metrics }}", "omit_when_absent": true },
        "date_period": { "template": "{{ config.start_date }}:{{ config.end_date }}", "omit_when_absent": true }
      },
      "records": { "path": "rows" },
      "computed_fields": {
        "date": "{{ record.dimensions.date }}",
        "country": "{{ record.dimensions.country }}",
        "app": "{{ record.dimensions.app }}",
        "installs": "{{ record.metrics.installs }}",
        "clicks": "{{ record.metrics.clicks }}",
        "cost": "{{ record.metrics.cost }}"
      },
      "schema": "schemas/reports.json"
    }
  ]
}
