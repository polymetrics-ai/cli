{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "none"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/__legacy_hook/check"
    },
    "error_map": []
  },
  "streams": [
    {
      "name": "customers",
      "method": "GET",
      "path": "/__legacy_hook/customers",
      "records": {
        "path": "data"
      },
      "schema": "schemas/customers.json"
    },
    {
      "name": "invoices",
      "method": "GET",
      "path": "/__legacy_hook/invoices",
      "records": {
        "path": "data"
      },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "products",
      "method": "GET",
      "path": "/__legacy_hook/products",
      "records": {
        "path": "data"
      },
      "schema": "schemas/products.json"
    },
    {
      "name": "recurring_invoices",
      "method": "GET",
      "path": "/__legacy_hook/recurring_invoices",
      "records": {
        "path": "data"
      },
      "schema": "schemas/recurring_invoices.json"
    },
    {
      "name": "revenues",
      "method": "GET",
      "path": "/__legacy_hook/revenues",
      "records": {
        "path": "data"
      },
      "schema": "schemas/revenues.json"
    }
  ]
}
