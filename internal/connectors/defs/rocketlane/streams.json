{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "api-key", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "pageSize",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/projects" },
    "error_map": [
      { "status": 401, "hint": "rocketlane api_key is missing or invalid; re-run pm credentials add rocketlane" },
      { "status": 403, "hint": "rocketlane account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "rocketlane rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "projects",
      "path": "/projects",
      "query": {
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "status": { "template": "{{ config.status }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "computed_fields": { "stream": "projects" },
      "projection": "passthrough",
      "schema": "schemas/projects.json"
    },
    {
      "name": "tasks",
      "path": "/tasks",
      "query": {
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "projectId": { "template": "{{ config.project_id }}", "omit_when_absent": true },
        "status": { "template": "{{ config.status }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "computed_fields": { "stream": "tasks" },
      "projection": "passthrough",
      "schema": "schemas/tasks.json"
    },
    {
      "name": "customers",
      "path": "/customers",
      "query": {
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "computed_fields": { "stream": "customers" },
      "projection": "passthrough",
      "schema": "schemas/customers.json"
    },
    {
      "name": "users",
      "path": "/users",
      "query": {
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "status": { "template": "{{ config.status }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "computed_fields": { "stream": "users" },
      "projection": "passthrough",
      "schema": "schemas/users.json"
    },
    {
      "name": "time_entries",
      "path": "/time-entries",
      "query": {
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "projectId": { "template": "{{ config.project_id }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "computed_fields": { "stream": "time_entries" },
      "projection": "passthrough",
      "schema": "schemas/time_entries.json"
    }
  ]
}
