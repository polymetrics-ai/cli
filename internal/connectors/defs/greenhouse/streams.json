{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {
      "On-Behalf-Of": "{{ config.on_behalf_of_user_id }}"
    },
    "auth": [
      {
        "mode": "basic",
        "username": "{{ secrets.api_key }}",
        "password": ""
      }
    ],
    "pagination": {
      "type": "link_header",
      "page_size": 100
    },
    "check": {
      "method": "GET",
      "path": "/jobs",
      "query": {
        "per_page": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "greenhouse api_key is missing or invalid; re-run pm credentials add greenhouse"
      },
      {
        "status": 403,
        "hint": "greenhouse account lacks access for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "greenhouse rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
