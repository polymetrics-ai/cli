{
  "api": "Greenhouse Harvest API (https://harvest.greenhouse.io/v1)",
  "docs": "https://developers.greenhouse.io/harvest.html",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only (candidates, applications, jobs, offers, users); the full Harvest surface (scorecards, scheduled_interviews, departments, offices, custom_fields, activity_feed, etc.) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/candidates", "covered_by": { "stream": "candidates" } },
    { "method": "GET", "path": "/applications", "covered_by": { "stream": "applications" } },
    { "method": "GET", "path": "/jobs", "covered_by": { "stream": "jobs" } },
    { "method": "GET", "path": "/offers", "covered_by": { "stream": "offers" } },
    { "method": "GET", "path": "/users", "covered_by": { "stream": "users" } },
    { "method": "POST", "path": "/candidates", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/scorecards", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/scheduled_interviews", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/departments", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/offices", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/custom_fields", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/activity_feed", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
