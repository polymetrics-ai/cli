{
  "api": "Pabbly Subscriptions Billing API",
  "docs": "https://www.pabbly.com/subscriptions/api/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only; legacy exposes no write actions and this bundle adds none",
  "endpoints": [
    { "method": "GET", "path": "/customers", "covered_by": { "stream": "customers" } },
