{
  "actions": [
    {
      "name": "create_booking_amendment",
      "kind": "create",
      "method": "POST",
      "path": "/booking_amendments",
      "body_type": "json",
      "body_fields": ["booking_id", "new_name", "amendment_note", "new_container_counts", "new_wants_pickup_service", "new_wants_import_customs_service", "new_wants_flexport_freight", "new_wants_bco", "new_wants_214_filing", "new_wants_ftz_entry", "new_origin_address_ref", "new_origin_port_us_cbp_port_code", "new_origin_port_loc_code", "new_destination_address_ref", "new_destination_port_us_cbp_port_code", "new_destination_port_loc_code", "new_cargo_ready_date", "new_delivery_date", "new_product_descriptions", "new_cargo", "new_metadata", "new_container_references"],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["booking_id"],
        "additionalProperties": false,
        "properties": {
          "booking_id": { "type": "integer" },
          "new_name": { "type": "string" },
          "amendment_note": { "type": "string" },
          "new_container_counts": { "type": "object" },
          "new_wants_pickup_service": { "type": "boolean" },
          "new_wants_import_customs_service": { "type": "boolean" },
          "new_wants_flexport_freight": { "type": "boolean" },
          "new_wants_bco": { "type": "boolean" },
          "new_wants_214_filing": { "type": "boolean" },
          "new_wants_ftz_entry": { "type": "boolean" },
          "new_origin_address_ref": { "type": "string" },
          "new_origin_port_us_cbp_port_code": { "type": "string" },
          "new_origin_port_loc_code": { "type": "string" },
          "new_destination_address_ref": { "type": "string" },
          "new_destination_port_us_cbp_port_code": { "type": "string" },
          "new_destination_port_loc_code": { "type": "string" },
          "new_cargo_ready_date": { "type": "string" },
          "new_delivery_date": { "type": "string" },
          "new_product_descriptions": { "type": "array", "items": { "type": "object" } },
          "new_cargo": { "type": "object" },
          "new_metadata": { "type": "object" },
          "new_container_references": { "type": "object" }
        }
      },
      "risk": "requests a booking amendment; Flexport may apply the change immediately or queue it for approval depending on shipment state"
    },
    {
      "name": "create_booking_line_item",
