{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ config.email }}", "password": "{{ secrets.password }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page",
      "token_path": "next_page"
    },
    "check": { "method": "GET", "path": "/events" },
    "error_map": [
      { "status": 401, "hint": "oveit credentials are missing or invalid; re-run pm credentials add oveit" },
      { "status": 403, "hint": "oveit account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "oveit rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "events",
      "path": "/events",
      "query": { "per_page": { "template": "{{ config.page_size }}", "default": "100" } },
      "records": { "path": "data" },
      "schema": "schemas/events.json"
    },
    {
      "name": "orders",
      "path": "/orders",
      "query": { "per_page": { "template": "{{ config.page_size }}", "default": "100" } },
      "records": { "path": "data" },
      "schema": "schemas/orders.json"
    },
    {
      "name": "attendees",
      "path": "/attendees",
      "query": { "per_page": { "template": "{{ config.page_size }}", "default": "100" } },
      "records": { "path": "data" },
      "schema": "schemas/attendees.json"
    }
  ]
}
