{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tavus Connection Specification",
  "type": "object",
  "required": ["api_key"],
  "properties": {
    "api_key": {
      "type": "string",
      "x-secret": true,
      "description": "Tavus API key, sent as the x-api-key header. Never logged."
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "default": "https://tavusapi.com/v2",
      "description": "Tavus API base URL override for tests or proxies."
    }
  }
}
