{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_token }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/customers", "query": { "page": "1", "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "repairshopr api_token is missing or invalid; re-run pm credentials add repairshopr" },
      { "status": 403, "hint": "repairshopr account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "repairshopr rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "customers",
      "path": "/customers",
      "query": {
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "query": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "customers" },
      "computed_fields": { "stream": "customers" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "tickets",
      "path": "/tickets",
      "query": {
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "query": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "tickets" },
      "computed_fields": { "stream": "tickets" },
      "schema": "schemas/tickets.json"
    },
    {
      "name": "invoices",
      "path": "/invoices",
      "query": {
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "query": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "invoices" },
      "computed_fields": { "stream": "invoices" },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "estimates",
      "path": "/estimates",
      "query": {
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "query": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "estimates" },
      "computed_fields": { "stream": "estimates" },
      "schema": "schemas/estimates.json"
    },
    {
      "name": "assets",
      "path": "/customer_assets",
      "query": {
        "created_after": { "template": "{{ config.created_after }}", "omit_when_absent": true },
        "updated_after": { "template": "{{ config.updated_after }}", "omit_when_absent": true },
        "query": { "template": "{{ config.query }}", "omit_when_absent": true }
      },
      "records": { "path": "assets" },
      "computed_fields": { "stream": "assets" },
      "schema": "schemas/assets.json"
    }
  ]
}
