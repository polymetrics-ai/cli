{
  "api": "Pexels API v1 (https://www.pexels.com/api/documentation/)",
  "docs": "https://www.pexels.com/api/documentation/",
  "reviewed_at": "2026-07-02",
  "scope": "wave2 fan-out migration: the 4 legacy-parity read streams only (photos, curated_photos, videos, popular_videos); legacy ships no writes.",
  "endpoints": [
    { "method": "GET", "path": "/v1/search", "covered_by": { "stream": "photos" } },
    { "method": "GET", "path": "/v1/curated", "covered_by": { "stream": "curated_photos" } },
    { "method": "GET", "path": "/v1/videos/search", "covered_by": { "stream": "videos" } },
    { "method": "GET", "path": "/v1/videos/popular", "covered_by": { "stream": "popular_videos" } },
    { "method": "GET", "path": "/v1/photos/{id}", "excluded": { "category": "out_of_scope", "reason": "single-resource lookup, not modeled by legacy; Pass B capability expansion" } },
    { "method": "GET", "path": "/v1/collections/featured", "excluded": { "category": "out_of_scope", "reason": "not modeled by legacy; Pass B capability expansion" } }
  ]
}
