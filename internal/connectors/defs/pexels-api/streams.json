{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Authorization", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "next_url",
      "next_url_path": "next_page"
    },
    "check": { "method": "GET", "path": "/v1/search" },
    "error_map": [
      { "status": 401, "hint": "pexels-api key is missing or invalid; re-run pm credentials add pexels-api" },
      { "status": 429, "class": "rate_limited", "hint": "pexels-api rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "photos",
      "path": "/v1/search",
      "query": {
        "page": "1",
        "per_page": "40",
        "query": { "template": "{{ config.query }}", "default": "people" },
        "orientation": { "template": "{{ config.orientation }}", "omit_when_absent": true },
        "size": { "template": "{{ config.size }}", "omit_when_absent": true },
        "color": { "template": "{{ config.color }}", "omit_when_absent": true },
        "locale": { "template": "{{ config.locale }}", "omit_when_absent": true }
      },
      "records": { "path": "photos" },
      "schema": "schemas/photos.json"
    },
    {
      "name": "curated_photos",
      "path": "/v1/curated",
      "query": {
        "page": "1",
        "per_page": "40",
        "orientation": { "template": "{{ config.orientation }}", "omit_when_absent": true },
        "size": { "template": "{{ config.size }}", "omit_when_absent": true },
        "color": { "template": "{{ config.color }}", "omit_when_absent": true },
        "locale": { "template": "{{ config.locale }}", "omit_when_absent": true }
      },
      "records": { "path": "photos" },
      "schema": "schemas/curated_photos.json"
    },
    {
      "name": "videos",
      "path": "/v1/videos/search",
      "query": {
        "page": "1",
        "per_page": "40",
        "query": { "template": "{{ config.query }}", "default": "people" },
        "orientation": { "template": "{{ config.orientation }}", "omit_when_absent": true },
        "size": { "template": "{{ config.size }}", "omit_when_absent": true },
        "color": { "template": "{{ config.color }}", "omit_when_absent": true },
        "locale": { "template": "{{ config.locale }}", "omit_when_absent": true }
      },
      "records": { "path": "videos" },
      "schema": "schemas/videos.json"
    },
    {
      "name": "popular_videos",
      "path": "/v1/videos/popular",
      "query": {
        "page": "1",
        "per_page": "40",
        "orientation": { "template": "{{ config.orientation }}", "omit_when_absent": true },
        "size": { "template": "{{ config.size }}", "omit_when_absent": true },
        "color": { "template": "{{ config.color }}", "omit_when_absent": true },
        "locale": { "template": "{{ config.locale }}", "omit_when_absent": true }
      },
      "records": { "path": "videos" },
      "schema": "schemas/popular_videos.json"
    }
  ]
}
