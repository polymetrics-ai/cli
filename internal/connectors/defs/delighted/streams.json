{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "basic", "username": "{{ secrets.api_key }}", "password": "" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/metrics.json" },
    "error_map": [
      { "status": 401, "hint": "delighted api_key is missing or invalid; re-run pm credentials add delighted" },
      { "status": 403, "hint": "delighted api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "delighted rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "survey_responses",
      "path": "/survey_responses.json",
      "records": { "path": "" },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "since",
        "param_format": "unix_seconds",
        "start_config_key": "start_date"
      },
      "schema": "schemas/survey_responses.json"
    },
    {
      "name": "people",
      "path": "/people.json",
      "records": { "path": "" },
      "schema": "schemas/people.json"
    },
    {
      "name": "bounces",
      "path": "/bounces.json",
      "records": { "path": "" },
      "schema": "schemas/bounces.json"
    },
    {
      "name": "unsubscribes",
      "path": "/unsubscribes.json",
      "records": { "path": "" },
      "schema": "schemas/unsubscribes.json"
    },
    {
      "name": "metrics",
      "path": "/metrics.json",
      "pagination": { "type": "none" },
      "records": { "path": "" },
      "incremental": {
        "cursor_field": "",
        "request_param": "since",
        "param_format": "unix_seconds",
        "start_config_key": "start_date"
      },
      "schema": "schemas/metrics.json"
    }
  ]
}
