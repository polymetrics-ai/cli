{
  "api": "Delighted API v1 (https://api.delighted.com/v1)",
  "docs": "https://delighted.com/docs/api",
  "reviewed_at": "2026-07-03",
  "scope": "Pass B expansion of Delighted's practical read/write surface: the five read streams plus people create/update and delete actions. Single-record reads are duplicates of list streams.",
  "endpoints": [
    { "method": "GET", "path": "/survey_responses.json", "covered_by": { "stream": "survey_responses" } },
    { "method": "GET", "path": "/people.json", "covered_by": { "stream": "people" } },
    { "method": "GET", "path": "/bounces.json", "covered_by": { "stream": "bounces" } },
    { "method": "GET", "path": "/unsubscribes.json", "covered_by": { "stream": "unsubscribes" } },
    { "method": "GET", "path": "/metrics.json", "covered_by": { "stream": "metrics" } },
    { "method": "POST", "path": "/people.json", "covered_by": { "write": "create_person" } },
    { "method": "DELETE", "path": "/people/{person_id}.json", "covered_by": { "write": "delete_person" } },
    { "method": "GET", "path": "/survey_responses/{id}.json", "excluded": { "category": "duplicate_of", "reason": "single-record fetch of the same object already covered by the survey_responses list stream" } }
  ]
}
