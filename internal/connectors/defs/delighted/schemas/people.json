{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "people",
  "type": "object",
  "x-primary-key": ["id"],
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "phone_number": { "type": ["string", "null"] },
    "created_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "last_sent_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "last_responded_at": { "type": ["integer", "null"], "description": "Unix seconds." },
    "next_survey_scheduled_at": { "type": ["integer", "null"], "description": "Unix seconds." }
  }
}
