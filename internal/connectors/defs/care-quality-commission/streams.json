{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Ocp-Apim-Subscription-Key", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/inspection-areas" },
    "error_map": [
      { "status": 401, "hint": "care-quality-commission api_key is missing or invalid; re-run pm credentials add care-quality-commission" },
      { "status": 403, "hint": "care-quality-commission api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "care-quality-commission rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "locations",
      "path": "/locations",
      "records": { "path": "locations" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "perPage",
        "start_page": 1,
        "page_size": 1000
      },
      "schema": "schemas/locations.json"
    },
    {
      "name": "providers",
      "path": "/providers",
      "records": { "path": "providers" },
      "pagination": {
        "type": "page_number",
        "page_param": "page",
        "size_param": "perPage",
        "start_page": 1,
        "page_size": 1000
      },
      "schema": "schemas/providers.json"
    },
    {
      "name": "inspection_areas",
      "path": "/inspection-areas",
      "records": { "path": "inspectionAreas" },
      "pagination": { "type": "none" },
      "schema": "schemas/inspection_areas.json"
    }
  ]
}
