{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Linear issue",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "properties": {
    "id": { "type": "string" },
    "identifier": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "priority": { "type": ["integer", "null"] },
    "estimate": { "type": ["number", "null"] },
    "url": { "type": ["string", "null"] },
    "branch_name": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "canceled_at": { "type": ["string", "null"], "format": "date-time" },
    "createdAt": { "type": ["string", "null"], "format": "date-time" },
    "updatedAt": { "type": ["string", "null"], "format": "date-time" },
    "state_id": { "type": ["string", "null"] },
    "state_name": { "type": ["string", "null"] },
    "state_type": { "type": ["string", "null"] },
    "team_id": { "type": ["string", "null"] },
    "team_key": { "type": ["string", "null"] },
    "assignee_id": { "type": ["string", "null"] },
    "assignee_email": { "type": ["string", "null"] },
    "creator_id": { "type": ["string", "null"] }
  }
}
