{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "query": {
      "since_date": { "template": "{{ config.since_date }}", "omit_when_absent": true },
      "limit": { "template": "{{ config.limit }}", "omit_when_absent": true }
    },
    "check": { "method": "GET", "path": "/budgets" },
    "error_map": [
      { "status": 401, "hint": "you-need-a-budget-ynab api_key is missing or invalid; re-run pm credentials add you-need-a-budget-ynab" },
      { "status": 429, "class": "rate_limited", "hint": "ynab rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "budgets",
      "path": "/budgets",
      "records": { "path": "data.budgets" },
      "projection": "passthrough",
      "computed_fields": {
        "updated_at": "{{ record.last_modified_on }}"
      },
      "schema": "schemas/budgets.json"
    },
    {
      "name": "accounts",
      "path": "/budgets/{{ config.budget_id }}/accounts",
      "records": { "path": "data.accounts" },
      "projection": "passthrough",
      "computed_fields": {
        "updated_at": "{{ record.last_modified_on }}"
      },
      "schema": "schemas/accounts.json"
    },
    {
      "name": "transactions",
      "path": "/budgets/{{ config.budget_id }}/transactions",
      "records": { "path": "data.transactions" },
      "projection": "passthrough",
      "computed_fields": {
        "name": "{{ record.payee_name }}",
        "updated_at": "{{ record.date }}"
      },
      "schema": "schemas/transactions.json"
    }
  ]
}
