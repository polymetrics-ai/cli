{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accounts",
  "type": "object",
  "x-primary-key": ["id"],
  "x-cursor-field": "updated_at",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "on_budget": { "type": ["boolean", "null"] },
    "closed": { "type": ["boolean", "null"] },
    "balance": { "type": ["integer", "null"] },
    "cleared_balance": { "type": ["integer", "null"] },
    "uncleared_balance": { "type": ["integer", "null"] },
    "last_reconciled_at": { "type": ["string", "null"] },
    "deleted": { "type": ["boolean", "null"] },
    "updated_at": { "type": ["string", "null"] }
  }
}
