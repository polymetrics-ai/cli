{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "/signature_requests" },
    "error_map": [
      { "status": 401, "hint": "yousign api_key is missing or invalid; re-run pm credentials add yousign" },
      { "status": 403, "hint": "yousign account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "yousign rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "signature_requests",
      "path": "/signature_requests",
      "query": {
        "limit": { "template": "{{ config.limit }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "projection": "passthrough",
      "computed_fields": {
        "updated_at": "{{ coalesce record.updated_at record.created_at }}"
      },
      "schema": "schemas/signature_requests.json"
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "query": {
        "limit": { "template": "{{ config.limit }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "projection": "passthrough",
      "computed_fields": {
        "name": "{{ coalesce record.name record.email }}",
        "updated_at": "{{ coalesce record.updated_at record.created_at }}"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "documents",
      "path": "/documents",
      "query": {
        "limit": { "template": "{{ config.limit }}", "omit_when_absent": true }
      },
      "records": { "path": "data" },
      "projection": "passthrough",
      "computed_fields": {
        "name": "{{ coalesce record.name record.filename }}",
        "updated_at": "{{ coalesce record.updated_at record.created_at }}"
      },
      "schema": "schemas/documents.json"
    },
    {
      "name": "webhooks",
      "path": "/webhooks",
      "records": { "path": "" },
      "computed_fields": {
        "name": "{{ record.description }}"
      },
      "schema": "schemas/webhooks.json"
    },
    {
      "name": "templates",
      "path": "/templates",
      "pagination": {
        "type": "cursor",
        "cursor_param": "after",
        "token_path": "meta.next_cursor"
      },
      "records": { "path": "data" },
      "schema": "schemas/templates.json"
    },
    {
      "name": "users",
      "path": "/users",
      "pagination": {
        "type": "cursor",
        "cursor_param": "after",
        "token_path": "meta.next_cursor"
      },
      "records": { "path": "data" },
      "computed_fields": {
        "name": "{{ record.first_name }} {{ record.last_name }}"
      },
      "schema": "schemas/users.json"
    },
    {
      "name": "workflow_sessions",
      "path": "/workflow_sessions",
      "pagination": {
        "type": "cursor",
        "cursor_param": "after",
        "token_path": "meta.next_cursor"
      },
      "records": { "path": "data" },
      "schema": "schemas/workflow_sessions.json"
    }
  ]
}
