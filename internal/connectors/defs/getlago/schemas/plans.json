{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "plans",
  "type": "object",
  "x-primary-key": ["lago_id"],
  "x-cursor-field": "created_at",
  "required": ["lago_id"],
  "properties": {
    "lago_id": { "type": "string" },
    "name": { "type": ["string", "null"] },
    "code": { "type": ["string", "null"] },
    "interval": { "type": ["string", "null"] },
    "amount_cents": { "type": ["integer", "null"] },
    "amount_currency": { "type": ["string", "null"] },
    "pay_in_advance": { "type": ["boolean", "null"] },
    "trial_period": { "type": ["number", "null"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
