{
  "api": "Lago API v1 (https://api.getlago.com/api/v1)",
  "docs": "https://doc.getlago.com/api-reference/intro",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 5 legacy-parity read streams only; Lago's write endpoints (creating customers/subscriptions/wallets, applying add-ons) are out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/customers", "covered_by": { "stream": "customers" } },
    { "method": "GET", "path": "/invoices", "covered_by": { "stream": "invoices" } },
    { "method": "GET", "path": "/subscriptions", "covered_by": { "stream": "subscriptions" } },
    { "method": "GET", "path": "/plans", "covered_by": { "stream": "plans" } },
    { "method": "GET", "path": "/billable_metrics", "covered_by": { "stream": "billable_metrics" } },
    { "method": "POST", "path": "/customers", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/subscriptions", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "POST", "path": "/invoices/{id}/refresh", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/wallets", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/credit_notes", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
