{
  "base": {
    "url": "{{ config.api_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "per_page",
      "start_page": 1,
      "page_size": 100
    },
    "check": { "method": "GET", "path": "/customers", "query": { "page": "1", "per_page": "1" } },
    "error_map": [
      { "status": 401, "hint": "getlago api_key is missing or invalid; re-run pm credentials add getlago" },
      { "status": 429, "class": "rate_limited", "hint": "getlago rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "customers",
      "path": "/customers",
      "records": { "path": "customers" },
      "schema": "schemas/customers.json"
    },
    {
      "name": "invoices",
      "path": "/invoices",
      "records": { "path": "invoices" },
      "schema": "schemas/invoices.json"
    },
    {
      "name": "subscriptions",
      "path": "/subscriptions",
      "records": { "path": "subscriptions" },
      "schema": "schemas/subscriptions.json"
    },
    {
      "name": "plans",
      "path": "/plans",
      "records": { "path": "plans" },
      "schema": "schemas/plans.json"
    },
    {
      "name": "billable_metrics",
      "path": "/billable_metrics",
      "records": { "path": "billable_metrics" },
      "schema": "schemas/billable_metrics.json"
    }
  ]
}
