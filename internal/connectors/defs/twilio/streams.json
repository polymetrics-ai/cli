{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "basic",
        "username": "{{ secrets.account_sid }}",
        "password": "{{ secrets.auth_token }}"
      }
    ],
    "pagination": {
      "type": "none"
    },
    "check": {
      "method": "GET",
      "path": "/Accounts/{{ secrets.account_sid }}/Messages.json"
    },
    "error_map": [
      {
        "status": 401,
        "hint": "twilio account_sid/auth_token is missing or invalid; re-run pm credentials add twilio"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "twilio rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "messages",
      "path": "/Accounts/{{ secrets.account_sid }}/Messages.json",
      "records": {
        "path": "messages"
      },
      "schema": "schemas/messages.json",
      "conformance": {
        "skip_dynamic": true,
        "reason": "StreamHook-handled (legacy's next_page_uri body-cursor pagination is a HOST-RELATIVE URL -- e.g. '/2010-04-01/Accounts/AC.../Messages.json?Page=1' -- which the engine's declarative next_url pagination type cannot express: engine/paginate.go's checkOrigin fail-closed SSRF guard hard-rejects any next-page URL with an empty Host, same ENGINE_GAP as docs/migration/quarantine.json's rootly/safetyculture entries; see docs.md's Streams notes). hook-covered, proven live by archived parity evidence for twilio (TestParityTwilio_MessagesTwoPagePagination) and internal/connectors/hooks/twilio/hooks_test.go"
      }
    },
    {
      "name": "calls",
      "path": "/Accounts/{{ secrets.account_sid }}/Calls.json",
      "records": {
        "path": "calls"
      },
      "schema": "schemas/calls.json",
