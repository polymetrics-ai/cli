{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "pagination": {
      "type": "page_number",
      "page_param": "pageno",
      "start_page": 1,
      "page_size": 10,
      "max_pages": 1
    },
    "check": { "method": "GET", "path": "/search" },
    "error_map": [
      { "status": 429, "class": "rate_limited", "hint": "searxng instance rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "search",
      "path": "/search",
      "query": {
        "q": "{{ config.query }}",
        "format": "json"
      },
      "records": { "path": "results" },
      "computed_fields": {
        "published_date": "{{ record.publishedDate }}"
      },
      "schema": "schemas/search.json"
    },
    {
      "name": "reddit",
      "path": "/search",
      "query": {
        "q": "site:reddit.com {{ config.query }}",
        "format": "json"
      },
      "records": { "path": "results" },
      "computed_fields": {
        "published_date": "{{ record.publishedDate }}"
      },
      "schema": "schemas/reddit.json"
    }
  ]
}
