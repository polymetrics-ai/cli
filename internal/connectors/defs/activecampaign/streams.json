{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "Api-Token", "value": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "offset_limit",
      "limit_param": "limit",
      "offset_param": "offset",
      "page_size": 20
    },
    "check": { "method": "GET", "path": "/contacts" },
    "error_map": [
      { "status": 401, "hint": "activecampaign api_key is missing or invalid; re-run pm credentials add activecampaign" },
      { "status": 403, "hint": "activecampaign api_key lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "activecampaign rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "contacts" },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "lists",
      "path": "/lists",
      "records": { "path": "lists" },
      "schema": "schemas/lists.json"
    },
    {
      "name": "deals",
      "path": "/deals",
      "records": { "path": "deals" },
      "schema": "schemas/deals.json"
    },
    {
      "name": "campaigns",
      "path": "/campaigns",
      "records": { "path": "campaigns" },
      "schema": "schemas/campaigns.json"
    }
  ]
}
