{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "next",
      "token_path": "next"
    },
    "check": { "method": "GET", "path": "/members", "query": { "limit": "1" } },
    "error_map": [
      { "status": 401, "hint": "huntr api_key is missing or invalid; re-run pm credentials add huntr" },
      { "status": 429, "class": "rate_limited", "hint": "huntr rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "members",
      "path": "/members",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/members.json"
    },
    {
      "name": "candidates",
      "path": "/candidates",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/candidates.json"
    },
    {
      "name": "activities",
      "path": "/activities",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/activities.json"
    },
    {
      "name": "notes",
      "path": "/notes/members",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/notes.json"
    },
    {
      "name": "actions",
      "path": "/actions",
      "query": { "limit": "100" },
      "records": { "path": "data" },
      "schema": "schemas/actions.json"
    }
  ]
}
