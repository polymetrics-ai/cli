{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      {
        "mode": "bearer",
        "token": "{{ secrets.api_key }}",
        "when": "{{ secrets.api_key }}"
      },
      {
        "mode": "custom",
        "hook": "salesloft",
        "token_url": "{{ config.token_url }}",
        "client_id": "{{ secrets.client_id }}",
        "client_secret": "{{ secrets.client_secret }}",
        "token": "{{ secrets.refresh_token }}",
        "when": "{{ secrets.refresh_token }}"
      },
      {
        "mode": "bearer",
        "token": "{{ secrets.access_token }}",
        "when": "{{ secrets.access_token }}"
      }
    ],
    "pagination": {
      "type": "cursor",
      "cursor_param": "page",
      "token_path": "metadata.paging.next_page"
    },
    "check": {
      "method": "GET",
      "path": "/users",
      "query": {
        "per_page": "1"
      }
    },
    "error_map": [
      {
        "status": 401,
        "hint": "salesloft credentials are missing or invalid; re-run pm credentials add salesloft"
      },
      {
        "status": 403,
        "hint": "salesloft account lacks access/scope for this request"
      },
      {
        "status": 429,
        "class": "rate_limited",
        "hint": "salesloft API rate limit exceeded; the connector will retry with backoff"
      }
    ]
  },
  "streams": [
    {
      "name": "people",
      "path": "/people",
      "query": {
        "per_page": "{{ config.page_size }}",
        "sort_by": {
          "template": "{{ incremental.lower_bound | const:updated_at }}",
          "omit_when_absent": true
        },
        "sort_direction": {
          "template": "{{ incremental.lower_bound | const:ASC }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "computed_fields": {
        "account_id": "{{ record.account.id }}",
        "owner_id": "{{ record.owner.id }}"
      },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[gte]",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/people.json"
    },
    {
      "name": "accounts",
      "path": "/accounts",
      "query": {
        "per_page": "{{ config.page_size }}",
        "sort_by": {
          "template": "{{ incremental.lower_bound | const:updated_at }}",
          "omit_when_absent": true
        },
        "sort_direction": {
          "template": "{{ incremental.lower_bound | const:ASC }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "computed_fields": {
        "owner_id": "{{ record.owner.id }}"
      },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[gte]",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/accounts.json"
    },
    {
      "name": "cadences",
      "path": "/cadences",
      "query": {
        "per_page": "{{ config.page_size }}",
        "sort_by": {
          "template": "{{ incremental.lower_bound | const:updated_at }}",
          "omit_when_absent": true
        },
        "sort_direction": {
          "template": "{{ incremental.lower_bound | const:ASC }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[gte]",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/cadences.json"
    },
    {
      "name": "users",
      "path": "/users",
      "query": {
        "per_page": "{{ config.page_size }}",
        "sort_by": {
          "template": "{{ incremental.lower_bound | const:updated_at }}",
          "omit_when_absent": true
        },
        "sort_direction": {
          "template": "{{ incremental.lower_bound | const:ASC }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[gte]",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/users.json"
    },
    {
      "name": "emails",
      "path": "/emails",
      "query": {
        "per_page": "{{ config.page_size }}",
        "sort_by": {
          "template": "{{ incremental.lower_bound | const:updated_at }}",
          "omit_when_absent": true
        },
        "sort_direction": {
          "template": "{{ incremental.lower_bound | const:ASC }}",
          "omit_when_absent": true
        }
      },
      "records": {
        "path": "data"
      },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[gte]",
        "param_format": "rfc3339",
        "start_config_key": "start_date"
      },
      "schema": "schemas/emails.json"
    }
  ]
}
