    "finished": { "type": ["boolean", "null"] },
    "language": { "type": ["string", "null"] },
    "data": { "type": ["object", "null"] },
    "meta": { "type": ["object", "null"] },
    "person": { "type": ["object", "null"] },
    "personAttributes": { "type": ["object", "null"] },
    "singleUseId": { "type": ["string", "null"] },
    "tags": { "type": ["array", "null"] },
    "ttc": { "type": ["object", "null"] },
    "created_at": { "type": ["string", "null"], "description": "Mapped from the raw API's createdAt field." },
    "updated_at": { "type": ["string", "null"], "description": "Mapped from the raw API's updatedAt field." }
