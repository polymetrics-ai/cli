{
  "actions": [
    {
      "name": "create_action_class",
      "kind": "create",
      "method": "POST",
      "path": "management/action-classes",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["workspaceId", "name", "type"],
        "properties": {
          "workspaceId": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["code", "noCode"] },
          "key": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "noCodeConfig": { "type": ["object", "null"] }
        }
      },
      "risk": "creates an action class in the configured Formbricks workspace"
    },
    {
      "name": "delete_action_class",
      "kind": "delete",
      "method": "DELETE",
      "path": "management/action-classes/{{ record.actionClassId }}",
      "path_fields": ["actionClassId"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["actionClassId"],
        "properties": {
          "actionClassId": { "type": "string" }
        }
      },
      "risk": "deletes an action class; automatic action classes may be rejected by Formbricks",
      "confirm": "destructive"
    },
    {
      "name": "create_response",
      "kind": "create",
      "method": "POST",
      "path": "management/responses",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["surveyId"],
        "properties": {
          "surveyId": { "type": "string" },
          "data": { "type": "object" },
          "finished": { "type": "boolean" },
          "language": { "type": "string" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        }
      },
      "risk": "creates a survey response and may trigger configured response pipelines"
    },
    {
      "name": "update_response",
      "kind": "update",
      "method": "PUT",
      "path": "management/responses/{{ record.responseId }}",
      "path_fields": ["responseId"],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["responseId"],
        "minProperties": 2,
        "properties": {
          "responseId": { "type": "string" },
          "data": { "type": "object" },
          "finished": { "type": "boolean" },
          "language": { "type": "string" }
        }
      },
      "risk": "updates a survey response and may trigger configured response pipelines"
    },
    {
      "name": "delete_response",
      "kind": "delete",
      "method": "DELETE",
      "path": "management/responses/{{ record.responseId }}",
      "path_fields": ["responseId"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["responseId"],
        "properties": {
          "responseId": { "type": "string" }
        }
      },
      "risk": "deletes a survey response",
      "confirm": "destructive"
    },
    {
      "name": "create_public_file_upload",
      "kind": "create",
      "method": "POST",
      "path": "management/storage",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["fileName", "fileType", "workspaceId"],
        "properties": {
          "fileName": { "type": "string" },
          "fileType": { "type": "string" },
          "workspaceId": { "type": "string" },
          "allowedFileExtensions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "risk": "creates a public file upload target and returns upload metadata"
    },
    {
      "name": "create_survey",
      "kind": "create",
      "method": "POST",
      "path": "management/surveys",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["workspaceId", "name", "type", "status"],
        "properties": {
          "workspaceId": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["link", "app"] },
          "status": { "type": "string", "enum": ["draft", "inProgress", "paused", "completed"] },
          "displayOption": { "type": "string" },
          "questions": { "type": "array", "items": { "type": "object" } },
          "languages": { "type": "array", "items": { "type": "object" } }
        }
      },
      "risk": "creates a survey in the configured Formbricks workspace"
    },
    {
      "name": "update_survey",
      "kind": "update",
      "method": "PUT",
      "path": "management/surveys/{{ record.surveyId }}",
      "path_fields": ["surveyId"],
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["surveyId"],
        "minProperties": 2,
        "properties": {
          "surveyId": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["link", "app"] },
          "status": { "type": "string", "enum": ["draft", "inProgress", "paused", "completed"] },
          "displayOption": { "type": "string" },
          "questions": { "type": "array", "items": { "type": "object" } },
          "languages": { "type": "array", "items": { "type": "object" } }
        }
      },
      "risk": "updates an existing survey"
    },
    {
      "name": "delete_survey",
      "kind": "delete",
      "method": "DELETE",
      "path": "management/surveys/{{ record.surveyId }}",
      "path_fields": ["surveyId"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["surveyId"],
        "properties": {
          "surveyId": { "type": "string" }
        }
      },
      "risk": "deletes a survey and its configured collection surface",
      "confirm": "destructive"
    },
    {
      "name": "create_webhook",
      "kind": "create",
      "method": "POST",
      "path": "webhooks",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["url", "triggers"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "triggers": { "type": "array", "items": { "type": "string", "enum": ["responseCreated", "responseUpdated", "responseFinished"] } },
          "surveyIds": { "type": "array", "items": { "type": "string" } },
          "name": { "type": ["string", "null"] }
        }
      },
      "risk": "creates a webhook that sends Formbricks events to the configured URL"
    },
    {
      "name": "delete_webhook",
      "kind": "delete",
      "method": "DELETE",
      "path": "webhooks/{{ record.webhookId }}",
      "path_fields": ["webhookId"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["webhookId"],
        "properties": {
          "webhookId": { "type": "string" }
        }
      },
      "risk": "deletes a webhook and stops future deliveries",
      "confirm": "destructive"
    }
  ]
}
