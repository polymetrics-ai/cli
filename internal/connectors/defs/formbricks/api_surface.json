{
  "api": "Formbricks API v1 REST API (https://formbricks.com/docs/api-reference/rest-api)",
  "docs": "https://formbricks.com/docs/api-reference/rest-api",
  "reviewed_at": "2026-07-04",
  "scope": "Pass B expansion of the API v1 Formbricks Management API documented under the connector docs URL. Current v1 management reads and JSON mutations are covered; client SDK endpoints, health checks, generated link helpers, and deprecated API-key helper pages are explicitly excluded.",
  "endpoints": [
    { "method": "POST", "path": "client/{workspaceId}/displays", "excluded": { "category": "out_of_scope", "reason": "Public Client API SDK event endpoint, not the authenticated Management API surface for this connector." } },
    { "method": "GET", "path": "client/{workspaceId}/environment", "excluded": { "category": "out_of_scope", "reason": "Public Client API SDK workspace-state endpoint; it requires a client workspace id rather than the management API-key connector model." } },
    { "method": "POST", "path": "client/{workspaceId}/responses", "excluded": { "category": "out_of_scope", "reason": "Public Client API response submission endpoint, separate from the authenticated Management API response mutation covered by create_response." } },
    { "method": "PUT", "path": "client/{workspaceId}/responses/{responseId}", "excluded": { "category": "out_of_scope", "reason": "Public Client API response update endpoint, separate from the authenticated Management API response mutation covered by update_response." } },
    { "method": "POST", "path": "client/{workspaceId}/user", "excluded": { "category": "out_of_scope", "reason": "Public Client API identify endpoint, not part of the management API-key connector surface." } },
    { "method": "GET", "path": "health", "excluded": { "category": "non_data_endpoint", "reason": "Operational health check; no connector records or reverse ETL action." } },
    { "method": "GET", "path": "me", "excluded": { "category": "duplicate_of", "reason": "Legacy API-key test helper page; the current Management API account metadata endpoint is covered by the me stream at management/me." } },
    { "method": "GET", "path": "management/me", "covered_by": { "stream": "me" } },
    { "method": "GET", "path": "management/action-classes", "covered_by": { "stream": "action_classes" } },
    { "method": "POST", "path": "management/action-classes", "covered_by": { "write": "create_action_class" } },
    { "method": "GET", "path": "management/action-classes/{actionClassId}", "covered_by": { "stream": "action_class_details" } },
    { "method": "DELETE", "path": "management/action-classes/{actionClassId}", "covered_by": { "write": "delete_action_class" } },
    { "method": "GET", "path": "management/attribute-classes", "covered_by": { "stream": "attribute_classes" } },
    { "method": "GET", "path": "management/contact-attribute-keys", "covered_by": { "stream": "contact_attribute_keys" } },
    { "method": "GET", "path": "management/contact-attribute-keys/{contactAttributeKeyId}", "covered_by": { "stream": "contact_attribute_key_details" } },
    { "method": "GET", "path": "management/contact-attributes", "covered_by": { "stream": "contact_attributes" } },
    { "method": "GET", "path": "management/contacts", "covered_by": { "stream": "contacts" } },
    { "method": "GET", "path": "management/contacts/{contactId}", "covered_by": { "stream": "contact_details" } },
    { "method": "GET", "path": "management/responses", "covered_by": { "stream": "responses" } },
    { "method": "POST", "path": "management/responses", "covered_by": { "write": "create_response" } },
    { "method": "GET", "path": "management/responses/{responseId}", "covered_by": { "stream": "response_details" } },
    { "method": "PUT", "path": "management/responses/{responseId}", "covered_by": { "write": "update_response" } },
    { "method": "DELETE", "path": "management/responses/{responseId}", "covered_by": { "write": "delete_response" } },
    { "method": "POST", "path": "management/storage", "covered_by": { "write": "create_public_file_upload" } },
    { "method": "GET", "path": "management/surveys", "covered_by": { "stream": "surveys" } },
    { "method": "POST", "path": "management/surveys", "covered_by": { "write": "create_survey" } },
    { "method": "GET", "path": "management/surveys/{surveyId}", "covered_by": { "stream": "survey_details" } },
    { "method": "PUT", "path": "management/surveys/{surveyId}", "covered_by": { "write": "update_survey" } },
    { "method": "DELETE", "path": "management/surveys/{surveyId}", "covered_by": { "write": "delete_survey" } },
    { "method": "GET", "path": "management/surveys/{surveyId}/singleUseIds", "excluded": { "category": "non_data_endpoint", "reason": "GET endpoint generates new single-use survey links; it is a side-effecting helper, not a persisted collection read." } },
    { "method": "GET", "path": "webhooks", "covered_by": { "stream": "webhooks" } },
    { "method": "POST", "path": "webhooks", "covered_by": { "write": "create_webhook" } },
    { "method": "GET", "path": "webhooks/{webhookId}", "covered_by": { "stream": "webhook_details" } },
    { "method": "DELETE", "path": "webhooks/{webhookId}", "covered_by": { "write": "delete_webhook" } }
  ]
}
