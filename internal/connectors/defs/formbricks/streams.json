{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "api_key_header", "header": "X-API-Key", "value": "{{ secrets.api_key }}" }
    ],
    "check": { "method": "GET", "path": "management/surveys" },
    "error_map": [
      { "status": 401, "hint": "formbricks api_key is missing or invalid; re-run pm credentials add formbricks" },
      { "status": 429, "class": "rate_limited", "hint": "formbricks rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "surveys",
      "path": "management/surveys",
      "records": { "path": "data" },
      "computed_fields": {
        "environment_id": "{{ record.environmentId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/surveys.json"
    },
    {
      "name": "survey_details",
      "path": "management/surveys/{{ fanout.id }}",
      "records": { "path": "data", "single_object": true },
      "fan_out": {
        "ids_from": { "request": { "path": "management/surveys", "records_path": "data", "id_field": "id" } },
        "into": { "path_var": "survey_id" }
      },
      "computed_fields": {
        "workspace_id": "{{ record.workspaceId }}",
        "created_by": "{{ record.createdBy }}",
        "display_option": "{{ record.displayOption }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/survey_details.json"
    },
    {
      "name": "responses",
      "path": "management/responses",
      "records": { "path": "data" },
      "pagination": {
        "type": "offset_limit",
        "limit_param": "limit",
        "offset_param": "skip",
        "page_size": 50
      },
      "query": {
        "surveyId": { "template": "{{ config.survey_id }}", "omit_when_absent": true }
      },
      "computed_fields": {
        "survey_id": "{{ record.surveyId }}",
        "contact_id": "{{ record.contactId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/responses.json"
    },
    {
      "name": "response_details",
      "path": "management/responses/{{ fanout.id }}",
      "records": { "path": "data", "single_object": true },
      "fan_out": {
        "ids_from": { "config_key": "response_ids" },
        "into": { "path_var": "response_id" }
      },
      "computed_fields": {
        "survey_id": "{{ record.surveyId }}",
        "contact_id": "{{ record.contactId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/response_details.json"
    },
    {
      "name": "action_classes",
      "path": "management/action-classes",
      "records": { "path": "data" },
      "computed_fields": {
        "environment_id": "{{ record.environmentId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/action_classes.json"
    },
    {
      "name": "action_class_details",
      "path": "management/action-classes/{{ fanout.id }}",
      "records": { "path": "data", "single_object": true },
      "fan_out": {
        "ids_from": { "request": { "path": "management/action-classes", "records_path": "data", "id_field": "id" } },
        "into": { "path_var": "action_class_id" }
      },
      "computed_fields": {
        "workspace_id": "{{ record.workspaceId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/action_class_details.json"
    },
    {
      "name": "attribute_classes",
      "path": "management/attribute-classes",
      "records": { "path": "data" },
      "computed_fields": {
        "environment_id": "{{ record.environmentId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/attribute_classes.json"
    },
    {
      "name": "contact_attribute_keys",
      "path": "management/contact-attribute-keys",
      "records": { "path": "data" },
      "computed_fields": {
        "is_unique": "{{ record.isUnique }}",
        "workspace_id": "{{ record.workspaceId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/contact_attribute_keys.json"
    },
    {
      "name": "contact_attribute_key_details",
      "path": "management/contact-attribute-keys/{{ fanout.id }}",
      "records": { "path": "data", "single_object": true },
      "fan_out": {
        "ids_from": { "request": { "path": "management/contact-attribute-keys", "records_path": "data", "id_field": "id" } },
        "into": { "path_var": "contact_attribute_key_id" }
      },
      "computed_fields": {
        "is_unique": "{{ record.isUnique }}",
        "workspace_id": "{{ record.workspaceId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/contact_attribute_keys.json"
    },
    {
      "name": "contact_attributes",
      "path": "management/contact-attributes",
      "records": { "path": "data" },
      "computed_fields": {
        "attribute_key_id": "{{ record.attributeKeyId }}",
        "contact_id": "{{ record.contactId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/contact_attributes.json"
    },
    {
      "name": "contacts",
      "path": "management/contacts",
      "records": { "path": "data" },
      "computed_fields": {
        "user_id": "{{ record.userId }}",
        "workspace_id": "{{ record.workspaceId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "contact_details",
      "path": "management/contacts/{{ fanout.id }}",
      "records": { "path": "data", "single_object": true },
      "fan_out": {
        "ids_from": { "request": { "path": "management/contacts", "records_path": "data", "id_field": "id" } },
        "into": { "path_var": "contact_id" }
      },
      "computed_fields": {
        "user_id": "{{ record.userId }}",
        "workspace_id": "{{ record.workspaceId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "me",
      "path": "management/me",
      "records": { "path": ".", "single_object": true },
      "computed_fields": {
        "id": "{{ record.organizationId }}",
        "organization_id": "{{ record.organizationId }}",
        "app_setup_completed": "{{ record.appSetupCompleted }}",
        "website_setup_completed": "{{ record.websiteSetupCompleted }}",
        "organization_access": "{{ record.organizationAccess }}",
        "environment_permissions": "{{ record.environmentPermissions }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/me.json"
    },
    {
      "name": "webhooks",
      "path": "webhooks",
      "records": { "path": "data" },
      "computed_fields": {
        "environment_id": "{{ record.environmentId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/webhooks.json"
    },
    {
      "name": "webhook_details",
      "path": "webhooks/{{ fanout.id }}",
      "records": { "path": "data", "single_object": true },
      "fan_out": {
        "ids_from": { "request": { "path": "webhooks", "records_path": "data", "id_field": "id" } },
        "into": { "path_var": "webhook_id" }
      },
      "computed_fields": {
        "workspace_id": "{{ record.workspaceId }}",
        "created_at": "{{ record.createdAt }}",
        "updated_at": "{{ record.updatedAt }}"
      },
      "schema": "schemas/webhook_details.json"
    }
  ]
}
