{
  "api": "Simplecast REST API (https://api.simplecast.com)",
  "docs": "https://developers.simplecast.com/",
  "reviewed_at": "2026-07-03",
  "scope": "wave2 fan-out migration: the 2 legacy-parity read streams only; the full Simplecast surface (analytics, transcripts, distribution) is out of scope until Pass B",
  "endpoints": [
    { "method": "GET", "path": "/podcasts", "covered_by": { "stream": "podcasts" } },
    { "method": "GET", "path": "/episodes", "covered_by": { "stream": "episodes" } },
    { "method": "GET", "path": "/podcasts/{id}/episodes", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } },
    { "method": "GET", "path": "/analytics", "excluded": { "category": "out_of_scope", "reason": "Pass B capability expansion" } }
  ]
}
