{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.api_key }}" }
    ],
    "pagination": {
      "type": "page_number",
      "page_param": "page",
      "size_param": "",
      "start_page": 1,
      "page_size": 25
    },
    "check": { "method": "GET", "path": "/teams", "query": { "page": "1" } },
    "error_map": [
      { "status": 401, "hint": "circa api_key is missing or invalid; re-run pm credentials add circa" },
      { "status": 403, "hint": "circa account lacks access for this request" },
      { "status": 429, "class": "rate_limited", "hint": "circa rate limit exceeded; the connector will retry with backoff" }
    ]
  },
  "streams": [
    {
      "name": "events",
      "path": "/events",
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[min]",
        "start_config_key": "start_date"
      },
      "schema": "schemas/events.json"
    },
    {
      "name": "contacts",
      "path": "/contacts",
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[min]",
        "start_config_key": "start_date"
      },
      "schema": "schemas/contacts.json"
    },
    {
      "name": "companies",
      "path": "/companies",
      "records": { "path": "data" },
      "incremental": {
        "cursor_field": "updated_at",
        "request_param": "updated_at[min]",
        "start_config_key": "start_date"
      },
      "schema": "schemas/companies.json"
    },
    {
      "name": "teams",
      "path": "/teams",
      "records": { "path": "data" },
      "schema": "schemas/teams.json"
    },
    {
      "name": "fields",
      "path": "/fields",
      "records": { "path": "data" },
      "schema": "schemas/fields.json"
    },
    {
      "name": "event_contacts",
      "path": "/events/{{ fanout.id }}/contacts",
      "records": { "path": "data" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/events", "records_path": "data", "id_field": "id" }
        },
        "into": { "path_var": "event_id" },
        "stamp_field": "event_id"
      },
      "schema": "schemas/event_contacts.json"
    },
    {
      "name": "event_staff",
      "path": "/events/{{ fanout.id }}/staff",
      "records": { "path": "data" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/events", "records_path": "data", "id_field": "id" }
        },
        "into": { "path_var": "event_id" },
        "stamp_field": "event_id"
      },
      "schema": "schemas/event_staff.json"
    },
    {
      "name": "event_expenses",
      "path": "/events/{{ fanout.id }}/expenses",
      "records": { "path": "data" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/events", "records_path": "data", "id_field": "id" }
        },
        "into": { "path_var": "event_id" },
        "stamp_field": "event_id"
      },
      "schema": "schemas/event_expenses.json"
    },
    {
      "name": "company_contacts",
      "path": "/companies/{{ fanout.id }}/contacts",
      "records": { "path": "data" },
      "fan_out": {
        "ids_from": {
          "request": { "path": "/companies", "records_path": "data", "id_field": "id" }
        },
        "into": { "path_var": "company_id" },
        "stamp_field": "company_id"
      },
      "schema": "schemas/company_contacts.json"
    }
  ]
}
