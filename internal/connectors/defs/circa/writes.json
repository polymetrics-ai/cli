    {
      "name": "delete_event",
      "kind": "delete",
      "method": "DELETE",
      "path": "/events/{{ record.id }}",
      "path_fields": ["id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "delete": { "missing_ok_status": [404] },
