    },
    {
      "name": "add_event_contact",
      "kind": "create",
      "method": "POST",
      "path": "/events/{{ record.event_id }}/contacts",
      "path_fields": ["event_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["event_id", "contact_id"],
        "properties": {
          "event_id": { "type": "string" },
          "contact_id": { "type": "string" }
        }
      },
      "risk": "external mutation; registers an existing contact onto an event"
    },
    {
      "name": "update_event_contact",
      "kind": "update",
      "method": "PATCH",
      "path": "/events/{{ record.event_id }}/contacts/{{ record.contact_id }}",
      "path_fields": ["event_id", "contact_id"],
      "body_type": "json",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["event_id", "contact_id"],
        "properties": {
          "event_id": { "type": "string" },
          "contact_id": { "type": "string" },
          "attendance_status": { "type": "string" },
          "registration_status": { "type": "string" }
        }
      },
      "risk": "external mutation; updates an event-contact's attendance/registration status"
    },
    {
      "name": "remove_event_contact",
      "kind": "delete",
      "method": "DELETE",
      "path": "/events/{{ record.event_id }}/contacts/{{ record.contact_id }}",
      "path_fields": ["event_id", "contact_id"],
      "body_type": "none",
      "record_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["event_id", "contact_id"],
        "properties": {
          "event_id": { "type": "string" },
          "contact_id": { "type": "string" }
        }
      },
      "delete": { "missing_ok_status": [404] },
      "risk": "irreversible external removal of a contact's event registration; approval required"
    }
