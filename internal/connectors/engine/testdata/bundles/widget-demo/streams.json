{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "polymetrics-go-cli",
    "headers": {},
    "auth": [
      { "mode": "bearer", "token": "{{ secrets.token }}", "when": "{{ secrets.token }}" },
      { "mode": "none", "when": "{{ config.base_url }}" }
    ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "/ping" },
    "error_map": [
      { "status": 401, "hint": "token is missing or expired" }
    ]
  },
  "streams": [
    {
      "name": "widgets",
      "path": "/widgets",
      "records": { "path": "data" },
      "schema": "schemas/widgets.json"
    }
  ]
}
