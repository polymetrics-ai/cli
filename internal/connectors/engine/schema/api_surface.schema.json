{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "api_surface.json",
  "type": "object",
  "required": ["api", "endpoints"],
  "additionalProperties": false,
  "properties": {
    "api": { "type": "string" },
    "docs": { "type": "string" },
    "reviewed_at": { "type": "string" },
    "operation_ledger_version": { "type": "integer", "enum": [1] },
    "scope": { "type": "string" },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "method": { "type": "string" },
          "path": { "type": "string" },
          "covered_by": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "stream": { "type": "string" },
              "write": { "type": "string" }
            }
          },
          "excluded": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "category": {
                "type": "string",
                "enum": [
                  "destructive_admin",
                  "requires_elevated_scope",
                  "binary_payload",
                  "deprecated",
                  "non_data_endpoint",
                  "duplicate_of",
                  "out_of_scope"
                ]
              },
              "reason": { "type": "string" }
            }
          },
          "operation": {
            "type": "object",
            "required": ["model", "status", "risk", "blocked_by_default", "reason"],
            "additionalProperties": false,
            "properties": {
              "model": {
                "type": "string",
                "enum": [
                  "direct_read",
                  "binary_read",
                  "sensitive_reverse_etl",
                  "admin_reverse_etl",
                  "destructive_action",
                  "local_workflow",
                  "duplicate",
                  "deprecated",
                  "disallowed"
                ]
              },
              "status": {
                "type": "string",
                "enum": ["blocked"]
              },
              "risk": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "blocked_by_default": { "type": "boolean", "enum": [true] },
              "reason": { "type": "string" },
              "source_url": { "type": "string" },
              "notes": { "type": "string" },
              "duplicate_of": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
