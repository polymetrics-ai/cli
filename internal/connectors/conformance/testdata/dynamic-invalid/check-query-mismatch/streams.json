{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "acme-conformance/1.0",
    "headers": {},
    "auth": [ { "mode": "bearer", "token": "{{ secrets.token }}", "when": "{{ secrets.token }}" }, { "mode": "none", "when": "{{ config.base_url }}" } ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "/ping", "query": { "limit": "1" } },
    "error_map": [ { "status": 401, "hint": "token is missing or expired" } ]
  },
  "streams": [
    {
      "name": "widgets",
      "path": "/widgets",
      "records": { "path": "data" },
      "pagination": { "type": "page_number", "page_param": "page", "start_page": 1, "page_size": 1 },
      "incremental": { "cursor_field": "updated_at", "request_param": "since", "param_format": "rfc3339", "start_config_key": "start_date" },
      "schema": "schemas/widgets.json"
    },
    {
      "name": "notes",
      "path": "/notes",
      "records": { "path": "data" },
      "schema": "schemas/notes.json"
    }
  ]
}
