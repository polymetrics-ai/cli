{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "acme-conformance/1.0",
    "headers": {},
    "auth": [ { "mode": "none", "when": "{{ config.base_url }}" } ],
    "pagination": { "type": "none" },
    "error_map": []
  },
  "streams": [
    {
      "name": "events",
      "path": "/events",
      "records": { "path": "data" },
      "incremental": { "cursor_field": "updated_at", "request_param": "updated_range", "param_format": "github_date_range", "start_config_key": "start_date" },
      "schema": "schemas/events.json"
    }
  ]
}
