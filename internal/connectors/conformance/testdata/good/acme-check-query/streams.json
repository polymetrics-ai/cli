{
  "base": {
    "url": "{{ config.base_url }}",
    "user_agent": "acme-conformance/1.0",
    "headers": {},
    "auth": [ { "mode": "none", "when": "{{ config.base_url }}" } ],
    "pagination": { "type": "none" },
    "check": { "method": "GET", "path": "/ping", "query": { "limit": "1" } },
    "error_map": []
  },
  "streams": [
    {
      "name": "events",
      "path": "/events",
      "records": { "path": "data" },
      "schema": "schemas/events.json"
    }
  ]
}
